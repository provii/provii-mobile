/* ==================== HELP TEXT DESCRIPTIONS ==================== */
"help_text_extra_large_text" = "يكبّر النص الكبير جدًا جميع النصوص في التطبيق بنسبة 50%.\n\nمفيد للمستخدمين الذين يعانون من:\n• ضعف البصر\n• صعوبات القراءة\n• التغيرات البصرية المرتبطة بالعمر\n\nيعمل مع الحجم الديناميكي في ⁨iOS⁩ لأحجام أكبر.";
"help_text_contrast_level" = "يتحكم مستوى التباين في تباين الألوان بين النص والخلفيات.\n\nثلاثة مستويات متاحة:\n• قياسي: الألوان الافتراضية\n• عالٍ (AA): نسبة تباين 4.5:1 - يستوفي معايير AA\n• أقصى (AAA): نسبة تباين 7:1 - يستوفي أعلى معايير AAA\n\nيجعل التباين الأعلى النص أسهل للقراءة في جميع ظروف الإضاءة.";
"help_text_high_contrast" = "يزيد وضع التباين العالي التباين بين النص والخلفية، مما يجعل القراءة أسهل.\n\nمفيد للمستخدمين الذين يعانون من:\n• ضعف البصر\n• حساسية الألوان\n• البيئات ذات الإضاءة الساطعة\n\nعند التفعيل:\n• يصبح النص أسود على أبيض\n• تضاف حدود للعناصر\n• تتبسط الألوان";
"help_text_reduce_transparency" = "يزيل تقليل الشفافية التأثيرات الضبابية والشفافية في التطبيق.\n\nهذا يساعد في:\n• تحسين قابلية قراءة النص\n• تقليل التعقيد البصري\n• زيادة الأداء على الأجهزة القديمة\n• جعل المحتوى أكثر قابلية للتنبؤ";
"help_text_color_blind_mode" = "تضبط أوضاع عمى الألوان الألوان لأنواع مختلفة من قصور رؤية الألوان.\n\nالأوضاع المتاحة:\n• عمى الأحمر (Protanopia): صعوبة في رؤية الأحمر\n• عمى الأخضر (Deuteranopia): صعوبة في رؤية الأخضر\n• عمى الأزرق (Tritanopia): صعوبة في رؤية الأزرق\n• أحادي اللون: تدرج رمادي فقط\n\nتضمن هذه الأوضاع عدم نقل المعلومات المهمة بالألوان وحدها.";
"help_text_line_spacing" = "يتحكم تباعد الأسطر في المسافة بين أسطر النص.\n\n• النطاق: 1.0x إلى 2.0x\n• معيار AAA: 1.5x كحد أدنى\n• الافتراضي: 1.0x\n\nزيادة تباعد الأسطر يجعل النص أسهل للقراءة ويساعد في تجنب تخطي الأسطر.";
"help_text_paragraph_spacing" = "يتحكم تباعد الفقرات في المسافة بين الفقرات.\n\n• النطاق: 1.0x إلى 3.0x\n• معيار AAA: 2.0x كحد أدنى\n• الافتراضي: 1.0x\n\nزيادة تباعد الفقرات يساعد في التمييز بين الأقسام المختلفة من النص.";
"help_text_letter_spacing" = "يتحكم تباعد الأحرف في المسافة بين الأحرف الفردية.\n\n• النطاق: 0.0em إلى 0.2em\n• معيار AAA: 0.12em كحد أدنى\n• الافتراضي: 0.0em\n\nزيادة تباعد الأحرف يحسّن التعرف على الأحرف وقابلية القراءة.";
"help_text_text_width" = "يتحكم عرض النص في أقصى طول للسطر للقراءة المريحة.\n\nالخيارات:\n• عرض كامل: بدون حد أقصى\n• مريح (80 حرفًا): مثالي للقراءة\n• ضيق (60 حرفًا): للتركيز\n\nتوصي إرشادات AAA بحد أقصى 80 حرفًا في السطر.";
"help_text_large_touch_targets" = "تكبّر أهداف اللمس جميع الأزرار والعناصر التفاعلية إلى 60 نقطة على الأقل.\n\nمفيد لـ:\n• الإعاقات الحركية\n• الارتعاش\n• استخدام التطبيق بالقفازات\n• الاستخدام بيد واحدة\n\nالحد الأدنى القياسي 44 نقطة؛ هذا الإعداد يرفعه إلى 60 نقطة.";
"help_text_reduce_motion" = "يقلل تقليل الحركة أو يزيل الرسوم المتحركة في التطبيق.\n\nمفيد للمستخدمين الذين يعانون من:\n• الحساسية للحركة\n• اضطرابات الجهاز الدهليزي\n• الصرع\n• محفزات الصداع النصفي\n\nعند التفعيل، تُستبدل الرسوم المتحركة بانتقالات فورية.";
"help_text_timeout_behavior" = "يتحكم سلوك المهلة في مدة العمليات قبل انتهاء مهلتها.\n\nالخيارات:\n• بدون مهلة (AAA): لا تنتهي مهلة العمليات أبدًا\n• قياسي (30 ثانية): مهلة افتراضية\n• ممتد (60 ثانية): ضعف الوقت القياسي\n\nوضع بدون مهلة يستوفي معايير إمكانية الوصول AAA.";
"help_text_simplified_gestures" = "يقلل الإيماءات المبسطة الإيماءات المتعددة اللمسات إلى نقرات بسيطة.\n\nمفيد لـ:\n• الإعاقات الحركية\n• محدودية البراعة\n• استخدام الأجهزة المساعدة\n• التشغيل بيد واحدة\n\nتُستبدل الإيماءات المعقدة بأزرار ونقرات بسيطة.";
"help_text_haptic_feedback" = "توفر الاستجابة اللمسية استجابة بالاهتزاز للإجراءات والإشعارات.\n\nمفيد لـ:\n• تأكيد النقر على الأزرار\n• التنبيه بالأخطاء\n• توفير تغذية راجعة غير بصرية\n• المستخدمين ذوي الإعاقات السمعية أو البصرية\n\nيمكنك تعطيلها إذا كانت الاهتزازات غير مريحة.";
"help_text_simplified_ui" = "تقلل الواجهة المبسطة التعقيد البصري في التطبيق.\n\nمفيد لـ:\n• الإعاقات الإدراكية\n• صعوبات التعلم\n• اضطرابات الانتباه\n• المستخدمين الجدد\n\nعند التفعيل:\n• عناصر أقل على الشاشة\n• أدوات تحكم أكبر وأوضح\n• ضوضاء بصرية أقل";
"help_text_step_indicators" = "تُظهر مؤشرات الخطوات تقدمك عبر العمليات متعددة الخطوات.\n\nهذا يساعد في:\n• فهم موضعك في العملية\n• معرفة عدد الخطوات المتبقية\n• تقليل العبء الإدراكي\n• توفير بنية واضحة\n\nيعرض 'الخطوة X من Y' مع نقاط تقدم بصرية.";
"help_text_verbose_descriptions" = "توفر الأوصاف التفصيلية نصًا توضيحيًا إضافيًا في التطبيق.\n\nمفيد لـ:\n• فهم الميزات المعقدة\n• تعلم كيفية استخدام التطبيق\n• الدعم الإدراكي\n• مستخدمي قارئ الشاشة\n\nيوفر السياق والتعليمات لجميع الميزات.";
"help_text_confirm_actions" = "يطلب تأكيد الإجراءات تأكيدًا قبل الإجراءات المهمة.\n\nهذا يساعد في منع:\n• الحذف العرضي\n• التغييرات غير المقصودة\n• الإرسال المبكر\n• فقدان البيانات\n\nملاحظة: الإجراءات التدميرية تتطلب دائمًا تأكيدًا (متطلب AAA).";
"help_text_manual_code_entry" = "يتيح لك إدخال الرمز يدويًا كتابة الرموز بدلًا من مسح رموز ⁨QR⁩.\n\nمفيد عندما:\n• الكاميرا لا تعمل\n• رمز ⁨QR⁩ تالف أو غير واضح\n• استخدام قارئ الشاشة\n• تفضيل الكتابة على المسح\n\nانقر فقط على 'إدخال الرمز يدويًا' لكتابة الرمز الظاهر على الشاشة.";
"help_text_voice_input" = "يتيح الإدخال الصوتي التحدث بالرموز بدلًا من المسح أو الكتابة.\n\nمفيد لـ:\n• محدودية الحركة\n• مستخدمي قارئ الشاشة\n• التشغيل بدون استخدام اليدين\n• تفضيل الصوت\n\nانقر على زر الميكروفون وتحدث بوضوح عند الطلب.";
"help_text_qr_scanning" = "يستخدم مسح رمز ⁨QR⁩ الكاميرا لقراءة رموز الاستجابة السريعة.\n\nكيفية المسح:\n1. وجّه الكاميرا نحو رمز ⁨QR⁩\n2. ضع الرمز في الإطار\n3. انتظر الاكتشاف التلقائي\n\nنصائح:\n• تأكد من الإضاءة الجيدة\n• امسك الجهاز بثبات\n• حافظ على استواء رمز ⁨QR⁩ وخلوه من العوائق\n• إذا فشل المسح، جرب إدخال الرمز يدويًا";
"help_text_age_verification" = "التحقق من العمر يُثبت أنك تستوفي شرط العمر دون الكشف عن عمرك الفعلي أو تاريخ ميلادك.\n\nكيف يعمل:\n1. تُنشئ جهة التحقق تحديًا\n2. تمسح رمز ⁨QR⁩ أو تدخله يدويًا\n3. ينشئ التطبيق إثبات معرفة صفرية\n4. تؤكد جهة التحقق أنك تستوفي الشرط\n\nحماية الخصوصية:\n• لن تتم مشاركة تاريخ ميلادك أبدًا\n• تعلم جهة التحقق فقط ما إذا كنت تستوفي الشرط\n• لا تتبع ولا جمع بيانات";
"help_text_credentials" = "بيانات الاعتماد الرقمية هي إثباتات تشفيرية لعمرك مخزّنة بأمان على جهازك.\n\nالميزات:\n• مخزّنة على جهازك فقط\n• لا يمكن نسخها أو تزويرها\n• تُستخدم للتحقق مع الحفاظ على الخصوصية\n• يمكن حذفها في أي وقت\n\nيجب الحصول على بيانات الاعتماد من جهة إصدار مرخّصة (مثل مكتب حكومي) قبل التمكن من التحقق من عمرك.";
"help_text_zero_knowledge" = "تتيح لك إثباتات المعرفة الصفرية إثبات صحة شيء ما دون الكشف عن المعلومات الأساسية.\n\nمثال:\n• التقليدي: إبراز الهوية (يكشف عن تاريخ الميلاد الدقيق)\n• المعرفة الصفرية: إثبات أنك فوق 18 دون إبراز تاريخ الميلاد\n\nالفوائد:\n• أقصى حماية للخصوصية\n• لا تُشارك بيانات شخصية\n• آمن تشفيريًا\n• لا يمكن تزويره أو إعادة تشغيله\n\nهذه هي التقنية الأساسية التي تجعل محفظة Provii خاصة.";
"help_text_credential_issuance" = "إصدار بيانات الاعتماد هو عملية الحصول على بيانات الاعتماد عمرك الرقمية من جهة إصدار مرخّصة.\n\nالخطوات:\n1. قم بزيارة جهة إصدار مرخّصة (مثل مكتب حكومي)\n2. أثبت هويتك بوثيقة هوية رسمية\n3. استلم رمز ⁨QR⁩ أو رابطًا مباشرًا من جهة الإصدار\n4. امسح رمز ⁨QR⁩ أو انقر على الرابط\n5. تُحسب بيانات الاعتماد محليًا وتُخزن على جهازك\n\nتضمن عملية الشهادة العمياء عدم إرسال تاريخ ميلادك عبر الشبكة.\nتحتاج إلى القيام بهذا مرة واحدة فقط. يمكن استخدام بيانات الاعتمادك بعد ذلك لعمليات تحقق غير محدودة.";
"help_text_officer_mode" = "وضع الموظف مخصص لجهات الإصدار المرخّصة لإنشاء بيانات الاعتماد للمستخدمين.\n\nيتطلب هذا الوضع:\n• مصادقة الموظف باستخدام ⁨YubiKey⁩\n• تفويض من سلطة الإصدار\n• التحقق الفعلي من هوية المستخدم\n\nالعملية:\n1. المصادقة كموظف\n2. التحقق من هوية المستخدم الرسمية\n3. إدخال تاريخ ميلاد المستخدم\n4. إنشاء رمز ⁨QR⁩ لشهادة الإثبات\n5. يمسح المستخدم الرمز لاستلام بيانات الاعتماد\n\nيجب أن يستخدم هذا الوضع موظفون مرخّصون فقط.";

/* ==================== SIMPLIFIED HELP TEXT ==================== */
"help_text_extra_large_text_simplified" = "يكبّر جميع النصوص بنسبة 50%.\n\nيساعدك إذا كنت:\n• تعاني من صعوبة في الرؤية\n• تجد القراءة صعبة\n• تحتاج إلى نص أكبر\n\nيعمل مع إعدادات حجم النص في هاتفك.";
"help_text_contrast_level_simplified" = "يغير مدى ظهور النص داكنًا.\n\nثلاثة خيارات:\n• قياسي: ألوان عادية\n• عالٍ: نص أداكن لقراءة سهلة\n• أقصى: نص داكن جدًا لأفضل قراءة\n\nالنص الأداكن أسهل للقراءة.";
"help_text_high_contrast_simplified" = "يجعل النص أسهل للرؤية.\n\nيساعدك إذا كنت:\n• تعاني من صعوبة في الرؤية\n• تحتاج إلى نص أداكن\n• تستخدم التطبيق في ضوء ساطع\n\nيصبح النص أسود على أبيض.";
"help_text_reduce_transparency_simplified" = "يزيل التأثيرات الضبابية.\n\nهذا يساعد في:\n• جعل النص أوضح\n• تبسيط التطبيق\n• تسريع الهواتف القديمة\n\nيبدو كل شيء أكثر صلابة.";
"help_text_color_blind_mode_simplified" = "يغير الألوان لمساعدتك على الرؤية بشكل أفضل.\n\nالخيارات:\n• وضع عمى الأحمر\n• وضع عمى الأخضر\n• وضع عمى الأزرق\n• وضع رمادي فقط\n\nيساعدك على رؤية الأشياء المهمة.";
"help_text_line_spacing_simplified" = "يغير المسافة بين أسطر النص.\n\nيمكنك الاختيار من 1.0x إلى 2.0x.\nالافتراضي 1.0x.\n\nمساحة أكثر تجعل القراءة أسهل.";
"help_text_paragraph_spacing_simplified" = "يغير المسافة بين الفقرات.\n\nيمكنك الاختيار من 1.0x إلى 3.0x.\nالافتراضي 1.0x.\n\nمساحة أكثر تساعدك على رؤية بداية الأفكار الجديدة.";
"help_text_letter_spacing_simplified" = "يغير المسافة بين الأحرف.\n\nيمكنك الاختيار من 0.0 إلى 0.2.\nالافتراضي 0.0.\n\nمساحة أكثر تجعل الأحرف أوضح.";
"help_text_text_width_simplified" = "يتحكم في اتساع النص.\n\nالخيارات:\n• عرض كامل: يستخدم الشاشة بالكامل\n• متوسط: جيد للقراءة\n• ضيق: الأفضل للتركيز\n\nالعرض المتوسط الأسهل للقراءة.";
"help_text_large_touch_targets_simplified" = "يكبّر جميع الأزرار.\n\nيساعدك إذا كنت:\n• تعاني من صعوبة في النقر على الأزرار الصغيرة\n• يرتعش يدك\n• ترتدي قفازات\n• تستخدم يدًا واحدة\n\nتصبح الأزرار 60 نقطة بدلًا من 44 نقطة.";
"help_text_reduce_motion_simplified" = "يزيل الرسوم المتحركة.\n\nيساعدك إذا:\n• تشعر بالدوار من الحركة\n• تصاب بالصداع من الحركة\n• تفضل أن تبقى الأشياء ثابتة\n\nتتغير الأشياء فورًا بدلًا من التحرك.";
"help_text_timeout_behavior_simplified" = "يتحكم في مدة المهام.\n\nالخيارات:\n• بدون حد: لا تتوقف المهام أبدًا\n• عادي: 30 ثانية\n• أطول: 60 ثانية\n\naختر 'بدون حد' إذا احتجت وقتًا أكثر.";
"help_text_simplified_gestures_simplified" = "يستبدل الإيماءات الصعبة بنقرات بسيطة.\n\nيساعدك إذا كنت:\n• تعاني من صعوبة في اللمسات المعقدة\n• تفضل النقرات البسيطة\n• تستخدم يدًا واحدة\n\nيستخدم كل شيء نقرات بسيطة.";
"help_text_haptic_feedback_simplified" = "يجعل هاتفك يهتز عند النقر.\n\nيساعدك في:\n• معرفة أنك نقرت على زر\n• الشعور بالأخطاء\n• التغذية الراجعة دون النظر\n\nأوقفه إذا كانت الاهتزازات تزعجك.";
"help_text_simplified_ui_simplified" = "يبسّط التطبيق.\n\nيساعدك إذا كنت:\n• تشعر بالارتباك من الشاشات المزدحمة\n• تفضل التخطيطات البسيطة\n• جديد على التطبيق\n\nيعرض أشياء أقل في وقت واحد.";
"help_text_step_indicators_simplified" = "يُظهر تقدمك عبر الخطوات.\n\nيساعدك في:\n• معرفة موضعك\n• رؤية عدد الخطوات المتبقية\n• البقاء منظمًا\n\nيعرض 'الخطوة 1 من 3' مع نقاط.";
"help_text_verbose_descriptions_simplified" = "يمنحك المزيد من الشروحات.\n\nيساعدك في:\n• فهم الميزات\n• تعلم كيفية استخدام التطبيق\n• الحصول على مزيد من التفاصيل\n\nيوفر مساعدة إضافية في كل مكان.";
"help_text_confirm_actions_simplified" = "يطلب منك تأكيد الإجراءات المهمة.\n\nيساعد في منع:\n• الحذف العرضي\n• التغييرات غير المرغوبة\n• الأخطاء\n\nستُسأل دائمًا 'هل أنت متأكد؟'";
"help_text_manual_code_entry_simplified" = "يتيح لك كتابة الرموز بدلًا من المسح.\n\nاستخدمه عندما:\n• الكاميرا لا تعمل\n• الرمز صعب المسح\n• تفضل الكتابة\n\nانقر على 'إدخال الرمز يدويًا' للكتابة.";
"help_text_voice_input_simplified" = "يتيح لك قول الرموز بدلًا من الكتابة.\n\nيساعدك إذا كنت:\n• تعاني من صعوبة في الكتابة\n• تفضل الكلام\n• تريد الاستخدام بدون اليدين\n\nانقر على الميكروفون وتحدث بوضوح.";
"help_text_qr_scanning_simplified" = "يستخدم كاميرتك لقراءة الرموز المربعة.\n\nكيفية المسح:\n1. وجّه الكاميرا نحو الرمز\n2. ضع الرمز في المنتصف\n3. انتظر القراءة\n\nنصائح:\n• استخدم إضاءة جيدة\n• امسك هاتفك بثبات\n• حافظ على استواء الرمز";
"help_text_age_verification_simplified" = "يُثبت أنك كبير بما يكفي دون مشاركة تاريخ ميلادك.\n\nكيف يعمل:\n1. ينشئ المكان طلبًا\n2. تمسح رمزه\n3. ينشئ التطبيق إثباتًا\n4. يؤكد المكان أنك كبير بما يكفي\n\nتاريخ ميلادك يبقى خاصًا.";
"help_text_credentials_simplified" = "إثبات رقمي لعمرك مخزّن على هاتفك.\n\nالميزات:\n• على هاتفك فقط\n• لا يمكن نسخه\n• يحافظ على خصوصيتك\n• يمكن حذفه في أي وقت\n\nتحصل عليه من مكتب حكومي.";
"help_text_zero_knowledge_simplified" = "يُثبت شيئًا دون مشاركة التفاصيل.\n\nمثال:\n• الطريقة القديمة: إبراز هويتك (يُظهر تاريخ الميلاد الدقيق)\n• الطريقة الجديدة: إثبات أنك فوق 18 (تاريخ الميلاد يبقى خاصًا)\n\nهذا يحافظ على خصوصية معلوماتك.";
"help_text_credential_issuance_simplified" = "الحصول على إثبات عمرك الرقمي.\n\nالخطوات:\n1. اذهب إلى المكتب الحكومي\n2. أبرز هويتك\n3. احصل على رمز\n4. امسح الرمز\n5. يُحفظ الإثبات على هاتفك\n\nافعل هذا مرة واحدة. ثم استخدمه مرات عديدة.";
"help_text_officer_mode_simplified" = "للموظفين الحكوميين لإنشاء إثباتات.\n\nيحتاج:\n• كلمة مرور الموظف\n• إذن الاستخدام\n• هوية المستخدم للتحقق\n\nالخطوات:\n1. سجّل الدخول كموظف\n2. تحقق من هوية المستخدم\n3. أدخل تاريخ ميلاده\n4. أنشئ الرمز\n5. يمسح المستخدم الرمز\n\nللموظفين المرخّصين فقط.";

