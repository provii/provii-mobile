"help_text_extra_large_text" = "Erittäin suuri teksti kasvattaa kaikkea tekstiä sovelluksessa 50 %.\n\nTämä auttaa käyttäjiä, joilla on:\n• Heikko näkö\n• Lukemisvaikeuksia\n• Ikään liittyvät näkömuutokset\n\nToimii iOS:n dynaamisen tyypin kanssa entistä suurempien kokojen saavuttamiseksi.";
"help_text_contrast_level" = "Kontrastitaso hallinnoi tekstin ja taustan välistä kontrastisuhdetta.\n\nKolme tasoa:\n• Vakio: Oletusvärit\n• Korkea (AA): 4,5:1 kontrastisuhde – täyttää AA-standardit\n• Maksimi (AAA): 7:1 kontrastisuhde – täyttää korkeimmat AAA-standardit\n\nKorkeampi kontrasti helpottaa tekstin lukemista kaikissa valaistusolosuhteissa.";
"help_text_high_contrast" = "Korkean kontrastin tila lisää tekstin ja taustan välistä kontrastia helpottaen lukemista.\n\nTämä auttaa käyttäjiä, joilla on:\n• Heikko näkö\n• Väriherkkkyys\n• Kirkkaat näyttöympäristöt\n\nKäytössä:\n• Teksti muuttuu mustaksi valkoisella taustalla\n• Elementteihin lisätään reunukset\n• Värit yksinkertaistuvat";
"help_text_reduce_transparency" = "Vähennä läpinäkyvyyttä poistaa epäterävyys- ja läpinäkyvyysefektit sovelluksesta.\n\nTämä auttaa:\n• Parantaa tekstin luettavuutta\n• Vähentää visuaalista monimutkaisuutta\n• Parantaa suorituskykyä vanhemmilla laitteilla\n• Tekee sisällöstä ennustettavampaa";
"help_text_color_blind_mode" = "Värisokeus-tilat säätävät värejä eri tyyppistä värisokeutta varten.\n\nTilat:\n• Protanopia: Punasokeus (vaikeus nähdä punaista)\n• Deuteranopia: Vihersokeus (vaikeus nähdä vihreää)\n• Tritanopia: Sinisokeus (vaikeus nähdä sinistä)\n• Mustavalkoinen: Vain harmaaskaala\n\nNämä tilat varmistavat, ettei tärkeää tietoa välitetä pelkästään värin avulla.";
"help_text_line_spacing" = "Riviväli hallinnoi tekstirivien välistä tilaa.\n\n• Alue: 1,0–2,0-kertainen\n• AAA-standardi: vähintään 1,5-kertainen\n• Oletus: 1,0-kertainen\n\nLisätty riviväli helpottaa tekstin lukemista ja auttaa ehkäisemään rivien ohittamista.";
"help_text_paragraph_spacing" = "Kappaleiden väli hallinnoi kappaleiden välistä tilaa.\n\n• Alue: 1,0–3,0-kertainen\n• AAA-standardi: vähintään 2,0-kertainen\n• Oletus: 1,0-kertainen\n\nLisätty kappaleiden väli auttaa erottamaan eri tekstiosat toisistaan.";
"help_text_letter_spacing" = "Kirjainväli hallinnoi yksittäisten merkkien välistä tilaa.\n\n• Alue: 0,0–0,2 em\n• AAA-standardi: vähintään 0,12 em\n• Oletus: 0,0 em\n\nLisätty kirjainväli parantaa merkkien tunnistamista ja luettavuutta.";
"help_text_text_width" = "Tekstin leveys hallinnoi rivin enimmäispituutta mukavan lukemisen vuoksi.\n\nVaihtoehdot:\n• Koko leveys: Ei enimmäistä\n• Mukava (80 merkkiä): Optimaalinen lukemiseen\n• Kapea (60 merkkiä): Keskittyneeseen lukemiseen\n\nAAA-ohjeet suosittelevat enintään 80 merkkiä per rivi.";
"help_text_large_touch_targets" = "Suuremmat kosketusalueet tekevät kaikista painikkeista ja vuorovaikutteisista elementeistä vähintään 60 pisteen kokoisia.\n\nTämä auttaa:\n• Liikuntarajoitteisia\n• Vapinasta kärsiviä\n• Sovelluksen käyttöä hansikkailla\n• Yhden käden käyttöä\n\nVakiominimikoko on 44 pistettä; tämä asetus kasvattaa sen 60 pisteeseen.";
"help_text_reduce_motion" = "Vähennä liikettä minimoi tai poistaa animaatiot sovelluksesta.\n\nTämä auttaa käyttäjiä, joilla on:\n• Liikeherkkkyys\n• Tasapainohäiriöitä\n• Epilepsia\n• Migreeniä laukaisevat tekijät\n\nKäytössä animaatiot korvataan välittömillä siirtymillä.";
"help_text_timeout_behavior" = "Aikakatkaisukäyttäytyminen hallinnoi, kuinka kauan toiminnot voivat kestää ennen aikakatkaisua.\n\nVaihtoehdot:\n• Ei aikakatkaisua (AAA): Toiminnot eivät koskaan aikakatkaise\n• Vakio (30 s): Oletusaikakatkaisu\n• Pidennetty (60 s): Kaksinkertainen vakioaika\n\nEi-aikakatkaisu-tila täyttää AAA-esteettömyysstandardit.";
"help_text_simplified_gestures" = "Yksinkertaistetut eleet vähentää monimutkaiset monikoske-eleet yksinkertaisiksi napautuksiksi.\n\nTämä auttaa:\n• Liikuntarajoitteisia\n• Rajallisesta näppäryydestä kärsiviä\n• Avustavien laitteiden käyttäjiä\n• Yhden käden käyttöä\n\nMonimutkaiset eleet korvataan painikkeilla ja yksinkertaisilla napautuksilla.";
"help_text_haptic_feedback" = "Haptinen palaute antaa värinäpalautetta toiminnoista ja ilmoituksista.\n\nTämä auttaa:\n• Vahvistamaan painalluksia\n• Ilmoittamaan virheistä tai varoituksista\n• Antamaan ei-visuaalista palautetta\n• Kuulo- tai näkövammaisia käyttäjiä\n\nVoit poistaa tämän käytöstä, jos värinät ovat epämiellyttäviä.";
"help_text_simplified_ui" = "Yksinkertaistettu käyttöliittymä vähentää visuaalista monimutkaisuutta sovelluksessa.\n\nTämä auttaa:\n• Kognitiivisista vammoista kärsiviä\n• Oppimisvaikeuksia omaavia\n• Tarkkaavaisuushäiriöistä kärsiviä\n• Uusia tai kokemattomia käyttäjiä\n\nKäytössä:\n• Vähemmän elementtejä näytöllä\n• Suuremmat, selkeämmät ohjaimet\n• Vähemmän visuaalista hälyä";
"help_text_step_indicators" = "Vaiheindikaattorit näyttävät edistymisesi monivaiheisissa prosesseissa.\n\nTämä auttaa:\n• Ymmärtämään missä prosessissa olet\n• Tietämään kuinka monta vaihetta on jäljellä\n• Vähentämään kognitiivista kuormaa\n• Tarjoamaan selkeän rakenteen\n\nNäyttää 'Vaihe X / Y' visuaalisilla edistymispisteillä.";
"help_text_verbose_descriptions" = "Yksityiskohtaiset kuvaukset tarjoaa lisää selittävää tekstiä sovelluksessa.\n\nTämä auttaa:\n• Ymmärtämään monimutkaisia ominaisuuksia\n• Oppimaan sovelluksen käyttöä\n• Kognitiivista tukea tarvitsevia\n• Ruudunlukijan käyttäjiä\n\nTarjoaa kontekstin ja ohjeet kaikille ominaisuuksille.";
"help_text_confirm_actions" = "Vahvista toiminnot pyytää vahvistuksen tärkeille toiminnoille.\n\nTämä auttaa ehkäisemään:\n• Vahingollisia poistoja\n• Tahattomia muutoksia\n• Ennenaikaisia lähetyksiä\n• Tietojen katoamista\n\nHuom: Tuhoavat toiminnot vaativat aina vahvistuksen (AAA-vaatimus).";
"help_text_manual_code_entry" = "Manuaalinen koodin syöttö mahdollistaa koodien kirjoittamisen QR-koodien skannauksen sijaan.\n\nTämä on hyödyllistä, kun:\n• Kamera ei toimi\n• QR-koodi on vaurioitunut tai epäselvä\n• Käytetään ruudunlukijaa\n• Kirjoittaminen on skannaamista parempi vaihtoehto\n\nNapauta 'Syötä koodi manuaalisesti' kirjoittaaksesi näytöllä näkyvän koodin.";
"help_text_voice_input" = "Äänisyöte mahdollistaa koodien puhumisen skannauksen tai kirjoittamisen sijaan.\n\nTämä auttaa:\n• Liikuntarajoitteisia\n• Ruudunlukijan käyttäjiä\n• Kädet vapaana -käyttöä\n• Äänenkäyttöä suosivia\n\nNapauta mikrofonipainiketta ja puhu selkeästi kun kehotetaan.";
"help_text_qr_scanning" = "QR-koodin skannaus käyttää kameraasi Quick Response -koodien lukemiseen.\n\nSkannausohjeet:\n1. Osoita kamera QR-koodiin\n2. Aseta koodi kehykseen\n3. Odota automaattista tunnistusta\n\nVinkkejä:\n• Varmista hyvä valaistus\n• Pidä laite vakaana\n• Pidä QR-koodi tasaisena ja esteettömänä\n• Jos skannaus epäonnistuu, kokeile manuaalista koodin syöttöä";
"help_text_age_verification" = "Iänvarmennus todistaa, että täytät ikävaatimuksen paljastamatta todellista ikääsi tai syntymäaikaasi.\n\nMiten se toimii:\n1. Varmentaja luo haasteen\n2. Skannaat QR-koodin tai syötät sen manuaalisesti\n3. Sovellus luo nollatietotodistuksen\n4. Varmentaja vahvistaa, että täytät vaatimuksen\n\nYksityisyys suojattu:\n• Syntymäaikaasi ei koskaan jaeta\n• Varmentaja saa tietää vain täytätkö vaatimuksen\n• Ei seurantaa tai tietojenkeräystä";
"help_text_credentials" = "Digitaaliset tunnisteet ovat salauksellisia todisteita iästäsi, jotka on tallennettu turvallisesti laitteellesi.\n\nOminaisuudet:\n• Tallennettu vain laitteellesi\n• Ei voida kopioida tai väärentää\n• Käytetään yksityisyyttä säilyttävään varmennukseen\n• Voidaan poistaa milloin tahansa\n\nSinun täytyy hankkia tunniste valtuutetulta myöntäjältä (kuten virastopisteestä) ennen kuin voit varmistaa ikäsi.";
"help_text_zero_knowledge" = "Nollatietotodistukset mahdollistavat jonkin asian todistamisen paljastamatta taustalla olevaa tietoa.\n\nEsimerkki:\n• Perinteinen: Näytä henkilötodistus (paljastaa tarkan syntymäpäivän)\n• Nollatiedollinen: Todista olevasi yli 18 vuotta näyttämättä syntymäpäivää\n\nEdut:\n• Maksimaalinen yksityisyydensuoja\n• Ei henkilötietoja jaeta\n• Salauksellisesti turvallinen\n• Ei voida väärentää tai toistaa\n\nTämä on Provii Walletin yksityisyyden mahdollistava perustekniikka.";
"help_text_credential_issuance" = "Tunnisteen myöntäminen on prosessi, jossa hankitaan digitaalinen ikätunniste valtuutetulta myöntäjältä.\n\nVaiheet:\n1. Käy valtuutetussa myöntäjäpisteessä (esim. virastopisteessä)\n2. Todista henkilöllisyytesi virallisella henkilöllisyystodistuksella\n3. Vastaanota QR-koodi tai syvälinkkiosoite myöntäjältä\n4. Skannaa QR-koodi tai napauta linkkiä\n5. Tunniste lasketaan paikallisesti ja tallennetaan laitteellesi\n\nSokon todistamisen prosessi varmistaa, ettei syntymäaikaasi koskaan lähetetä verkon kautta.\nSinun tarvitsee tehdä tämä vain kerran. Tunnistettasi voidaan sen jälkeen käyttää rajoittamattomaan määrään varmennuksia.";
"help_text_officer_mode" = "Virkailijan tila on tarkoitettu valtuutetuille myöntäjille luomaan tunnisteita käyttäjille.\n\nTämä tila vaatii:\n• Virkailijan todennuksen YubiKey-avaimella\n• Valtuutuksen myöntävältä viranomaiselta\n• Käyttäjän henkilöllisyystodistuksen fyysisen tarkistuksen\n\nProsessi:\n1. Todenna virkailijana\n2. Tarkista käyttäjän virallinen henkilöllisyystodistus\n3. Syötä käyttäjän syntymäaika\n4. Luo todistus-QR-koodi\n5. Käyttäjä skannaa koodin vastaanottaakseen tunnisteen\n\nVain valtuutettu henkilöstö saa käyttää tätä tilaa.";

"help_text_extra_large_text_simplified" = "Suurentaa kaiken tekstin 50 % isommaksi.\n\nAuttaa sinua, jos:\n• Sinulla on näkemisvaikeuksia\n• Lukeminen on hankalaa\n• Tarvitset suurempaa tekstiä\n\nToimii puhelimesi tekstikokoasetusten kanssa.";

"help_text_contrast_level_simplified" = "Muuttaa tekstin tummuutta.\n\nKolme valintaa:\n• Vakio: Normaalit värit\n• Korkea: Tummempi teksti helpompaa lukemista varten\n• Maksimi: Hyvin tumma teksti parhaaseen lukemiseen\n\nTummempi teksti on helpompi lukea.";

"help_text_high_contrast_simplified" = "Helpottaa tekstin näkemistä.\n\nAuttaa sinua, jos:\n• Sinulla on näkemisvaikeuksia\n• Tarvitset tummempaa tekstiä\n• Käytät sovellusta kirkkaassa valossa\n\nTekstistä tulee mustaa valkoisella taustalla.";

"help_text_reduce_transparency_simplified" = "Poistaa epäterävät efektit.\n\nTämä auttaa:\n• Tekemään tekstistä selkeämpää\n• Tekemään sovelluksesta yksinkertaisempaa\n• Nopeuttamaan vanhempia puhelimia\n\nKaikki näyttää kiinteämmältä.";

"help_text_color_blind_mode_simplified" = "Muuttaa värejä auttamaan sinua näkemään paremmin.\n\nValinnat:\n• Punasokeus-tila\n• Vihersokeus-tila\n• Sinisokeus-tila\n• Vain harmaa -tila\n\nAuttaa näkemään tärkeät asiat.";

"help_text_line_spacing_simplified" = "Muuttaa tilaa tekstirivien välillä.\n\nVoit valita 1,0- ja 2,0-kertaisen välillä.\nOletus on 1,0-kertainen.\n\nEnemmän tilaa helpottaa lukemista.";

"help_text_paragraph_spacing_simplified" = "Muuttaa tilaa kappaleiden välillä.\n\nVoit valita 1,0- ja 3,0-kertaisen välillä.\nOletus on 1,0-kertainen.\n\nEnemmän tilaa auttaa näkemään missä uudet ideat alkavat.";

"help_text_letter_spacing_simplified" = "Muuttaa tilaa kirjainten välillä.\n\nVoit valita 0,0 ja 0,2 välillä.\nOletus on 0,0.\n\nEnemmän tilaa tekee kirjaimista selkeämpiä.";

"help_text_text_width_simplified" = "Hallinnoi tekstin leveyttä.\n\nValinnat:\n• Koko leveys: Käyttää koko näytön\n• Keskikokoinen: Hyvä lukemiseen\n• Kapea: Paras keskittymiseen\n\nKeskikokoinen leveys on helpoin lukea.";

"help_text_large_touch_targets_simplified" = "Tekee kaikista painikkeista suurempia.\n\nAuttaa sinua, jos:\n• Sinulla on vaikeuksia napauttaa pieniä painikkeita\n• Kätesi tärisevät\n• Käytät hanskoja\n• Käytät yhtä kättä\n\nPainikkeet kasvavat 60 pisteeseen 44 pisteen sijaan.";

"help_text_reduce_motion_simplified" = "Poistaa liikkuvat animaatiot.\n\nAuttaa sinua, jos:\n• Liike saa sinut huonovointiseksi\n• Saat päänsärkyä liikkeestä\n• Haluat asioiden pysyvän paikallaan\n\nAsiat muuttuvat välittömästi liikkumisen sijaan.";

"help_text_timeout_behavior_simplified" = "Hallinnoi kuinka kauan tehtävät voivat kestää.\n\nValinnat:\n• Ei rajoitusta: Tehtävät eivät lopu koskaan\n• Normaali: 30 sekuntia\n• Pidempi: 60 sekuntia\n\nValitse 'Ei rajoitusta' jos tarvitset enemmän aikaa.";

"help_text_simplified_gestures_simplified" = "Korvaa hankalat eleet yksinkertaisilla napautuksilla.\n\nAuttaa sinua, jos:\n• Sinulla on vaikeuksia monimutkaisissa kosketuksissa\n• Haluat yksinkertaisia napautuksia\n• Käytät yhtä kättä\n\nKaikki käyttää yksinkertaisia napautuksia.";

"help_text_haptic_feedback_simplified" = "Saa puhelimesi värisemään kun napautat.\n\nAuttaa sinua:\n• Tietämään kun napautit painiketta\n• Tuntemaan virheet tai varoitukset\n• Saamaan palautetta katsomatta\n\nKytke pois päältä jos värinät häiritsevät.";

"help_text_simplified_ui_simplified" = "Tekee sovelluksesta yksinkertaisempaa.\n\nAuttaa sinua, jos:\n• Täysistä näytöistä tulee sekava olo\n• Haluat yksinkertaisia asetteluja\n• Olet uusi sovelluksen käyttäjä\n\nNäyttää vähemmän asioita kerrallaan.";

"help_text_step_indicators_simplified" = "Näyttää edistymisesi vaiheissa.\n\nAuttaa sinua:\n• Tietämään missä olet\n• Näkemään kuinka monta vaihetta on jäljellä\n• Pysymään järjestyksessä\n\nNäyttää 'Vaihe 1 / 3' pisteiden kanssa.";

"help_text_verbose_descriptions_simplified" = "Antaa sinulle enemmän selityksiä.\n\nAuttaa sinua:\n• Ymmärtämään ominaisuuksia\n• Oppimaan sovelluksen käyttöä\n• Saamaan lisätietoja\n\nTarjoaa ylimääräistä apua kaikkialla.";

"help_text_confirm_actions_simplified" = "Pyytää sinua vahvistamaan tärkeät toiminnot.\n\nEhkäisee:\n• Vahingolliset poistot\n• Tahattomia muutoksia\n• Virheitä\n\nSinulta kysytään aina 'Oletko varma?'";

"help_text_manual_code_entry_simplified" = "Mahdollistaa koodien kirjoittamisen skannauksen sijaan.\n\nKäytä tätä, kun:\n• Kamerasi ei toimi\n• Koodia on vaikea skannata\n• Haluat kirjoittaa\n\nNapauta 'Syötä koodi manuaalisesti' kirjoittaaksesi.";

"help_text_voice_input_simplified" = "Mahdollistaa koodien puhumisen kirjoittamisen sijaan.\n\nAuttaa sinua, jos:\n• Sinulla on vaikeuksia kirjoittaa\n• Haluat puhua\n• Haluat kädet vapaana\n\nNapauta mikrofonia ja puhu selkeästi.";

"help_text_qr_scanning_simplified" = "Käyttää kameraasi neliön muotoisten koodien lukemiseen.\n\nSkannausohjeet:\n1. Osoita kamera koodiin\n2. Aseta koodi kohdakkain\n3. Odota lukemista\n\nVinkkejä:\n• Käytä hyvää valaistusta\n• Pidä puhelimesi vakaana\n• Pidä koodi tasaisena";

"help_text_age_verification_simplified" = "Todistaa olevasi tarpeeksi vanha ilman syntymäpäivän jakamista.\n\nMiten se toimii:\n1. Yritys luo pyynnön\n2. Skannaat heidän koodinsa\n3. Sovellus luo todistuksen\n4. Yritys vahvistaa olevasi tarpeeksi vanha\n\nSyntymäpäiväsi pysyy yksityisenä.";

"help_text_credentials_simplified" = "Digitaalinen todistus iästäsi tallennettu puhelimeesi.\n\nOminaisuudet:\n• Vain puhelimessasi\n• Ei voida kopioida\n• Pitää sinut yksityisenä\n• Voit poistaa sen milloin tahansa\n\nSaat sen virastopisteestä.";

"help_text_zero_knowledge_simplified" = "Todistaa jonkin asian ilman tietojen jakamista.\n\nEsimerkki:\n• Vanha tapa: Näytä henkilötodistus (näyttää tarkan syntymäpäivän)\n• Uusi tapa: Todista olevasi yli 18 (syntymäpäivä pysyy yksityisenä)\n\nTämä pitää tietosi yksityisinä.";

"help_text_credential_issuance_simplified" = "Digitaalisen ikätodistuksesi hankkiminen.\n\nVaiheet:\n1. Mene virastopisteeseen\n2. Näytä henkilötodistuksesi\n3. Hanki koodi\n4. Skannaa koodi\n5. Todistus tallennetaan puhelimeesi\n\nTee tämä kerran. Käytä sitten monta kertaa.";

"help_text_officer_mode_simplified" = "Virastohenkilöille tunnisteiden luomiseen.\n\nTarvitaan:\n• Virkailijan salasana\n• Käyttölupa\n• Käyttäjän henkilötodistus tarkistettavaksi\n\nVaiheet:\n1. Kirjaudu sisään virkailijana\n2. Tarkista käyttäjän henkilötodistus\n3. Syötä heidän syntymäpäivänsä\n4. Luo koodi\n5. Käyttäjä skannaa koodin\n\nVain valtuutetuille henkilöille.";

