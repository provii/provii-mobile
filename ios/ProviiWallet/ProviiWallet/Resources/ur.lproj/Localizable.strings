/* ==================== HELP TEXT DESCRIPTIONS ==================== */
"help_text_extra_large_text" = "بہت بڑا متن ایپ میں تمام متن کو ⁨50%⁩ بڑھاتا ہے۔\n\nیہ ان صارفین کے لیے مفید ہے جن کو:\n• کم بینائی ہو\n• پڑھنے میں دشواری ہو\n• عمر سے متعلق بصری تبدیلیاں ہوں\n\nزیادہ سے زیادہ لچک کے لیے ⁨iOS Dynamic Type⁩ کے ساتھ کام کرتا ہے۔";
"help_text_contrast_level" = "کنٹراسٹ کی سطح متن اور پس منظر کے درمیان رنگ کا تضاد کنٹرول کرتی ہے۔\n\nتین سطحیں دستیاب ہیں:\n• معیاری: ڈیفالٹ رنگ\n• اعلیٰ ⁨(AA)⁩: ⁨4.5:1⁩ کنٹراسٹ تناسب\n• زیادہ سے زیادہ ⁨(AAA)⁩: ⁨7:1⁩ کنٹراسٹ تناسب\n\nزیادہ تضاد تمام روشنی کے حالات میں متن پڑھنا آسان بناتا ہے۔";
"help_text_high_contrast" = "زیادہ تضاد موڈ متن اور پس منظر کے درمیان تضاد بڑھاتا ہے، پڑھنا آسان بناتا ہے۔\n\nیہ ان صارفین کے لیے مفید ہے جن کو:\n• کم بینائی ہو\n• رنگ کی حساسیت ہو\n• روشن اسکرین ماحول ہو\n\nفعال ہونے پر:\n• متن سفید پر سیاہ ہو جاتا ہے\n• عناصر میں حد بندیاں شامل ہو جاتی ہیں\n• رنگ آسان ہو جاتے ہیں";
"help_text_reduce_transparency" = "شفافیت کم کرنا پوری ایپ میں بلر اور شفافیت کے اثرات ہٹاتا ہے۔\n\nیہ مدد کرتا ہے:\n• متن کی پڑھائی بہتر کرنے میں\n• بصری پیچیدگی کم کرنے میں\n• پرانے آلات پر کارکردگی بہتر کرنے میں\n• مواد کو زیادہ قابل پیش گوئی بنانے میں";
"help_text_color_blind_mode" = "رنگ کور موڈ مختلف اقسام کی رنگ بینائی کمی کے لیے رنگ ایڈجسٹ کرتا ہے۔\n\nدستیاب موڈ:\n• پروٹانوپیا: سرخ نابینا\n• ڈیوٹیرانوپیا: سبز نابینا\n• ٹریٹانوپیا: نیلا نابینا\n• یک رنگ: صرف گریسکیل\n\nیہ موڈ یقینی بناتے ہیں کہ اہم معلومات صرف رنگ کے ذریعے نہ پہنچائی جائے۔";
"help_text_line_spacing" = "سطر کا فاصلہ متن کی سطروں کے درمیان جگہ کنٹرول کرتا ہے۔\n\n• رینج: ⁨1.0x⁩ سے ⁨2.0x⁩\n• ⁨AAA⁩ معیار: کم از کم ⁨1.5x⁩\n• ڈیفالٹ: ⁨1.0x⁩\n\nبڑھا ہوا سطر فاصلہ متن پڑھنا آسان بناتا ہے اور سطر چھوڑنے سے بچاتا ہے۔";
"help_text_paragraph_spacing" = "پیراگراف کا فاصلہ پیراگرافوں کے درمیان جگہ کنٹرول کرتا ہے۔\n\n• رینج: ⁨1.0x⁩ سے ⁨3.0x⁩\n• ⁨AAA⁩ معیار: کم از کم ⁨2.0x⁩\n• ڈیفالٹ: ⁨1.0x⁩\n\nبڑھا ہوا پیراگراف فاصلہ متن کے مختلف حصوں میں فرق کرنے میں مدد کرتا ہے۔";
"help_text_letter_spacing" = "حروف کا فاصلہ انفرادی حروف کے درمیان جگہ کنٹرول کرتا ہے۔\n\n• رینج: ⁨0.0em⁩ سے ⁨0.2em⁩\n• ⁨AAA⁩ معیار: کم از کم ⁨0.12em⁩\n• ڈیفالٹ: ⁨0.0em⁩\n\nبڑھا ہوا حروف کا فاصلہ حروف کی شناخت اور پڑھائی بہتر کرتا ہے۔";
"help_text_text_width" = "متن کی چوڑائی آرام دہ پڑھائی کے لیے سطر کی زیادہ سے زیادہ لمبائی کنٹرول کرتی ہے۔\n\nاختیارات:\n• پوری چوڑائی: کوئی زیادہ سے زیادہ نہیں\n• آرام دہ ⁨(80 حروف)⁩: پڑھنے کے لیے بہترین\n• تنگ ⁨(60 حروف)⁩: مرکوز پڑھنے کے لیے\n\n⁨AAA⁩ رہنما اصول فی سطر زیادہ سے زیادہ ⁨80⁩ حروف تجویز کرتے ہیں۔";
"help_text_large_touch_targets" = "بڑے ٹچ اہداف تمام بٹنوں اور انٹریکٹو عناصر کو کم از کم ⁨60pt⁩ سائز کا بناتے ہیں۔\n\nیہ مفید ہے:\n• حرکتی معذوری کے لیے\n• لرزش یا کپکپاہٹ کے لیے\n• دستانوں میں ایپ استعمال کرنے کے لیے\n• ایک ہاتھ سے استعمال کے لیے\n\nمعیاری کم از کم ⁨44pt⁩ ہے؛ یہ ترتیب ⁨60pt⁩ تک بڑھاتی ہے۔";
"help_text_reduce_motion" = "حرکت کم کرنا پوری ایپ میں اینیمیشنز کو کم یا ختم کرتا ہے۔\n\nیہ ان صارفین کے لیے مفید ہے جن کو:\n• حرکت کی حساسیت ہو\n• ویسٹیبولر عوارض ہوں\n• مرگی ہو\n• درد شقیقہ کے محرکات ہوں\n\nفعال ہونے پر، اینیمیشنز فوری ٹرانزیشن سے بدل دی جاتی ہیں۔";
"help_text_timeout_behavior" = "ٹائم آؤٹ رویہ کنٹرول کرتا ہے کہ عمل ٹائم آؤٹ ہونے سے پہلے کتنا وقت لے سکتا ہے۔\n\nاختیارات:\n• کوئی ٹائم آؤٹ نہیں ⁨(AAA)⁩: عمل کبھی ٹائم آؤٹ نہیں ہوتے\n• معیاری ⁨(30s)⁩: ڈیفالٹ ٹائم آؤٹ\n• توسیعی ⁨(60s)⁩: معیاری وقت سے دوگنا\n\nکوئی ٹائم آؤٹ نہیں موڈ ⁨AAA⁩ رسائی معیار پورا کرتا ہے۔";
"help_text_simplified_gestures" = "آسان اشارے پیچیدہ کثیر ٹچ اشاروں کو آسان ٹیپس سے بدلتے ہیں۔\n\nیہ مفید ہے:\n• حرکتی معذوری کے لیے\n• محدود لچک کے لیے\n• معاون آلات استعمال کرنے کے لیے\n• ایک ہاتھ کے آپریشن کے لیے\n\nپیچیدہ اشارے بٹنوں اور آسان ٹیپس سے بدل دیے جاتے ہیں۔";
"help_text_haptic_feedback" = "ہیپٹک فیڈبیک اعمال اور اطلاعات کے لیے وائبریشن فراہم کرتا ہے۔\n\nیہ مفید ہے:\n• بٹن دبانے کی تصدیق کے لیے\n• خرابیوں یا تنبیہات کی اطلاع کے لیے\n• غیر بصری فیڈبیک فراہم کرنے کے لیے\n• سماعت یا بصارت کی معذوری والے صارفین کے لیے\n\nاگر وائبریشن تکلیف دہ ہو تو اسے غیر فعال کیا جا سکتا ہے۔";
"help_text_simplified_ui" = "آسان انٹرفیس پوری ایپ میں بصری پیچیدگی کم کرتا ہے۔\n\nیہ مفید ہے:\n• ذہنی معذوری کے لیے\n• سیکھنے کی مشکلات کے لیے\n• توجہ کے عوارض کے لیے\n• نئے یا تجربہ کار صارفین کے لیے\n\nفعال ہونے پر:\n• اسکرین پر کم عناصر\n• بڑے، واضح کنٹرولز\n• کم بصری شور";
"help_text_step_indicators" = "مرحلہ اشارے کثیر مرحلے کے عمل میں آپ کی پیشرفت دکھاتے ہیں۔\n\nیہ مدد کرتا ہے:\n• عمل میں اپنا مقام سمجھنے میں\n• کتنے مراحل باقی ہیں جاننے میں\n• ذہنی بوجھ کم کرنے میں\n• واضح ڈھانچہ فراہم کرنے میں\n\n'مرحلہ ⁨X⁩ از ⁨Y⁩' بصری پیشرفت نقاط کے ساتھ دکھاتا ہے۔";
"help_text_verbose_descriptions" = "تفصیلی وضاحتیں پوری ایپ میں اضافی وضاحتی متن فراہم کرتی ہیں۔\n\nیہ مفید ہے:\n• پیچیدہ خصوصیات سمجھنے کے لیے\n• ایپ استعمال کرنا سیکھنے کے لیے\n• ذہنی معاونت کے لیے\n• اسکرین ریڈر صارفین کے لیے\n\nتمام خصوصیات کے لیے سیاق اور ہدایات فراہم کرتا ہے۔";
"help_text_confirm_actions" = "اعمال کی تصدیق اہم اعمال سے پہلے تصدیق مانگتی ہے۔\n\nیہ روکنے میں مدد کرتا ہے:\n• حادثاتی حذف\n• غیر ارادی تبدیلیاں\n• قبل از وقت جمع کرائی\n• ڈیٹا کا ضیاع\n\nنوٹ: تخریبی اعمال ہمیشہ تصدیق مانگتے ہیں ⁨(AAA⁩ ضرورت)۔";
"help_text_manual_code_entry" = "دستی کوڈ اندراج آپ کو ⁨QR کوڈز⁩ اسکین کرنے کی بجائے کوڈ ٹائپ کرنے دیتا ہے۔\n\nیہ مفید ہے جب:\n• کیمرہ کام نہ کر رہا ہو\n• ⁨QR کوڈ⁩ خراب یا غیر واضح ہو\n• اسکرین ریڈر استعمال ہو رہا ہو\n• اسکیننگ کی بجائے ٹائپ کرنا پسند ہو\n\nاسکرین پر دکھایا گیا کوڈ ٹائپ کرنے کے لیے بس 'کوڈ دستی درج کریں' ٹیپ کریں۔";
"help_text_voice_input" = "آواز ان پٹ آپ کو اسکیننگ یا ٹائپنگ کی بجائے کوڈ بولنے دیتا ہے۔\n\nیہ مفید ہے:\n• محدود نقل و حرکت کے لیے\n• اسکرین ریڈر صارفین کے لیے\n• ہاتھوں سے آزاد آپریشن کے لیے\n• آواز کی ترجیح کے لیے\n\nمائیکروفون بٹن ٹیپ کریں اور اشارہ ملنے پر واضح آواز میں بولیں۔";
"help_text_qr_scanning" = "⁨QR کوڈ⁩ اسکیننگ آپ کے کیمرے سے کوئیک رسپانس کوڈ پڑھنے کے لیے استعمال ہوتی ہے۔\n\nاسکین کرنے کا طریقہ:\n⁨1.⁩ کیمرہ ⁨QR کوڈ⁩ پر رکھیں\n⁨2.⁩ کوڈ کو فریم میں ترتیب دیں\n⁨3.⁩ خودکار پتہ لگانے کا انتظار کریں\n\nتجاویز:\n• اچھی روشنی یقینی بنائیں\n• آلہ مستحکم رکھیں\n• ⁨QR کوڈ⁩ سیدھا اور بغیر رکاوٹ کے رکھیں\n• اگر اسکیننگ ناکام ہو تو دستی کوڈ اندراج آزمائیں";
"help_text_age_verification" = "عمر کی تصدیق ثابت کرتی ہے کہ آپ آپ کی اصل عمر یا تاریخ پیدائش ظاہر کیے بغیر عمر کی شرط پوری کرتے ہیں۔\n\nیہ کیسے کام کرتی ہے:\n⁨1.⁩ تصدیق کنندہ ایک چیلنج بناتا ہے\n⁨2.⁩ آپ ⁨QR کوڈ⁩ اسکین کرتے ہیں یا دستی درج کرتے ہیں\n⁨3.⁩ ایپ صفر علم ثبوت بناتی ہے\n⁨4.⁩ تصدیق کنندہ تصدیق کرتا ہے کہ آپ شرط پوری کرتے ہیں\n\nرازداری محفوظ ہے:\n• آپ کی تاریخ پیدائش کبھی شیئر نہیں کی جاتی\n• تصدیق کنندہ صرف جانتا ہے کہ آپ شرط پوری کرتے ہیں\n• کوئی ٹریکنگ یا ڈیٹا اکٹھا نہیں";
"help_text_credentials" = "ڈیجیٹل اسناد آپ کی عمر کے خفیہ نگاری کے ثبوت ہیں جو آپ کے آلے پر محفوظ طریقے سے ذخیرہ ہوتے ہیں۔\n\nخصوصیات:\n• صرف آپ کے آلے پر ذخیرہ\n• کاپی یا جعل نہیں کی جا سکتیں\n• رازداری کو محفوظ رکھنے والی تصدیق کے لیے استعمال\n• کسی بھی وقت حذف کی جا سکتی ہیں\n\nعمر تصدیق کرنے سے پہلے آپ کو کسی مجاز جاری کنندہ (جیسے سرکاری دفتر) سے سند حاصل کرنی ہوگی۔";
"help_text_zero_knowledge" = "صفر علم ثبوت آپ کو بنیادی معلومات ظاہر کیے بغیر کچھ سچ ثابت کرنے دیتے ہیں۔\n\nمثال:\n• روایتی: شناختی کارڈ دکھائیں (اصل سالگرہ ظاہر ہوتی ہے)\n• صفر علم: ⁨18⁩ سال سے بڑا ثابت کریں (سالگرہ نجی رہتی ہے)\n\nفوائد:\n• زیادہ سے زیادہ رازداری کا تحفظ\n• کوئی ذاتی ڈیٹا شیئر نہیں\n• خفیہ نگاری کے ذریعے محفوظ\n• جعل یا دوبارہ استعمال نہیں ہو سکتا\n\nیہ وہ بنیادی ٹیکنالوجی ہے جو ⁨Provii Wallet⁩ کو نجی بناتی ہے۔";
"help_text_credential_issuance" = "سند کا اجراء مجاز جاری کنندہ سے ڈیجیٹل عمر کی سند حاصل کرنے کا عمل ہے۔\n\nمراحل:\n⁨1.⁩ مجاز جاری کنندہ کے پاس جائیں (مثلاً سرکاری دفتر)\n⁨2.⁩ سرکاری شناختی کارڈ سے اپنی شناخت ثابت کریں\n⁨3.⁩ جاری کنندہ سے ⁨QR کوڈ⁩ یا ڈیپ لنک حاصل کریں\n⁨4.⁩ ⁨QR کوڈ⁩ اسکین کریں یا لنک ٹیپ کریں\n⁨5.⁩ سند مقامی طور پر حساب ہو کر آپ کے آلے پر ذخیرہ ہو جاتی ہے\n\nاندھا تصدیق نامے کا عمل یقینی بناتا ہے کہ آپ کی تاریخ پیدائش نیٹ ورک پر کبھی نہ بھیجی جائے۔\nیہ صرف ایک بار کرنا پڑتا ہے۔ اس کے بعد آپ کی سند لامحدود تصدیقوں کے لیے استعمال ہو سکتی ہے۔";
"help_text_officer_mode" = "افسر موڈ مجاز جاری کنندگان کے لیے صارفین کے لیے اسناد بنانے کا ذریعہ ہے۔\n\nاس موڈ کے لیے ضروری ہے:\n• ⁨YubiKey⁩ کے ساتھ افسر کی توثیق\n• جاری کنندہ اتھارٹی سے اجازت\n• صارف کی شناختی دستاویز کی جسمانی تصدیق\n\nعمل:\n⁨1.⁩ افسر کے طور پر توثیق کریں\n⁨2.⁩ صارف کی سرکاری شناختی دستاویز کی تصدیق کریں\n⁨3.⁩ صارف کی تاریخ پیدائش درج کریں\n⁨4.⁩ تصدیق نامے کا ⁨QR کوڈ⁩ بنائیں\n⁨5.⁩ صارف سند حاصل کرنے کے لیے کوڈ اسکین کرے\n\nصرف مجاز اہلکار ہی اس موڈ کو استعمال کریں۔";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "تمام متن ⁨50%⁩ بڑا کرتا ہے۔\n\nمدد کرتا ہے اگر آپ کو:\n• دیکھنے میں پریشانی ہو\n• پڑھنا مشکل ہو\n• بڑے متن کی ضرورت ہو\n\nآپ کے فون کی متن سائز ترتیبات کے ساتھ کام کرتا ہے۔";
"help_text_contrast_level_simplified" = "متن کتنا گہرا ہے تبدیل کرتا ہے۔\n\nتین انتخاب:\n• معیاری: عام رنگ\n• اعلیٰ: آسان پڑھائی کے لیے گہرا متن\n• زیادہ سے زیادہ: بہترین پڑھائی کے لیے بہت گہرا متن\n\nگہرا متن پڑھنا آسان ہوتا ہے۔";
"help_text_high_contrast_simplified" = "متن دیکھنا آسان بناتا ہے۔\n\nمدد کرتا ہے اگر آپ کو:\n• دیکھنے میں پریشانی ہو\n• گہرے متن کی ضرورت ہو\n• روشن روشنی میں ایپ استعمال کریں\n\nمتن سفید پر سیاہ ہو جاتا ہے۔";
"help_text_reduce_transparency_simplified" = "دھندلے اثرات ہٹاتا ہے۔\n\nیہ مدد کرتا ہے:\n• متن واضح کرنے میں\n• ایپ آسان بنانے میں\n• پرانے فونوں کو تیز کرنے میں\n\nسب کچھ زیادہ ٹھوس نظر آتا ہے۔";
"help_text_color_blind_mode_simplified" = "بہتر دیکھنے کے لیے رنگ تبدیل کرتا ہے۔\n\nانتخاب:\n• سرخ نابینا موڈ\n• سبز نابینا موڈ\n• نیلا نابینا موڈ\n• صرف سرمئی موڈ\n\nاہم چیزیں دیکھنے میں مدد کرتا ہے۔";
"help_text_line_spacing_simplified" = "متن کی سطروں کے درمیان جگہ تبدیل کرتا ہے۔\n\n⁨1.0x⁩ سے ⁨2.0x⁩ تک منتخب کر سکتے ہیں۔\nڈیفالٹ ⁨1.0x⁩ ہے۔\n\nزیادہ جگہ پڑھنا آسان بناتی ہے۔";
"help_text_paragraph_spacing_simplified" = "پیراگرافوں کے درمیان جگہ تبدیل کرتا ہے۔\n\n⁨1.0x⁩ سے ⁨3.0x⁩ تک منتخب کر سکتے ہیں۔\nڈیفالٹ ⁨1.0x⁩ ہے۔\n\nزیادہ جگہ دیکھنے میں مدد کرتی ہے کہ نئے خیالات کہاں شروع ہوتے ہیں۔";
"help_text_letter_spacing_simplified" = "حروف کے درمیان جگہ تبدیل کرتا ہے۔\n\n⁨0.0⁩ سے ⁨0.2⁩ تک منتخب کر سکتے ہیں۔\nڈیفالٹ ⁨0.0⁩ ہے۔\n\nزیادہ جگہ حروف کو واضح کرتی ہے۔";
"help_text_text_width_simplified" = "متن کتنا چوڑا ہے کنٹرول کرتا ہے۔\n\nانتخاب:\n• پوری چوڑائی: پوری اسکرین استعمال\n• درمیانی: پڑھنے کے لیے اچھی\n• تنگ: توجہ کے لیے بہترین\n\nدرمیانی چوڑائی پڑھنا سب سے آسان ہوتا ہے۔";
"help_text_large_touch_targets_simplified" = "تمام بٹن بڑے کرتا ہے۔\n\nمدد کرتا ہے اگر آپ کو:\n• چھوٹے بٹن ٹیپ کرنے میں پریشانی ہو\n• ہاتھ کانپتے ہوں\n• دستانے پہنے ہوں\n• ایک ہاتھ استعمال کریں\n\nبٹن ⁨44pt⁩ کی بجائے ⁨60pt⁩ ہو جاتے ہیں۔";
"help_text_reduce_motion_simplified" = "حرکت والی اینیمیشنز ہٹاتا ہے۔\n\nمدد کرتا ہے اگر:\n• حرکت سے چکر آتا ہو\n• حرکت سے سر درد ہو\n• چیزوں کو ثابت رہنا پسند ہو\n\nچیزیں حرکت کی بجائے فوری تبدیل ہوتی ہیں۔";
"help_text_timeout_behavior_simplified" = "کام کتنی دیر کر سکتا ہے کنٹرول کرتا ہے۔\n\nانتخاب:\n• کوئی حد نہیں: کام کبھی نہیں رکتے\n• عام: ⁨30⁩ سیکنڈ\n• زیادہ: ⁨60⁩ سیکنڈ\n\nزیادہ وقت چاہیے تو 'کوئی حد نہیں' منتخب کریں۔";
"help_text_simplified_gestures_simplified" = "مشکل اشاروں کو آسان ٹیپس سے بدلتا ہے۔\n\nمدد کرتا ہے اگر آپ کو:\n• پیچیدہ ٹچ سے پریشانی ہو\n• آسان ٹیپ پسند ہو\n• ایک ہاتھ استعمال کریں\n\nسب کچھ آسان ٹیپس استعمال کرتا ہے۔";
"help_text_haptic_feedback_simplified" = "ٹیپ کرنے پر فون وائبریٹ کرتا ہے۔\n\nمدد کرتا ہے:\n• جاننے میں کہ بٹن دبایا\n• خرابیاں یا تنبیہات محسوس کرنے میں\n• دیکھے بغیر فیڈبیک حاصل کرنے میں\n\nبند کریں اگر وائبریشن پریشان کرے۔";
"help_text_simplified_ui_simplified" = "ایپ آسان بناتا ہے۔\n\nمدد کرتا ہے اگر آپ:\n• مصروف اسکرینوں سے پریشان ہوں\n• آسان ترتیب پسند کریں\n• ایپ میں نئے ہوں\n\nایک وقت میں کم چیزیں دکھاتا ہے۔";
"help_text_step_indicators_simplified" = "مراحل میں آپ کی پیشرفت دکھاتا ہے۔\n\nمدد کرتا ہے:\n• جاننے میں کہ آپ کہاں ہیں\n• دیکھنے میں کتنے مراحل باقی ہیں\n• منظم رہنے میں\n\n'مرحلہ ⁨1⁩ از ⁨3⁩' نقاط کے ساتھ دکھاتا ہے۔";
"help_text_verbose_descriptions_simplified" = "آپ کو زیادہ وضاحتیں دیتا ہے۔\n\nمدد کرتا ہے:\n• خصوصیات سمجھنے میں\n• ایپ استعمال کرنا سیکھنے میں\n• زیادہ تفصیلات حاصل کرنے میں\n\nہر جگہ اضافی مدد فراہم کرتا ہے۔";
"help_text_confirm_actions_simplified" = "اہم اعمال کی تصدیق مانگتا ہے۔\n\nروکنے میں مدد کرتا ہے:\n• حادثاتی حذف\n• غیر مطلوب تبدیلیاں\n• غلطیاں\n\nہمیشہ پوچھا جائے گا 'کیا آپ یقینی ہیں؟'";
"help_text_manual_code_entry_simplified" = "اسکین کی بجائے کوڈ ٹائپ کرنے دیتا ہے۔\n\nاستعمال کریں جب:\n• کیمرہ کام نہ کرے\n• کوڈ اسکین کرنا مشکل ہو\n• ٹائپ کرنا پسند ہو\n\n'کوڈ دستی درج کریں' ٹیپ کریں۔";
"help_text_voice_input_simplified" = "ٹائپ کرنے کی بجائے کوڈ بولنے دیتا ہے۔\n\nمدد کرتا ہے اگر آپ کو:\n• ٹائپ کرنے میں پریشانی ہو\n• بولنا پسند ہو\n• ہاتھوں سے آزاد استعمال چاہیں\n\nمائیکروفون ٹیپ کریں اور واضح آواز میں بولیں۔";
