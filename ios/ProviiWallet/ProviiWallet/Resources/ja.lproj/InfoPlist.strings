/* InfoPlist.strings - Japanese */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Walletは資格証明の取得と年齢検証のためにQRコードをスキャンする際、カメラへのアクセスが必要です。";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii WalletはNFCを使用して、担当者の安全な認証のためにYubiKeyと通信します。";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Walletはアクセシビリティモードの音声コマンドに音声認識を使用します。ハンズフリーでアプリを操作できます。";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Walletはアクセシビリティモードが有効な場合の音声コントロール機能にマイクへのアクセスが必要です。";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii WalletはFace IDを使用して、年齢資格証明へのアクセスとユーザー認証を安全に行います。";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Walletは近くの資格証明発行者を探すためにローカルネットワークを使用する場合があります。";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii WalletはYubiKeyデバイスとの通信にBluetoothを使用する場合があります。";
