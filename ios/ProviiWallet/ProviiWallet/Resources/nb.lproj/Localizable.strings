/* Hjelpetekstbeskrivelser */
"help_text_extra_large_text" = "Ekstra stor tekst øker all tekst i appen med 50 %.\n\nDette er nyttig for brukere med:\n• Nedsatt syn\n• Leseproblemer\n• Aldersrelaterte synsendringer\n\nFungerer med iOS Dynamic Type for enda større størrelser.";
"help_text_contrast_level" = "Kontrastnivå kontrollerer fargekontrasten mellom tekst og bakgrunner.\n\nTre nivåer tilgjengelig:\n• Standard: Standardfarger\n• Høy (AA): 4,5:1 kontrastforhold – oppfyller AA-standarder\n• Maksimal (AAA): 7:1 kontrastforhold – oppfyller de høyeste AAA-standardene\n\nHøyere kontrast gjør tekst lettere å lese i alle lysforhold.";
"help_text_high_contrast" = "Høykontrastmodus øker kontrasten mellom tekst og bakgrunn, noe som gjør det lettere å lese.\n\nDette er nyttig for brukere med:\n• Nedsatt syn\n• Fargesensitivitet\n• Lyse skjermmiljøer\n\nNår aktivert:\n• Tekst blir svart på hvitt\n• Kanter legges til elementer\n• Farger forenkles";
"help_text_reduce_transparency" = "Reduser gjennomsiktighet fjerner uskarphet og gjennomsiktighetseffekter i hele appen.\n\nDette hjelper:\n• Forbedre tekstlesbarhet\n• Redusere visuell kompleksitet\n• Øke ytelsen på eldre enheter\n• Gjøre innhold mer forutsigbart";
"help_text_color_blind_mode" = "Fargeblindmodi justerer farger for ulike typer fargesyn.\n\nTilgjengelige modi:\n• Protanopi: Rødblind\n• Deuteranopi: Grønnblind\n• Tritanopi: Blåblind\n• Monokrom: Kun gråskala\n\nDisse modiene sikrer at viktig informasjon ikke formidles utelukkende via farge.";
"help_text_line_spacing" = "Linjeavstand kontrollerer mellomrommet mellom tekstlinjer.\n\n• Område: 1,0x til 2,0x\n• AAA-standard: minst 1,5x\n• Standard: 1,0x\n\nØkt linjeavstand gjør tekst lettere å lese og hjelper med å forhindre at linjer hoppes over.";
"help_text_paragraph_spacing" = "Avsnittsavstand kontrollerer mellomrommet mellom avsnitt.\n\n• Område: 1,0x til 3,0x\n• AAA-standard: minst 2,0x\n• Standard: 1,0x\n\nØkt avsnittsavstand hjelper med å skille mellom ulike tekstdeler.";
"help_text_letter_spacing" = "Bokstavavstand kontrollerer mellomrommet mellom enkeltbokstaver.\n\n• Område: 0,0 em til 0,2 em\n• AAA-standard: minst 0,12 em\n• Standard: 0,0 em\n\nØkt bokstavavstand forbedrer gjenkjenning av bokstaver og lesbarhet.";
"help_text_text_width" = "Tekstbredde kontrollerer maksimal linjelengde for behagelig lesing.\n\nAlternativer:\n• Full bredde: Ingen maksimum\n• Behagelig (80 tegn): Optimal for lesing\n• Smal (60 tegn): For konsentrert lesing\n\nAAA-retningslinjer anbefaler maksimalt 80 tegn per linje.";
"help_text_large_touch_targets" = "Større berøringsflater gjør alle knapper og interaktive elementer minst 60 punkter store.\n\nDette er nyttig for:\n• Motoriske funksjonsnedsettelser\n• Skjelving\n• Bruk av appen med hansker\n• Enhendig bruk\n\nStandardminimum er 44 punkter; denne innstillingen øker til 60 punkter.";
"help_text_reduce_motion" = "Reduser bevegelse minimerer eller fjerner animasjoner i hele appen.\n\nDette er nyttig for brukere med:\n• Bevegelsessensitivitet\n• Vestibulære lidelser\n• Epilepsi\n• Migrenetriggere\n\nNår aktivert erstattes animasjoner med øyeblikkelige overganger.";
"help_text_timeout_behavior" = "Tidsavbruddsatferd kontrollerer hvor lenge operasjoner kan ta før tidsavbrudd.\n\nAlternativer:\n• Ingen tidsavbrudd (AAA): Operasjoner får aldri tidsavbrudd\n• Standard (30 s): Standard tidsavbrudd\n• Utvidet (60 s): Dobbelt standard tid\n\nIngen tidsavbrudd-modus oppfyller AAA-tilgjengelighetsstandarder.";
"help_text_simplified_gestures" = "Forenklede bevegelser reduserer komplekse flerfingerbevegelser til enkle trykk.\n\nDette er nyttig for:\n• Motoriske funksjonsnedsettelser\n• Begrenset fingerferdighet\n• Bruk av hjelpemidler\n• Enhendig bruk\n\nKomplekse bevegelser erstattes med knapper og enkle trykk.";
"help_text_haptic_feedback" = "Haptisk tilbakemelding gir vibrasjonsfeedback for handlinger og varsler.\n\nDette er nyttig for:\n• Bekreftelse av knappetrykk\n• Varsling om feil\n• Ikke-visuell tilbakemelding\n• Brukere med hørsels- eller synsnedsettelser\n\nDu kan deaktivere dette hvis vibrasjoner er ubehagelige.";
"help_text_simplified_ui" = "Forenklet grensesnitt reduserer visuell kompleksitet i hele appen.\n\nDette er nyttig for:\n• Kognitive funksjonsnedsettelser\n• Lærevansker\n• Oppmerksomhetsforstyrrelser\n• Nye eller uerfarne brukere\n\nNår aktivert:\n• Færre elementer på skjermen\n• Større, tydeligere kontroller\n• Mindre visuell støy";
"help_text_step_indicators" = "Trinnsindikatorer viser fremdriften din gjennom flertrinns prosesser.\n\nDette hjelper:\n• Forstå hvor du er i en prosess\n• Vite hvor mange trinn som gjenstår\n• Redusere kognitiv belastning\n• Gi klar struktur\n\nViser «Steg X av Y» med visuelle fremdriftsprikker.";
"help_text_verbose_descriptions" = "Detaljerte beskrivelser gir ekstra forklarende tekst i hele appen.\n\nDette er nyttig for:\n• Forståelse av komplekse funksjoner\n• Lære hvordan appen brukes\n• Kognitiv støtte\n• Brukere av skjermlesere\n\nGir kontekst og instruksjoner for alle funksjoner.";
"help_text_confirm_actions" = "Bekreft handlinger ber om bekreftelse før viktige handlinger.\n\nDette hjelper med å forhindre:\n• Utilsiktet sletting\n• Uintenderte endringer\n• For tidlig innsending\n• Datatap\n\nMerk: Destruktive handlinger krever alltid bekreftelse (AAA-krav).";
"help_text_manual_code_entry" = "Manuell koderegistrering lar deg taste inn koder i stedet for å skanne QR-koder.\n\nDette er nyttig når:\n• Kameraet ikke fungerer\n• QR-koden er skadet eller uklar\n• Du bruker skjermleser\n• Du foretrekker å taste inn fremfor å skanne\n\nTrykk på «Tast inn kode manuelt» for å taste inn koden som vises på skjermen.";
"help_text_voice_input" = "Stemmeinndata lar deg si koder i stedet for å skanne eller taste.\n\nDette er nyttig for:\n• Begrenset mobilitet\n• Brukere av skjermlesere\n• Håndfri bruk\n• Preferanse for stemme\n\nTrykk på mikrofonknappen og si tydelig når du blir bedt om det.";
"help_text_qr_scanning" = "QR-kodeskanning bruker kameraet ditt til å lese Quick Response-koder.\n\nSlik skanner du:\n1. Pek kameraet mot QR-koden\n2. Juster koden i rammen\n3. Vent på automatisk oppdagelse\n\nTips:\n• Sørg for god belysning\n• Hold enheten i ro\n• Hold QR-koden flat og uhindret\n• Hvis skanning mislykkes, prøv manuell koderegistrering";
"help_text_age_verification" = "Aldersverifisering beviser at du oppfyller et alderskrav uten å avsløre den faktiske alderen eller fødselsdatoen din.\n\nSlik fungerer det:\n1. Verifisatør genererer en utfordring\n2. Du skanner QR-koden eller taster inn manuelt\n3. Appen oppretter et nullkunnskapsbevis\n4. Verifisatør bekrefter at du oppfyller kravet\n\nPersonvern beskyttet:\n• Fødselsdatoen din deles aldri\n• Verifisatøren lærer bare om du oppfyller kravet\n• Ingen sporing eller datainnsamling";
"help_text_credentials" = "Digitale legitimasjoner er kryptografiske bevis på alderen din lagret sikkert på enheten din.\n\nFunksjoner:\n• Lagres kun på enheten din\n• Kan ikke kopieres eller forfalskes\n• Brukes til personvernbevarende verifisering\n• Kan slettes når som helst\n\nDu må hente en legitimasjon fra en autorisert utsteder (for eksempel et offentlig kontor) før du kan verifisere alderen din.";
"help_text_zero_knowledge" = "Nullkunnskapsbevis lar deg bevise at noe er sant uten å avsløre den underliggende informasjonen.\n\nEksempel:\n• Tradisjonelt: Vis ID (avslører eksakt bursdag)\n• Nullkunnskap: Bevis at du er over 18 uten å vise bursdagen\n\nFordeler:\n• Maksimal personvernbeskyttelse\n• Ingen persondata deles\n• Kryptografisk sikker\n• Kan ikke forfalskes eller spilles av\n\nDette er kjerneteknologien som gjør Provii Wallet privat.";
"help_text_credential_issuance" = "Legitimasjonsutstedelse er prosessen med å hente din digitale alderslegitimasjon fra en autorisert utsteder.\n\nTrinn:\n1. Besøk autorisert utsteder (f.eks. offentlig kontor)\n2. Bevis identiteten din med offisiell ID\n3. Motta QR-kode eller dyplenke fra utsteder\n4. Skann QR-kode eller trykk på lenken\n5. Legitimasjon beregnes lokalt og lagres på enheten din\n\nProsessen med blind attest sikrer at fødselsdatoen din aldri overføres over nettverket.\nDu trenger bare å gjøre dette én gang. Legitimasjonen kan deretter brukes til ubegrenset antall verifiseringer.";
"help_text_officer_mode" = "Tjenestepersonmodus er for autoriserte utstedere som oppretter legitimasjoner for brukere.\n\nDenne modusen krever:\n• Tjenestepersonautentisering med YubiKey\n• Autorisasjon fra utstedermyndigheten\n• Fysisk verifisering av brukerens ID\n\nProsess:\n1. Autentiser som tjenesteperson\n2. Verifiser brukerens offisielle ID\n3. Tast inn brukerens fødselsdato\n4. Generer attest-QR-kode\n5. Bruker skanner koden for å motta legitimasjon\n\nKun autorisert personell skal bruke denne modusen.";

/* Forenklet hjelpetekst */
"help_text_extra_large_text_simplified" = "Gjør all tekst 50 % større.\n\nHjelper deg hvis du:\n• Har problemer med synet\n• Synes lesing er vanskelig\n• Trenger større tekst\n\nFungerer med telefonens tekststørrelsesinnstillinger.";
"help_text_contrast_level_simplified" = "Endrer hvor mørk teksten er.\n\nTre valg:\n• Standard: Normale farger\n• Høy: Mørkere tekst for enkel lesing\n• Maksimal: Veldig mørk tekst for best lesing\n\nMørkere tekst er lettere å lese.";
"help_text_high_contrast_simplified" = "Gjør tekst lettere å se.\n\nHjelper deg hvis du:\n• Har problemer med synet\n• Trenger mørkere tekst\n• Bruker appen i sterkt lys\n\nTekst blir svart på hvitt.";
"help_text_reduce_transparency_simplified" = "Fjerner uskarphet.\n\nDette hjelper:\n• Gjøre tekst tydeligere\n• Gjøre appen enklere\n• Øke hastigheten på eldre telefoner\n\nAlt ser mer solid ut.";
"help_text_color_blind_mode_simplified" = "Endrer farger for å hjelpe deg å se bedre.\n\nValg:\n• Modus for rødblindet\n• Modus for grønnblindet\n• Modus for blåblindet\n• Kun grå\n\nHjelper deg å se viktige ting.";
"help_text_line_spacing_simplified" = "Endrer mellomrom mellom tekstlinjer.\n\nDu kan velge fra 1,0x til 2,0x.\nStandard er 1,0x.\n\nMer mellomrom gjør lesing enklere.";
"help_text_paragraph_spacing_simplified" = "Endrer mellomrom mellom avsnitt.\n\nDu kan velge fra 1,0x til 3,0x.\nStandard er 1,0x.\n\nMer mellomrom hjelper deg å se hvor nye ideer starter.";
"help_text_letter_spacing_simplified" = "Endrer mellomrom mellom bokstaver.\n\nDu kan velge fra 0,0 til 0,2.\nStandard er 0,0.\n\nMer mellomrom gjør bokstaver tydeligere.";
"help_text_text_width_simplified" = "Kontrollerer hvor bred teksten er.\n\nValg:\n• Full bredde: Bruker hele skjermen\n• Middels: Bra for lesing\n• Smal: Best for fokus\n\nMiddels bredde er lettest å lese.";
"help_text_large_touch_targets_simplified" = "Gjør alle knapper større.\n\nHjelper deg hvis du:\n• Har problemer med å trykke på små knapper\n• Har skjelvende hender\n• Bruker hansker\n• Bruker én hånd\n\nKnapper blir 60 punkter i stedet for 44 punkter.";
"help_text_reduce_motion_simplified" = "Fjerner animasjoner.\n\nHjelper deg hvis:\n• Bevegelse gjør deg svimmel\n• Du får hodepine av bevegelse\n• Du foretrekker at ting er i ro\n\nTing endres øyeblikkelig i stedet for å bevege seg.";
"help_text_timeout_behavior_simplified" = "Kontrollerer hvor lenge oppgaver kan ta.\n\nValg:\n• Ingen grense: Oppgaver stopper aldri\n• Normal: 30 sekunder\n• Lengre: 60 sekunder\n\nVelg «Ingen grense» hvis du trenger mer tid.";
"help_text_simplified_gestures_simplified" = "Erstatter vanskelige bevegelser med enkle trykk.\n\nHjelper deg hvis du:\n• Har problemer med komplekse berøringer\n• Foretrekker enkle trykk\n• Bruker én hånd\n\nAlt bruker enkle trykk.";
"help_text_haptic_feedback_simplified" = "Får telefonen til å vibrere når du trykker.\n\nHjelper deg:\n• Vite når du trykket på en knapp\n• Kjenne feil\n• Få tilbakemelding uten å se\n\nSlå av hvis vibrasjoner er ubehagelige.";
"help_text_simplified_ui_simplified" = "Gjør appen enklere.\n\nHjelper deg hvis du:\n• Blir forvirret av travle skjermer\n• Foretrekker enkle oppsett\n• Er ny i appen\n\nViser færre ting på én gang.";
"help_text_step_indicators_simplified" = "Viser fremdriften din gjennom trinn.\n\nHjelper deg:\n• Vite hvor du er\n• Se hvor mange trinn som gjenstår\n• Holde oversikten\n\nViser «Steg 1 av 3» med prikker.";
"help_text_verbose_descriptions_simplified" = "Gir deg flere forklaringer.\n\nHjelper deg:\n• Forstå funksjoner\n• Lære å bruke appen\n• Få flere detaljer\n\nGir ekstra hjelp overalt.";
"help_text_confirm_actions_simplified" = "Ber deg bekrefte viktige handlinger.\n\nHjelper med å forhindre:\n• Utilsiktet sletting\n• Uønskede endringer\n• Feil\n\nDu vil alltid bli spurt «Er du sikker?»";
"help_text_manual_code_entry_simplified" = "Lar deg taste inn koder i stedet for å skanne.\n\nBruk dette når:\n• Kameraet ikke fungerer\n• Koden er vanskelig å skanne\n• Du foretrekker å taste inn\n\nTrykk på «Tast inn kode manuelt» for å taste.";
"help_text_voice_input_simplified" = "Lar deg si koder i stedet for å taste.\n\nHjelper deg hvis du:\n• Har problemer med å taste\n• Foretrekker å snakke\n• Vil bruke håndfritt\n\nTrykk på mikrofonen og si tydelig.";
"help_text_qr_scanning_simplified" = "Bruker kameraet til å lese firkantede koder.\n\nSlik skanner du:\n1. Pek kameraet mot koden\n2. Juster koden\n3. Vent til den leses\n\nTips:\n• Bruk god belysning\n• Hold telefonen i ro\n• Hold koden flat";
"help_text_age_verification_simplified" = "Beviser at du er gammel nok uten å dele bursdagen din.\n\nSlik fungerer det:\n1. Bedrift oppretter en forespørsel\n2. Du skanner koden deres\n3. Appen oppretter et bevis\n4. Bedrift bekrefter at du er gammel nok\n\nBursdagen din forblir privat.";
"help_text_credentials_simplified" = "Digital bevis på alderen din lagret på telefonen.\n\nFunksjoner:\n• Kun på telefonen din\n• Kan ikke kopieres\n• Holder deg privat\n• Du kan slette den når som helst\n\nDu får den fra et offentlig kontor.";
"help_text_zero_knowledge_simplified" = "Beviser noe uten å dele detaljer.\n\nEksempel:\n• Gammel måte: Vis ID (viser eksakt bursdag)\n• Ny måte: Bevis at du er over 18 (bursdag forblir privat)\n\nDette holder informasjonen din privat.";
"help_text_credential_issuance_simplified" = "Hente din digitale aldersbevis.\n\nTrinn:\n1. Gå til offentlig kontor\n2. Vis ID-en din\n3. Hent en kode\n4. Skann koden\n5. Bevis lagres på telefonen\n\nGjør dette én gang. Bruk det mange ganger.";
"help_text_officer_mode_simplified" = "For offentlig ansatte for å opprette bevis.\n\nKrever:\n• Tjenestepersonnøkkel\n• Tillatelse til bruk\n• Brukerens ID å sjekke\n\nTrinn:\n1. Logg inn som tjenesteperson\n2. Sjekk brukerens ID\n3. Tast inn bursdagen deres\n4. Opprett kode\n5. Bruker skanner kode\n\nKun for autoriserte ansatte.";

