// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Ekstra stor tekst øger al tekst i appen med 50%.\n\nDette er nyttigt for brugere med:\n• Nedsat syn\n• Læsevanskeligheder\n• Aldersrelaterede synsændringer\n\nVirker med iOS Dynamic Type til endnu større størrelser.";
"help_text_contrast_level" = "Kontrastniveau styrer farvekontrasten mellem tekst og baggrunde.\n\nTre niveauer:\n• Standard: Standardfarver\n• Høj (AA): 4,5:1 kontrastforhold – opfylder AA-standarder\n• Maksimum (AAA): 7:1 kontrastforhold – opfylder de højeste AAA-standarder\n\nHøjere kontrast gør tekst lettere at læse i alle lysforhold.";
"help_text_high_contrast" = "Høj kontrasttilstand øger kontrasten mellem tekst og baggrund, så det er lettere at læse.\n\nDette er nyttigt for brugere med:\n• Nedsat syn\n• Farveoverfølsomhed\n• Lyse skærmmiljøer\n\nNår aktiveret:\n• Tekst bliver sort på hvid\n• Kanter tilføjes til elementer\n• Farver forenkles";
"help_text_reduce_transparency" = "Reducer gennemsigtighed fjerner slørings- og gennemsigtighedseffekter i appen.\n\nDette hjælper:\n• Forbedre tekstlæsbarhed\n• Reducere visuel kompleksitet\n• Øge ydeevnen på ældre enheder\n• Gøre indhold mere forudsigeligt";
"help_text_color_blind_mode" = "Farveblindhedstilstande justerer farver til forskellige typer farvesynsdeficits.\n\nTilgængelige tilstande:\n• Protanopi: Rødblind (vanskeligheder med at se rød)\n• Deuteranopi: Grønblind (vanskeligheder med at se grøn)\n• Tritanopi: Blåblind (vanskeligheder med at se blå)\n• Monokrom: Kun gråtoner\n\nDisse tilstande sikrer at vigtig information ikke kun formidles via farve.";
"help_text_line_spacing" = "Linjeafstand styrer afstanden mellem tekstlinjer.\n\n• Interval: 1,0x til 2,0x\n• AAA-standard: minimum 1,5x\n• Standard: 1,0x\n\nØget linjeafstand gør tekst lettere at læse og hjælper med at forhindre linjespring.";
"help_text_paragraph_spacing" = "Afsnitsafstand styrer afstanden mellem afsnit.\n\n• Interval: 1,0x til 3,0x\n• AAA-standard: minimum 2,0x\n• Standard: 1,0x\n\nØget afsnitsafstand hjælper med at skelne mellem forskellige tekstafsnit.";
"help_text_letter_spacing" = "Bogstavafstand styrer afstanden mellem individuelle tegn.\n\n• Interval: 0,0em til 0,2em\n• AAA-standard: minimum 0,12em\n• Standard: 0,0em\n\nØget bogstavafstand forbedrer tegngenkendelse og læsbarhed.";
"help_text_text_width" = "Tekstbredde styrer den maksimale linjelængde for komfortabel læsning.\n\nMuligheder:\n• Fuld bredde: Ingen maksimum\n• Komfortabel (80 tegn): Optimal til læsning\n• Smal (60 tegn): Til koncentreret læsning\n\nAAA-retningslinjerne anbefaler maksimalt 80 tegn per linje.";
"help_text_large_touch_targets" = "Større berøringsflader gør alle knapper og interaktive elementer mindst 60pt store.\n\nDette er nyttigt til:\n• Motoriske handicap\n• Skælven\n• Brug med handsker\n• Envånds brug\n\nStandard minimum er 44pt; denne indstilling øger til 60pt.";
"help_text_reduce_motion" = "Reducer bevægelse minimerer eller fjerner animationer i appen.\n\nDette er nyttigt for brugere med:\n• Bevægelsesfølsomhed\n• Vestibulære forstyrrelser\n• Epilepsi\n• Migrænetriggers\n\nNår aktiveret erstattes animationer med øjeblikkelige overgange.";
"help_text_timeout_behavior" = "Timeoutadfærd styrer hvor lang tid handlinger kan tage inden de får timeout.\n\nMuligheder:\n• Ingen timeout (AAA): Handlinger får aldrig timeout\n• Standard (30s): Standard timeout\n• Udvidet (60s): Dobbelt standard tid\n\nIngen timeout-tilstand opfylder AAA-tilgængelighedsstandarder.";
"help_text_simplified_gestures" = "Forenklede bevægelser reducerer komplekse multi-touch-bevægelser til simple tryk.\n\nDette er nyttigt til:\n• Motoriske handicap\n• Begrænset fingerfærdighed\n• Brug af hjælpemidler\n• Envånds betjening\n\nKomplekse bevægelser erstattes med knapper og simple tryk.";
"help_text_haptic_feedback" = "Haptisk feedback giver vibrationsfeedback til handlinger og notifikationer.\n\nDette er nyttigt til:\n• Bekræftelse af knaptryk\n• Varsling om fejl eller advarsler\n• Ikke-visuel feedback\n• Brugere med høre- eller synshandicap\n\nDu kan deaktivere dette hvis vibrationer er ubehagelige.";
"help_text_simplified_ui" = "Forenklet brugerflade reducerer visuel kompleksitet i appen.\n\nDette er nyttigt til:\n• Kognitive handicap\n• Indlæringsvanskeligheder\n• Opmærksomhedsforstyrrelser\n• Nye eller uerfarne brugere\n\nNår aktiveret:\n• Færre elementer på skærmen\n• Større, tydeligere kontroller\n• Mindre visuel støj";
"help_text_step_indicators" = "Trinindikatorer viser din fremgang gennem flertrinsprocesser.\n\nDette hjælper:\n• Forstå hvor du er i en proces\n• Vide hvor mange trin der er tilbage\n• Reducere kognitiv belastning\n• Give klar struktur\n\nViser 'Trin X af Y' med visuelle fremgangsprikker.";
"help_text_verbose_descriptions" = "Detaljerede beskrivelser giver yderligere forklarende tekst i appen.\n\nDette er nyttigt til:\n• Forståelse af komplekse funktioner\n• Lærdom om brug af appen\n• Kognitiv støtte\n• Skærmlæserbrugere\n\nGiver kontekst og instruktioner til alle funktioner.";
"help_text_confirm_actions" = "Bekræft handlinger beder om bekræftelse inden vigtige handlinger.\n\nDette hjælper med at forhindre:\n• Utilsigtede sletninger\n• Uønskede ændringer\n• For tidlige indsendelser\n• Datatab\n\nBemærk: Destruktive handlinger kræver altid bekræftelse (AAA-krav).";
"help_text_manual_code_entry" = "Manuel kodeindtastning giver dig mulighed for at taste koder i stedet for at scanne QR-koder.\n\nDette er nyttigt når:\n• Kamera ikke virker\n• QR-kode er beskadiget eller uklar\n• Du bruger skærmlæser\n• Du foretrækker at taste frem for at scanne\n\nTryk blot 'Indtast kode manuelt' for at taste koden vist på skærmen.";
"help_text_voice_input" = "Stemme-input giver dig mulighed for at sige koder i stedet for at scanne eller taste.\n\nDette er nyttigt til:\n• Begrænset bevægelighed\n• Skærmlæserbrugere\n• Håndfri betjening\n• Præference for stemme\n\nTryk mikrofon­knappen og tal tydeligt når du bliver bedt om det.";
"help_text_qr_scanning" = "QR-kodescanning bruger dit kamera til at læse Quick Response-koder.\n\nSådan scanner du:\n1. Ret kamera mod QR-kode\n2. Placer kode i rammen\n3. Vent på automatisk registrering\n\nTips:\n• Sørg for god belysning\n• Hold enheden stille\n• Hold QR-koden flad og fri\n• Prøv manuel kodeindtastning hvis scanning mislykkedes";
"help_text_age_verification" = "Aldersverifikation beviser at du opfylder et alderskrav uden at afsløre din faktiske alder eller fødselsdato.\n\nSådan fungerer det:\n1. Verificereren genererer en udfordring\n2. Du scanner QR-koden eller indtaster manuelt\n3. Appen opretter et nulvidensbevis\n4. Verificereren bekræfter at du opfylder kravet\n\nPrivatlivsbeskyttelse:\n• Din fødselsdato deles aldrig\n• Verificereren erfarer kun om du opfylder kravet\n• Ingen sporing eller dataindsamling";
"help_text_credentials" = "Digitale legitimationer er kryptografiske beviser for din alder gemt sikkert på din enhed.\n\nFunktioner:\n• Gemt kun på din enhed\n• Kan ikke kopieres eller forfalskes\n• Bruges til privatlivsbevarende verifikation\n• Kan slettes til enhver tid\n\nDu skal hente en legitimation fra en autoriseret udsteder (f.eks. et offentligt kontor) inden du kan verificere din alder.";
"help_text_zero_knowledge" = "Nulvidensbevis giver dig mulighed for at bevise at noget er sandt uden at afsløre den underliggende information.\n\nEksempel:\n• Traditionel: Vis ID (afslører præcis fødselsdag)\n• Nulviden: Bevis du er over 18 uden at vise fødselsdag\n\nFordele:\n• Maksimal privatlivsbeskyttelse\n• Ingen personoplysninger deles\n• Kryptografisk sikret\n• Kan ikke forfalskes eller genafspilles\n\nDette er kerneteknologien der gør Provii Wallet privat.";
"help_text_credential_issuance" = "Legitimationsudstedelse er processen med at hente din digitale alderslegitimation fra en autoriseret udsteder.\n\nTrin:\n1. Besøg autoriseret udsteder (f.eks. offentligt kontor)\n2. Bevis din identitet med officielt ID\n3. Modtag QR-kode eller deeplink fra udsteder\n4. Scan QR-kode eller tryk på linket\n5. Legitimation beregnes lokalt og gemmes på din enhed\n\nBlind attesterings-processen sikrer at din fødselsdato aldrig overføres over netværket.\nDu behøver kun gøre dette én gang. Din legitimation kan derefter bruges til ubegrænsede verifikationer.";
"help_text_officer_mode" = "Embedsmandstilstand er til autoriserede udstedere der skal oprette legitimationer til brugere.\n\nDenne tilstand kræver:\n• Embedsmandsgodkendelse med YubiKey\n• Autorisation fra udstedende myndighed\n• Fysisk verifikation af brugerens ID\n\nProces:\n1. Godkend som embedsmand\n2. Verificer brugerens officielle ID\n3. Indtast brugerens fødselsdato\n4. Generer attesterings-QR-kode\n5. Brugeren scanner koden for at modtage legitimationen\n\nKun autoriseret personale bør bruge denne tilstand.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Gør al tekst 50% større.\n\nHjælper dig hvis du:\n• Har svært ved at se\n• Har svært ved at læse\n• Har brug for større tekst\n\nVirker med telefonens tekststørrelsesindstillinger.";

"help_text_contrast_level_simplified" = "Ændrer hvor mørk teksten er.\n\nTre valg:\n• Standard: Normale farver\n• Høj: Mørkere tekst til nem læsning\n• Maksimum: Meget mørk tekst til bedst læsning\n\nMørkere tekst er lettere at læse.";

"help_text_high_contrast_simplified" = "Gør tekst lettere at se.\n\nHjælper dig hvis du:\n• Har svært ved at se\n• Har brug for mørkere tekst\n• Bruger appen i stærkt lys\n\nTekst bliver sort på hvid.";

"help_text_reduce_transparency_simplified" = "Fjerner slørede effekter.\n\nDette hjælper:\n• Gøre tekst klarere\n• Gøre appen enklere\n• Fremskynde ældre telefoner\n\nAlt ser mere fast ud.";

"help_text_color_blind_mode_simplified" = "Ændrer farver så du kan se bedre.\n\nValg:\n• Rødblind-tilstand\n• Grønblind-tilstand\n• Blåblind-tilstand\n• Kun grå-tilstand\n\nHjælper dig med at se vigtige ting.";

"help_text_line_spacing_simplified" = "Ændrer afstand mellem tekstlinjer.\n\nDu kan vælge fra 1,0x til 2,0x.\nStandard er 1,0x.\n\nMere afstand gør læsning lettere.";

"help_text_paragraph_spacing_simplified" = "Ændrer afstand mellem afsnit.\n\nDu kan vælge fra 1,0x til 3,0x.\nStandard er 1,0x.\n\nMere afstand hjælper dig med at se hvor nye ideer starter.";

"help_text_letter_spacing_simplified" = "Ændrer afstand mellem bogstaver.\n\nDu kan vælge fra 0,0 til 0,2.\nStandard er 0,0.\n\nMere afstand gør bogstaver klarere.";

"help_text_text_width_simplified" = "Styrer hvor bred tekst er.\n\nValg:\n• Fuld bredde: Bruger hele skærmen\n• Middel: God til læsning\n• Smal: Bedst til fokus\n\nMiddel bredde er lettest at læse.";

"help_text_large_touch_targets_simplified" = "Gør alle knapper større.\n\nHjælper dig hvis du:\n• Har svært ved at trykke på små knapper\n• Har rystende hænder\n• Bærer handsker\n• Bruger én hånd\n\nKnapper bliver 60pt i stedet for 44pt.";

"help_text_reduce_motion_simplified" = "Fjerner bevægende animationer.\n\nHjælper dig hvis:\n• Bevægelse gør dig svimmel\n• Du får hovedpine af bevægelse\n• Du foretrækker at tingene er stille\n\nTing ændres øjeblikkeligt i stedet for at bevæge sig.";

"help_text_timeout_behavior_simplified" = "Styrer hvor lang tid opgaver kan tage.\n\nValg:\n• Ingen grænse: Opgaver stopper aldrig\n• Normal: 30 sekunder\n• Længere: 60 sekunder\n\nVælg 'Ingen grænse' hvis du har brug for mere tid.";

"help_text_simplified_gestures_simplified" = "Erstatter svære bevægelser med simple tryk.\n\nHjælper dig hvis du:\n• Har svært ved komplekse berøringer\n• Foretrækker simple tryk\n• Bruger én hånd\n\nAlt bruger simple tryk.";

"help_text_haptic_feedback_simplified" = "Får din telefon til at vibrere når du trykker.\n\nHjælper dig:\n• Vide hvornår du trykkede på en knap\n• Mærke fejl eller advarsler\n• Få feedback uden at se\n\nSluk hvis vibrationer generer dig.";

"help_text_simplified_ui_simplified" = "Gør appen enklere.\n\nHjælper dig hvis du:\n• Bliver forvirret af travle skærme\n• Foretrækker enkle layouts\n• Er ny til appen\n\nViser færre ting ad gangen.";

"help_text_step_indicators_simplified" = "Viser din fremgang gennem trin.\n\nHjælper dig:\n• Vide hvor du er\n• Se hvor mange trin der er tilbage\n• Holde overblikket\n\nViser 'Trin 1 af 3' med prikker.";

"help_text_verbose_descriptions_simplified" = "Giver dig flere forklaringer.\n\nHjælper dig:\n• Forstå funktioner\n• Lære at bruge appen\n• Få flere detaljer\n\nGiver ekstra hjælp overalt.";

"help_text_confirm_actions_simplified" = "Beder dig bekræfte vigtige handlinger.\n\nHjælper med at forhindre:\n• Utilsigtede sletninger\n• Uønskede ændringer\n• Fejl\n\nDu vil altid blive spurgt 'Er du sikker?'";

"help_text_manual_code_entry_simplified" = "Lader dig taste koder i stedet for at scanne.\n\nBrug dette når:\n• Dit kamera ikke virker\n• Koden er svær at scanne\n• Du foretrækker at taste\n\nTryk 'Indtast kode manuelt' for at taste.";

"help_text_voice_input_simplified" = "Lader dig sige koder i stedet for at taste.\n\nHjælper dig hvis du:\n• Har svært ved at taste\n• Foretrækker at tale\n• Vil bruge håndfrit\n\nTryk mikrofonen og tal tydeligt.";

"help_text_qr_scanning_simplified" = "Bruger dit kamera til at læse firkantede koder.\n\nSådan scanner du:\n1. Ret kamera mod koden\n2. Placer koden\n3. Vent til den læses\n\nTips:\n• Brug god belysning\n• Hold telefonen stille\n• Hold koden flad";

"help_text_age_verification_simplified" = "Beviser at du er gammel nok uden at dele din fødselsdag.\n\nSådan fungerer det:\n1. Butikken opretter en anmodning\n2. Du scanner deres kode\n3. Appen opretter et bevis\n4. Butikken bekræfter at du er gammel nok\n\nDin fødselsdag forbliver privat.";

"help_text_credentials_simplified" = "Digitalt bevis for din alder gemt på din telefon.\n\nFunktioner:\n• Kun på din telefon\n• Kan ikke kopieres\n• Holder dig privat\n• Du kan slette det til enhver tid\n\nDu henter det fra et offentligt kontor.";

"help_text_zero_knowledge_simplified" = "Beviser noget uden at dele detaljer.\n\nEksempel:\n• Gammel måde: Vis dit ID (viser præcis fødselsdag)\n• Ny måde: Bevis du er over 18 (fødselsdag forbliver privat)\n\nDette holder dine oplysninger private.";

"help_text_credential_issuance_simplified" = "Henter dit digitale aldersbevis.\n\nTrin:\n1. Gå til offentligt kontor\n2. Vis dit ID\n3. Hent en kode\n4. Scan koden\n5. Bevis gemmes på din telefon\n\nGør dette én gang. Brug det derefter mange gange.";

"help_text_officer_mode_simplified" = "Til offentligt ansatte der skal oprette beviser.\n\nKræver:\n• Embedsmandsadgangskode\n• Tilladelse til at bruge\n• Brugerens ID til kontrol\n\nTrin:\n1. Log ind som embedsmand\n2. Kontroller brugerens ID\n3. Indtast deres fødselsdag\n4. Opret kode\n5. Bruger scanner koden\n\nKun til autoriserede ansatte.";

