/* InfoPlist.strings - Punjabi (pa) */
/* Provii Wallet ਲਈ ਅਨੁਮਤੀ ਵਰਣਨ */

/* ਕੈਮਰਾ ਪਹੁੰਚ */
"NSCameraUsageDescription" = "Provii Wallet ਨੂੰ ਪ੍ਰਮਾਣ ਪੱਤਰ ਲੈਣ ਅਤੇ ਉਮਰ ਦੀ ਤਸਦੀਕ ਲਈ QR ਕੋਡ ਸਕੈਨ ਕਰਨ ਹੇਤੁ ਕੈਮਰੇ ਦੀ ਪਹੁੰਚ ਦੀ ਲੋੜ ਹੈ।";

/* NFC ਪਹੁੰਚ */
"NFCReaderUsageDescription" = "Provii Wallet ਅਧਿਕਾਰੀਆਂ ਦੀ ਸੁਰੱਖਿਅਤ ਪ੍ਰਮਾਣੀਕਰਨ ਲਈ ਤੁਹਾਡੀ YubiKey ਨਾਲ ਸੰਚਾਰ ਕਰਨ ਹੇਤੁ NFC ਵਰਤਦਾ ਹੈ।";

/* ਸਪੀਚ ਰਿਕੋਗਨਿਸ਼ਨ */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet ਪਹੁੰਚਯੋਗਤਾ ਮੋਡ ਵਿੱਚ ਵੌਇਸ ਕਮਾਂਡਾਂ ਲਈ ਸਪੀਚ ਰਿਕੋਗਨਿਸ਼ਨ ਵਰਤਦਾ ਹੈ, ਜਿਸ ਨਾਲ ਤੁਸੀਂ ਬਿਨਾਂ ਹੱਥ ਲਗਾਏ ਐਪ ਕੰਟਰੋਲ ਕਰ ਸਕਦੇ ਹੋ।";

/* ਮਾਈਕ੍ਰੋਫ਼ੋਨ ਪਹੁੰਚ */
"NSMicrophoneUsageDescription" = "ਜਦੋਂ ਪਹੁੰਚਯੋਗਤਾ ਮੋਡ ਚਾਲੂ ਹੋਵੇ ਤਾਂ Provii Wallet ਨੂੰ ਵੌਇਸ ਕੰਟਰੋਲ ਫੀਚਰਾਂ ਲਈ ਮਾਈਕ੍ਰੋਫ਼ੋਨ ਦੀ ਪਹੁੰਚ ਦੀ ਲੋੜ ਹੈ।";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet ਤੁਹਾਡੇ ਉਮਰ ਪ੍ਰਮਾਣ ਪੱਤਰਾਂ ਤੱਕ ਸੁਰੱਖਿਅਤ ਪਹੁੰਚ ਅਤੇ ਪਛਾਣ ਦੀ ਤਸਦੀਕ ਲਈ Face ID ਵਰਤਦਾ ਹੈ।";

/* ਲੋਕਲ ਨੈੱਟਵਰਕ */
"NSLocalNetworkUsageDescription" = "Provii Wallet ਨੇੜੇ ਦੇ ਪ੍ਰਮਾਣ ਪੱਤਰ ਜਾਰੀਕਰਤਾਵਾਂ ਦਾ ਪਤਾ ਲਗਾਉਣ ਲਈ ਲੋਕਲ ਨੈੱਟਵਰਕ ਵਰਤ ਸਕਦਾ ਹੈ।";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet YubiKey ਡਿਵਾਈਸਾਂ ਨਾਲ ਸੰਚਾਰ ਕਰਨ ਲਈ Bluetooth ਵਰਤ ਸਕਦਾ ਹੈ।";
