// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Teks Sangat Besar meningkatkan semua teks dalam aplikasi sebanyak 50%.\n\nIni membantu pengguna yang:\n• Mempunyai penglihatan lemah\n• Mengalami kesukaran membaca\n• Mengalami perubahan penglihatan berkaitan usia\n\nBerfungsi dengan Jenis Dinamik iOS untuk saiz yang lebih besar.";
"help_text_contrast_level" = "Tahap Kontras mengawal kontras warna antara teks dan latar belakang.\n\nTiga tahap tersedia:\n• Standard: Warna lalai\n• Tinggi (AA): Nisbah kontras 4.5:1 - memenuhi piawaian AA\n• Maksimum (AAA): Nisbah kontras 7:1 - memenuhi piawaian AAA tertinggi\n\nKontras lebih tinggi memudahkan pembacaan teks dalam semua keadaan pencahayaan.";
"help_text_high_contrast" = "Mod Kontras Tinggi meningkatkan kontras antara teks dan latar belakang, memudahkan pembacaan.\n\nIni membantu pengguna yang:\n• Mempunyai penglihatan lemah\n• Mempunyai kepekaan warna\n• Menggunakan skrin dalam persekitaran cerah\n\nApabila diaktifkan:\n• Teks menjadi hitam pada putih\n• Sempadan ditambah pada elemen\n• Warna dipermudahkan";
"help_text_reduce_transparency" = "Kurangkan Ketelusan membuang kesan kabur dan ketelusan di seluruh aplikasi.\n\nIni membantu:\n• Meningkatkan kebolehbacaan teks\n• Mengurangkan kerumitan visual\n• Meningkatkan prestasi pada peranti lama\n• Menjadikan kandungan lebih mudah diramal";
"help_text_color_blind_mode" = "Mod Buta Warna melaraskan warna untuk pelbagai jenis kekurangan penglihatan warna.\n\nMod yang tersedia:\n• Protanopia: Buta merah (kesukaran melihat merah)\n• Deuteranopia: Buta hijau (kesukaran melihat hijau)\n• Tritanopia: Buta biru (kesukaran melihat biru)\n• Monokrom: Skala kelabu sahaja\n\nMod ini memastikan maklumat penting tidak disampaikan melalui warna sahaja.";
"help_text_line_spacing" = "Jarak Baris mengawal ruang antara baris teks.\n\n• Julat: 1.0x hingga 2.0x\n• Piawaian AAA: minimum 1.5x\n• Lalai: 1.0x\n\nJarak baris yang meningkat memudahkan pembacaan teks dan membantu mengelakkan pelompatan baris.";
"help_text_paragraph_spacing" = "Jarak Perenggan mengawal ruang antara perenggan.\n\n• Julat: 1.0x hingga 3.0x\n• Piawaian AAA: minimum 2.0x\n• Lalai: 1.0x\n\nJarak perenggan yang meningkat membantu membezakan antara bahagian teks yang berbeza.";
"help_text_letter_spacing" = "Jarak Huruf mengawal ruang antara aksara individu.\n\n• Julat: 0.0em hingga 0.2em\n• Piawaian AAA: minimum 0.12em\n• Lalai: 0.0em\n\nJarak huruf yang meningkat meningkatkan pengecaman aksara dan kebolehbacaan.";
"help_text_text_width" = "Lebar Teks mengawal panjang baris maksimum untuk pembacaan yang selesa.\n\nPilihan:\n• Lebar Penuh: Tiada maksimum\n• Selesa (80 aksara): Optimum untuk pembacaan\n• Sempit (60 aksara): Untuk pembacaan yang tertumpu\n\nGaris panduan AAA mengesyorkan maksimum 80 aksara setiap baris.";
"help_text_large_touch_targets" = "Sasaran Sentuhan Lebih Besar menjadikan semua butang dan elemen interaktif sekurang-kurangnya 60pt.\n\nIni membantu:\n• Masalah motor\n• Gegaran atau tangan yang tidak stabil\n• Menggunakan aplikasi dengan sarung tangan\n• Penggunaan satu tangan\n\nMinimum standard ialah 44pt; tetapan ini meningkat kepada 60pt.";
"help_text_reduce_motion" = "Kurangkan Gerakan meminimumkan atau membuang animasi di seluruh aplikasi.\n\nIni membantu pengguna yang:\n• Mempunyai kepekaan gerakan\n• Mengalami gangguan vestibular\n• Menghidap epilepsi\n• Mempunyai pencetus migrain\n\nApabila diaktifkan, animasi digantikan dengan peralihan segera.";
"help_text_timeout_behavior" = "Kelakuan Tamat Masa mengawal berapa lama operasi boleh mengambil masa sebelum tamat masa.\n\nPilihan:\n• Tiada Tamat Masa (AAA): Operasi tidak pernah tamat masa\n• Standard (30s): Tamat masa lalai\n• Dilanjutkan (60s): Dua kali masa standard\n\nMod tanpa tamat masa memenuhi piawaian kebolehcapaian AAA.";
"help_text_simplified_gestures" = "Isyarat Dipermudahkan mengurangkan isyarat berbilang sentuhan kepada ketikan ringkas.\n\nIni membantu:\n• Masalah motor\n• Ketangkasan terhad\n• Menggunakan peranti bantuan\n• Operasi satu tangan\n\nIsyarat kompleks digantikan dengan butang dan ketikan ringkas.";
"help_text_haptic_feedback" = "Maklum Balas Haptik menyediakan maklum balas getaran untuk tindakan dan pemberitahuan.\n\nIni membantu:\n• Mengesahkan tekanan butang\n• Memberi amaran ralat atau amaran\n• Menyediakan maklum balas bukan visual\n• Pengguna yang mengalami masalah pendengaran atau penglihatan\n\nAnda boleh menyahaktifkan ini jika getaran tidak selesa.";
"help_text_simplified_ui" = "Antara Muka Dipermudahkan mengurangkan kerumitan visual di seluruh aplikasi.\n\nIni membantu:\n• Ketidakupayaan kognitif\n• Kesukaran pembelajaran\n• Gangguan perhatian\n• Pengguna baru atau tidak berpengalaman\n\nApabila diaktifkan:\n• Lebih sedikit elemen pada skrin\n• Kawalan yang lebih besar dan lebih jelas\n• Kurang bunyi visual";
"help_text_step_indicators" = "Penunjuk Langkah menunjukkan kemajuan anda melalui proses berbilang langkah.\n\nIni membantu:\n• Memahami kedudukan anda dalam proses\n• Mengetahui berapa banyak langkah yang tinggal\n• Mengurangkan beban kognitif\n• Menyediakan struktur yang jelas\n\nMenunjukkan 'Langkah X daripada Y' dengan titik kemajuan visual.";
"help_text_verbose_descriptions" = "Penerangan Terperinci menyediakan teks penerangan tambahan di seluruh aplikasi.\n\nIni membantu:\n• Memahami ciri yang kompleks\n• Mempelajari cara menggunakan aplikasi\n• Sokongan kognitif\n• Pengguna pembaca skrin\n\nMenyediakan konteks dan arahan untuk semua ciri.";
"help_text_confirm_actions" = "Sahkan Tindakan meminta pengesahan sebelum tindakan penting.\n\nIni membantu mencegah:\n• Pemadaman tidak sengaja\n• Perubahan yang tidak diingini\n• Penyerahan pramatang\n• Kehilangan data\n\nNota: Tindakan merosakkan sentiasa memerlukan pengesahan (keperluan AAA).";
"help_text_manual_code_entry" = "Kemasukan Kod Manual membolehkan anda menaip kod dan bukannya mengimbas kod QR.\n\nIni berguna apabila:\n• Kamera tidak berfungsi\n• Kod QR rosak atau tidak jelas\n• Menggunakan pembaca skrin\n• Lebih suka menaip daripada mengimbas\n\nHanya ketik 'Masukkan Kod Secara Manual' untuk menaip kod yang ditunjukkan pada skrin.";
"help_text_voice_input" = "Input Suara membolehkan anda menyebut kod dan bukannya mengimbas atau menaip.\n\nIni membantu:\n• Mobiliti terhad\n• Pengguna pembaca skrin\n• Operasi tanpa tangan\n• Keutamaan suara\n\nKetik butang mikrofon dan sebut dengan jelas apabila digesa.";
"help_text_qr_scanning" = "Pengimbasan Kod QR menggunakan kamera anda untuk membaca kod Tindak Balas Pantas.\n\nCara mengimbas:\n1. Arahkan kamera ke kod QR\n2. Sejajarkan kod dalam bingkai\n3. Tunggu pengesanan automatik\n\nPetua:\n• Pastikan pencahayaan yang baik\n• Pegang peranti dengan stabil\n• Pastikan kod QR rata dan tidak terhalang\n• Jika pengimbasan gagal, cuba Kemasukan Kod Manual";
"help_text_age_verification" = "Pengesahan Umur membuktikan anda memenuhi keperluan umur tanpa mendedahkan umur atau tarikh lahir sebenar anda.\n\nCara ia berfungsi:\n1. Pengesah menjana cabaran\n2. Anda mengimbas kod QR atau memasukkan secara manual\n3. Aplikasi mencipta bukti pengetahuan sifar\n4. Pengesah mengesahkan anda memenuhi keperluan\n\nPrivasi dilindungi:\n• Tarikh lahir anda tidak pernah dikongsi\n• Pengesah hanya mengetahui sama ada anda memenuhi keperluan\n• Tiada penjejakan atau pengumpulan data";
"help_text_credentials" = "Kelayakan Digital ialah bukti kriptografi umur anda yang disimpan dengan selamat pada peranti anda.\n\nCiri:\n• Disimpan hanya pada peranti anda\n• Tidak boleh disalin atau dipalsukan\n• Digunakan untuk pengesahan yang memelihara privasi\n• Boleh dipadam pada bila-bila masa\n\nAnda mesti mendapatkan kelayakan daripada penerbit yang diberi kuasa (seperti pejabat kerajaan) sebelum anda boleh mengesahkan umur anda.";
"help_text_zero_knowledge" = "Bukti Pengetahuan Sifar membolehkan anda membuktikan sesuatu adalah benar tanpa mendedahkan maklumat asas.\n\nContoh:\n• Tradisional: Tunjukkan IC (mendedahkan tarikh lahir tepat)\n• Pengetahuan Sifar: Buktikan anda berumur lebih 18 tanpa menunjukkan tarikh lahir\n\nManfaat:\n• Perlindungan privasi maksimum\n• Tiada data peribadi dikongsi\n• Selamat secara kriptografi\n• Tidak boleh dipalsukan atau diulang\n\nInilah teknologi teras yang menjadikan Provii Wallet peribadi.";
"help_text_credential_issuance" = "Pengeluaran Kelayakan ialah proses mendapatkan kelayakan umur digital anda daripada penerbit yang diberi kuasa.\n\nLangkah:\n1. Lawati penerbit yang diberi kuasa (cth., pejabat kerajaan)\n2. Buktikan identiti anda dengan ID rasmi\n3. Terima kod QR atau pautan dalam daripada penerbit\n4. Imbas kod QR atau ketik pautan\n5. Kelayakan dikira secara tempatan dan disimpan pada peranti anda\n\nProses perakuan buta memastikan tarikh lahir anda tidak pernah dihantar melalui rangkaian.\nAnda hanya perlu melakukan ini sekali. Kelayakan anda kemudian boleh digunakan untuk pengesahan tanpa had.";
"help_text_officer_mode" = "Mod Pegawai adalah untuk penerbit yang diberi kuasa untuk mencipta kelayakan bagi pengguna.\n\nMod ini memerlukan:\n• Pengesahihan pegawai dengan YubiKey\n• Kebenaran daripada pihak berkuasa pengeluaran\n• Pengesahan fizikal ID pengguna\n\nProses:\n1. Sahkan sebagai pegawai\n2. Sahkan ID rasmi pengguna\n3. Masukkan tarikh lahir pengguna\n4. Jana kod QR perakuan\n5. Pengguna mengimbas kod untuk menerima kelayakan\n\nHanya kakitangan yang diberi kuasa yang boleh menggunakan mod ini.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Menjadikan semua teks 50% lebih besar.\n\nMembantu anda jika anda:\n• Mengalami kesukaran melihat\n• Mendapati pembacaan sukar\n• Memerlukan teks lebih besar\n\nBerfungsi dengan tetapan saiz teks telefon anda.";

"help_text_contrast_level_simplified" = "Menukar betapa gelap teksnya.\n\nTiga pilihan:\n• Standard: Warna biasa\n• Tinggi: Teks lebih gelap untuk pembacaan mudah\n• Maksimum: Teks sangat gelap untuk pembacaan terbaik\n\nTeks lebih gelap lebih mudah dibaca.";

"help_text_high_contrast_simplified" = "Menjadikan teks lebih mudah dilihat.\n\nMembantu anda jika anda:\n• Mengalami kesukaran melihat\n• Memerlukan teks lebih gelap\n• Menggunakan aplikasi dalam cahaya terang\n\nTeks menjadi hitam pada putih.";

"help_text_reduce_transparency_simplified" = "Membuang kesan kabur.\n\nIni membantu:\n• Menjadikan teks lebih jelas\n• Menjadikan aplikasi lebih ringkas\n• Mempercepatkan telefon lama\n\nSemua kelihatan lebih padat.";

"help_text_color_blind_mode_simplified" = "Menukar warna untuk membantu anda melihat dengan lebih baik.\n\nPilihan:\n• Mod buta merah\n• Mod buta hijau\n• Mod buta biru\n• Mod kelabu sahaja\n\nMembantu anda melihat perkara penting.";

"help_text_line_spacing_simplified" = "Menukar ruang antara baris teks.\n\nAnda boleh memilih dari 1.0x hingga 2.0x.\nLalai ialah 1.0x.\n\nLebih banyak ruang memudahkan pembacaan.";

"help_text_paragraph_spacing_simplified" = "Menukar ruang antara perenggan.\n\nAnda boleh memilih dari 1.0x hingga 3.0x.\nLalai ialah 1.0x.\n\nLebih banyak ruang membantu anda melihat di mana idea baharu bermula.";

"help_text_letter_spacing_simplified" = "Menukar ruang antara huruf.\n\nAnda boleh memilih dari 0.0 hingga 0.2.\nLalai ialah 0.0.\n\nLebih banyak ruang menjadikan huruf lebih jelas.";

"help_text_text_width_simplified" = "Mengawal betapa lebarnya teks.\n\nPilihan:\n• Lebar penuh: Menggunakan keseluruhan skrin\n• Sederhana: Baik untuk pembacaan\n• Sempit: Terbaik untuk fokus\n\nLebar sederhana paling mudah dibaca.";

"help_text_large_touch_targets_simplified" = "Menjadikan semua butang lebih besar.\n\nMembantu anda jika anda:\n• Mengalami kesukaran mengetik butang kecil\n• Mempunyai tangan yang tidak stabil\n• Memakai sarung tangan\n• Menggunakan satu tangan\n\nButang menjadi 60pt dan bukannya 44pt.";

"help_text_reduce_motion_simplified" = "Membuang animasi bergerak.\n\nMembantu anda jika:\n• Pergerakan menyebabkan anda pening\n• Anda mendapat sakit kepala akibat gerakan\n• Anda suka sesuatu kekal tidak bergerak\n\nPerkara berubah serta-merta dan bukannya bergerak.";

"help_text_timeout_behavior_simplified" = "Mengawal berapa lama tugasan boleh mengambil masa.\n\nPilihan:\n• Tiada had: Tugasan tidak pernah berhenti\n• Biasa: 30 saat\n• Lebih lama: 60 saat\n\nPilih 'Tiada had' jika anda memerlukan lebih masa.";

"help_text_simplified_gestures_simplified" = "Menggantikan isyarat sukar dengan ketikan ringkas.\n\nMembantu anda jika anda:\n• Mengalami kesukaran dengan sentuhan kompleks\n• Lebih suka ketikan ringkas\n• Menggunakan satu tangan\n\nSemua menggunakan ketikan ringkas.";

"help_text_haptic_feedback_simplified" = "Menjadikan telefon anda bergetar apabila anda mengetik.\n\nMembantu anda:\n• Mengetahui bila anda mengetik butang\n• Merasai ralat atau amaran\n• Mendapat maklum balas tanpa melihat\n\nMatikan jika getaran mengganggu anda.";

"help_text_simplified_ui_simplified" = "Menjadikan aplikasi lebih ringkas.\n\nMembantu anda jika anda:\n• Keliru dengan skrin yang sesak\n• Lebih suka susun atur ringkas\n• Baru dengan aplikasi\n\nMenunjukkan lebih sedikit perkara pada satu masa.";

"help_text_step_indicators_simplified" = "Menunjukkan kemajuan anda melalui langkah.\n\nMembantu anda:\n• Mengetahui kedudukan anda\n• Melihat berapa banyak langkah yang tinggal\n• Kekal teratur\n\nMenunjukkan 'Langkah 1 daripada 3' dengan titik.";

"help_text_verbose_descriptions_simplified" = "Memberikan anda lebih banyak penerangan.\n\nMembantu anda:\n• Memahami ciri\n• Mempelajari cara menggunakan aplikasi\n• Mendapatkan lebih banyak butiran\n\nMenyediakan bantuan tambahan di mana-mana.";

"help_text_confirm_actions_simplified" = "Meminta anda mengesahkan tindakan penting.\n\nMembantu mencegah:\n• Pemadaman tidak sengaja\n• Perubahan yang tidak diingini\n• Kesilapan\n\nAnda akan sentiasa ditanya 'Adakah anda pasti?'";

"help_text_manual_code_entry_simplified" = "Membolehkan anda menaip kod dan bukannya mengimbas.\n\nGunakan ini apabila:\n• Kamera anda tidak berfungsi\n• Kod sukar diimbas\n• Anda lebih suka menaip\n\nKetik 'Masukkan Kod Secara Manual' untuk menaip.";

"help_text_voice_input_simplified" = "Membolehkan anda menyebut kod dan bukannya menaip.\n\nMembantu anda jika anda:\n• Mengalami kesukaran menaip\n• Lebih suka bercakap\n• Mahu penggunaan tanpa tangan\n\nKetik mikrofon dan sebut dengan jelas.";

"help_text_qr_scanning_simplified" = "Menggunakan kamera anda untuk membaca kod petak.\n\nCara mengimbas:\n1. Arahkan kamera ke kod\n2. Jajarkan kod\n3. Tunggu ia membaca\n\nPetua:\n• Gunakan pencahayaan yang baik\n• Pegang telefon anda dengan stabil\n• Pastikan kod rata";

"help_text_age_verification_simplified" = "Membuktikan anda cukup umur tanpa berkongsi tarikh lahir anda.\n\nCara ia berfungsi:\n1. Perniagaan mencipta permintaan\n2. Anda mengimbas kod mereka\n3. Aplikasi mencipta bukti\n4. Perniagaan mengesahkan anda cukup umur\n\nTarikh lahir anda kekal peribadi.";

"help_text_credentials_simplified" = "Bukti digital umur anda yang disimpan pada telefon anda.\n\nCiri:\n• Hanya pada telefon anda\n• Tidak boleh disalin\n• Menjaga privasi anda\n• Anda boleh memadamnya pada bila-bila masa\n\nAnda mendapatkannya daripada pejabat kerajaan.";

"help_text_zero_knowledge_simplified" = "Membuktikan sesuatu tanpa berkongsi butiran.\n\nContoh:\n• Cara lama: Tunjukkan IC anda (menunjukkan tarikh lahir tepat)\n• Cara baharu: Buktikan anda berumur lebih 18 (tarikh lahir kekal peribadi)\n\nIni menjaga maklumat anda peribadi.";

"help_text_credential_issuance_simplified" = "Mendapatkan bukti umur digital anda.\n\nLangkah:\n1. Pergi ke pejabat kerajaan\n2. Tunjukkan IC anda\n3. Dapatkan kod\n4. Imbas kod\n5. Bukti disimpan pada telefon anda\n\nLakukan ini sekali. Kemudian gunakannya berkali-kali.";

"help_text_officer_mode_simplified" = "Untuk pekerja kerajaan untuk mencipta bukti.\n\nMemerlukan:\n• Kata laluan pegawai\n• Kebenaran untuk menggunakan\n• IC pengguna untuk disemak\n\nLangkah:\n1. Log masuk sebagai pegawai\n2. Semak IC pengguna\n3. Masukkan tarikh lahir mereka\n4. Cipta kod\n5. Pengguna mengimbas kod\n\nHanya untuk pekerja yang diberi kuasa.";

