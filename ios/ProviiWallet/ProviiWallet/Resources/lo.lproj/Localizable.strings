/* Help Text Descriptions */
"help_text_extra_large_text" = "ຕົວໜັງສືໃຫຍ່ພິເສດ ເພີ່ມຂໍ້ຄວາມທັງໝົດ 50%.\n\nຊ່ວຍຜູ້ໃຊ້ທີ່ມີ:\n• ສາຍຕາຕ່ຳ\n• ຄວາມຫຍຸ້ງຍາກໃນການອ່ານ\n• ການປ່ຽນແປງສາຍຕາຕາມອາຍຸ\n\nໃຊ້ຮ່ວມກັບ iOS Dynamic Type.";
"help_text_contrast_level" = "ລະດັບຄວາມແຕກຕ່າງ ຄວບຄຸມອັດຕາສ່ວນຄວາມແຕກຕ່າງ.\n\nສາມລະດັບ:\n• ມາດຕະຖານ: ສີຄ່າເລີ່ມຕົ້ນ\n• ສູງ (AA): 4.5:1\n• ສູງສຸດ (AAA): 7:1";
"help_text_high_contrast" = "ໂໝດຄວາມແຕກຕ່າງສູງ ເພີ່ມຄວາມແຕກຕ່າງລະຫວ່າງຂໍ້ຄວາມ ແລະ ພື້ນຫຼັງ.";
"help_text_reduce_transparency" = "ຫຼຸດຄວາມໂປ່ງໃສ ລຶບເອັບເຟັກ blur ແລະ ຄວາມໂປ່ງໃສ.";
"help_text_color_blind_mode" = "ໂໝດຕາບອດສີ ປັບສີສຳລັບການຂາດດ້ານການເຫັນສີ.";
"help_text_line_spacing" = "ໄລຍະຫ່າງຕ່ອນ ຄວບຄຸມໄລຍະຫ່າງລະຫວ່າງຕ່ອນ.\n\n• ຊ່ວງ: 1.0x ຫາ 2.0x\n• ມາດຕະຖານ AAA: 1.5x ຢ່າງໜ້ອຍ";
"help_text_paragraph_spacing" = "ໄລຍະຫ່າງຍ່ອໜ້າ ຄວບຄຸມໄລຍະຫ່າງລະຫວ່າງຍ່ອໜ້າ.\n\n• ຊ່ວງ: 1.0x ຫາ 3.0x\n• ມາດຕະຖານ AAA: 2.0x ຢ່າງໜ້ອຍ";
"help_text_letter_spacing" = "ໄລຍະຫ່າງຕົວອັກຂະລະ ຄວບຄຸມໄລຍະຫ່າງ.\n\n• ຊ່ວງ: 0.0em ຫາ 0.2em\n• ມາດຕະຖານ AAA: 0.12em ຢ່າງໜ້ອຍ";
"help_text_text_width" = "ຄວາມກວ້າງຂໍ້ຄວາມ ຄວບຄຸມຄວາມຍາວສາຍສູງສຸດ.\n\nຕົວເລືອກ:\n• ຄວາມກວ້າງເຕັມ\n• ສະດວກສະບາຍ (80 ຕົວ)\n• ແຄບ (60 ຕົວ)";
"help_text_large_touch_targets" = "ເປົ້າໝາຍສຳຜັດໃຫຍ່ຂຶ້ນ ເຮັດໃຫ້ທຸກປຸ່ມ ≥60pt.\n\nຊ່ວຍສຳລັບ:\n• ຄວາມດ້ອຍດ້ານການເຄື່ອນໄຫວ\n• ມືສັ່ນ\n• ໃຊ້ດ້ວຍມືດຽວ";
"help_text_reduce_motion" = "ຫຼຸດພາບເຄື່ອນໄຫວ ຫຼຸດ ຫຼື ລຶບການເຄື່ອນໄຫວ.\n\nຊ່ວຍສຳລັບ:\n• ຄວາມໄວຕໍ່ການເຄື່ອນໄຫວ\n• ໂຣກ Vestibular\n• ໂລກລະມານ";
"help_text_timeout_behavior" = "ພຶດຕິກຳໝົດເວລາ ຄວບຄຸມໄລຍະເວລາ.\n\nຕົວເລືອກ:\n• ບໍ່ໝົດເວລາ (AAA)\n• ມາດຕະຖານ (30 ວິ)\n• ຂະຫຍາຍ (60 ວິ)";
"help_text_simplified_gestures" = "ທ່າທາງທີ່ລຽບງ່າຍ ຫຼຸດທ່າທາງຫຼາຍຈຸດ.\n\nຊ່ວຍສຳລັບ:\n• ຄວາມດ້ອຍດ້ານການເຄື່ອນໄຫວ\n• ການໃຊ້ດ້ວຍມືດຽວ";
"help_text_haptic_feedback" = "ການສັ່ນສະທ້ານ ການສັ່ນສຳລັບການດຳເນີນການ.\n\nຊ່ວຍ:\n• ຢືນຢັນການກົດປຸ່ມ\n• ແຈ້ງຂໍ້ຜິດພາດ";
"help_text_simplified_ui" = "ໜ້າຈໍທີ່ລຽບງ່າຍ ຫຼຸດຄວາມຊັບຊ້ອນ.\n\nຊ່ວຍສຳລັບ:\n• ຄວາມດ້ອຍດ້ານສະໝອງ\n• ຜູ້ໃຊ້ໃໝ່";
"help_text_step_indicators" = "ຕົວຊີ້ວັດຂັ້ນຕອນ ສະແດງຄວາມຄືບໜ້າ.\n\nສະແດງ 'ຂັ້ນຕອນທີ X ຈາກ Y' ດ້ວຍຈຸດຄວາມຄືບໜ້າ.";
"help_text_verbose_descriptions" = "ຄຳອະທິບາຍລະອຽດ ສົ່ງຂໍ້ຄວາມອະທິບາຍເພີ່ມເຕີມ.";
