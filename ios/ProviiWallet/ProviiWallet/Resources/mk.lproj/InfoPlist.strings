/* InfoPlist.strings - Macedonian */
/* Локализирани описи на дозволи за Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet треба пристап до камера за скенирање QR кодови за подигање акредитив и верификација на возраст.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet користи NFC за комуникација со вашиот YubiKey за безбедна автентикација на службеник.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet користи препознавање на говор за гласовни команди во режим на пристапност, овозможувајќи ви да ја контролирате апликацијата без употреба на рацете.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet треба пристап до микрофон за функциите за гласовна контрола кога е овозможен режимот на пристапност.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet користи Face ID за безбеден пристап до вашите акредитиви за возраст и верификација на вашиот идентитет.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet може да ја користи локалната мрежа за откривање на блиски издавачи на акредитиви.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet може да користи Bluetooth за комуникација со YubiKey уреди.";
