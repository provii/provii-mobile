/* InfoPlist.strings - Lao */
/* Localised permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet ຕ້ອງການສິດທ໌ກ້ອງເພື່ອສະແກນລະຫັດ QR ສຳລັບການຮັບໃບຢັ້ງຢືນ ແລະ ການຢັ້ງຢືນອາຍຸ.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet ໃຊ້ NFC ເພື່ອສື່ສານກັບ YubiKey ຂອງທ່ານສຳລັບການກວດສອບຕົວຕົນເຈົ້າໜ້າທີ່ທີ່ປອດໄພ.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet ໃຊ້ການຮັບຮູ້ສຽງສຳລັບຄຳສັ່ງສຽງໃນໂໝດການເຂົ້າເຖິງ ຊ່ວຍໃຫ້ທ່ານຄວບຄຸມແອັບດ້ວຍມືທີ່ວ່າງ.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet ຕ້ອງການສິດທ໌ໄມໂຄໂຟນສຳລັບຄຸນສົມບັດການຄວບຄຸມດ້ວຍສຽງເມື່ອເປີດໃຊ້ໂໝດການເຂົ້າເຖິງ.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet ໃຊ້ Face ID ເພື່ອເຂົ້າເຖິງໃບຢັ້ງຢືນອາຍຸ ແລະ ຢືນຢັນຕົວຕົນຂອງທ່ານຢ່າງປອດໄພ.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet ອາດໃຊ້ເຄືອຂ່າຍທ້ອງຖິ່ນເພື່ອຄົ້ນຫາຜູ້ອອກໃບຢັ້ງຢືນທີ່ຢູ່ໃກ້.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet ອາດໃຊ້ Bluetooth ເພື່ອສື່ສານກັບອຸປະກອນ YubiKey.";
