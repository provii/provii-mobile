"help_text_extra_large_text_simplified" = "सर्व मजकूर 50% मोठा करतो.\n\nहे मदत करते जर तुम्हाला:\n• पाहण्यात त्रास होतो\n• वाचणे कठीण वाटते\n• मोठा मजकूर हवा आहे\n\nतुमच्या फोनच्या मजकूर आकार सेटिंग्जसह काम करते.";

"help_text_contrast_level_simplified" = "मजकूर किती गडद आहे ते बदलतो.\n\nतीन निवडी:\n• मानक: सामान्य रंग\n• उच्च: सहज वाचनासाठी गडद मजकूर\n• कमाल: सर्वोत्तम वाचनासाठी खूप गडद मजकूर\n\nगडद मजकूर वाचणे सोपे आहे.";

"help_text_high_contrast_simplified" = "मजकूर पाहणे सोपे करतो.\n\nहे मदत करते जर तुम्हाला:\n• पाहण्यात त्रास होतो\n• गडद मजकूर हवा आहे\n• तेजस्वी प्रकाशात अॅप वापरतो\n\nमजकूर पांढऱ्यावर काळा होतो.";

"help_text_reduce_transparency_simplified" = "धुकट प्रभाव काढतो.\n\nहे मदत करते:\n• मजकूर स्पष्ट करतो\n• अॅप सोपा करतो\n• जुने फोन वेगवान करतो\n\nसर्वकाही अधिक घन दिसते.";

"help_text_color_blind_mode_simplified" = "चांगले पाहण्यासाठी रंग बदलतो.\n\nनिवडी:\n• लाल-अंध मोड\n• हिरवा-अंध मोड\n• निळा-अंध मोड\n• फक्त राखाडी मोड\n\nमहत्त्वाच्या गोष्टी पाहण्यास मदत करतो.";

"help_text_line_spacing_simplified" = "मजकूराच्या ओळींमधील जागा बदलतो.\n\nतुम्ही 1.0x ते 2.0x पर्यंत निवडू शकता.\nडीफॉल्ट 1.0x आहे.\n\nअधिक जागा वाचणे सोपे करते.";

"help_text_paragraph_spacing_simplified" = "परिच्छेदांमधील जागा बदलतो.\n\nतुम्ही 1.0x ते 3.0x पर्यंत निवडू शकता.\nडीफॉल्ट 1.0x आहे.\n\nअधिक जागा नवीन कल्पना कुठे सुरू होतात ते पाहण्यास मदत करते.";

"help_text_letter_spacing_simplified" = "अक्षरांमधील जागा बदलतो.\n\nतुम्ही 0.0 ते 0.2 पर्यंत निवडू शकता.\nडीफॉल्ट 0.0 आहे.\n\nअधिक जागा अक्षरे स्पष्ट करते.";

"help_text_text_width_simplified" = "मजकूर किती रुंद आहे ते नियंत्रित करतो.\n\nनिवडी:\n• पूर्ण रुंदी: संपूर्ण स्क्रीन वापरतो\n• मध्यम: वाचनासाठी चांगले\n• अरुंद: एकाग्रतेसाठी सर्वोत्तम\n\nमध्यम रुंदी वाचणे सर्वात सोपे आहे.";

"help_text_large_touch_targets_simplified" = "सर्व बटणे मोठी करतो.\n\nहे मदत करते जर तुम्हाला:\n• लहान बटणे टॅप करण्यात त्रास होतो\n• हात थरथरतात\n• हातमोजे घालतो\n• एक हात वापरतो\n\nबटणे 44pt ऐवजी 60pt होतात.";

"help_text_reduce_motion_simplified" = "हलणारी अॅनिमेशन काढतो.\n\nहे मदत करते जर:\n• हालचालीमुळे चक्कर येते\n• गतीमुळे डोकेदुखी होते\n• सर्वकाही स्थिर राहणे पसंत आहे\n\nगोष्टी हलण्याऐवजी त्वरित बदलतात.";

"help_text_timeout_behavior_simplified" = "कार्ये किती वेळ घेऊ शकतात ते नियंत्रित करतो.\n\nनिवडी:\n• मर्यादा नाही: कार्ये कधीच थांबत नाहीत\n• सामान्य: 30 सेकंद\n• जास्त: 60 सेकंद\n\nजर तुम्हाला जास्त वेळ हवा असेल तर 'मर्यादा नाही' निवडा.";

"help_text_simplified_gestures_simplified" = "कठीण जेश्चर साध्या टॅपने बदलतो.\n\nहे मदत करते जर तुम्हाला:\n• जटिल स्पर्शांमध्ये त्रास होतो\n• साधे टॅप पसंत आहेत\n• एक हात वापरतो\n\nसर्वकाही साधे टॅप वापरते.";

"help_text_haptic_feedback_simplified" = "टॅप केल्यावर फोन कंपन करतो.\n\nहे मदत करते:\n• बटण टॅप केल्याचे जाणण्यास\n• त्रुटी किंवा सावधाणी अनुभवण्यास\n• न पाहता फीडबॅक मिळवण्यास\n\nकंपन त्रासदायक असल्यास बंद करा.";

"help_text_simplified_ui_simplified" = "अॅप सोपा करतो.\n\nहे मदत करते जर तुम्हाला:\n• व्यस्त स्क्रीनमुळे गोंधळ होतो\n• साध्या मांडणी पसंत आहेत\n• अॅपमध्ये नवीन आहात\n\nएकावेळी कमी गोष्टी दाखवतो.";

"help_text_step_indicators_simplified" = "चरणांमधील तुमची प्रगती दाखवतो.\n\nहे मदत करते:\n• तुम्ही कुठे आहात ते जाणण्यास\n• किती चरण उरले ते पाहण्यास\n• संघटित राहण्यास\n\nबिंदूंसह 'चरण 1 पैकी 3' दाखवतो.";

"help_text_verbose_descriptions_simplified" = "अधिक स्पष्टीकरणे देतो.\n\nहे मदत करते:\n• वैशिष्ट्ये समजण्यास\n• अॅप कसे वापरायचे ते शिकण्यास\n• अधिक तपशील मिळवण्यास\n\nसर्वत्र अतिरिक्त मदत प्रदान करते.";

"help_text_confirm_actions_simplified" = "महत्त्वाच्या क्रियांपूर्वी पुष्टी मागतो.\n\nहे रोखण्यास मदत करते:\n• चुकून हटवणे\n• नको ते बदल\n• चुका\n\nतुम्हाला नेहमी 'तुम्हाला खात्री आहे का?' विचारले जाईल.";

"help_text_manual_code_entry_simplified" = "स्कॅन करण्याऐवजी कोड टाइप करण्याची परवानगी देतो.\n\nहे वापरा जेव्हा:\n• तुमचा कॅमेरा काम करत नाही\n• कोड स्कॅन करणे कठीण आहे\n• टाइप करणे पसंत आहे\n\nटाइप करण्यासाठी 'कोड हस्तचलितपणे प्रविष्ट करा' टॅप करा.";

"help_text_voice_input_simplified" = "टाइप करण्याऐवजी कोड बोलण्याची परवानगी देतो.\n\nहे मदत करते जर तुम्हाला:\n• टाइप करण्यात त्रास होतो\n• बोलणे पसंत आहे\n• हात-मुक्त वापर हवा आहे\n\nमायक्रोफोन टॅप करा आणि स्पष्टपणे बोला.";

"help_text_qr_scanning_simplified" = "चौरस कोड वाचण्यासाठी तुमचा कॅमेरा वापरतो.\n\nस्कॅन कसे करायचे:\n1. कोडकडे कॅमेरा निर्देशित करा\n2. कोड संरेखित करा\n3. वाचण्याची प्रतीक्षा करा\n\nटिप्स:\n• चांगला प्रकाश वापरा\n• तुमचा फोन स्थिर ठेवा\n• कोड सपाट ठेवा";

"help_text_age_verification_simplified" = "तुमचा वाढदिवस न सांगता तुम्ही पुरेसे वयस्क असल्याचे सिद्ध करतो.\n\nहे कसे कार्य करते:\n1. व्यवसाय एक विनंती तयार करतो\n2. तुम्ही त्यांचा कोड स्कॅन करता\n3. अॅप एक पुरावा तयार करतो\n4. व्यवसाय पुष्टी करतो की तुम्ही पुरेसे वयस्क आहात\n\nतुमचा वाढदिवस खाजगी राहतो.";

"help_text_credentials_simplified" = "तुमच्या फोनवर संग्रहित तुमच्या वयाचा डिजिटल पुरावा.\n\nवैशिष्ट्ये:\n• फक्त तुमच्या फोनवर\n• कॉपी करता येत नाही\n• तुम्हाला खाजगी ठेवतो\n• कधीही हटवता येतो\n\nसरकारी कार्यालयातून मिळवतो.";

"help_text_zero_knowledge_simplified" = "तपशील न सांगता काहीतरी सिद्ध करतो.\n\nउदाहरण:\n• जुनी पद्धत: तुमचे ID दाखवा (अचूक वाढदिवस दाखवतो)\n• नवीन पद्धत: 18 पेक्षा जास्त असल्याचे सिद्ध करा (वाढदिवस खाजगी राहतो)\n\nतुमची माहिती खाजगी ठेवते.";

"help_text_credential_issuance_simplified" = "तुमचा डिजिटल वय पुरावा मिळवणे.\n\nचरण:\n1. सरकारी कार्यालयात जा\n2. तुमचे ID दाखवा\n3. एक कोड मिळवा\n4. कोड स्कॅन करा\n5. पुरावा तुमच्या फोनवर जतन होतो\n\nहे एकदाच करा. मग अनेकदा वापरा.";

"help_text_officer_mode_simplified" = "सरकारी कर्मचाऱ्यांसाठी पुरावे तयार करण्यासाठी.\n\nआवश्यक:\n• अधिकारी पासवर्ड\n• वापरण्याची परवानगी\n• तपासण्यासाठी वापरकर्त्याचे ID\n\nचरण:\n1. अधिकारी म्हणून लॉग इन करा\n2. वापरकर्त्याचे ID तपासा\n3. त्यांचा वाढदिवस प्रविष्ट करा\n4. कोड तयार करा\n5. वापरकर्ता कोड स्कॅन करतो\n\nफक्त अधिकृत कर्मचाऱ्यांसाठी.";

