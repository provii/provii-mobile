/* Hulpteks-beskrywings */
"help_text_extra_large_text" = "Ekstra groot teks vergroot alle teks in die app met 50%.\n\nDit is nuttig vir gebruikers met:\n• Swak sig\n• Leesprobleme\n• Ouderdomsverwante sigveranderinge\n\nWerk met iOS Dinamiese Tipe vir selfs groter groottes.";
"help_text_contrast_level" = "Kontrasvlak beheer die kleurkontras tussen teks en agtergronde.\n\nDrie vlakke beskikbaar:\n• Standaard: Verstekkleure\n• Hoog (AA): 4.5:1 kontrasverhouding - voldoen aan AA-standaarde\n• Maksimum (AAA): 7:1 kontrasverhouding - voldoen aan hoogste AAA-standaarde\n\nHoër kontras maak teks makliker om te lees in alle ligsomstandighede.";
"help_text_high_contrast" = "Hoëkontras-modus verhoog die kontras tussen teks en agtergrond, wat dit makliker maak om te lees.\n\nDit is nuttig vir gebruikers met:\n• Swak sig\n• Kleurgevoeligheid\n• Helder skerm-omgewings\n\nWanneer geaktiveer:\n• Teks word swart op wit\n• Grense word by elemente gevoeg\n• Kleure word vereenvoudig";
"help_text_reduce_transparency" = "Verminder deursigtigheid verwyder was- en deursigtigheidseffekte regdeur die app.\n\nDit help om:\n• Teks-leesbaarheid te verbeter\n• Visuele kompleksiteit te verminder\n• Werkverrigting op ouer toestelle te verbeter\n• Inhoud meer voorspelbaar te maak";
"help_text_color_blind_mode" = "Kleurblindmodusse pas kleure aan vir verskillende tipes kleurvisie-gebrek.\n\nBeskikbare modusse:\n• Protanopia: Rooiblind (moeite om rooi te sien)\n• Deuteranopia: Groenblind (moeite om groen te sien)\n• Tritanopia: Bloublind (moeite om blou te sien)\n• Monochroom: Slegs gryskleurig\n\nHierdie modusse verseker dat belangrike inligting nie slegs deur kleur oorgedra word nie.";
"help_text_line_spacing" = "Reëlspasiëring beheer die spasie tussen teksreëls.\n\n• Reeks: 1.0x tot 2.0x\n• AAA-standaard: 1.5x minimum\n• Verstek: 1.0x\n\nVergroot reëlspasiëring maak teks makliker om te lees en help om reëls oor te slaan te voorkom.";
"help_text_paragraph_spacing" = "Paragrafspasiëring beheer die spasie tussen paragrawe.\n\n• Reeks: 1.0x tot 3.0x\n• AAA-standaard: 2.0x minimum\n• Verstek: 1.0x\n\nVergroot paragrafspasiëring help om tussen verskillende afdelings van teks te onderskei.";
"help_text_letter_spacing" = "Letterspasiëring beheer die spasie tussen individuele karakters.\n\n• Reeks: 0.0em tot 0.2em\n• AAA-standaard: 0.12em minimum\n• Verstek: 0.0em\n\nVergroot letterspasiëring verbeter karakter-herkenning en leesbaarheid.";
"help_text_text_width" = "Tekswydte beheer die maksimum reëllengte vir gemaklike lees.\n\nOpsies:\n• Volle breedte: Geen maksimum\n• Gemaklik (80 karakters): Optimaal vir lees\n• Smal (60 karakters): Vir gekonsentreerde lees\n\nAAA-riglyne beveel 80 karakters per reël maksimum aan.";
"help_text_large_touch_targets" = "Groter raakteikens maak alle knoppies en interaktiewe elemente ten minste 60 pt groot.\n\nDit is nuttig vir:\n• Motoriese gestremdhede\n• Bewerige hande\n• Gebruik van die app met handskoene\n• Eenhandige gebruik\n\nDie standaard minimum is 44 pt; hierdie instelling verhoog na 60 pt.";
"help_text_reduce_motion" = "Verminder beweging minimeer of verwyder animasies regdeur die app.\n\nDit is nuttig vir gebruikers met:\n• Bewegingsgevoeligheid\n• Vestibulêre steurnisse\n• Epilepsie\n• Migraineaanlokkers\n\nWanneer geaktiveer word animasies vervang deur onmiddellike oorgange.";
"help_text_timeout_behavior" = "Uitty-gedrag beheer hoe lank bewerkings kan neem voor dit uitty.\n\nOpsies:\n• Geen uitty (AAA): Bewerkings raak nooit uit tyd nie\n• Standaard (30s): Verstekuitty\n• Verleng (60s): Dubbel die standaardtyd\n\nGeen uitty-modus voldoen aan AAA-toeganklikheidstandaarde.";
"help_text_simplified_gestures" = "Vereenvoudigde gebare verminder komplekse multi-aanraking gebare na eenvoudige tikke.\n\nDit is nuttig vir:\n• Motoriese gestremdhede\n• Beperkte beweeglikheid\n• Gebruik van hulptoestelle\n• Eenhandige werking\n\nKomplekse gebare word vervang deur knoppies en eenvoudige tikke.";
"help_text_haptic_feedback" = "Haptiese terugvoer verskaf vibrasie-terugvoer vir aksies en kennisgewings.\n\nDit is nuttig vir:\n• Bevestiging van knoppie-druk\n• Waarskuwing van foute of waarskuwings\n• Verskaffing van nie-visuele terugvoer\n• Gebruikers met gehoor- of sig-gestremdhede\n\nU kan dit deaktiveer as vibrasies ongemaklik is.";
"help_text_simplified_ui" = "Vereenvoudigde koppelvlak verminder visuele kompleksiteit regdeur die app.\n\nDit is nuttig vir:\n• Kognitiewe gestremdhede\n• Leerproblem\n• Aandag-steurnisse\n• Nuwe of onervare gebruikers\n\nWanneer geaktiveer:\n• Minder elemente op die skerm\n• Groter, duideliker beheerders\n• Minder visuele geraas";
"help_text_step_indicators" = "Stap-aanwysers wys u vordering deur multi-stap prosesse.\n\nDit help om:\n• Te verstaan waar u in 'n proses is\n• Te weet hoeveel stappe oorbly\n• Kognitiewe las te verminder\n• Duidelike struktuur te verskaf\n\nWys 'Stap X van Y' met visuele vordering-kolletjies.";
"help_text_verbose_descriptions" = "Gedetailleerde beskrywings verskaf bykomende verklarende teks regdeur die app.\n\nDit is nuttig vir:\n• Begrip van komplekse funksies\n• Leer van die gebruik van die app\n• Kognitiewe ondersteuning\n• Skermleser-gebruikers\n\nVerskaf konteks en instruksies vir alle funksies.";
"help_text_confirm_actions" = "Bevestig aksies vra vir bevestiging voor belangrike aksies.\n\nDit help om te voorkom:\n• Toevallige uitvee\n• Onbedoelde veranderinge\n• Vroeë indiening\n• Data-verlies\n\nLet wel: Vernietigende aksies vereis altyd bevestiging (AAA-vereiste).";
"help_text_manual_code_entry" = "Handmatige kode-invoer stel u in staat om kodes te tik in plaas van QR-kodes te skandeer.\n\nDit is nuttig wanneer:\n• Kamera nie werk nie\n• QR-kode beskadig of onduidelik is\n• Skermleser gebruik word\n• Voorkeur is om te tik eerder as te skandeer\n\nTik eenvoudig 'Voer kode handmatig in' om die kode te tik wat op die skerm vertoon word.";
"help_text_voice_input" = "Spraakinvoer stel u in staat om kodes te praat in plaas van te skandeer of te tik.\n\nDit is nuttig vir:\n• Beperkte beweeglikheid\n• Skermleser-gebruikers\n• Hande-vrye werking\n• Voorkeur vir spraak\n\nTik die mikrofoon-knoppie en praat duidelik wanneer gevra.";
"help_text_qr_scanning" = "QR-kode-skandering gebruik u kamera om Quick Response-kodes te lees.\n\nHoe om te skandeer:\n1. Rig kamera op QR-kode\n2. Sentreer kode in raam\n3. Wag vir outomatiese bespeuring\n\nWenke:\n• Verseker goeie beligting\n• Hou toestel stil\n• Hou QR-kode plat en sonder hindernisse\n• As skandering misluk, probeer handmatige kode-invoer";
"help_text_age_verification" = "Ouderdomsverifikasie bewys dat u aan 'n ouderdomsvereiste voldoen sonder om u werklike ouderdom of geboortedatum te openbaar.\n\nHoe dit werk:\n1. Verifieerder genereer 'n uitdaging\n2. U skandeer die QR-kode of voer dit handmatig in\n3. App skep 'n nulkennisbewys\n4. Verifieerder bevestig dat u aan vereiste voldoen\n\nPrivaatheid beskerm:\n• U geboortedatum word nooit gedeel nie\n• Verifieerder leer slegs of u aan vereiste voldoen\n• Geen opsporing of data-insameling nie";
"help_text_credentials" = "Digitale geloofsbriewe is kriptografiese bewyse van u ouderdom wat veilig op u toestel gestoor word.\n\nKenmerke:\n• Slegs op u toestel gestoor\n• Kan nie gekopieer of vervals word nie\n• Word gebruik vir privaatheid-bewarende verifikasie\n• Kan te eniger tyd uitgevee word\n\nU moet 'n geloofsbrief van 'n gemagtigde uitreiker (soos 'n regeringskantoor) verkry voordat u u ouderdom kan verifieer.";
"help_text_zero_knowledge" = "Nulkennisbewyse stel u in staat om te bewys dat iets waar is sonder om die onderliggende inligting te openbaar.\n\nVoorbeeld:\n• Tradisioneel: Wys ID (openbaar presiese verjaardag)\n• Nulkennis: Bewys dat u ouer as 18 is sonder om verjaardag te wys\n\nVoordele:\n• Maksimum privaatheidbeskerming\n• Geen persoonlike data gedeel nie\n• Kriptografies veilig\n• Kan nie vervals of herhaal word nie\n\nDit is die kernstegnologie wat Provii Wallet privaat maak.";
"help_text_credential_issuance" = "Geloofsbrief-uitreiking is die proses om u digitale ouderdomsgeloofsbrief van 'n gemagtigde uitreiker te verkry.\n\nStappe:\n1. Besoek gemagtigde uitreiker (bv. regeringskantoor)\n2. Bewys u identiteit met amptelike identifikasie\n3. Ontvang QR-kode of diepskakel van uitreiker\n4. Skandeer QR-kode of tik op die skakel\n5. Geloofsbrief word plaaslik bereken en op u toestel gestoor\n\nDie blinde attestasie-proses verseker dat u geboortedatum nooit oor die netwerk oorgedra word nie.\nU hoef dit slegs een keer te doen. U geloofsbrief kan dan vir onbeperkte verifikasies gebruik word.";
"help_text_officer_mode" = "Beamptemodus is vir gemagtigde uitreikers om geloofsbriewe vir gebruikers te skep.\n\nHierdie modus vereis:\n• Beampte-stawing met YubiKey\n• Magtiging van uitreikingsowerheid\n• Fisiese verifikasie van gebruiker se identifikasie\n\nProses:\n1. Staaf as beampte\n2. Verifieer gebruiker se amptelike identifikasie\n3. Voer gebruiker se geboortedatum in\n4. Genereer attestasie QR-kode\n5. Gebruiker skandeer kode om geloofsbrief te ontvang\n\nSlegs gemagtigde personeel mag hierdie modus gebruik.";

/* Vereenvoudigde hulpteks (Leesvlak: Graad 6-8) */
"help_text_extra_large_text_simplified" = "Maak alle teks 50% groter.\n\nHelp u as u:\n• Moeite het om te sien\n• Lees moeilik is\n• Groter teks nodig het\n\nWerk met u foon se teksgrootte-instellings.";
"help_text_contrast_level_simplified" = "Verander hoe donker die teks is.\n\nDrie keuses:\n• Standaard: Normale kleure\n• Hoog: Donkerder teks vir maklike lees\n• Maksimum: Baie donker teks vir beste lees\n\nDonkerder teks is makliker om te lees.";
"help_text_high_contrast_simplified" = "Maak teks makliker om te sien.\n\nHelp u as u:\n• Moeite het om te sien\n• Donkerder teks nodig het\n• Die app in helder lig gebruik\n\nTeks word swart op wit.";
"help_text_reduce_transparency_simplified" = "Verwyder wasige effekte.\n\nDit help om:\n• Teks duideliker te maak\n• Die app eenvoudiger te maak\n• Ouer fone te versnel\n\nAlles lyk meer solied.";
"help_text_color_blind_mode_simplified" = "Verander kleure om u beter te help sien.\n\nKeuses:\n• Rooiblind-modus\n• Groenblind-modus\n• Bloublind-modus\n• Slegs grys-modus\n\nHelp u om belangrike dinge te sien.";
"help_text_line_spacing_simplified" = "Verander spasie tussen teksreëls.\n\nU kan kies van 1.0x tot 2.0x.\nVerstek is 1.0x.\n\nMeer spasie maak lees makliker.";
"help_text_paragraph_spacing_simplified" = "Verander spasie tussen paragrawe.\n\nU kan kies van 1.0x tot 3.0x.\nVerstek is 1.0x.\n\nMeer spasie help u sien waar nuwe idees begin.";
"help_text_letter_spacing_simplified" = "Verander spasie tussen letters.\n\nU kan kies van 0.0 tot 0.2.\nVerstek is 0.0.\n\nMeer spasie maak letters duideliker.";
"help_text_text_width_simplified" = "Beheer hoe wyd teks is.\n\nKeuses:\n• Volle breedte: Gebruik hele skerm\n• Medium: Goed vir lees\n• Smal: Beste vir fokus\n\nMedium breedte is maklikste om te lees.";
"help_text_large_touch_targets_simplified" = "Maak alle knoppies groter.\n\nHelp u as u:\n• Moeite het om klein knoppies te tik\n• Bewerige hande het\n• Handskoene dra\n• Een hand gebruik\n\nKnoppies word 60 pt in plaas van 44 pt.";
"help_text_reduce_motion_simplified" = "Verwyder bewegende animasies.\n\nHelp u as:\n• Beweging u duiselig maak\n• U hoofpyn kry van beweging\n• U verkies dat dinge stil bly\n\nDinge verander onmiddellik in plaas van te beweeg.";
"help_text_timeout_behavior_simplified" = "Beheer hoe lank take kan neem.\n\nKeuses:\n• Geen limiet: Take stop nooit\n• Normaal: 30 sekondes\n• Langer: 60 sekondes\n\nKies 'Geen limiet' as u meer tyd nodig het.";
"help_text_simplified_gestures_simplified" = "Vervang moeilike gebare met eenvoudige tikke.\n\nHelp u as u:\n• Moeite het met komplekse aanrakings\n• Eenvoudige tikke verkies\n• Een hand gebruik\n\nAlles gebruik eenvoudige tikke.";
"help_text_haptic_feedback_simplified" = "Laat u foon vibreer wanneer u tik.\n\nHelp u om:\n• Te weet wanneer u 'n knoppie getik het\n• Foute of waarskuwings te voel\n• Terugvoer te kry sonder om te kyk\n\nSkakel af as vibrasies u hinder.";
"help_text_simplified_ui_simplified" = "Maak die app eenvoudiger.\n\nHelp u as u:\n• Verwar word deur besige skerms\n• Eenvoudige uitleg verkies\n• Nuut is by die app\n\nWys minder dinge op 'n slag.";
"help_text_step_indicators_simplified" = "Wys u vordering deur stappe.\n\nHelp u om:\n• Te weet waar u is\n• Te sien hoeveel stappe oor is\n• Georganiseerd te bly\n\nWys 'Stap 1 van 3' met kolletjies.";
"help_text_verbose_descriptions_simplified" = "Gee u meer verklarings.\n\nHelp u om:\n• Funksies te verstaan\n• Te leer hoe om die app te gebruik\n• Meer besonderhede te kry\n\nVerskaf ekstra hulp oral.";
"help_text_confirm_actions_simplified" = "Vra u om belangrike aksies te bevestig.\n\nHelp om te voorkom:\n• Toevallige uitvee\n• Ongewenste veranderinge\n• Foute\n\nU sal altyd gevra word 'Is u seker?'";
"help_text_manual_code_entry_simplified" = "Laat u kodes tik in plaas van skandeer.\n\nGebruik dit wanneer:\n• U kamera nie werk nie\n• Die kode moeilik is om te skandeer\n• U verkies om te tik\n\nTik 'Voer kode handmatig in' om te tik.";
"help_text_voice_input_simplified" = "Laat u kodes praat in plaas van tik.\n\nHelp u as u:\n• Moeite het om te tik\n• Verkies om te praat\n• Hande-vrye gebruik wil hê\n\nTik die mikrofoon en praat duidelik.";
"help_text_qr_scanning_simplified" = "Gebruik u kamera om vierkantige kodes te lees.\n\nHoe om te skandeer:\n1. Rig kamera op die kode\n2. Lê die kode op lyn\n3. Wag vir dit om te lees\n\nWenke:\n• Gebruik goeie beligting\n• Hou u foon stil\n• Hou die kode plat";
"help_text_age_verification_simplified" = "Bewys dat u oud genoeg is sonder om u verjaardag te deel.\n\nHoe dit werk:\n1. Sake-onderneming skep 'n versoek\n2. U skandeer hul kode\n3. App skep 'n bewys\n4. Sake-onderneming bevestig dat u oud genoeg is\n\nU verjaardag bly privaat.";
"help_text_credentials_simplified" = "Digitale bewys van u ouderdom gestoor op u foon.\n\nKenmerke:\n• Slegs op u foon\n• Kan nie gekopieer word nie\n• Hou u privaat\n• U kan dit te eniger tyd uitvee\n\nU kry dit van 'n regeringskantoor.";
"help_text_zero_knowledge_simplified" = "Bewys iets sonder om besonderhede te deel.\n\nVoorbeeld:\n• Ou manier: Wys u ID (wys presiese verjaardag)\n• Nuwe manier: Bewys dat u ouer as 18 is (verjaardag bly privaat)\n\nDit hou u inligting privaat.";
"help_text_credential_issuance_simplified" = "Kry u digitale ouderdomsbewys.\n\nStappe:\n1. Gaan na regeringskantoor\n2. Wys u identifikasie\n3. Kry 'n kode\n4. Skandeer die kode\n5. Bewys word op u foon gestoor\n\nDoen dit een keer. Gebruik dit dan baie kere.";
"help_text_officer_mode_simplified" = "Vir regeringswerkers om bewyse te skep.\n\nBenodig:\n• Beampte-wagwoord\n• Toestemming om te gebruik\n• Gebruiker se identifikasie om na te gaan\n\nStappe:\n1. Meld aan as beampte\n2. Gaan gebruiker se identifikasie na\n3. Voer hul verjaardag in\n4. Skep kode\n5. Gebruiker skandeer kode\n\nSlegs vir gemagtigde werkers.";

