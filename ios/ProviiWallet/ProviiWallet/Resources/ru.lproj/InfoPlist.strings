/* InfoPlist.strings - Russian */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet требует доступ к камере для сканирования QR-кодов при получении удостоверений и проверке возраста.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet использует NFC для связи с вашим YubiKey при защищённой аутентификации сотрудника.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet использует распознавание речи для голосовых команд в режиме специальных возможностей, позволяя управлять приложением без рук.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet требует доступ к микрофону для функций голосового управления при включённом режиме специальных возможностей.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet использует Face ID для безопасного доступа к вашим возрастным удостоверениям и проверки вашей личности.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet может использовать локальную сеть для обнаружения ближайших эмитентов удостоверений.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet может использовать Bluetooth для связи с устройствами YubiKey.";
