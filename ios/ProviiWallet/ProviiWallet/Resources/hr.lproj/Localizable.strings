// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Iznimno veliki tekst povećava sav tekst u aplikaciji za 50%.\n\nTo je korisno za korisnike s:\n• Slabim vidom\n• Teškoćama čitanja\n• Promjenama vida vezanim uz dob\n\nRadi s iOS Dynamic Type za još veće veličine.";
"help_text_contrast_level" = "Razina kontrasta kontrolira kontrast boja između teksta i pozadina.\n\nDostupne su tri razine:\n• Standardno: Zadane boje\n• Visoko (AA): Omjer kontrasta 4,5:1 - zadovoljava AA standarde\n• Maksimalno (AAA): Omjer kontrasta 7:1 - zadovoljava najviše AAA standarde\n\nViši kontrast čini tekst lakšim za čitanje u svim uvjetima osvjetljenja.";
"help_text_high_contrast" = "Način rada visokog kontrasta povećava kontrast između teksta i pozadine, čineći ga lakšim za čitanje.\n\nTo je korisno za korisnike s:\n• Slabim vidom\n• Osjetljivošću na boje\n• Okruženjima s jakim osvjetljenjem zaslona\n\nKada je omogućen:\n• Tekst postaje crn na bijelom\n• Elementima se dodaju obrubi\n• Boje su pojednostavnjene";
"help_text_reduce_transparency" = "Smanjivanje prozirnosti uklanja efekte zamagljivanja i prozirnosti u cijeloj aplikaciji.\n\nTo pomaže:\n• Poboljšati čitljivost teksta\n• Smanjiti vizualnu složenost\n• Povećati performanse na starijim uređajima\n• Učiniti sadržaj predvidljivijim";
"help_text_color_blind_mode" = "Načini rada za daltoniste prilagođavaju boje za različite vrste nedostatka vidnog vida.\n\nDostupni načini:\n• Protanopija: Sljepilo za crvenu (teškoće s viđenjem crvene)\n• Deuteranopija: Sljepilo za zelenu (teškoće s viđenjem zelene)\n• Tritanopija: Sljepilo za plavu (teškoće s viđenjem plave)\n• Monokrom: Samo nijanse sive\n\nOvi načini osiguravaju da važne informacije nisu prenošene samo bojom.";
"help_text_line_spacing" = "Razmak između redaka kontrolira prostor između redaka teksta.\n\n• Raspon: 1,0x do 2,0x\n• AAA standard: minimum 1,5x\n• Zadano: 1,0x\n\nPovećani razmak između redaka čini tekst lakšim za čitanje i pomaže u sprječavanju preskakanja redaka.";
"help_text_paragraph_spacing" = "Razmak između odlomaka kontrolira prostor između odlomaka.\n\n• Raspon: 1,0x do 3,0x\n• AAA standard: minimum 2,0x\n• Zadano: 1,0x\n\nPovećani razmak između odlomaka pomaže u razlikovanju između različitih odjeljaka teksta.";
"help_text_letter_spacing" = "Razmak između slova kontrolira prostor između pojedinih znakova.\n\n• Raspon: 0,0 em do 0,2 em\n• AAA standard: minimum 0,12 em\n• Zadano: 0,0 em\n\nPovećani razmak između slova poboljšava prepoznavanje znakova i čitljivost.";
"help_text_text_width" = "Širina teksta kontrolira maksimalnu duljinu retka za ugodno čitanje.\n\nOpcije:\n• Puna širina: Bez maksimuma\n• Udobno (80 znakova): Optimalno za čitanje\n• Usko (60 znakova): Za koncentrirano čitanje\n\nAAA smjernice preporučuju maksimalno 80 znakova po retku.";
"help_text_large_touch_targets" = "Veće zone dodira čine sve gumbe i interaktivne elemente najmanje 60 točaka.\n\nTo je korisno za:\n• Motoričke teškoće\n• Tremor ili drhtanje\n• Korištenje aplikacije s rukavicama\n• Korištenje jednom rukom\n\nStandardni minimum je 44 točke; ova postavka povećava na 60 točaka.";
"help_text_reduce_motion" = "Smanjivanje kretanja minimizira ili uklanja animacije u cijeloj aplikaciji.\n\nTo je korisno za korisnike s:\n• Osjetljivošću na kretanje\n• Vestibularnim poremećajima\n• Epilepsijom\n• Okidačima migrene\n\nKada je omogućeno, animacije se zamjenjuju trenutačnim prijelazima.";
"help_text_timeout_behavior" = "Ponašanje vremenskog ograničenja kontrolira koliko dugo operacije mogu trajati.\n\nOpcije:\n• Bez vremenskog ograničenja (AAA): Operacije nikada ne istječu\n• Standardno (30 s): Zadano vremensko ograničenje\n• Prošireno (60 s): Dvostruko standardno vrijeme\n\nNačin bez vremenskog ograničenja zadovoljava AAA standarde pristupačnosti.";
"help_text_simplified_gestures" = "Pojednostavnjene geste smanjuju složene geste višestrukim dodirom na jednostavne dodire.\n\nTo je korisno za:\n• Motoričke teškoće\n• Ograničenu spretnost\n• Korištenje asistivnih uređaja\n• Rad jednom rukom\n\nSložene geste zamjenjuju se gumbima i jednostavnim dodirima.";
"help_text_haptic_feedback" = "Haptička povratna informacija pruža vibracijsku povratnu informaciju za radnje i obavijesti.\n\nTo je korisno za:\n• Potvrdu pritisaka gumba\n• Upozoravanje na pogreške ili upozorenja\n• Pružanje nevizualne povratne informacije\n• Korisnike s oštećenjem sluha ili vida\n\nMožete onemogućiti ovo ako su vibracije neugodne.";
"help_text_simplified_ui" = "Pojednostavnjeno sučelje smanjuje vizualnu složenost u cijeloj aplikaciji.\n\nTo je korisno za:\n• Kognitivne teškoće\n• Teškoće učenja\n• Poremećaje pažnje\n• Nove ili neiskusne korisnike\n\nKada je omogućeno:\n• Manje elemenata na zaslonu\n• Veće, jasnije kontrole\n• Manje vizualne buke";
"help_text_step_indicators" = "Indikatori koraka prikazuju napredak kroz višekorake procese.\n\nTo pomaže:\n• Razumjeti gdje se nalazite u procesu\n• Znati koliko je koraka ostalo\n• Smanjiti kognitivno opterećenje\n• Pružiti jasnu strukturu\n\nPrikazuje \"Korak X od Y\" s vizualnim točkama napretka.";
"help_text_verbose_descriptions" = "Detaljni opisi pružaju dodatni obrazložidbeni tekst u cijeloj aplikaciji.\n\nTo je korisno za:\n• Razumijevanje složenih značajki\n• Učenje korištenja aplikacije\n• Kognitivnu podršku\n• Korisnike čitača zaslona\n\nPruža kontekst i upute za sve značajke.";
"help_text_confirm_actions" = "Potvrda radnji traži potvrdu prije važnih radnji.\n\nTo pomaže u sprječavanju:\n• Slučajnih brisanja\n• Nenamjernih promjena\n• Preuranjenih slanja\n• Gubitka podataka\n\nNapomena: Destruktivne radnje uvijek zahtijevaju potvrdu (AAA zahtjev).";
"help_text_manual_code_entry" = "Ručni unos koda omogućuje Vam tipkanje kodova umjesto skeniranja QR kodova.\n\nTo je korisno kada:\n• Kamera ne radi\n• QR kod je oštećen ili nejasan\n• Koristite čitač zaslona\n• Preferirate tipkanje umjesto skeniranja\n\nJednostavno dodirnite \"Unesite kod ručno\" za tipkanje koda prikazanog na zaslonu.";
"help_text_voice_input" = "Glasovni unos omogućuje Vam izgovaranje kodova umjesto skeniranja ili tipkanja.\n\nTo je korisno za:\n• Ograničenu pokretljivost\n• Korisnike čitača zaslona\n• Rad bez ruku\n• Preferenciju za glas\n\nDodirnite gumb mikrofona i jasno govorite kada se to od Vas zatraži.";
"help_text_qr_scanning" = "Skeniranje QR koda koristi kameru za čitanje kodova brzog odgovora.\n\nKako skenirati:\n1. Usmjerite kameru prema QR kodu\n2. Poravnajte kod u okviru\n3. Pričekajte automatsko otkrivanje\n\nSavjeti:\n• Osigurajte dobro osvjetljenje\n• Držite uređaj mirno\n• QR kod neka bude ravan i bez prepreka\n• Ako skeniranje ne uspije, pokušajte ručni unos koda";
"help_text_age_verification" = "Provjera dobi dokazuje da ispunjavate uvjet dobi bez otkrivanja Vaše stvarne dobi ili datuma rođenja.\n\nKako to funkcionira:\n1. Verifikator generira izazov\n2. Skenirate QR kod ili unosite ručno\n3. Aplikacija izrađuje dokaz nultog znanja\n4. Verifikator potvrđuje da ispunjavate uvjet\n\nPrivatnost zaštićena:\n• Vaš datum rođenja nikada se ne dijeli\n• Verifikator saznaje samo ispunjavate li uvjet\n• Nema praćenja ni prikupljanja podataka";
"help_text_credentials" = "Digitalne vjerodajnice su kriptografski dokazi Vaše dobi koji su sigurno pohranjeni na Vašem uređaju.\n\nZnačajke:\n• Pohranjene samo na Vašem uređaju\n• Ne mogu se kopirati ili krivotvoriti\n• Koriste se za provjeru uz zaštitu privatnosti\n• Mogu se izbrisati u bilo koje vrijeme\n\nMorate nabaviti vjerodajnicu od ovlaštenog izdavatelja (poput vladine institucije) prije nego što možete provjeriti svoju dob.";
"help_text_zero_knowledge" = "Dokazi nultog znanja omogućuju Vam dokazivanje da je nešto istinito bez otkrivanja temeljnih informacija.\n\nPrimjer:\n• Tradicionalno: Pokažite identifikaciju (otkriva točan datum rođenja)\n• Nulto znanje: Dokažite da imate više od 18 godina bez prikazivanja datuma rođenja\n\nPrednosti:\n• Maksimalna zaštita privatnosti\n• Nikakvi osobni podaci se ne dijele\n• Kriptografski sigurno\n• Ne može se krivotvoriti ili reproducirati\n\nOvo je osnovna tehnologija koja čini Provii Wallet privatnim.";
"help_text_credential_issuance" = "Izdavanje vjerodajnice je proces dobivanja Vaše digitalne vjerodajnice dobi od ovlaštenog izdavatelja.\n\nKoraci:\n1. Posjetite ovlaštenog izdavatelja (npr. vladinu instituciju)\n2. Dokažite svoj identitet službenom identifikacijom\n3. Primite QR kod ili duboku vezu od izdavatelja\n4. Skenirajte QR kod ili dodirnite vezu\n5. Vjerodajnica se izračunava lokalno i pohranjuje na Vašem uređaju\n\nProces slijepe atestacije osigurava da Vaš datum rođenja nikada nije prenesen mrežom.\nTo je potrebno učiniti samo jednom. Vaša vjerodajnica može se koristiti za neograničene provjere.";
"help_text_officer_mode" = "Način rada za službenike je za ovlaštene izdavatelje koji izrađuju vjerodajnice za korisnike.\n\nOvaj način zahtijeva:\n• Autentifikaciju službenika s YubiKeyem\n• Autorizaciju od tijela za izdavanje\n• Fizičku provjeru identifikacije korisnika\n\nProces:\n1. Autentificirajte se kao službenik\n2. Provjerite službenu identifikaciju korisnika\n3. Unesite datum rođenja korisnika\n4. Generirajte QR kod atestacije\n5. Korisnik skenira kod za primanje vjerodajnice\n\nOvaj način smiju koristiti samo ovlaštene osobe.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Čini sav tekst 50% većim.\n\nPomaže Vam ako:\n• Imate poteškoće s vidom\n• Smatrate čitanje teškim\n• Trebate veći tekst\n\nRadi s postavkama veličine teksta telefona.";

"help_text_contrast_level_simplified" = "Mijenja koliko je tekst taman.\n\nTri izbora:\n• Standardno: Normalne boje\n• Visoko: Tamniji tekst za lakše čitanje\n• Maksimalno: Vrlo taman tekst za najbolje čitanje\n\nTamniji tekst je lakši za čitanje.";

"help_text_high_contrast_simplified" = "Čini tekst lakšim za vidjeti.\n\nPomaže Vam ako:\n• Imate poteškoće s vidom\n• Trebate tamniji tekst\n• Koristite aplikaciju na jakom svjetlu\n\nTekst postaje crn na bijelom.";

"help_text_reduce_transparency_simplified" = "Uklanja zamagljene efekte.\n\nTo pomaže:\n• Učiniti tekst jasnijim\n• Učiniti aplikaciju jednostavnijom\n• Ubrzati starije telefone\n\nSve izgleda čvršće.";

"help_text_color_blind_mode_simplified" = "Mijenja boje kako bi Vam pomoglo bolje vidjeti.\n\nIzbori:\n• Način rada za sljepilo za crvenu\n• Način rada za sljepilo za zelenu\n• Način rada za sljepilo za plavu\n• Samo sivi ton\n\nPomaže Vam vidjeti važne stvari.";

"help_text_line_spacing_simplified" = "Mijenja prostor između redaka teksta.\n\nMožete odabrati od 1,0x do 2,0x.\nZadano je 1,0x.\n\nViše prostora čini čitanje lakšim.";

"help_text_paragraph_spacing_simplified" = "Mijenja prostor između odlomaka.\n\nMožete odabrati od 1,0x do 3,0x.\nZadano je 1,0x.\n\nViše prostora pomaže Vam vidjeti gdje počinju nove ideje.";

"help_text_letter_spacing_simplified" = "Mijenja prostor između slova.\n\nMožete odabrati od 0,0 do 0,2.\nZadano je 0,0.\n\nViše prostora čini slova jasnijima.";

"help_text_text_width_simplified" = "Kontrolira koliko je tekst širok.\n\nIzbori:\n• Puna širina: Koristi cijeli zaslon\n• Srednje: Dobro za čitanje\n• Usko: Najbolje za fokus\n\nSrednja širina je najlakša za čitanje.";

"help_text_large_touch_targets_simplified" = "Čini sve gumbe većima.\n\nPomaže Vam ako:\n• Imate poteškoće s dodirivanjem malih gumba\n• Imate drhtave ruke\n• Nosite rukavice\n• Koristite jednu ruku\n\nGumbi postaju 60 točaka umjesto 44 točke.";

"help_text_reduce_motion_simplified" = "Uklanja animacije kretanja.\n\nPomaže Vam ako:\n• Kretanje Vam izaziva vrtoglavicu\n• Dobivate glavobolje od kretanja\n• Preferirate da stvari ostanu mirne\n\nStvari se mijenjaju odmah umjesto kretanja.";

"help_text_timeout_behavior_simplified" = "Kontrolira koliko dugo zadaci mogu trajati.\n\nIzbori:\n• Bez ograničenja: Zadaci nikada ne prestaju\n• Normalno: 30 sekundi\n• Dulje: 60 sekundi\n\nOdaberite 'Bez ograničenja' ako Vam treba više vremena.";

"help_text_simplified_gestures_simplified" = "Zamjenjuje teške geste jednostavnim dodirima.\n\nPomaže Vam ako:\n• Imate poteškoće sa složenim dodirima\n• Preferirate jednostavne dodire\n• Koristite jednu ruku\n\nSve koristi jednostavne dodire.";

"help_text_haptic_feedback_simplified" = "Čini da Vaš telefon vibrira kada dodirnete.\n\nPomaže Vam:\n• Znati kada ste dodirnuli gumb\n• Osjetiti pogreške ili upozorenja\n• Dobiti povratnu informaciju bez gledanja\n\nIsključite ako Vam vibracije smetaju.";

"help_text_simplified_ui_simplified" = "Čini aplikaciju jednostavnijom.\n\nPomaže Vam ako:\n• Zbusite se zbog pretrpanog zaslona\n• Preferirate jednostavne rasporede\n• Ste novi korisnik aplikacije\n\nPrikazuje manje stvari odjednom.";

"help_text_step_indicators_simplified" = "Prikazuje napredak kroz korake.\n\nPomaže Vam:\n• Znati gdje se nalazite\n• Vidjeti koliko je koraka ostalo\n• Ostati organizirani\n\nPrikazuje 'Korak 1 od 3' s točkama.";

"help_text_verbose_descriptions_simplified" = "Daje Vam više objašnjenja.\n\nPomaže Vam:\n• Razumjeti značajke\n• Naučiti koristiti aplikaciju\n• Dobiti više pojedinosti\n\nPruža dodatnu pomoć svugdje.";

"help_text_confirm_actions_simplified" = "Traži od Vas potvrdu za važne radnje.\n\nPomaže u sprječavanju:\n• Slučajnih brisanja\n• Neželjenih promjena\n• Grešaka\n\nUvijek će Vas pitati 'Jeste li sigurni?'";

"help_text_manual_code_entry_simplified" = "Omogućuje tipkanje kodova umjesto skeniranja.\n\nKoristite ovo kada:\n• Kamera ne radi\n• Kod je teško skenirati\n• Preferirate tipkanje\n\nDodirnite 'Unesite kod ručno' za tipkanje.";

"help_text_voice_input_simplified" = "Omogućuje izgovaranje kodova umjesto tipkanja.\n\nPomaže Vam ako:\n• Imate poteškoće s tipkanjem\n• Preferirate govoriti\n• Želite korištenje bez ruku\n\nDodirnite mikrofon i jasno govorite.";

"help_text_qr_scanning_simplified" = "Koristi kameru za čitanje kvadratnih kodova.\n\nKako skenirati:\n1. Usmjerite kameru prema kodu\n2. Poravnajte kod\n3. Pričekajte dok se pročita\n\nSavjeti:\n• Koristite dobro osvjetljenje\n• Držite telefon mirno\n• Neka kod bude ravan";

"help_text_age_verification_simplified" = "Dokazuje da ste dovoljno stari bez dijeljenja datuma rođenja.\n\nKako to funkcionira:\n1. Poslovni subjekt izrađuje zahtjev\n2. Skenirate njihov kod\n3. Aplikacija izrađuje dokaz\n4. Poslovni subjekt potvrđuje da ste dovoljno stari\n\nVaš datum rođenja ostaje privatan.";

"help_text_credentials_simplified" = "Digitalni dokaz Vaše dobi pohranjen na telefonu.\n\nZnačajke:\n• Samo na Vašem telefonu\n• Ne može se kopirati\n• Čuva Vašu privatnost\n• Možete ga izbrisati u bilo koje vrijeme\n\nDobivate ga od vladine institucije.";

"help_text_zero_knowledge_simplified" = "Dokazuje nešto bez dijeljenja pojedinosti.\n\nPrimjer:\n• Stari način: Pokažite identifikaciju (prikazuje točan datum rođenja)\n• Novi način: Dokažite da imate više od 18 (datum rođenja ostaje privatan)\n\nOvo čuva Vaše privatne podatke.";

"help_text_credential_issuance_simplified" = "Dobivanje Vašeg digitalnog dokaza dobi.\n\nKoraci:\n1. Idite u vladinu instituciju\n2. Pokažite identifikaciju\n3. Primite kod\n4. Skenirajte kod\n5. Dokaz je pohranjen na Vašem telefonu\n\nUčinite to jednom. Zatim koristite mnogo puta.";

"help_text_officer_mode_simplified" = "Za državne službenike za izradu dokaza.\n\nPotrebno:\n• Lozinka službenika\n• Dozvola za korištenje\n• Identifikacija korisnika za provjeru\n\nKoraci:\n1. Prijavite se kao službenik\n2. Provjerite identifikaciju korisnika\n3. Unesite njihov datum rođenja\n4. Izradite kod\n5. Korisnik skenira kod\n\nSamo za ovlaštene zaposlenike.";

