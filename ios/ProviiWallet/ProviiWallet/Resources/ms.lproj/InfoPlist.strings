/* InfoPlist.strings - Malay */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet memerlukan akses kamera untuk mengimbas kod QR bagi pengambilan kelayakan dan pengesahan umur.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet menggunakan NFC untuk berkomunikasi dengan YubiKey anda bagi pengesahihan pegawai yang selamat.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet menggunakan pengecaman pertuturan untuk perintah suara dalam mod kebolehcapaian, membolehkan anda mengawal aplikasi tanpa menggunakan tangan.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet memerlukan akses mikrofon untuk ciri kawalan suara apabila mod kebolehcapaian diaktifkan.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet menggunakan Face ID untuk mengakses kelayakan umur anda dengan selamat dan mengesahkan identiti anda.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet mungkin menggunakan rangkaian tempatan untuk menemukan penerbit kelayakan berdekatan.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet mungkin menggunakan Bluetooth untuk berkomunikasi dengan peranti YubiKey.";
