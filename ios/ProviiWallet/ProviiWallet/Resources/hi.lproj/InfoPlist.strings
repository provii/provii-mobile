/* InfoPlist.strings - Hindi (hi) */
/* Provii Wallet के लिए अनुमति विवरण */

/* कैमरा एक्सेस */
"NSCameraUsageDescription" = "Provii Wallet को प्रमाण-पत्र प्राप्त करने और आयु सत्यापन के लिए QR कोड स्कैन करने हेतु कैमरा एक्सेस की आवश्यकता है।";

/* NFC एक्सेस */
"NFCReaderUsageDescription" = "Provii Wallet सुरक्षित अधिकारी प्रमाणीकरण के लिए आपकी YubiKey से संवाद करने हेतु NFC का उपयोग करता है।";

/* स्पीच रिकॉग्निशन */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet सुलभता मोड में वॉइस कमांड के लिए स्पीच रिकॉग्निशन का उपयोग करता है, जिससे आप बिना हाथ लगाए ऐप को नियंत्रित कर सकते हैं।";

/* माइक्रोफ़ोन एक्सेस */
"NSMicrophoneUsageDescription" = "जब सुलभता मोड चालू हो तो Provii Wallet को वॉइस कंट्रोल फ़ीचर के लिए माइक्रोफ़ोन की अनुमति चाहिए।";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet आपकी आयु प्रमाण-पत्रों तक सुरक्षित पहुँच और पहचान सत्यापन के लिए Face ID का उपयोग करता है।";

/* लोकल नेटवर्क */
"NSLocalNetworkUsageDescription" = "Provii Wallet आसपास के प्रमाण-पत्र जारीकर्ताओं को खोजने के लिए लोकल नेटवर्क का उपयोग कर सकता है।";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet YubiKey डिवाइस से संवाद करने के लिए Bluetooth का उपयोग कर सकता है।";
