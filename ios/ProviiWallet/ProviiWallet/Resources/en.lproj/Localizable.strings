// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Extra Large Text increases all text in the app by 50%.\n\nThis is helpful for users with:\n• Low vision\n• Reading difficulties\n• Age-related vision changes\n\nWorks with iOS Dynamic Type for even larger sizes.";
"help_text_contrast_level" = "Contrast Level controls the color contrast between text and backgrounds.\n\nThree levels available:\n• Standard: Default colors\n• High (AA): 4.5:1 contrast ratio - meets AA standards\n• Maximum (AAA): 7:1 contrast ratio - meets highest AAA standards\n\nHigher contrast makes text easier to read in all lighting conditions.";
"help_text_high_contrast" = "High Contrast Mode increases the contrast between text and background, making it easier to read.\n\nThis is helpful for users with:\n• Low vision\n• Color sensitivity\n• Bright screen environments\n\nWhen enabled:\n• Text becomes black on white\n• Borders are added to elements\n• Colors are simplified";
"help_text_reduce_transparency" = "Reduce Transparency removes blur and transparency effects throughout the app.\n\nThis helps:\n• Improve text readability\n• Reduce visual complexity\n• Increase performance on older devices\n• Make content more predictable";
"help_text_color_blind_mode" = "Color Blind Modes adjust colors for different types of color vision deficiency.\n\nModes available:\n• Protanopia: Red-blind (difficulty seeing red)\n• Deuteranopia: Green-blind (difficulty seeing green)\n• Tritanopia: Blue-blind (difficulty seeing blue)\n• Monochrome: Grayscale only\n\nThese modes ensure important information isn't conveyed by color alone.";
"help_text_line_spacing" = "Line Spacing controls the space between lines of text.\n\n• Range: 1.0x to 2.0x\n• AAA standard: 1.5x minimum\n• Default: 1.0x\n\nIncreased line spacing makes text easier to read and helps prevent line skipping.";
"help_text_paragraph_spacing" = "Paragraph Spacing controls the space between paragraphs.\n\n• Range: 1.0x to 3.0x\n• AAA standard: 2.0x minimum\n• Default: 1.0x\n\nIncreased paragraph spacing helps distinguish between different sections of text.";
"help_text_letter_spacing" = "Letter Spacing controls the space between individual characters.\n\n• Range: 0.0em to 0.2em\n• AAA standard: 0.12em minimum\n• Default: 0.0em\n\nIncreased letter spacing improves character recognition and readability.";
"help_text_text_width" = "Text Width controls the maximum line length for comfortable reading.\n\nOptions:\n• Full Width: No maximum\n• Comfortable (80 chars): Optimal for reading\n• Narrow (60 chars): For concentrated reading\n\nAAA guidelines recommend 80 characters maximum per line.";
"help_text_large_touch_targets" = "Larger Touch Targets makes all buttons and interactive elements at least 60pt in size.\n\nThis is helpful for:\n• Motor impairments\n• Tremors or shaking\n• Using the app with gloves\n• One-handed use\n\nThe standard minimum is 44pt; this setting increases to 60pt.";
"help_text_reduce_motion" = "Reduce Motion minimises or removes animations throughout the app.\n\nThis is helpful for users with:\n• Motion sensitivity\n• Vestibular disorders\n• Epilepsy\n• Migraine triggers\n\nWhen enabled, animations are replaced with instant transitions.";
"help_text_timeout_behavior" = "Timeout Behavior controls how long operations can take before timing out.\n\nOptions:\n• No Timeout (AAA): Operations never timeout\n• Standard (30s): Default timeout\n• Extended (60s): Double the standard time\n\nNo timeout mode meets AAA accessibility standards.";
"help_text_simplified_gestures" = "Simplified Gestures reduces complex multi-touch gestures to simple taps.\n\nThis is helpful for:\n• Motor impairments\n• Limited dexterity\n• Using assistive devices\n• One-handed operation\n\nComplex gestures are replaced with buttons and simple taps.";
"help_text_haptic_feedback" = "Haptic Feedback provides vibration feedback for actions and notifications.\n\nThis is helpful for:\n• Confirming button presses\n• Alerting to errors or warnings\n• Providing non-visual feedback\n• Users with hearing or vision impairments\n\nYou can disable this if vibrations are uncomfortable.";
"help_text_simplified_ui" = "Simplified Interface reduces visual complexity throughout the app.\n\nThis is helpful for:\n• Cognitive disabilities\n• Learning difficulties\n• Attention disorders\n• New or inexperienced users\n\nWhen enabled:\n• Fewer elements on screen\n• Larger, clearer controls\n• Less visual noise";
"help_text_step_indicators" = "Step Indicators show your progress through multi-step processes.\n\nThis helps:\n• Understand where you are in a process\n• Know how many steps remain\n• Reduce cognitive load\n• Provide clear structure\n\nShows \"Step X of Y\" with visual progress dots.";
"help_text_verbose_descriptions" = "Detailed Descriptions provides additional explanatory text throughout the app.\n\nThis is helpful for:\n• Understanding complex features\n• Learning how to use the app\n• Cognitive support\n• Screen reader users\n\nProvides context and instructions for all features.";
"help_text_confirm_actions" = "Confirm Actions asks for confirmation before important actions.\n\nThis helps prevent:\n• Accidental deletions\n• Unintended changes\n• Premature submissions\n• Data loss\n\nNote: Destructive actions always require confirmation (AAA requirement).";
"help_text_manual_code_entry" = "Manual Code Entry allows you to type codes instead of scanning QR codes.\n\nThis is helpful when:\n• Camera is not working\n• QR code is damaged or unclear\n• Using screen reader\n• Prefer typing to scanning\n\nSimply tap \"Enter Code Manually\" to type the code shown on screen.";
"help_text_voice_input" = "Voice Input allows you to speak codes instead of scanning or typing.\n\nThis is helpful for:\n• Limited mobility\n• Screen reader users\n• Hands-free operation\n• Preference for voice\n\nTap the microphone button and speak clearly when prompted.";
"help_text_qr_scanning" = "QR Code Scanning uses your camera to read Quick Response codes.\n\nHow to scan:\n1. Point camera at QR code\n2. Align code in frame\n3. Wait for automatic detection\n\nTips:\n• Ensure good lighting\n• Hold device steady\n• Keep QR code flat and unobstructed\n• If scanning fails, try Manual Code Entry";
"help_text_age_verification" = "Age Verification proves you meet an age requirement without revealing your actual age or date of birth.\n\nHow it works:\n1. Verifier generates a challenge\n2. You scan the QR code or enter manually\n3. App creates a zero knowledge proof\n4. Verifier confirms you meet requirement\n\nPrivacy protected:\n• Your date of birth is never shared\n• Verifier only learns if you meet requirement\n• No tracking or data collection";
"help_text_credentials" = "Digital Credentials are cryptographic proofs of your age stored securely on your device.\n\nFeatures:\n• Stored only on your device\n• Cannot be copied or forged\n• Used for privacy preserving verification\n• Can be deleted at any time\n\nYou must obtain a credential from an authorised issuer (like a government office) before you can verify your age.";
"help_text_zero_knowledge" = "Zero Knowledge Proofs allow you to prove something is true without revealing the underlying information.\n\nExample:\n• Traditional: Show ID (reveals exact birthday)\n• Zero Knowledge: Prove you're over 18 without showing birthday\n\nBenefits:\n• Maximum privacy protection\n• No personal data shared\n• Cryptographically secure\n• Cannot be forged or replayed\n\nThis is the core technology that makes Provii Wallet private.";
"help_text_credential_issuance" = "Credential Issuance is the process of obtaining your digital age credential from an authorised issuer.\n\nSteps:\n1. Visit authorised issuer (e.g., government office)\n2. Prove your identity with official ID\n3. Receive QR code or deep link from issuer\n4. Scan QR code or tap the link\n5. Credential is computed locally and stored on your device\n\nThe blind attestation process ensures your date of birth is never transmitted over the network.\nYou only need to do this once. Your credential can then be used for unlimited verifications.";
"help_text_officer_mode" = "Officer Mode is for authorised issuers to create credentials for users.\n\nThis mode requires:\n• Officer authentication with YubiKey\n• Authorisation from issuing authority\n• Physical verification of user's ID\n\nProcess:\n1. Authenticate as officer\n2. Verify user's official ID\n3. Enter user's date of birth\n4. Generate attestation QR code\n5. User scans code to receive credential\n\nOnly authorised personnel should use this mode.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Makes all text 50% bigger.\n\nHelps you if you:\n• Have trouble seeing\n• Find reading hard\n• Need larger text\n\nWorks with your phone's text size settings.";

"help_text_contrast_level_simplified" = "Changes how dark the text is.\n\nThree choices:\n• Standard: Normal colors\n• High: Darker text for easy reading\n• Maximum: Very dark text for best reading\n\nDarker text is easier to read.";

"help_text_high_contrast_simplified" = "Makes text easier to see.\n\nHelps you if you:\n• Have trouble seeing\n• Need darker text\n• Use the app in bright light\n\nText becomes black on white.";

"help_text_reduce_transparency_simplified" = "Removes blurry effects.\n\nThis helps:\n• Make text clearer\n• Make the app simpler\n• Speed up older phones\n\nEverything looks more solid.";

"help_text_color_blind_mode_simplified" = "Changes colors to help you see better.\n\nChoices:\n• Red-blind mode\n• Green-blind mode\n• Blue-blind mode\n• Gray only mode\n\nHelps you see important things.";

"help_text_line_spacing_simplified" = "Changes space between lines of text.\n\nYou can pick from 1.0x to 2.0x.\nDefault is 1.0x.\n\nMore space makes reading easier.";

"help_text_paragraph_spacing_simplified" = "Changes space between paragraphs.\n\nYou can pick from 1.0x to 3.0x.\nDefault is 1.0x.\n\nMore space helps you see where new ideas start.";

"help_text_letter_spacing_simplified" = "Changes space between letters.\n\nYou can pick from 0.0 to 0.2.\nDefault is 0.0.\n\nMore space makes letters clearer.";

"help_text_text_width_simplified" = "Controls how wide text is.\n\nChoices:\n• Full width: Uses whole screen\n• Medium: Good for reading\n• Narrow: Best for focus\n\nMedium width is easiest to read.";

"help_text_large_touch_targets_simplified" = "Makes all buttons bigger.\n\nHelps you if you:\n• Have trouble tapping small buttons\n• Have shaky hands\n• Wear gloves\n• Use one hand\n\nButtons become 60pt instead of 44pt.";

"help_text_reduce_motion_simplified" = "Removes moving animations.\n\nHelps you if:\n• Movement makes you dizzy\n• You get headaches from motion\n• You prefer things to stay still\n\nThings change instantly instead of moving.";

"help_text_timeout_behavior_simplified" = "Controls how long tasks can take.\n\nChoices:\n• No limit: Tasks never stop\n• Normal: 30 seconds\n• Longer: 60 seconds\n\nPick 'No limit' if you need more time.";

"help_text_simplified_gestures_simplified" = "Replaces hard gestures with simple taps.\n\nHelps you if you:\n• Have trouble with complex touches\n• Prefer simple taps\n• Use one hand\n\nEverything uses simple taps.";

"help_text_haptic_feedback_simplified" = "Makes your phone vibrate when you tap.\n\nHelps you:\n• Know when you tapped a button\n• Feel errors or warnings\n• Get feedback without looking\n\nTurn off if vibrations bother you.";

"help_text_simplified_ui_simplified" = "Makes the app simpler.\n\nHelps you if you:\n• Get confused by busy screens\n• Prefer simple layouts\n• Are new to the app\n\nShows fewer things at once.";

"help_text_step_indicators_simplified" = "Shows your progress through steps.\n\nHelps you:\n• Know where you are\n• See how many steps are left\n• Stay organized\n\nShows 'Step 1 of 3' with dots.";

"help_text_verbose_descriptions_simplified" = "Gives you more explanations.\n\nHelps you:\n• Understand features\n• Learn how to use the app\n• Get more details\n\nProvides extra help everywhere.";

"help_text_confirm_actions_simplified" = "Asks you to confirm important actions.\n\nHelps prevent:\n• Accidental deletions\n• Unwanted changes\n• Mistakes\n\nYou'll always be asked 'Are you sure?'";

"help_text_manual_code_entry_simplified" = "Lets you type codes instead of scanning.\n\nUse this when:\n• Your camera doesn't work\n• The code is hard to scan\n• You prefer typing\n\nTap 'Enter Code Manually' to type.";

"help_text_voice_input_simplified" = "Lets you speak codes instead of typing.\n\nHelps you if you:\n• Have trouble typing\n• Prefer talking\n• Want hands-free use\n\nTap the microphone and speak clearly.";

"help_text_qr_scanning_simplified" = "Uses your camera to read square codes.\n\nHow to scan:\n1. Point camera at the code\n2. Line up the code\n3. Wait for it to read\n\nTips:\n• Use good lighting\n• Hold your phone steady\n• Keep the code flat";

"help_text_age_verification_simplified" = "Proves you're old enough without sharing your birthday.\n\nHow it works:\n1. Business creates a request\n2. You scan their code\n3. App creates a proof\n4. Business confirms you're old enough\n\nYour birthday stays private.";

"help_text_credentials_simplified" = "Digital proof of your age stored on your phone.\n\nFeatures:\n• Only on your phone\n• Cannot be copied\n• Keeps you private\n• You can delete it anytime\n\nYou get it from a government office.";

"help_text_zero_knowledge_simplified" = "Proves something without sharing details.\n\nExample:\n• Old way: Show your ID (shows exact birthday)\n• New way: Prove you're over 18 (birthday stays private)\n\nThis keeps your information private.";

"help_text_credential_issuance_simplified" = "Getting your digital age proof.\n\nSteps:\n1. Go to government office\n2. Show your ID\n3. Get a code\n4. Scan the code\n5. Proof is saved on your phone\n\nDo this once. Then use it many times.";

"help_text_officer_mode_simplified" = "For government workers to create proofs.\n\nNeeds:\n• Officer password\n• Permission to use\n• User's ID to check\n\nSteps:\n1. Log in as officer\n2. Check user's ID\n3. Enter their birthday\n4. Create code\n5. User scans code\n\nOnly for authorised workers.";

