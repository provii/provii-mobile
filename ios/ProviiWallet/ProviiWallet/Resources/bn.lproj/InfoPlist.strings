/* InfoPlist.strings - Bengali */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "প্রমাণপত্র সংগ্রহ এবং বয়স যাচাইয়ের জন্য QR কোড স্ক্যান করতে Provii Wallet-এর ক্যামেরা অ্যাক্সেস প্রয়োজন।";

/* NFC Access */
"NFCReaderUsageDescription" = "নিরাপদ অফিসার প্রমাণীকরণের জন্য আপনার YubiKey-এর সাথে যোগাযোগ করতে Provii Wallet NFC ব্যবহার করে।";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "অ্যাক্সেসিবিলিটি মোডে ভয়েস কমান্ডের জন্য Provii Wallet স্পিচ রিকগনিশন ব্যবহার করে, যা আপনাকে হাত-মুক্তভাবে অ্যাপ নিয়ন্ত্রণ করতে দেয়।";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "অ্যাক্সেসিবিলিটি মোড চালু থাকলে ভয়েস কন্ট্রোল ফিচারের জন্য Provii Wallet-এর মাইক্রোফোন অ্যাক্সেস প্রয়োজন।";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "আপনার বয়স যাচাইয়ের প্রমাণপত্র নিরাপদে অ্যাক্সেস করতে এবং আপনার পরিচয় যাচাই করতে Provii Wallet Face ID ব্যবহার করে।";

/* Local Network */
"NSLocalNetworkUsageDescription" = "কাছাকাছি প্রমাণপত্র ইস্যুকারী খুঁজে পেতে Provii Wallet লোকাল নেটওয়ার্ক ব্যবহার করতে পারে।";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "YubiKey ডিভাইসের সাথে যোগাযোগ করতে Provii Wallet Bluetooth ব্যবহার করতে পারে।";
