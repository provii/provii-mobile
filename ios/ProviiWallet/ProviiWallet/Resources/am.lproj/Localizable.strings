// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "ተጨማሪ ትልቅ ጽሑፍ ሁሉም ጽሑፍ ባፕ ውስጥ 50% ይጨምራሉ።\n\nይህ ለሚከተሉ ጠቃሚ ነው፦\n• ዝቅተኛ ዕይታ\n• ንባብ ችግር\n• ዕድሜ ምክንያት ዕይታ ለውጥ\n\nለሁለቱ ትልቅ መጠኖች ከ iOS Dynamic Type ጋር ይሰራሉ።";
"help_text_contrast_level" = "የንፅፅር ደረጃ ጽሑፍ እና ዳራ ያለውን የቀለም ንፅፅር ይቆጣጠራሉ።\n\nሦስት ደረጃዎች አሉ፦\n• ደረጃ፦ ነባሪ ቀለሞች\n• ከፍተኛ (AA)፦ 4.5፡1 የንፅፅር ምጣኔ\n• ከፍተኛ ደረጃ (AAA)፦ 7፡1 የንፅፅር ምጣኔ\n\nከፍ ያለ ንፅፅር ጽሑፍ ሁሉም ብርሃን ሁኔታዎች ላይ ቀላሉ ያደርጋሉ።";
"help_text_high_contrast" = "ከፍተኛ ንፅፅር ሁነታ ጽሑፍ እና ዳራ ያለውን ንፅፅር ይጨምሩ ለቀሉ ለማንበብ ያደርጋቸዋል።\n\nይህ ለሚከተሉ ጠቃሚ ነው፦\n• ዝቅተኛ ዕይታ\n• ቀለም ስሜታዊነት\n• ደምቅ ስክሪን አካባቢዎች\n\nሲነቃ፦\n• ጽሑፍ ነጭ ላይ ጥቁር ይሆናሉ\n• ድንበሮች ለአካሎች ይጨምሩ\n• ቀለሞች ቀለሉ ይሆናሉ";
"help_text_reduce_transparency" = "ግልፀኝነት ቀንስ ሁሉም ባፕ ውስጥ ደብዛዛ እና ግልፀኝነት ተጽዕኖዎች ያስወግዳሉ።\n\nይህ ይረዳሉ፦\n• ጽሑፍ ንባብ ለማሻሻል\n• ዕይታ ውስብስብነትን ለመቀነስ\n• በድሮ መሳሪያዎች ፍጥነትን ለማሻሻል\n• ይዘቱ ተጨባጭ ለማድረግ";
"help_text_color_blind_mode" = "ለቀለም ዕውሮ ሁነታዎች ለተለያዩ ዓይነቶች የቀለም ዕይታ ችግር ቀለሞችን ያስተካክሉ።\n\nሁነታዎች፦\n• ፕሮታኖፒያ፦ ቀይ-ዕውር\n• ዱቴራኖፒያ፦ አረንጓዴ-ዕውር\n• ትሪታኖፒያ፦ ሰማያዊ-ዕውር\n• ሞኖክሮም፦ ግራጫ ብቻ\n\nእነዚህ ሁነታዎች አስፈላጊ መረጃ ቀለም ብቻ ሳይሆን ሌሎች ዘዴዎችም እንዲጠቀሙ ያረጋግጣሉ።";
"help_text_line_spacing" = "የመስመር ክፍተት ዳሰሳ ጽሑፍ መስመሮች ያለውን ቦታ ይቆጣጠሩ።\n\n• ክልል፦ 1.0x እስከ 2.0x\n• AAA ደረጃ፦ 1.5x ዝቅተኛ\n• ነባሪ፦ 1.0x\n\nጨምሮ ያለ መስመር ክፍተት ጽሑፍ ለማንበብ ቀሉ ያደርጋሉ።";
"help_text_paragraph_spacing" = "የአንቀጽ ክፍተት አንቀጾች ያለውን ቦታ ይቆጣጠሩ።\n\n• ክልል፦ 1.0x እስከ 3.0x\n• AAA ደረጃ፦ 2.0x ዝቅተኛ\n• ነባሪ፦ 1.0x\n\nጨምሮ ያለ አንቀጽ ክፍተት ጽሑፍ ተለያይ ክፍሎቹ ለማወቅ ይረዳሉ።";
"help_text_letter_spacing" = "የፊደል ክፍተት ፊደሎች ያለውን ቦታ ይቆጣጠሩ።\n\n• ክልል፦ 0.0em እስከ 0.2em\n• AAA ደረጃ፦ 0.12em ዝቅተኛ\n• ነባሪ፦ 0.0em\n\nጨምሮ ያለ ፊደል ክፍተት ፊደሎችን ለማወቅ እና ንባብ ያሻሽሉ።";
"help_text_text_width" = "የጽሑፍ ስፋት ለምቹ ንባብ ከፍተኛ ዳሰሳ ርዝሞት ይቆጣጠሩ።\n\nአማራጮች፦\n• ሙሉ ስፋት፦ ከፍተኛ የለም\n• ምቹ (80 ፊደሎች)፦ ለንባብ ምርጥ\n• ጠባብ (60 ፊደሎች)፦ ለተሰበሰበ ንባብ\n\nAAA መምሪያዎች ከፍተኛ 80 ፊደሎች ይጠቁሙ ናቸው።";
"help_text_large_touch_targets" = "ትልቅ የንክኪ ዒላማዎች ሁሉም ቁልፎች እና የሚነኩ አካሎች ቢያንስ 60 ፕት ያደርጋቸዋል።\n\nይህ ለሚከተሉ ጠቃሚ ነው፦\n• የሞተር ጉዳት\n• መርጠፍ ወይም ንቅናቄ\n• ጓንት ለብሶ አፕ ሲጠቀሙ\n• በአንድ እጅ ሲጠቀሙ\n\nደረጃ ዝቅተኛ 44 ፕት ነው፤ ይህ ቅንብር ወደ 60 ፕት ያሳድጋቸዋል።";
"help_text_reduce_motion" = "እንቅስቃሴ ቀንስ ሁሉም ባፕ ውስጥ አኒሜሽኖችን ይቀንሳሉ ወይም ያስወግዳሉ።\n\nይህ ለሚከተሉ ጠቃሚ ነው፦\n• ንቅናቄ ስሜታዊነት\n• ቬስቲቡላር ችግሮች\n• የሚጥል በሽታ\n• ሚግሬን ቅስቀሳ\n\nሲነቃ አኒሜሽኖች ቅፅበታዊ ሽግግር ይሆናሉ።";
"help_text_timeout_behavior" = "የጊዜ ገደብ ባህሪ ሥራዎች ጊዜ ከማለቃቸው በፊት ምን ያህል ረዘም ሊወስዱ እንደሚቻሉ ይቆጣጠሩ።\n\nአማራጮች፦\n• ጊዜ ገደብ የለም (AAA)፦ ሥራዎች ጊዜ ፈጽሞ አያልቅባቸውም\n• ደረጃ (30ሰ)፦ ነባሪ ጊዜ ገደብ\n• የተራዘመ (60ሰ)፦ ሁለት እጥፍ ደረጃ ጊዜ\n\nጊዜ ገደብ የሌለ ሁነታ AAA ተደራሽነት ደረጃዎችን ያሟላሉ።";
"help_text_simplified_gestures" = "ቀለሉ ምልክቶች ውስብስብ ባዱ-ሁለት ሆን ምልክቶችን ወደ ቀላሉ ንካዎች ይቀንሱ።\n\nይህ ለሚከተሉ ጠቃሚ ነው፦\n• የሞተር ጉዳት\n• ፈርቃዊ ቅያሴ\n• ድጋፍ መሳሪያዎች ሲጠቀሙ\n• በአንድ እጅ ሲሠሩ\n\nውስብስብ ምልክቶች ቁልፎችና ቀለሉ ንካዎች ይሆናሉ።";
"help_text_haptic_feedback" = "ሃፕቲክ አስተያየት ለድርጊቶች እና ማሳወቂያዎች የንዝረት ስሜት ይሰጣሉ።\n\nይህ ለሚከተሉ ጠቃሚ ነው፦\n• ቁልፍ ጫኑ ለማረጋገጥ\n• ስህተቶቹ ወይም ማስጠንቀቂያዎችን ለማሳወቅ\n• ያለ ዕይታ ምላሽ ለመስጠት\n• ሰሚ ወይም ዕይታ ጉዳት ላለባቸው ተጠቃሚዎች\n\nንዝረቶቹ ምቹ ካልሆኑ ማጥፋት ይቻሉ።";
"help_text_simplified_ui" = "ቀላል ተጠቃሚ ገጽ ሁሉም ባፕ ውስጥ ዕይታ ውስብስብነትን ይቀንሱ።\n\nይህ ለሚከተሉ ጠቃሚ ነው፦\n• የአዕምሮ ጉዳቶች\n• ትምህርት ችግሮች\n• ትኩረት ችግሮች\n• አዲስ ወይም ልምድ የሌላቸው ተጠቃሚዎች\n\nሲነቃ፦\n• ስክሪን ላይ ያነሱ አካሎች\n• ትልቅ ግልጽ ቁጥጥሮች\n• ያነሰ ዕይታ ጫጫታ";
"help_text_step_indicators" = "የደረጃ ጠቋሚዎች ባዱ-ደረጃ ሂደቶች ሂደቱን ያሳያሉ።\n\nይህ ይረዳሉ፦\n• ሂደቱ ውስጥ ያሉበቱን ለማወቅ\n• ምን ያህል ደረጃዎች ቀሩ ለማወቅ\n• አዕምሮ ጫና ለመቀነስ\n• ግልጽ ቅርጸ ለማቅረብ\n\n'ደረጃ X ከ Y' ከዕይታ ሂደት ነጥቦች ጋር ያሳያሉ።";
"help_text_verbose_descriptions" = "ዝርዝር መግለጫዎች ሁሉም ባፕ ውስጥ ተጨማሪ ማብራሪያ ጽሑፍ ይሰጣሉ።\n\nይህ ለሚከተሉ ጠቃሚ ነው፦\n• ውስብስብ ባህሪያትን ለመረዳት\n• አፕ ሲጠቀሙ ለመማር\n• የአዕምሮ ድጋፍ\n• ስክሪን አንባቢ ተጠቃሚዎች\n\nሁሉም ባህሪያት ዐውድ እና መምሪያዎችን ይሰጣሉ።";
"help_text_confirm_actions" = "ድርጊቶች ያረጋግጡ ለአስፈላጊ ድርጊቶች ቅን ያስፈልጋሉ።\n\nይህ ለሚከተሉ ይረዳሉ፦\n• አጋጣሚ ሰርዛ ለመከላከል\n• ያልፈለጉ ለውጦች ለመከላከል\n• ቅድሚያ ቀሪ ለመከላከል\n• ውሂብ ጥፋት ለመከላከል\n\nማሳሰቢያ፦ አጥፊ ድርጊቶቹ ሁሌ ቅን ያስፈልጋሉ (AAA መስፈርት)።";
"help_text_manual_code_entry" = "በእጅ ኮድ ማስገቢያ QR ኮዶች ከመቃኘት ይልቅ ኮዶችን ለመጻፍ ያስፈቅዳሉ።\n\nይህ ጠቃሚ ነው ሲ፦\n• ካሜራ አይሰራም\n• QR ኮዱ ጎዷ ወይም ዐሳሳቢ ነው\n• ስክሪን አንባቢ ሲጠቀሙ\n• ከቃኘት ይልቅ ለመጻፍ ይመርጣሉ\n\n'ኮዱን በእጅ ያስገቡ' ይንኩ ስክሪን ላይ ያለው ኮድ ለመጻፍ።";
"help_text_voice_input" = "የድምፅ ግቤት ከቃኘት ወይም ከጻፈ ይልቅ ኮዶችን ለመናገር ያስፈቅዳሉ።\n\nይህ ለሚከተሉ ጠቃሚ ነው፦\n• ቅያሴ ችግር\n• ስክሪን አንባቢ ተጠቃሚዎች\n• ያለ እጅ ሥራ\n• ለድምፅ ምርጫ\n\nማይክሮፎን ቁልፉን ይንኩ ሲሚጠቁ ጮክ ብለው ይናገሩ።";
"help_text_qr_scanning" = "QR ኮድ ቅኝት ካሜራዎን ፈጣን ምላሽ ኮዶችን ለማንበብ ይጠቀማሉ።\n\nለመቃኘት፦\n1. ካሜራ ወደ QR ኮዱ ያዞሩ\n2. ኮዱን ፍሬሙ ውስጥ ያቀናብሩ\n3. ብቻዬን ይቃኛሉ ድረስ ይጠብቁ\n\nምክሮች፦\n• ጥሩ ብርሃን ያስፈልጋሉ\n• ስልኩን አቆዩ\n• QR ኮዱ ፍፁምና ያልተዘጋ ያዝዙ\n• ቅኝቱ ካልሰራ በእጅ ኮድ ማስገቢያ ይሞክሩ";
"help_text_age_verification" = "ዕድሜ ማረጋገጥ ትክክለኛ ዕድሜዎን ወይም የልደት ቀንዎን ሳይገልጹ የዕድሜ መስፈርቱን እንደሟሉ ያረጋግጣሉ።\n\nሥርዓቱ፦\n1. አረጋጋጭ ፈተና ያዘጋጃሉ\n2. QR ኮዱን ይቃኙ ወይም ኮዱን ይጻፉ\n3. አፕ ዜሮ-እውቀት ማረጋገጫ ይፈጥሩ\n4. አረጋጋጭ መስፈርቱን ያሟሉ መሆኑን ያረጋግጣሉ\n\nግላዊነት ተጠብቋል፦\n• የልደት ቀንዎ ፈጽሞ አይጋራም\n• አረጋጋጩ መስፈርቱን ያሟሉ መሆኑን ብቻ ያውቃሉ\n• ምንም ክትትል ወይም ውሂብ ሰብሰባ የለም";
"help_text_credentials" = "ዲጂታል ማረጋገጫ ሰነዶች ዕድሜዎን ደህንነቱ ተጠብቆ በቦታዎ መሳሪያ ላይ የሚቀመጡ ክሪፕቶግራፊያዊ ማረጋገጫዎ ናቸው።\n\nባህሪያት፦\n• በቦታዎ መሳሪያ ላይ ብቻ ይቀመጣሉ\n• ሊቀዱ ወይም ሊጭበርቡ አይቻልም\n• ሥውር ማረጋገጥ ለሚደርጉ ተጠቅሙ\n• ማንኛውም ጊዜ መሰረዝ ይቻሉ\n\nዕድሜ ማረጋገጥ ከማድረጉ በፊት ፈቃድ ካለው አሳዳሪ ማረጋገጫ ሰነድ ማግኘት አለብዎ።";
"help_text_zero_knowledge" = "ዜሮ-እውቀት ማረጋገጫዎች ስር ያለው መረጃ ሳይገልጹ ነገሩ ትክክል መሆኑን ለማረጋገጥ ይፈቅዳሉ።\n\nምሳሌ፦\n• ተለምዷዊ፦ መታወቂያ ያሳዩ (ትክክለኛ የልደት ቀን ያሳያሉ)\n• ዜሮ-እውቀት፦ ዕድሜዎ 18 ካለፈ ያረጋግጡ (የልደት ቀን ሳያሳዩ)\n\nጥቅሞች፦\n• ከፍተኛ ግላዊነት ጥበቃ\n• ምንም ግል ውሂብ አይጋራም\n• ክሪፕቶግራፊያዊ ደህንነት\n• ሊጭበርቡ ወይም ዳግም ሊጠቀሙ አይቻልም\n\nይህ Provii Wallet ሥውር ሁነት የሚያስቻለው ዋናው ቴክኖሎጂ ነው።";
"help_text_credential_issuance" = "ማረጋገጫ ሰነድ ማወጣጣ ዲጂታል ዕድሜ ማረጋገጫ ሰነድዎን ከፈቃድ ካለው አሳዳሪ የማግኘት ሂደት ነው።\n\nደረጃዎቹ፦\n1. ፈቃድ ያለው አሳዳሪ ይጎብኙ\n2. ሰንዳዊ መታወቂያ ሳያሳዩ ማንነትዎን ያረጋግጡ\n3. ከአሳዳሪ QR ኮድ ወይም ዲፕ ሊንክ ይቀበሉ\n4. QR ኮዱን ይቃኙ ወይም ሊንኩን ይጫኑ\n5. ማረጋገጫ ሰነዱ ቦታዎ ላይ ሂሳብ ሆኖ ይቀመጣሉ\n\nዓይነ ስውር ምስክር ወረቀት ሂደቱ የልደት ቀንዎ ኔትወርክ ላይ ፈጽሞ እንዳይተላለፍ ያረጋግጣሉ።\nይህን አንድ ጊዜ ማድረግ ብቻ ይበቃሉ። ማረጋገጫ ሰነድዎ ያለ ወሰን ማረጋገጫ ለሚደርጉ ሊያገለግሉ ይቻሉ።";
"help_text_officer_mode" = "የሹም ሁነታ ፈቃድ ያላቸው አሳዳሪዎች ለተጠቃሚዎች ማረጋገጫ ሰነዶችን ለማፍጠር ያስፈቅዳሉ።\n\nይህ ሁነታ ያስፈልጋቸዋል፦\n• ከ YubiKey ጋር የሹም ማረጋገጫ\n• ከሚያወጡ ባለሥልጣናት ፈቃድ\n• ተጠቃሚ የቦታ ላይ መታወቂያ ማረጋገጥ\n\nሂደቱ፦\n1. እንደ ሹም ያረጋግጡ\n2. ተጠቃሚ ሰንዳዊ መታወቂያ ያረጋግጡ\n3. ተጠቃሚ የልደት ቀን ያስገቡ\n4. ምስክር ወረቀት QR ኮድ ያፍጥሩ\n5. ተጠቃሚ ኮዱን ቃኝቶ ማረጋገጫ ሰነዱን ይቀበሉ\n\nፈቃድ ያለው ሠራተኞች ብቻ ይህን ሁነታ ሊጠቀሙ ይቻሉ።";

