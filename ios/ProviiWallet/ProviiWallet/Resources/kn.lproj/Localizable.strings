// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "ಅತಿ ದೊಡ್ಡ ಪಠ್ಯ ಅಪ್ಲಿಕೇಶನ್‌ನಲ್ಲಿ ಎಲ್ಲಾ ಪಠ್ಯವನ್ನು 50% ದೊಡ್ಡದಾಗಿಸುತ್ತದೆ.\n\nಇದು ಈ ಬಳಕೆದಾರರಿಗೆ ಸಹಾಯಕ:\n• ದೃಷ್ಟಿ ದೋಷ\n• ಓದುವ ತೊಂದರೆ\n• ವಯಸ್ಸಿಗೆ ಸಂಬಂಧಿಸಿದ ದೃಷ್ಟಿ ಬದಲಾವಣೆಗಳು\n• ಇನ್ನಷ್ಟು ದೊಡ್ಡ ಗಾತ್ರಗಳಿಗೆ iOS Dynamic Type ಜೊತೆ ಕೆಲಸ ಮಾಡುತ್ತದೆ.";
"help_text_contrast_level" = "ಕಾಂಟ್ರಾಸ್ಟ್ ಮಟ್ಟ ಪಠ್ಯ ಮತ್ತು ಹಿನ್ನೆಲೆಯ ನಡುವಿನ ಬಣ್ಣ ವ್ಯತ್ಯಾಸವನ್ನು ನಿಯಂತ್ರಿಸುತ್ತದೆ.\n\nಮೂರು ಹಂತಗಳು ಲಭ್ಯ:\n• ಪ್ರಮಾಣಿತ: ಡೀಫಾಲ್ಟ್ ಬಣ್ಣಗಳು\n• ಹೆಚ್ಚು (AA): 4.5:1 ಕಾಂಟ್ರಾಸ್ಟ್ ಅನುಪಾತ - AA ಮಾನದಂಡ ಪೂರೈಸುತ್ತದೆ\n• ಗರಿಷ್ಠ (AAA): 7:1 ಕಾಂಟ್ರಾಸ್ಟ್ ಅನುಪಾತ - ಅತ್ಯುನ್ನತ AAA ಮಾನದಂಡ ಪೂರೈಸುತ್ತದೆ\n\nಹೆಚ್ಚಿನ ಕಾಂಟ್ರಾಸ್ಟ್ ಎಲ್ಲಾ ಬೆಳಕಿನ ಪರಿಸ್ಥಿತಿಗಳಲ್ಲಿ ಪಠ್ಯ ಓದಲು ಸುಲಭಗೊಳಿಸುತ್ತದೆ.";
"help_text_high_contrast" = "ಹೈ ಕಾಂಟ್ರಾಸ್ಟ್ ಮೋಡ್ ಪಠ್ಯ ಮತ್ತು ಹಿನ್ನೆಲೆಯ ನಡುವಿನ ವ್ಯತ್ಯಾಸ ಹೆಚ್ಚಿಸಿ, ಓದಲು ಸುಲಭಗೊಳಿಸುತ್ತದೆ.\n\nಇದು ಈ ಬಳಕೆದಾರರಿಗೆ ಸಹಾಯಕ:\n• ದೃಷ್ಟಿ ದೋಷ\n• ಬಣ್ಣ ಸಂವೇದನಾಶೀಲತೆ\n• ಪ್ರಕಾಶಮಾನ ಪರದೆ ಪರಿಸರ\n\nಸಕ್ರಿಯಗೊಂಡಾಗ:\n• ಪಠ್ಯ ಬಿಳಿ ಮೇಲೆ ಕಪ್ಪಾಗುತ್ತದೆ\n• ಅಂಶಗಳಿಗೆ ಗಡಿಗಳನ್ನು ಸೇರಿಸಲಾಗುತ್ತದೆ\n• ಬಣ್ಣಗಳು ಸರಳಗೊಳಿಸಲ್ಪಡುತ್ತವೆ";
"help_text_reduce_transparency" = "ಪಾರದರ್ಶಕತೆ ಕಡಿಮೆ ಮಾಡಿ ಅಪ್ಲಿಕೇಶನ್‌ ಉದ್ದಕ್ಕೂ ಬ್ಲರ್ ಮತ್ತು ಪಾರದರ್ಶಕ ಪ್ರಭಾವಗಳನ್ನು ತೆಗೆದುಹಾಕುತ್ತದೆ.\n\nಇದು ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಪಠ್ಯ ಓದುವ ಸಾಮರ್ಥ್ಯ ಸುಧಾರಿಸಿ\n• ದೃಶ್ಯ ಸಂಕೀರ್ಣತೆ ಕಡಿಮೆ ಮಾಡಿ\n• ಹಳೆಯ ಸಾಧನಗಳಲ್ಲಿ ಕಾರ್ಯಕ್ಷಮತೆ ಹೆಚ್ಚಿಸಿ\n• ವಿಷಯವನ್ನು ಹೆಚ್ಚು ಊಹಿಸಬಹುದಾಗಿಸಿ";
"help_text_color_blind_mode" = "ವರ್ಣ ಕುರುಡು ಮೋಡ್‌ಗಳು ವಿವಿಧ ರೀತಿಯ ವರ್ಣ ದೃಷ್ಟಿ ದೋಷಗಳಿಗೆ ಬಣ್ಣಗಳನ್ನು ಹೊಂದಿಸುತ್ತವೆ.\n\nಲಭ್ಯ ಮೋಡ್‌ಗಳು:\n• Protanopia: ಕೆಂಪು ಕುರುಡು (ಕೆಂಪು ನೋಡಲು ತೊಂದರೆ)\n• Deuteranopia: ಹಸಿರು ಕುರುಡು (ಹಸಿರು ನೋಡಲು ತೊಂದರೆ)\n• Tritanopia: ನೀಲಿ ಕುರುಡು (ನೀಲಿ ನೋಡಲು ತೊಂದರೆ)\n• Monochrome: ಬೂದು ಮಾತ್ರ\n\nಈ ಮೋಡ್‌ಗಳು ಮಹತ್ವದ ಮಾಹಿತಿ ಬಣ್ಣದ ಮೂಲಕ ಮಾತ್ರ ತಿಳಿಸಲ್ಪಡುವುದಿಲ್ಲ ಎಂದು ಖಚಿತಪಡಿಸುತ್ತವೆ.";
"help_text_line_spacing" = "ಸಾಲಿನ ಅಂತರ ಪಠ್ಯದ ಸಾಲುಗಳ ನಡುವಿನ ಜಾಗವನ್ನು ನಿಯಂತ್ರಿಸುತ್ತದೆ.\n\n• ಶ್ರೇಣಿ: 1.0x ರಿಂದ 2.0x\n• AAA ಮಾನದಂಡ: ಕನಿಷ್ಠ 1.5x\n• ಡೀಫಾಲ್ಟ್: 1.0x\n\nಹೆಚ್ಚಿನ ಸಾಲಿನ ಅಂತರ ಪಠ್ಯ ಓದಲು ಸುಲಭಗೊಳಿಸಿ ಸಾಲು ಬಿಟ್ಟುಹೋಗುವುದನ್ನು ತಡೆಯುತ್ತದೆ.";
"help_text_paragraph_spacing" = "ಪ್ಯಾರಾಗ್ರಾಫ್ ಅಂತರ ಪ್ಯಾರಾಗ್ರಾಫ್‌ಗಳ ನಡುವಿನ ಜಾಗವನ್ನು ನಿಯಂತ್ರಿಸುತ್ತದೆ.\n\n• ಶ್ರೇಣಿ: 1.0x ರಿಂದ 3.0x\n• AAA ಮಾನದಂಡ: ಕನಿಷ್ಠ 2.0x\n• ಡೀಫಾಲ್ಟ್: 1.0x\n\nಹೆಚ್ಚಿನ ಪ್ಯಾರಾಗ್ರಾಫ್ ಅಂತರ ಪಠ್ಯದ ವಿವಿಧ ವಿಭಾಗಗಳ ನಡುವೆ ವ್ಯತ್ಯಾಸ ಗುರುತಿಸಲು ಸಹಾಯ ಮಾಡುತ್ತದೆ.";
"help_text_letter_spacing" = "ಅಕ್ಷರ ಅಂತರ ಪ್ರತ್ಯೇಕ ಅಕ್ಷರಗಳ ನಡುವಿನ ಜಾಗವನ್ನು ನಿಯಂತ್ರಿಸುತ್ತದೆ.\n\n• ಶ್ರೇಣಿ: 0.0em ರಿಂದ 0.2em\n• AAA ಮಾನದಂಡ: ಕನಿಷ್ಠ 0.12em\n• ಡೀಫಾಲ್ಟ್: 0.0em\n\nಹೆಚ್ಚಿನ ಅಕ್ಷರ ಅಂತರ ಅಕ್ಷರ ಗುರುತಿಸುವಿಕೆ ಮತ್ತು ಓದುವ ಸಾಮರ್ಥ್ಯ ಸುಧಾರಿಸುತ್ತದೆ.";
"help_text_text_width" = "ಪಠ್ಯ ಅಗಲ ಆರಾಮದಾಯಕ ಓದಿಗೆ ಗರಿಷ್ಠ ಸಾಲು ಉದ್ದವನ್ನು ನಿಯಂತ್ರಿಸುತ್ತದೆ.\n\nಆಯ್ಕೆಗಳು:\n• ಪೂರ್ಣ ಅಗಲ: ಯಾವುದೇ ಗರಿಷ್ಠ ಇಲ್ಲ\n• ಆರಾಮದಾಯಕ (80 ಅಕ್ಷರಗಳು): ಓದಿಗೆ ಸೂಕ್ತ\n• ಕಿರಿದು (60 ಅಕ್ಷರಗಳು): ಕೇಂದ್ರೀಕೃತ ಓದಿಗೆ\n\nAAA ಮಾರ್ಗಸೂಚಿಗಳು ಪ್ರತಿ ಸಾಲಿಗೆ ಗರಿಷ್ಠ 80 ಅಕ್ಷರಗಳನ್ನು ಶಿಫಾರಸು ಮಾಡುತ್ತವೆ.";
"help_text_large_touch_targets" = "ದೊಡ್ಡ ಟಚ್ ಟಾರ್ಗೆಟ್‌ಗಳು ಎಲ್ಲಾ ಬಟನ್‌ಗಳು ಮತ್ತು ಸಂವಾದಾತ್ಮಕ ಅಂಶಗಳನ್ನು ಕನಿಷ್ಠ 60pt ಗಾತ್ರದಲ್ಲಿ ಮಾಡುತ್ತದೆ.\n\nಇದು ಸಹಾಯಕ:\n• ಚಲನ ವೈಕಲ್ಯಗಳು\n• ನಡುಕ ಅಥವಾ ಕಂಪನ\n• ಕೈಗವಸುಗಳೊಂದಿಗೆ ಅಪ್ಲಿಕೇಶನ್ ಬಳಸುವಾಗ\n• ಒಂದೇ ಕೈ ಬಳಕೆ\n\nಪ್ರಮಾಣಿತ ಕನಿಷ್ಠ 44pt; ಈ ಸೆಟ್ಟಿಂಗ್ 60pt ಗೆ ಹೆಚ್ಚಿಸುತ್ತದೆ.";
"help_text_reduce_motion" = "ಚಲನ ಕಡಿಮೆ ಮಾಡಿ ಅಪ್ಲಿಕೇಶನ್‌ ಉದ್ದಕ್ಕೂ ಅನಿಮೇಷನ್‌ಗಳನ್ನು ಕಡಿಮೆ ಮಾಡಿ ಅಥವಾ ತೆಗೆದುಹಾಕುತ್ತದೆ.\n\nಇದು ಈ ಬಳಕೆದಾರರಿಗೆ ಸಹಾಯಕ:\n• ಚಲನ ಸಂವೇದನಾಶೀಲತೆ\n• ವೆಸ್ಟಿಬ್ಯುಲರ್ ಅಸ್ವಸ್ಥತೆಗಳು\n• ಅಪಸ್ಮಾರ\n• ಮೈಗ್ರೇನ್ ಪ್ರಚೋದಕಗಳು\n\nಸಕ್ರಿಯಗೊಂಡಾಗ, ಅನಿಮೇಷನ್‌ಗಳನ್ನು ತಕ್ಷಣ ಪರಿವರ್ತನೆಗಳಿಂದ ಬದಲಾಯಿಸಲಾಗುತ್ತದೆ.";
"help_text_timeout_behavior" = "ಟೈಮ್‌ಔಟ್ ನಡವಳಿಕೆ ಕಾರ್ಯಾಚರಣೆಗಳು ಟೈಮ್‌ಔಟ್ ಆಗುವ ಮೊದಲು ಎಷ್ಟು ಸಮಯ ತೆಗೆದುಕೊಳ್ಳಬಹುದು ಎಂಬುದನ್ನು ನಿಯಂತ್ರಿಸುತ್ತದೆ.\n\nಆಯ್ಕೆಗಳು:\n• ಟೈಮ್‌ಔಟ್ ಇಲ್ಲ (AAA): ಕಾರ್ಯಾಚರಣೆಗಳು ಎಂದಿಗೂ ಟೈಮ್‌ಔಟ್ ಆಗುವುದಿಲ್ಲ\n• ಪ್ರಮಾಣಿತ (30s): ಡೀಫಾಲ್ಟ್ ಟೈಮ್‌ಔಟ್\n• ವಿಸ್ತರಿತ (60s): ಪ್ರಮಾಣಿತ ಸಮಯದ ದ್ವಿಗುಣ\n\nಟೈಮ್‌ಔಟ್ ಇಲ್ಲ ಮೋಡ್ AAA ಪ್ರವೇಶಸಾಧ್ಯತೆ ಮಾನದಂಡಗಳನ್ನು ಪೂರೈಸುತ್ತದೆ.";
"help_text_simplified_gestures" = "ಸರಳ ಗೆಸ್ಚರ್‌ಗಳು ಸಂಕೀರ್ಣ ಮಲ್ಟಿ-ಟಚ್ ಗೆಸ್ಚರ್‌ಗಳನ್ನು ಸರಳ ಟ್ಯಾಪ್‌ಗಳಿಗೆ ಇಳಿಸುತ್ತವೆ.\n\nಇದು ಸಹಾಯಕ:\n• ಚಲನ ವೈಕಲ್ಯಗಳು\n• ಸೀಮಿತ ಚಾಕಚಕ್ಯತೆ\n• ಸಹಾಯಕ ಸಾಧನಗಳ ಬಳಕೆ\n• ಒಂದು ಕೈ ಕಾರ್ಯಾಚರಣೆ\n\nಸಂಕೀರ್ಣ ಗೆಸ್ಚರ್‌ಗಳನ್ನು ಬಟನ್‌ಗಳು ಮತ್ತು ಸರಳ ಟ್ಯಾಪ್‌ಗಳಿಂದ ಬದಲಾಯಿಸಲಾಗುತ್ತದೆ.";
"help_text_haptic_feedback" = "ಹ್ಯಾಪ್ಟಿಕ್ ಫೀಡ್‌ಬ್ಯಾಕ್ ಕ್ರಿಯೆಗಳು ಮತ್ತು ಅಧಿಸೂಚನೆಗಳಿಗೆ ಕಂಪನ ಪ್ರತಿಕ್ರಿಯೆ ನೀಡುತ್ತದೆ.\n\nಇದು ಸಹಾಯಕ:\n• ಬಟನ್ ಒತ್ತುವಿಕೆ ದೃಢಪಡಿಸಲು\n• ದೋಷಗಳು ಅಥವಾ ಎಚ್ಚರಿಕೆಗಳ ಬಗ್ಗೆ ಎಚ್ಚರಿಸಲು\n• ದೃಶ್ಯೇತರ ಪ್ರತಿಕ್ರಿಯೆ ಒದಗಿಸಲು\n• ಶ್ರವಣ ಅಥವಾ ದೃಷ್ಟಿ ದೋಷ ಇರುವ ಬಳಕೆದಾರರಿಗೆ\n\nಕಂಪನಗಳು ಅಸ್ವಸ್ಥತೆಯನ್ನು ಉಂಟುಮಾಡಿದರೆ ಇದನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಬಹುದು.";
"help_text_simplified_ui" = "ಸರಳ ಇಂಟರ್ಫೇಸ್ ಅಪ್ಲಿಕೇಶನ್‌ ಉದ್ದಕ್ಕೂ ದೃಶ್ಯ ಸಂಕೀರ್ಣತೆ ಕಡಿಮೆ ಮಾಡುತ್ತದೆ.\n\nಇದು ಸಹಾಯಕ:\n• ಅರಿವಿನ ಅಸಾಮರ್ಥ್ಯಗಳು\n• ಕಲಿಕಾ ತೊಂದರೆಗಳು\n• ಗಮನ ಅಸ್ವಸ್ಥತೆಗಳು\n• ಹೊಸ ಅಥವಾ ಅನನುಭವಿ ಬಳಕೆದಾರರು\n\nಸಕ್ರಿಯಗೊಂಡಾಗ:\n• ಪರದೆಯ ಮೇಲೆ ಕಡಿಮೆ ಅಂಶಗಳು\n• ದೊಡ್ಡ, ಸ್ಪಷ್ಟ ನಿಯಂತ್ರಣಗಳು\n• ಕಡಿಮೆ ದೃಶ್ಯ ಶಬ್ದ";
"help_text_step_indicators" = "ಹಂತ ಸೂಚಕಗಳು ಬಹು-ಹಂತ ಪ್ರಕ್ರಿಯೆಗಳ ಮೂಲಕ ನಿಮ್ಮ ಪ್ರಗತಿ ತೋರಿಸುತ್ತದೆ.\n\nಇದು ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಪ್ರಕ್ರಿಯೆಯಲ್ಲಿ ನೀವು ಎಲ್ಲಿ ಇದ್ದೀರಿ ಎಂಬುದು ತಿಳಿಯಲು\n• ಎಷ್ಟು ಹಂತಗಳು ಉಳಿದಿವೆ ಎಂದು ತಿಳಿಯಲು\n• ಅರಿವಿನ ಹೊರೆ ಕಡಿಮೆ ಮಾಡಲು\n• ಸ್ಪಷ್ಟ ರಚನೆ ಒದಗಿಸಲು\n\n\"ಹಂತ X ರಲ್ಲಿ Y\" ಎಂದು ದೃಶ್ಯ ಪ್ರಗತಿ ಚುಕ್ಕೆಗಳೊಂದಿಗೆ ತೋರಿಸುತ್ತದೆ.";
"help_text_verbose_descriptions" = "ವಿಸ್ತೃತ ವಿವರಣೆಗಳು ಅಪ್ಲಿಕೇಶನ್‌ ಉದ್ದಕ್ಕೂ ಹೆಚ್ಚುವರಿ ವಿವರಣಾತ್ಮಕ ಪಠ್ಯ ಒದಗಿಸುತ್ತದೆ.\n\nಇದು ಸಹಾಯಕ:\n• ಸಂಕೀರ್ಣ ವೈಶಿಷ್ಟ್ಯಗಳನ್ನು ಅರ್ಥಮಾಡಿಕೊಳ್ಳಲು\n• ಅಪ್ಲಿಕೇಶನ್ ಬಳಸುವುದನ್ನು ಕಲಿಯಲು\n• ಅರಿವಿನ ಬೆಂಬಲ\n• ಸ್ಕ್ರೀನ್ ರೀಡರ್ ಬಳಕೆದಾರರು\n\nಎಲ್ಲಾ ವೈಶಿಷ್ಟ್ಯಗಳಿಗೆ ಸಂದರ್ಭ ಮತ್ತು ಸೂಚನೆಗಳನ್ನು ಒದಗಿಸುತ್ತದೆ.";
"help_text_confirm_actions" = "ಕ್ರಿಯೆ ದೃಢೀಕರಿಸಿ ಮಹತ್ವದ ಕ್ರಿಯೆಗಳಿಗೆ ಮೊದಲು ದೃಢೀಕರಣ ಕೇಳುತ್ತದೆ.\n\nಇದು ತಡೆಯಲು ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಆಕಸ್ಮಿಕ ಅಳಿಸುವಿಕೆ\n• ಅಜಾಗ್ರತೆಯ ಬದಲಾವಣೆಗಳು\n• ಅಕಾಲಿಕ ಸಲ್ಲಿಕೆಗಳು\n• ಡೇಟಾ ನಷ್ಟ\n\nಗಮನಿಸಿ: ವಿನಾಶಕಾರಿ ಕ್ರಿಯೆಗಳು ಯಾವಾಗಲೂ ದೃಢೀಕರಣ ಅಗತ್ಯಪಡಿಸುತ್ತವೆ (AAA ಅಗತ್ಯ).";
"help_text_manual_code_entry" = "ಕೈಯಾರೆ ಕೋಡ್ ನಮೂದು QR ಕೋಡ್‌ಗಳನ್ನು ಸ್ಕ್ಯಾನ್ ಮಾಡುವ ಬದಲು ಕೋಡ್‌ಗಳನ್ನು ಟೈಪ್ ಮಾಡಲು ಅನುಮತಿಸುತ್ತದೆ.\n\nಇದು ಸಹಾಯಕ ಯಾವಾಗ:\n• ಕ್ಯಾಮೆರಾ ಕೆಲಸ ಮಾಡುತ್ತಿಲ್ಲ\n• QR ಕೋಡ್ ಹಾನಿಗೊಳಗಾಗಿದೆ ಅಥವಾ ಅಸ್ಪಷ್ಟ\n• ಸ್ಕ್ರೀನ್ ರೀಡರ್ ಬಳಸುವಾಗ\n• ಸ್ಕ್ಯಾನ್ ಮಾಡುವ ಬದಲು ಟೈಪ್ ಮಾಡಲು ಆದ್ಯತೆ\n\nಪರದೆಯ ಮೇಲೆ ತೋರಿಸಿದ ಕೋಡ್ ಟೈಪ್ ಮಾಡಲು \"ಕೋಡ್ ಕೈಯಾರೆ ನಮೂದಿಸಿ\" ಟ್ಯಾಪ್ ಮಾಡಿ.";
"help_text_voice_input" = "ಧ್ವನಿ ಇನ್‌ಪುಟ್ ಸ್ಕ್ಯಾನ್ ಮಾಡುವ ಅಥವಾ ಟೈಪ್ ಮಾಡುವ ಬದಲು ಕೋಡ್‌ಗಳನ್ನು ಮಾತನಾಡಲು ಅನುಮತಿಸುತ್ತದೆ.\n\nಇದು ಸಹಾಯಕ:\n• ಸೀಮಿತ ಚಲನಶೀಲತೆ\n• ಸ್ಕ್ರೀನ್ ರೀಡರ್ ಬಳಕೆದಾರರು\n• ಕೈ ಮುಕ್ತ ಕಾರ್ಯಾಚರಣೆ\n• ಧ್ವನಿಗೆ ಆದ್ಯತೆ\n\nಮೈಕ್ರೊಫೋನ್ ಬಟನ್ ಟ್ಯಾಪ್ ಮಾಡಿ ಮತ್ತು ಪ್ರಾಂಪ್ಟ್ ಆದಾಗ ಸ್ಪಷ್ಟವಾಗಿ ಮಾತನಾಡಿ.";
"help_text_qr_scanning" = "QR ಕೋಡ್ ಸ್ಕ್ಯಾನಿಂಗ್ ಕ್ವಿಕ್ ರೆಸ್ಪಾನ್ಸ್ ಕೋಡ್‌ಗಳನ್ನು ಓದಲು ನಿಮ್ಮ ಕ್ಯಾಮೆರಾ ಬಳಸುತ್ತದೆ.\n\nಸ್ಕ್ಯಾನ್ ಮಾಡುವ ವಿಧಾನ:\n1. QR ಕೋಡ್‌ನತ್ತ ಕ್ಯಾಮೆರಾ ತೋರಿಸಿ\n2. ಚೌಕಟ್ಟಿನಲ್ಲಿ ಕೋಡ್ ಜೋಡಿಸಿ\n3. ಸ್ವಯಂ ಗ್ರಹಿಕೆಗಾಗಿ ಕಾಯಿರಿ\n\nಸಲಹೆಗಳು:\n• ಉತ್ತಮ ಬೆಳಕು ಖಚಿತಪಡಿಸಿ\n• ಸಾಧನ ಸ್ಥಿರವಾಗಿ ಹಿಡಿಯಿರಿ\n• QR ಕೋಡ್ ಚಪ್ಪಟೆ ಮತ್ತು ಅಡಚಣೆ ಇಲ್ಲದಿರಲಿ\n• ಸ್ಕ್ಯಾನಿಂಗ್ ವಿಫಲವಾದರೆ, ಕೈಯಾರೆ ಕೋಡ್ ನಮೂದು ಪ್ರಯತ್ನಿಸಿ";
"help_text_age_verification" = "ವಯಸ್ಸು ಪರಿಶೀಲನೆ ನಿಮ್ಮ ನಿಜವಾದ ವಯಸ್ಸು ಅಥವಾ ಜನ್ಮ ದಿನಾಂಕ ಬಹಿರಂಗಪಡಿಸದೆ ನೀವು ವಯಸ್ಸಿನ ಅವಶ್ಯಕತೆ ಪೂರೈಸುತ್ತೀರಿ ಎಂದು ಸಾಬೀತುಪಡಿಸುತ್ತದೆ.\n\nಹೇಗೆ ಕಾರ್ಯನಿರ್ವಹಿಸುತ್ತದೆ:\n1. ಪರಿಶೀಲಕರು ಸವಾಲು ರಚಿಸುತ್ತಾರೆ\n2. ನೀವು QR ಕೋಡ್ ಸ್ಕ್ಯಾನ್ ಮಾಡಿ ಅಥವಾ ಕೈಯಾರೆ ನಮೂದಿಸಿ\n3. ಅಪ್ಲಿಕೇಶನ್ ಶೂನ್ಯ-ಜ್ಞಾನ ಪುರಾವೆ ರಚಿಸುತ್ತದೆ\n4. ಪರಿಶೀಲಕರು ನೀವು ಅವಶ್ಯಕತೆ ಪೂರೈಸುತ್ತೀರಿ ಎಂದು ದೃಢಪಡಿಸುತ್ತಾರೆ\n\nಗೋಪ್ಯತೆ ರಕ್ಷಿಸಲ್ಪಟ್ಟಿದೆ:\n• ನಿಮ್ಮ ಜನ್ಮ ದಿನಾಂಕ ಎಂದಿಗೂ ಹಂಚಿಕೊಳ್ಳಲ್ಪಡುವುದಿಲ್ಲ\n• ಪರಿಶೀಲಕರು ನೀವು ಅವಶ್ಯಕತೆ ಪೂರೈಸುತ್ತೀರೇ ಎಂಬುದನ್ನು ಮಾತ್ರ ತಿಳಿಯುತ್ತಾರೆ\n• ಟ್ರ್ಯಾಕಿಂಗ್ ಅಥವಾ ಡೇಟಾ ಸಂಗ್ರಹ ಇಲ್ಲ";
"help_text_credentials" = "ಡಿಜಿಟಲ್ ಪ್ರಮಾಣಪತ್ರಗಳು ನಿಮ್ಮ ಸಾಧನದಲ್ಲಿ ಸುರಕ್ಷಿತವಾಗಿ ಸಂಗ್ರಹಿಸಲಾದ ನಿಮ್ಮ ವಯಸ್ಸಿನ ಕ್ರಿಪ್ಟೋಗ್ರಾಫಿಕ್ ಪ್ರಮಾಣಗಳಾಗಿವೆ.\n\nವೈಶಿಷ್ಟ್ಯಗಳು:\n• ಕೇವಲ ನಿಮ್ಮ ಸಾಧನದಲ್ಲಿ ಸಂಗ್ರಹಿಸಲಾಗಿದೆ\n• ನಕಲಿಸಲು ಅಥವಾ ನಕಲಿ ಮಾಡಲು ಸಾಧ್ಯವಿಲ್ಲ\n• ಗೋಪ್ಯತೆ-ಸಂರಕ್ಷಿಸುವ ಪರಿಶೀಲನೆಗಾಗಿ ಬಳಸಲಾಗುತ್ತದೆ\n• ಯಾವುದೇ ಸಮಯದಲ್ಲಿ ಅಳಿಸಬಹುದು\n\nನೀವು ವಯಸ್ಸನ್ನು ಪರಿಶೀಲಿಸುವ ಮೊದಲು ಅಧಿಕೃತ ನಿರ್ಗಮಕ (ಸರ್ಕಾರಿ ಕಚೇರಿಯಂತಹ) ನಿಂದ ಪ್ರಮಾಣಪತ್ರ ಪಡೆಯಬೇಕು.";
"help_text_zero_knowledge" = "ಶೂನ್ಯ-ಜ್ಞಾನ ಪುರಾವೆಗಳು ಆಧಾರ ಮಾಹಿತಿ ಬಹಿರಂಗಪಡಿಸದೆ ಏನಾದರೂ ನಿಜ ಎಂದು ಸಾಬೀತುಪಡಿಸಲು ಅನುಮತಿಸುತ್ತದೆ.\n\nಉದಾಹರಣೆ:\n• ಸಾಂಪ್ರದಾಯಿಕ: ID ತೋರಿಸಿ (ನಿಖರ ಹುಟ್ಟಿದ ದಿನ ಬಹಿರಂಗ)\n• ಶೂನ್ಯ-ಜ್ಞಾನ: ಹುಟ್ಟಿದ ದಿನ ತೋರಿಸದೆ 18 ವರ್ಷಕ್ಕಿಂತ ಮೇಲಿದ್ದೀರಿ ಎಂದು ಸಾಬೀತುಪಡಿಸಿ\n\nಪ್ರಯೋಜನಗಳು:\n• ಗರಿಷ್ಠ ಗೋಪ್ಯತೆ ರಕ್ಷಣೆ\n• ಯಾವುದೇ ವೈಯಕ್ತಿಕ ಡೇಟಾ ಹಂಚಿಕೊಳ್ಳಲ್ಪಡುವುದಿಲ್ಲ\n• ಕ್ರಿಪ್ಟೋಗ್ರಾಫಿಕ್ ಸುರಕ್ಷಿತ\n• ನಕಲಿ ಅಥವಾ ಮರುಪ್ಲೇ ಮಾಡಲು ಸಾಧ್ಯವಿಲ್ಲ\n\nಇದು Provii Wallet ಖಾಸಗಿಯಾಗಿ ಮಾಡುವ ಮೂಲ ತಂತ್ರಜ್ಞಾನ.";
"help_text_credential_issuance" = "ಪ್ರಮಾಣಪತ್ರ ನಿರ್ಗಮನ ಅಧಿಕೃತ ನಿರ್ಗಮಕರಿಂದ ನಿಮ್ಮ ಡಿಜಿಟಲ್ ವಯಸ್ಸಿನ ಪ್ರಮಾಣಪತ್ರ ಪಡೆಯುವ ಪ್ರಕ್ರಿಯೆ.\n\nಹಂತಗಳು:\n1. ಅಧಿಕೃತ ನಿರ್ಗಮಕರ ಬಳಿ ಭೇಟಿ ಮಾಡಿ (ಉದಾ., ಸರ್ಕಾರಿ ಕಚೇರಿ)\n2. ಅಧಿಕೃತ ID ಮೂಲಕ ನಿಮ್ಮ ಗುರುತು ಸಾಬೀತುಪಡಿಸಿ\n3. ನಿರ್ಗಮಕರಿಂದ QR ಕೋಡ್ ಅಥವಾ ಡೀಪ್ ಲಿಂಕ್ ಸ್ವೀಕರಿಸಿ\n4. QR ಕೋಡ್ ಸ್ಕ್ಯಾನ್ ಮಾಡಿ ಅಥವಾ ಲಿಂಕ್ ಟ್ಯಾಪ್ ಮಾಡಿ\n5. ಪ್ರಮಾಣಪತ್ರ ಸ್ಥಳೀಯವಾಗಿ ಲೆಕ್ಕಹಾಕಲ್ಪಟ್ಟು ನಿಮ್ಮ ಸಾಧನದಲ್ಲಿ ಸಂಗ್ರಹಿಸಲ್ಪಡುತ್ತದೆ\n\nಅಂಧ ಸಾಕ್ಷ್ಯ ಪ್ರಕ್ರಿಯೆ ನಿಮ್ಮ ಜನ್ಮ ದಿನಾಂಕ ನೆಟ್‌ವರ್ಕ್ ಮೂಲಕ ಎಂದಿಗೂ ರವಾನೆಯಾಗುವುದಿಲ್ಲ ಎಂದು ಖಚಿತಪಡಿಸುತ್ತದೆ.\nನೀವು ಇದನ್ನು ಒಮ್ಮೆ ಮಾಡಬೇಕು. ನಿಮ್ಮ ಪ್ರಮಾಣಪತ್ರ ನಂತರ ಅಪರಿಮಿತ ಪರಿಶೀಲನೆಗಳಿಗೆ ಬಳಸಬಹುದು.";
"help_text_officer_mode" = "ಅಧಿಕಾರಿ ಮೋಡ್ ಅಧಿಕೃತ ನಿರ್ಗಮಕರು ಬಳಕೆದಾರರಿಗೆ ಪ್ರಮಾಣಪತ್ರ ರಚಿಸಲು ಉದ್ದೇಶಿಸಿದೆ.\n\nಈ ಮೋಡ್‌ಗೆ ಅಗತ್ಯ:\n• YubiKey ಮೂಲಕ ಅಧಿಕಾರಿ ದೃಢೀಕರಣ\n• ನಿರ್ಗಮನ ಪ್ರಾಧಿಕಾರದಿಂದ ಅಧಿಕಾರ\n• ಬಳಕೆದಾರರ ID ಭೌತಿಕ ಪರಿಶೀಲನೆ\n\nಪ್ರಕ್ರಿಯೆ:\n1. ಅಧಿಕಾರಿಯಾಗಿ ದೃಢೀಕರಿಸಿ\n2. ಬಳಕೆದಾರರ ಅಧಿಕೃತ ID ಪರಿಶೀಲಿಸಿ\n3. ಬಳಕೆದಾರರ ಜನ್ಮ ದಿನಾಂಕ ನಮೂದಿಸಿ\n4. ಸಾಕ್ಷ್ಯ QR ಕೋಡ್ ರಚಿಸಿ\n5. ಬಳಕೆದಾರರು ಕೋಡ್ ಸ್ಕ್ಯಾನ್ ಮಾಡಿ ಪ್ರಮಾಣಪತ್ರ ಸ್ವೀಕರಿಸುತ್ತಾರೆ\n\nಅಧಿಕೃತ ಸಿಬ್ಬಂದಿ ಮಾತ್ರ ಈ ಮೋಡ್ ಬಳಸಬೇಕು.";

