/* InfoPlist.strings - Turkish */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet, kimlik belgesi alımı ve yaş doğrulaması için QR kodlarını taramak amacıyla kamera erişimine ihtiyaç duyar.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet, güvenli yetkili kimlik doğrulaması için YubiKey cihazınızla iletişim kurmak amacıyla NFC kullanır.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet, erişilebilirlik modunda uygulamayı eller serbest kontrol etmenizi sağlamak için sesli komutlarda konuşma tanıma kullanır.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet, erişilebilirlik modu etkinleştirildiğinde sesli kontrol özellikleri için mikrofon erişimine ihtiyaç duyar.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet, yaş kimlik belgelerinize güvenli şekilde erişmek ve kimliğinizi doğrulamak için Face ID kullanır.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet, yakındaki kimlik belgesi veren kuruluşları bulmak için yerel ağı kullanabilir.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet, YubiKey cihazlarıyla iletişim kurmak için Bluetooth kullanabilir.";
