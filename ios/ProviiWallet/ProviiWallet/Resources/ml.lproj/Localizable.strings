"percent" = "ശതമാനം";
"help_text_extra_large_text" = "അതിവലിയ ടെക്സ്റ്റ് ആപ്പിലെ എല്ലാ ടെക്സ്റ്റും 50% വർദ്ധിപ്പിക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് ഉപകരിക്കുന്നു:\n• ദൃഷ്ടി കുറഞ്ഞവർ\n• വായനാ ബുദ്ധിമുട്ടുകൾ\n• പ്രായ-ബന്ധിത ദൃഷ്ടി മാറ്റങ്ങൾ\n\nകൂടുതൽ വലിയ വലിപ്പങ്ങൾക്ക് iOS Dynamic Type-ൽ പ്രവർത്തിക്കുന്നു.";
"help_text_contrast_level" = "കോൺട്രാസ്റ്റ് ലെവൽ ടെക്സ്റ്റും പശ്ചാത്തലങ്ങളും തമ്മിലുള്ള നിറ കോൺട്രാസ്റ്റ് നിയന്ത്രിക്കുന്നു.\n\nമൂന്ന് ലെവൽ ലഭ്യം:\n• സ്റ്റാൻഡേർഡ്: ഡിഫോൾട്ട് നിറങ്ങൾ\n• ഉയർന്ന (AA): 4.5:1 കോൺട്രാസ്റ്റ് അനുപാതം\n• പരമാവധി (AAA): 7:1 കോൺട്രാസ്റ്റ് അനുപാതം\n\nഉയർന്ന കോൺട്രാസ്റ്റ് ടെക്സ്റ്റ് എല്ലാ വെളിച്ചത്തിലും വായിക്കാൻ എളുപ്പമാക്കുന്നു.";
"help_text_high_contrast" = "ഉയർന്ന കോൺട്രാസ്റ്റ് മോഡ് ടെക്സ്റ്റിനും പശ്ചാത്തലത്തിനും ഇടയിലുള്ള കോൺട്രാസ്റ്റ് വർദ്ധിപ്പിക്കുന്നു, വായിക്കാൻ എളുപ്പമാക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് ഉപകരിക്കുന്നു:\n• ദൃഷ്ടി കുറഞ്ഞവർ\n• നിറ സംവേദനക്ഷമത\n• തിളക്കമുള്ള സ്ക്രീൻ പരിതസ്ഥിതികൾ\n• തിളക്കമുള്ള സ്ക്രീൻ ഉപയോഗം\n\nപ്രവർത്തനക്ഷമമാക്കുമ്പോൾ:\n• ടെക്സ്റ്റ് വെള്ളത്തിൽ കറുത്തതാകുന്നു\n• ഘടകങ്ങൾക്ക് അതിർത്തി ചേർക്കുന്നു\n• നിറങ്ങൾ ലളിതമാക്കുന്നു";
"help_text_reduce_transparency" = "സുതാര്യത കുറയ്ക്കൽ ആപ്പ് മൊത്തത്തിൽ ബ്ലർ, സുതാര്യ ഇഫക്ടുകൾ നീക്കം ചെയ്യുന്നു.\n\nഇത് സഹായിക്കുന്നു:\n• ടെക്സ്റ്റ് വായനാക്ഷമത മെച്ചപ്പെടുത്തുന്നു\n• ദൃശ്യ സങ്കീർണ്ണത കുറയ്ക്കുന്നു\n• പഴയ ഉപകരണങ്ങളിൽ പ്രകടനം വർദ്ധിപ്പിക്കുന്നു\n• ഉള്ളടക്കം കൂടുതൽ പ്രവചനീയമാക്കുന്നു";
"help_text_color_blind_mode" = "കളർ ബ്ലൈൻഡ് മോഡുകൾ വ്യത്യസ്ത തരം നിറ ദർശന കുറവുകൾക്ക് നിറങ്ങൾ ക്രമീകരിക്കുന്നു.\n\nലഭ്യമായ മോഡുകൾ:\n• പ്രൊട്ടനോപ്പിയ: ചുവപ്പ് അന്ധത (ചുവപ്പ് കാണുന്നതിൽ ബുദ്ധിമുട്ട്)\n• ഡ്യൂട്ടെറനോപ്പിയ: പച്ച അന്ധത (പച്ച കാണുന്നതിൽ ബുദ്ധിമുട്ട്)\n• ട്രൈറ്റനോപ്പിയ: നീല അന്ധത (നീല കാണുന്നതിൽ ബുദ്ധിമുട്ട്)\n• മോണോക്രോം: ഗ്രേസ്കെയ്ൽ മാത്രം\n\nഈ മോഡുകൾ നിറം മാത്രം ഉപയോഗിച്ച് പ്രധാന വിവരങ്ങൾ കൈമാറില്ലെന്ന് ഉറപ്പ് നൽകുന്നു.";
"help_text_line_spacing" = "വരി ഇടം ടെക്സ്റ്റ് വരികൾ തമ്മിലുള്ള ഇടം നിയന്ത്രിക്കുന്നു.\n\n• ശ്രേണി: 1.0x മുതൽ 2.0x\n• AAA സ്റ്റാൻഡേർഡ്: 1.5x ഏറ്റവും കുറഞ്ഞത്\n• ഡിഫോൾട്ട്: 1.0x";
"help_text_paragraph_spacing" = "ഖണ്ഡിക ഇടം ഖണ്ഡികകൾ തമ്മിലുള്ള ഇടം നിയന്ത്രിക്കുന്നു.\n\n• ശ്രേണി: 1.0x മുതൽ 3.0x\n• AAA സ്റ്റാൻഡേർഡ്: 2.0x ഏറ്റവും കുറഞ്ഞത്\n• ഡിഫോൾട്ട്: 1.0x";
"help_text_letter_spacing" = "അക്ഷര ഇടം അക്ഷരങ്ങൾ തമ്മിലുള്ള ഇടം നിയന്ത്രിക്കുന്നു.\n\n• ശ്രേണി: 0.0em മുതൽ 0.2em\n• AAA സ്റ്റാൻഡേർഡ്: 0.12em ഏറ്റവും കുറഞ്ഞത്\n• ഡിഫോൾട്ട്: 0.0em";
"help_text_text_width" = "ടെക്സ്റ്റ് വീതി സൗകര്യകരമായ വായനയ്ക്ക് പരമാവധി വരി ദൈർഘ്യം നിയന്ത്രിക്കുന്നു.\n\nഓപ്ഷനുകൾ:\n• പൂർണ്ണ വീതി: പരമാവധി ഇല്ല\n• സൗകര്യകരം (80 അക്ഷരങ്ങൾ): വായനയ്ക്ക് അനുയോജ്യം\n• ഇടുങ്ങിയ (60 അക്ഷരങ്ങൾ): ഏകാഗ്രതയോടെ വായിക്കാൻ\n\nAAA മാർഗ്ഗനിർദ്ദേശങ്ങൾ ഒരു വരിക്ക് പരമാവധി 80 അക്ഷരങ്ങൾ ശുപാർശ ചെയ്യുന്നു.";
"help_text_large_touch_targets" = "വലിയ ടച്ച് ടാർഗറ്റുകൾ എല്ലാ ബട്ടണുകളും ഇന്ററാക്ടീവ് ഘടകങ്ങളും കുറഞ്ഞത് 60pt വലിപ്പം ഉറപ്പാക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് ഉപകരിക്കുന്നു:\n• ചലന വൈകല്യങ്ങൾ\n• കൈ വിറയ്ക്കൽ\n• കൈയുറ ധരിച്ച് ആപ്പ് ഉപയോഗിക്കൽ\n• ഒറ്റ കൈ ഉപയോഗം\n\nസ്റ്റാൻഡേർഡ് ഏറ്റവും കുറഞ്ഞ 44pt; ഈ ക്രമീകരണം 60pt ആയി വർദ്ധിക്കുന്നു.";
"help_text_reduce_motion" = "ചലനം കുറയ്ക്കൽ ആപ്പ് മൊത്തത്തിൽ ആനിമേഷനുകൾ ലഘൂകരിക്കുകയോ നീക്കം ചെയ്യുകയോ ചെയ്യുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് ഉപകരിക്കുന്നു:\n• ചലന സംവേദനക്ഷമത\n• വെസ്റ്റിബ്യൂലർ തകരാറുകൾ\n• അപസ്മാരം\n• മൈഗ്രേൻ ഉദ്ദീപകങ്ങൾ\n\nപ്രവർത്തനക്ഷമമാക്കുമ്പോൾ ആനിമേഷനുകൾ ഉടനടി ട്രാൻസിഷനുകൾ ഉപയോഗിച്ച് മാറ്റിസ്ഥാപിക്കുന്നു.";
"help_text_timeout_behavior" = "ടൈംഔട്ട് സ്വഭാവം ഓപ്പറേഷനുകൾ ടൈംഔട്ടാകുന്നതിന് മുമ്പ് എത്ര ദൈർഘ്യം ഉണ്ടാകാം എന്ന് നിയന്ത്രിക്കുന്നു.\n\nഓപ്ഷനുകൾ:\n• ടൈംഔട്ട് ഇല്ല (AAA): ഓപ്പറേഷനുകൾ ഒരിക്കലും ടൈംഔട്ടാകില്ല\n• സ്റ്റാൻഡേർഡ് (30s): ഡിഫോൾട്ട് ടൈംഔട്ട്\n• വിപുലീകൃതം (60s): സ്റ്റാൻഡേർഡ് സമയത്തിന്റെ ഇരട്ടി\n\nടൈംഔട്ട് ഇല്ലാ മോഡ് AAA ആക്സസിബിലിറ്റി സ്റ്റാൻഡേർഡുകൾ പൂർത്തിയാക്കുന്നു.";
"help_text_simplified_gestures" = "ലളിതമായ ജെസ്ചറുകൾ സങ്കീർണ്ണ മൾട്ടി-ടച്ച് ജെസ്ചറുകൾ ലളിതമായ ബദലുകൾ ഉപയോഗിച്ച് മാറ്റിസ്ഥാപിക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് ഉപകരിക്കുന്നു:\n• ചലന വൈകല്യങ്ങൾ\n• പരിമിതമായ ചലിക്കാനുള്ള ശേഷി\n• സഹായ ഉപകരണങ്ങൾ ഉപയോഗിക്കൽ\n• ഒറ്റ കൈ ഓപ്പറേഷൻ\n\nസങ്കീർണ്ണ ജെസ്ചറുകൾ ബട്ടണുകളും ലളിതമായ ടാപ്പുകളും ഉപയോഗിച്ച് മാറ്റിസ്ഥാപിക്കുന്നു.";
"help_text_haptic_feedback" = "ഹാപ്റ്റിക് ഫീഡ്ബാക്ക് ക്രിയകൾക്കും അറിയിപ്പുകൾക്കും വൈബ്രേഷൻ ഫീഡ്ബാക്ക് നൽകുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് ഉപകരിക്കുന്നു:\n• ബട്ടൺ അമർത്തൽ സ്ഥിരീകരിക്കാൻ\n• പിശകുകളോ മുന്നറിയിപ്പുകളോ അറിയിക്കാൻ\n• ദൃശ്യേതര ഫീഡ്ബാക്ക് നൽകാൻ\n• കേൾവി അല്ലെങ്കിൽ ദൃഷ്ടി വൈകല്യമുള്ള ഉപയോക്താക്കൾക്ക്\n\nവൈബ്രേഷൻ അസ്വസ്ഥകരമാണെങ്കിൽ ഇത് പ്രവർത്തനരഹിതമാക്കാം.";
"help_text_simplified_ui" = "ലളിതമായ ഇൻറർഫേസ് ആപ്പ് മൊത്തത്തിൽ ദൃശ്യ സങ്കീർണ്ണത കുറയ്ക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് ഉപകരിക്കുന്നു:\n• ബൌദ്ധിക വൈകല്യങ്ങൾ\n• പഠനബുദ്ധിമുട്ടുകൾ\n• ശ്രദ്ധ തകരാറുകൾ\n• പുതിയ അല്ലെങ്കിൽ അനുഭവ കുറഞ്ഞ ഉപയോക്താക്കൾ\n\nപ്രവർത്തനക്ഷമമാക്കുമ്പോൾ:\n• സ്ക്രീനിൽ കുറഞ്ഞ ഘടകങ്ങൾ\n• വലുതും വ്യക്തവുമായ നിയന്ത്രണങ്ങൾ\n• കുറഞ്ഞ ദൃശ്യ ശബ്ദം";
"help_text_step_indicators" = "ഘട്ട ഇൻഡിക്കേറ്ററുകൾ മൾട്ടി-ഘട്ട പ്രക്രിയകളിലൂടെ നിങ്ങളുടെ പ്രോഗ്രസ് കാണിക്കുന്നു.\n\nഇത് സഹായിക്കുന്നു:\n• ഒരു പ്രക്രിയയിൽ നിങ്ങൾ എവിടെ ആണെന്ന് മനസ്സിലാക്കാൻ\n• എത്ര ഘട്ടങ്ങൾ ബാക്കിയുണ്ടെന്ന് അറിയാൻ\n• ബൌദ്ധിക ഭാരം കുറയ്ക്കാൻ\n• വ്യക്തമായ ഘടന നൽകാൻ\n\nദൃശ്യ പ്രോഗ്രസ് ഡോട്ടുകളോടൊപ്പം 'ഘട്ടം X of Y' കാണിക്കുന്നു.";
"help_text_verbose_descriptions" = "വിശദ വിവരണങ്ങൾ ആപ്പ് മൊത്തത്തിൽ അധിക വിശദീകരണ ടെക്സ്റ്റ് നൽകുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് ഉപകരിക്കുന്നു:\n• സങ്കീർണ്ണ ഫീച്ചറുകൾ മനസ്സിലാക്കാൻ\n• ആപ്പ് ഉപയോഗിക്കാൻ പഠിക്കാൻ\n• ബൌദ്ധിക പിന്തുണ\n• സ്ക്രീൻ റീഡർ ഉപയോക്താക്കൾ\n\nഎല്ലാ ഫീച്ചറുകൾക്കും സന്ദർഭവും നിർദ്ദേശങ്ങളും നൽകുന്നു.";
"help_text_confirm_actions" = "ക്രിയകൾ ഉറപ്പിക്കൽ പ്രധാനപ്പെട്ട ക്രിയകൾക്ക് മുമ്പ് സ്ഥിരീകരണം ആവശ്യമായ ആഗ്രഹം.\n\nഇത് തടയാൻ സഹായിക്കുന്നു:\n• അബദ്ധ ഇല്ലാതാക്കലുകൾ\n• ഉദ്ദേശിക്കാത്ത മാറ്റങ്ങൾ\n• നേരത്തെ സമർപ്പിക്കൽ\n• ഡേറ്റ നഷ്ടം\n\nശ്രദ്ധ: നശിപ്പിക്കുന്ന ക്രിയകൾ എല്ലായ്‌പ്പോഴും സ്ഥിരീകരണം ആവശ്യമാണ് (AAA ആവശ്യകത).";
"help_text_manual_code_entry" = "മാനുവൽ കോഡ് ഇൻപുട്ട് QR കോഡ് സ്കാൻ ചെയ്യുന്നതിന് പകരം കോഡുകൾ ടൈപ്പ് ചെയ്യാൻ അനുവദിക്കുന്നു.\n\nഇനിപ്പറയുന്ന സന്ദർഭങ്ങളിൽ ഉപകരിക്കുന്നു:\n• ക്യാമറ പ്രവർത്തിക്കുന്നില്ല\n• QR കോഡ് കേടായതോ അവ്യക്തമായതോ ആണ്\n• സ്ക്രീൻ റീഡർ ഉപയോഗിക്കൽ\n• സ്കാൻ ചെയ്യുന്നതിനേക്കാൾ ടൈപ്പ് ചെയ്യൽ ഇഷ്ടപ്പെടുക\n\nസ്ക്രീനിൽ കാണിക്കുന്ന കോഡ് ടൈപ്പ് ചെയ്യാൻ 'കോഡ് മാനുവലായി നൽകുക' ടാപ്പ് ചെയ്യുക.";
"help_text_voice_input" = "വോയ്സ് ഇൻപുട്ട് സ്കാൻ ചെയ്യുന്നതിനോ ടൈപ്പ് ചെയ്യുന്നതിനോ പകരം കോഡുകൾ പറയാൻ അനുവദിക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് ഉപകരിക്കുന്നു:\n• പരിമിതമായ ചലനശേഷി\n• സ്ക്രീൻ റീഡർ ഉപയോക്താക്കൾ\n• ഹാൻഡ്‌സ്-ഫ്രീ ഓപ്പറേഷൻ\n• വോയ്സ് ഇഷ്ടപ്പെടുക\n\nമൈക്രോഫോൺ ബട്ടൺ ടാപ്പ് ചെയ്‌ത് ആവശ്യപ്പെടുമ്പോൾ വ്യക്തമായി സംസാരിക്കുക.";
"help_text_qr_scanning" = "QR കോഡ് സ്കാനിംഗ് ക്വിക്ക് റെസ്‌പോൺസ് കോഡ് വായിക്കാൻ ക്യാമറ ഉപയോഗിക്കുന്നു.\n\nസ്കാൻ ചെയ്യാൻ:\n1. ക്യാമറ QR കോഡിലേക്ക് ചൂണ്ടുക\n2. ഫ്രേമിൽ കോഡ് വിന്യസിക്കുക\n3. സ്വയം തിരിച്ചറിയുന്നതിനായി കാത്തിരിക്കുക\n\nനുറുങ്ങുകൾ:\n• നല്ല വെളിച്ചം ഉറപ്പ് വരുത്തുക\n• ഉപകരണം സ്ഥിരമായി പിടിക്കുക\n• QR കോഡ് പരന്നതും തടസ്സമില്ലാത്തതുമാക്കുക\n• സ്കാൻ പരാജയപ്പെട്ടാൽ മാനുവൽ കോഡ് ഇൻപുട്ട് ശ്രമിക്കുക";
"help_text_age_verification" = "പ്രായ സ്ഥിരീകരണം നിങ്ങളുടെ യഥാർത്ഥ പ്രായം അല്ലെങ്കിൽ ജനനതീയതി വെളിപ്പെടുത്താതെ ഒരു പ്രായ ആവശ്യകത നിറവേറ്റുന്നുണ്ടെന്ന് തെളിയിക്കുന്നു.\n\nഇത് എങ്ങനെ പ്രവർത്തിക്കുന്നു:\n1. സ്ഥിരീകരണക്കാരൻ ഒരു ചലഞ്ച് സൃഷ്ടിക്കുന്നു\n2. നിങ്ങൾ QR കോഡ് സ്കാൻ ചെയ്യുകയോ മാനുവലായി നൽകുകയോ ചെയ്യുന്നു\n3. ആപ്പ് ഒരു ജ്ഞാനരഹിത തെളിവ് സൃഷ്ടിക്കുന്നു\n4. സ്ഥിരീകരണക്കാരൻ നിങ്ങൾ ആവശ്യകത നിറവേറ്റുന്നുണ്ടെന്ന് സ്ഥിരീകരിക്കുന്നു\n\nസ്വകാര്യത സംരക്ഷണം:\n• നിങ്ങളുടെ ജനനതീയതി ഒരിക്കലും പങ്കിടില്ല\n• നിങ്ങൾ ആവശ്യകത നിറവേറ്റുന്നുണ്ടോ എന്ന് മാത്രം സ്ഥിരീകരണക്കാരൻ അറിയുന്നു\n• ട്രാക്കിംഗോ ഡേറ്റ ശേഖരണമോ ഇല്ല";
"help_text_credentials" = "ഡിജിറ്റൽ യോഗ്യതാപത്രങ്ങൾ നിങ്ങളുടെ ഉപകരണത്തിൽ സുരക്ഷിതമായി സംഭരിക്കുന്ന നിങ്ങളുടെ പ്രായത്തിന്റെ ക്രിപ്‌റ്റോഗ്രഫിക് തെളിവുകളാണ്.\n\nഫീച്ചറുകൾ:\n• നിങ്ങളുടെ ഉപകരണത്തിൽ മാത്രം സംഭരിക്കുന്നു\n• പകർത്താനോ കൃത്രിമം കാണിക്കാനോ കഴിയില്ല\n• സ്വകാര്യത-സംരക്ഷക സ്ഥിരീകരണത്തിനായി ഉപയോഗിക്കുന്നു\n• ഏത് സമയത്തും ഇല്ലാതാക്കാം\n\nപ്രായം സ്ഥിരീകരിക്കുന്നതിന് മുമ്പ് ഒരു അധികൃത ഇഷ്യൂവറിൽ നിന്ന് (സർക്കാർ ഓഫീസ് പോലെ) ഒരു യോഗ്യതാപത്രം നേടേണ്ടതുണ്ട്.";
"help_text_zero_knowledge" = "ജ്ഞാനരഹിത തെളിവുകൾ അടിസ്ഥാന വിവരങ്ങൾ വെളിപ്പെടുത്താതെ എന്തെങ്കിലും സത്യമാണെന്ന് തെളിയിക്കാൻ അനുവദിക്കുന്നു.\n\nഉദാഹരണം:\n• പരമ്പരാഗതം: ID കാണിക്കുക (കൃത്യ ജനനദിവസം വെളിപ്പെടുത്തുന്നു)\n• ജ്ഞാനരഹിതം: ജനനദിവസം കാണിക്കാതെ 18 വയസ്സ് കഴിഞ്ഞതെന്ന് തെളിയിക്കുക\n\nഗുണങ്ങൾ:\n• പരമ്പരിത സ്വകാര്യ സംരക്ഷണം\n• വ്യക്തിഗത ഡേറ്റ പങ്കിടില്ല\n• ക്രിപ്‌റ്റോഗ്രഫിക്കലി സുരക്ഷിതം\n• കൃത്രിമം കാണിക്കാനോ ആവർത്തിക്കാനോ കഴിയില്ല\n\nProvii Wallet-നെ സ്വകാര്യമാക്കുന്ന കേന്ദ്ര സാങ്കേതികവിദ്യ ഇതാണ്.";
"help_text_credential_issuance" = "യോഗ്യതാപത്രം ഇഷ്യൂവൻസ് ഒരു അംഗീകൃത ഇഷ്യൂവറിൽ നിന്ന് ഡിജിറ്റൽ പ്രായ യോഗ്യതാപത്രം ലഭ്യമാക്കുന്ന പ്രക്രിയയാണ്.\n\nഘട്ടങ്ങൾ:\n1. അംഗീകൃത ഇഷ്യൂവർ സന്ദർശിക്കുക (ഉദാ: സർക്കാർ ഓഫീസ്)\n2. ഔദ്യോഗിക ID ഉപയോഗിച്ച് ഐഡന്റിറ്റി തെളിയിക്കുക\n3. ഇഷ്യൂവറിൽ നിന്ന് QR കോഡ് അല്ലെങ്കിൽ ഡീപ് ലിങ്ക് ലഭിക്കുക\n4. QR കോഡ് സ്കാൻ ചെയ്യുകയോ ലിങ്ക് ടാപ്പ് ചെയ്യുകയോ ചെയ്യുക\n5. യോഗ്യതാപത്രം പ്രാദേശികമായി കണക്കാക്കി ഉപകരണത്തിൽ സംഭരിക്കുന്നു\n\nബ്ലൈൻഡ് അറ്റസ്റ്റേഷൻ പ്രക്രിയ ജനനതീയതി നെറ്റ്‌വർക്കിലൂടെ ഒരിക്കലും കൈമാറ്റം ചെയ്യില്ലെന്ന് ഉറപ്പ് നൽകുന്നു.\nഒരു തവണ മാത്രം ഇത് ചെയ്‌താൽ മതി. നിങ്ങളുടെ യോഗ്യതാപത്രം പരിധിയില്ലാത്ത സ്ഥിരീകരണങ്ങൾക്ക് ഉപയോഗിക്കാം.";
"help_text_officer_mode" = "ഉദ്യോഗസ്ഥ മോഡ് ഉപയോക്താക്കൾക്ക് യോഗ്യതാപത്രങ്ങൾ സൃഷ്ടിക്കാൻ അംഗീകൃത ഇഷ്യൂവർമാർക്കുള്ളതാണ്.\n\nഈ മോഡ് ആവശ്യമാണ്:\n• YubiKey ഉപയോഗിച്ച് ഉദ്യോഗസ്ഥ പ്രാമാണീകരണം\n• ഇഷ്യൂ ചെയ്യുന്ന അധികാരത്തിൽ നിന്ന് അംഗീകാരം\n• ഉപയോക്താവിന്റെ ID ശാരീരിക സ്ഥിരീകരണം\n\nപ്രക്രിയ:\n1. ഉദ്യോഗസ്ഥനായി പ്രാമാണീകരിക്കുക\n2. ഉപയോക്താവിന്റെ ഔദ്യോഗിക ID സ്ഥിരീകരിക്കുക\n3. ഉപയോക്താവിന്റെ ജനനതീയതി നൽകുക\n4. അറ്റസ്റ്റേഷൻ QR കോഡ് സൃഷ്ടിക്കുക\n5. ഉപയോക്താവ് യോഗ്യതാപത്രം ലഭിക്കാൻ കോഡ് സ്കാൻ ചെയ്യുന്നു\n\nഈ മോഡ് അധികൃത ഉദ്യോഗസ്ഥർ മാത്രം ഉപയോഗിക്കണം.";
"help_text_extra_large_text_simplified" = "എല്ലാ ടെക്സ്റ്റും 50% വലുതാക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് സഹായിക്കുന്നു:\n• കാണാൻ ബുദ്ധിമുട്ട്\n• വായന ബുദ്ധിമുട്ടുള്ളവർ\n• വലിയ ടെക്സ്റ്റ് ആവശ്യമുള്ളവർ";
"help_text_contrast_level_simplified" = "ടെക്സ്റ്റ് എത്ര ഇരുണ്ടതാണ് എന്ന് മാറ്റുന്നു.\n\nമൂന്ന് തിരഞ്ഞെടുപ്പ്:\n• സ്റ്റാൻഡേർഡ്: സാധാരണ നിറങ്ങൾ\n• ഉയർന്ന: ആഴ്‌ന്ന ടെക്സ്റ്റ്\n• പരമാവധി: ഏറ്റവും ഇരുണ്ട ടെക്സ്റ്റ്";
"help_text_high_contrast_simplified" = "ടെക്സ്റ്റ് കാണാൻ എളുപ്പമാക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് സഹായിക്കുന്നു:\n• കാണാൻ ബുദ്ധിമുട്ട്\n• ഇരുണ്ട ടെക്സ്റ്റ് ആവശ്യം\n• തിളക്കമുള്ള വെളിച്ചത്തിൽ ആപ്പ് ഉപയോഗിക്കൽ\n• ഇരുണ്ട ടെക്സ്റ്റ് ഇഷ്ടപ്പെടൽ\n\nടെക്സ്റ്റ് വെള്ളത്തിൽ കറുത്തതാകുന്നു.";
"help_text_reduce_transparency_simplified" = "മങ്ങിയ ഇഫക്ടുകൾ നീക്കം ചെയ്യുന്നു.\n\nഇത് സഹായിക്കുന്നു:\n• ടെക്സ്റ്റ് വ്യക്തമാക്കുന്നു\n• ആപ്പ് ലളിതമാക്കുന്നു\n• പഴയ ഫോണുകൾ വേഗത്തിലാക്കുന്നു\n\nഎല്ലാം കൂടുതൽ ഖരമായി ദൃശ്യമാകുന്നു.";
"help_text_color_blind_mode_simplified" = "നിങ്ങൾക്ക് നന്നായി കാണാൻ നിറങ്ങൾ മാറ്റുന്നു.\n\nതിരഞ്ഞെടുപ്പുകൾ:\n• ചുവപ്പ് അന്ധ മോഡ്\n• പച്ച അന്ധ മോഡ്\n• നീല അന്ധ മോഡ്\n• ഗ്രേ മാത്രം മോഡ്\n\nപ്രധാന കാര്യങ്ങൾ കാണാൻ സഹായിക്കുന്നു.";
"help_text_line_spacing_simplified" = "ടെക്സ്റ്റ് വരികൾ തമ്മിലുള്ള ഇടം മാറ്റുന്നു.\n\nകൂടുതൽ ഇടം വായന എളുപ്പമാക്കുന്നു.";
"help_text_paragraph_spacing_simplified" = "ഖണ്ഡികകൾ തമ്മിലുള്ള ഇടം മാറ്റുന്നു.\n\nകൂടുതൽ ഇടം പുതിയ ആശയങ്ങൾ ആരംഭിക്കുന്നിടം കാണാൻ സഹായിക്കുന്നു.";
"help_text_letter_spacing_simplified" = "അക്ഷരങ്ങൾ തമ്മിലുള്ള ഇടം മാറ്റുന്നു.\n\nകൂടുതൽ ഇടം അക്ഷരങ്ങൾ വ്യക്തമാക്കുന്നു.";
"help_text_text_width_simplified" = "ടെക്സ്റ്റ് എത്ര വീതിയുള്ളതാണ് എന്ന് നിയന്ത്രിക്കുന്നു.\n\nമധ്യ വീതി വായിക്കാൻ ഏറ്റവും എളുപ്പം.";
"help_text_large_touch_targets_simplified" = "എല്ലാ ബട്ടണുകളും വലുതാക്കുന്നു.\n\nചെറിയ ബട്ടണുകൾ ടാപ്പ് ചെയ്യുന്നതിൽ ബുദ്ധിമുട്ടുള്ളവർക്ക് സഹായിക്കുന്നു.";
"help_text_reduce_motion_simplified" = "ചലിക്കുന്ന ആനിമേഷനുകൾ നീക്കം ചെയ്യുന്നു.\n\nചലനം ചക്കരച്ചൽ ഉണ്ടാക്കുന്നവർക്ക് സഹായിക്കുന്നു.";
"help_text_timeout_behavior_simplified" = "ജോലികൾ എത്ര ദൈർഘ്യം ആകാം എന്ന് നിയന്ത്രിക്കുന്നു.\n\nകൂടുതൽ സമയം ആവശ്യമെങ്കിൽ 'പരിധി ഇല്ല' തിരഞ്ഞെടുക്കുക.";
"help_text_simplified_gestures_simplified" = "ബുദ്ധിമുട്ടുള്ള ജെസ്ചറുകൾ ലളിതമായ ടാപ്പുകൾ ഉപയോഗിച്ച് മാറ്റിസ്ഥാപിക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് സഹായിക്കുന്നു:\n• സങ്കീർണ്ണ ടച്ചുകളിൽ ബുദ്ധിമുട്ട്\n• ലളിതമായ ടാപ്പുകൾ ഇഷ്ടപ്പെടൽ\n• ഒറ്റ കൈ ഉപയോഗം\n\nഎല്ലാം ലളിതമായ ടാപ്പുകൾ ഉപയോഗിക്കുന്നു.";
"help_text_haptic_feedback_simplified" = "ടാപ്പ് ചെയ്യുമ്പോൾ ഫോൺ വൈബ്രേറ്റ് ചെയ്യുന്നു.\n\nവൈബ്രേഷൻ ശല്യമാണെങ്കിൽ ഓഫ് ചെയ്യുക.";
"help_text_simplified_ui_simplified" = "ആപ്പ് ലളിതമാക്കുന്നു.\n\nഒരേ സമയം കുറച്ച് കാര്യങ്ങൾ കാണിക്കുന്നു.";
"help_text_step_indicators_simplified" = "ഘട്ടങ്ങളിലൂടെ നിങ്ങളുടെ പ്രോഗ്രസ് കാണിക്കുന്നു.\n\n'ഘട്ടം 1 of 3' ഡോട്ടുകളോടെ കാണിക്കുന്നു.";
"help_text_verbose_descriptions_simplified" = "കൂടുതൽ വിശദീകരണങ്ങൾ നൽകുന്നു.\n\nഫീച്ചറുകൾ മനസ്സിലാക്കാൻ സഹായിക്കുന്നു.";
"help_text_confirm_actions_simplified" = "പ്രധാനപ്പെട്ട ക്രിയകൾ ഉറപ്പിക്കാൻ ചോദിക്കുന്നു.\n\n'ഉറപ്പാണോ?' എന്ന് ചോദിക്കുന്നു.";
"help_text_manual_code_entry_simplified" = "സ്കാൻ ചെയ്യുന്നതിന് പകരം കോഡുകൾ ടൈപ്പ് ചെയ്യാൻ അനുവദിക്കുന്നു.\n\nഇത് ഉപയോഗിക്കുക:\n• ക്യാമറ പ്രവർത്തിക്കുന്നില്ലെങ്കിൽ\n• കോഡ് സ്കാൻ ചെയ്യാൻ ബുദ്ധിമുട്ടെങ്കിൽ\n• ടൈപ്പ് ചെയ്യൽ ഇഷ്ടപ്പെടുന്നെങ്കിൽ\n\nടൈപ്പ് ചെയ്യാൻ 'കോഡ് മാനുവലായി നൽകുക' ടാപ്പ് ചെയ്യുക.";
"help_text_voice_input_simplified" = "ടൈപ്പ് ചെയ്യുന്നതിന് പകരം കോഡുകൾ പറയാൻ അനുവദിക്കുന്നു.\n\nഇനിപ്പറയുന്നവർക്ക് സഹായിക്കുന്നു:\n• ടൈപ്പ് ചെയ്യുന്നതിൽ ബുദ്ധിമുട്ട്\n• സംസാരം ഇഷ്ടപ്പെടൽ\n• ഹാൻഡ്‌സ്-ഫ്രീ ഉപയോഗം ആഗ്രഹം\n\nമൈക്രോഫോൺ ടാപ്പ് ചെയ്ത് വ്യക്തമായി സംസാരിക്കുക.";
"help_text_qr_scanning_simplified" = "ചതുര കോഡ് വായിക്കാൻ ക്യാമറ ഉപയോഗിക്കുന്നു.\n\nസ്കാൻ ചെയ്യാൻ:\n1. ക്യാമറ കോഡിലേക്ക് ചൂണ്ടുക\n2. കോഡ് ഫ്രേമിൽ ഇടുക\n3. വായിക്കുന്നതിനായി കാത്തിരിക്കുക\n\nനുറുങ്ങുകൾ:\n• നല്ല വെളിച്ചം ഉപയോഗിക്കുക\n• ഫോൺ സ്ഥിരമായി പിടിക്കുക\n• കോഡ് പരന്നതായി സൂക്ഷിക്കുക";
"help_text_age_verification_simplified" = "ജന്മദിനം പങ്കിടാതെ നിങ്ങൾ പ്രായത്തിൽ ഉൾപ്പെടുന്നുവെന്ന് തെളിയിക്കുന്നു.\n\nഇത് എങ്ങനെ പ്രവർത്തിക്കുന്നു:\n1. ബിസിനസ് ഒരു അഭ്യർത്ഥന സൃഷ്ടിക്കുന്നു\n2. നിങ്ങൾ അവരുടെ കോഡ് സ്കാൻ ചെയ്യുന്നു\n3. ആപ്പ് ഒരു തെളിവ് സൃഷ്ടിക്കുന്നു\n4. ബിസിനസ് നിങ്ങൾ മതിയായ പ്രായമുള്ളതെന്ന് ഉറപ്പ് വരുത്തുന്നു\n\nനിങ്ങളുടെ ജന്മദിനം സ്വകാര്യമായി നിൽക്കുന്നു.";
"help_text_credentials_simplified" = "ഫോണിൽ സംഭരിക്കുന്ന പ്രായത്തിന്റെ ഡിജിറ്റൽ തെളിവ്.\n\nഗവൺമെന്റ് ഓഫീസിൽ നിന്ന് ലഭ്യമാകുന്നു.";
"help_text_zero_knowledge_simplified" = "വിശദാംശങ്ങൾ പങ്കിടാതെ ഒരു കാര്യം തെളിയിക്കുന്നു.\n\nഉദാഹരണം: 18 വയസ്സിൽ കൂടുതലാണെന്ന് തെളിയിക്കുന്നു, ജന്മദിനം സ്വകാര്യമായി നിൽക്കുന്നു.";
"help_text_credential_issuance_simplified" = "ഡിജിറ്റൽ പ്രായ തെളിവ് ലഭ്യമാക്കൽ.\n\nഘട്ടങ്ങൾ:\n1. ഗവൺമെന്റ് ഓഫീസ് സന്ദർശിക്കുക\n2. ID കാണിക്കുക\n3. കോഡ് ലഭ്യമാക്കുക\n4. കോഡ് സ്കാൻ ചെയ്യുക\n5. തെളിവ് ഫോണിൽ സംരക്ഷിക്കും";
"help_text_officer_mode_simplified" = "ഗവൺമെന്റ് ജീവനക്കാർ തെളിവുകൾ സൃഷ്ടിക്കുന്നതിന്.\n\nഘട്ടങ്ങൾ:\n1. ഉദ്യോഗസ്ഥനായി ലോഗിൻ ചെയ്യുക\n2. ഉപയോക്താവിന്റെ ID പരിശോധിക്കുക\n3. ജന്മദിനം നൽകുക\n4. കോഡ് സൃഷ്ടിക്കുക\n5. ഉപയോക്താവ് കോഡ് സ്കാൻ ചെയ്യുന്നു";
