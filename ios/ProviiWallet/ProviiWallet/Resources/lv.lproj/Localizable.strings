"percent" = "procenti";
"help_text_extra_large_text" = "Ļoti liels teksts palielina visu tekstu lietotnē par 50%.\n\nTas ir noderīgi lietotājiem ar:\n• Vāju redzi\n• Lasīšanas grūtībām\n• Ar vecumu saistītām redzes izmaiņām\n\nDarbojas ar iOS dinamisko tipu vēl lielākiem izmēriem.";
"help_text_contrast_level" = "Kontrasta līmenis kontrolē krāsu kontrastu starp tekstu un foniem.\n\nPieejami trīs līmeņi:\n• Standarta: Noklusējuma krāsas\n• Augsts (AA): 4.5:1 kontrasta attiecība , atbilst AA standartiem\n• Maksimālais (AAA): 7:1 kontrasta attiecība , atbilst augstākajiem AAA standartiem\n\nAugstāks kontrasts atvieglo teksta lasīšanu visos apgaismojuma apstākļos.";
"help_text_high_contrast" = "Augsta kontrasta režīms palielina kontrastu starp tekstu un fonu, atvieglojot lasīšanu.\n\nTas ir noderīgi lietotājiem ar:\n• Vāju redzi\n• Krāsu jutīgumu\n• Spilgtas ekrāna vides\n\nKad iespējots:\n• Teksts kļūst melns uz balta\n• Elementiem tiek pievienotas apmales\n• Krāsas tiek vienkāršotas";
"help_text_reduce_transparency" = "Samazināt caurspīdīgumu noņem blur un caurspīdīguma efektus visā lietotnē.\n\nTas palīdz:\n• Uzlabot teksta lasāmību\n• Samazināt vizuālo sarežģītību\n• Palielināt veiktspēju vecākās ierīcēs\n• Padarīt saturu prognozējamāku";
"help_text_color_blind_mode" = "Krāsu akluma režīmi pielāgo krāsas dažādiem krāsu redzes trūkumu veidiem.\n\nPieejamie režīmi:\n• Protanopija: Sarkanā aklums (grūtības redzēt sarkano)\n• Deuteranopija: Zaļā aklums (grūtības redzēt zaļo)\n• Tritanopija: Zilā aklums (grūtības redzēt zilo)\n• Melnbaltā: Tikai pelēktoņi\n\nŠie režīmi nodrošina, ka svarīga informācija netiek nodota tikai ar krāsu.";
"help_text_line_spacing" = "Rindas atstarpe kontrolē atstarpi starp teksta rindām.\n\n• Diapazons: 1.0x līdz 2.0x\n• AAA standarts: Minimums 1.5x\n• Noklusējums: 1.0x\n\nPalielināta rindas atstarpe atvieglo teksta lasīšanu un palīdz izvairīties no rindas izlaišanas.";
"help_text_paragraph_spacing" = "Paragrāfa atstarpe kontrolē atstarpi starp paragrāfiem.\n\n• Diapazons: 1.0x līdz 3.0x\n• AAA standarts: Minimums 2.0x\n• Noklusējums: 1.0x\n\nPalielināta paragrāfa atstarpe palīdz atšķirt dažādas teksta sadaļas.";
"help_text_letter_spacing" = "Burtu atstarpe kontrolē atstarpi starp atsevišķiem rakstzīmēm.\n\n• Diapazons: 0.0em līdz 0.2em\n• AAA standarts: Minimums 0.12em\n• Noklusējums: 0.0em\n\nPalielināta burtu atstarpe uzlabo rakstzīmju atpazīšanu un lasāmību.";
"help_text_text_width" = "Teksta platums kontrolē maksimālo rindu garumu ērtai lasīšanai.\n\nIespējas:\n• Pilns platums: Nav maksimuma\n• Ērts (80 rakstzīmes): Optimāls lasīšanai\n• Šaurs (60 rakstzīmes): Koncentrētai lasīšanai\n\nAAA vadlīnijas iesaka maksimāli 80 rakstzīmes vienā rindā.";
"help_text_large_touch_targets" = "Lielāki skāriena mērķi padara visas pogas un interaktīvos elementus vismaz 60pt lielus.\n\nTas ir noderīgi:\n• Motoriskas invaliditātes gadījumā\n• Trīces vai kratīšanas gadījumā\n• Lietojot lietotni ar cimdiem\n• Vienas rokas lietošanai\n\nStandarta minimums ir 44pt; šis iestatījums palielina līdz 60pt.";
"help_text_reduce_motion" = "Samazināt kustību samazina vai noņem animācijas visā lietotnē.\n\nTas ir noderīgi lietotājiem ar:\n• Kustības jutīgumu\n• Vestibulāras sistēmas traucējumiem\n• Epilepsiju\n• Migrēnas izraisītājiem\n\nKad iespējots, animācijas tiek aizstātas ar tūlītējiem pārejiem.";
"help_text_timeout_behavior" = "Noilguma uzvedība kontrolē, cik ilgi darbības var ilgt pirms noilguma.\n\nIespējas:\n• Nav noilguma (AAA): Darbības nekad nebeidz\n• Standarta (30s): Noklusējuma noilgums\n• Pagarināts (60s): Divreiz vairāk par standarta laiku\n\nNav noilguma režīms atbilst AAA pieejamības standartiem.";
"help_text_simplified_gestures" = "Vienkāršoti žesti samazina sarežģītus daudzskārienu žestus līdz vienkāršiem pieskārieniem.\n\nTas ir noderīgi:\n• Motoriskas invaliditātes gadījumā\n• Ierobežotas veiklības gadījumā\n• Izmantojot palīgierīces\n• Vienas rokas darbībai\n\nSarežģīti žesti tiek aizstāti ar pogām un vienkāršiem pieskārieniem.";
"help_text_haptic_feedback" = "Haptiskā atgriezeniskā saite nodrošina vibrācijas atgriezenisko saiti darbībām un paziņojumiem.\n\nTas ir noderīgi:\n• Pogu nospiešanas apstiprināšanai\n• Brīdināšanai par kļūdām vai perspektīvām\n• Neredzes atgriezeniskās saites nodrošināšanai\n• Lietotājiem ar dzirdes vai redzes traucējumiem\n\nJūs varat atspējot šo, ja vibrācijas ir neērtā.";
"help_text_simplified_ui" = "Vienkāršots interfeiss samazina vizuālo sarežģītību visā lietotnē.\n\nTas ir noderīgi:\n• Kognitīvas invaliditātes gadījumā\n• Mācīšanās grūtību gadījumā\n• Uzmanības traucējumu gadījumā\n• Jauniem vai nepieredzējušiem lietotājiem\n\nKad iespējots:\n• Mazāk elementu uz ekrāna\n• Lielāki, skaidrāki vadīklas\n• Mazāk vizuālā troksņa";
"help_text_step_indicators" = "Soļu indikatori rāda jūsu progresu daudzsoļu procesos.\n\nTas palīdz:\n• Saprast, kur atrodaties procesā\n• Zināt, cik soļu atlicis\n• Samazināt kognitīvo slodzi\n• Nodrošināt skaidru struktūru\n\nRāda \"Solis X no Y\" ar vizuālajiem progresa punktiem.";
"help_text_verbose_descriptions" = "Detalizēti apraksti nodrošina papildu skaidrojošu tekstu visā lietotnē.\n\nTas ir noderīgi:\n• Sarežģītu funkciju izpratnei\n• Lietotnes lietošanas apgūšanai\n• Kognitīvajam atbalstam\n• Ekrāna lasītāja lietotājiem\n\nNodrošina kontekstu un instrukcijas visām funkcijām.";
"help_text_confirm_actions" = "Apstiprināt darbības pieprasa apstiprinājumu pirms svarīgām darbībām.\n\nTas palīdz novērst:\n• Nejaušas dzēšanas\n• Nedomātas izmaiņas\n• Priekšlaicīgas iesniegšanas\n• Datu zudumu\n\nPiezīme: Destruktīvas darbības vienmēr prasa apstiprinājumu (AAA prasība).";
"help_text_manual_code_entry" = "Manuāla koda ievade ļauj ievadīt kodus, nevis skenēt QR kodus.\n\nTas ir noderīgi, kad:\n• Kamera nedarbojas\n• QR kods ir bojāts vai neskaidrs\n• Izmantojat ekrāna lasītāju\n• Dodat priekšroku rakstīšanai nevis skenēšanai\n\nVienkārši pieskarieties \"Ievadīt kodu manuāli\", lai ievadītu ekrānā redzamo kodu.";
"help_text_voice_input" = "Balss ievade ļauj runāt kodus, nevis skenēt vai rakstīt.\n\nTas ir noderīgi:\n• Ierobežotas mobilitātes gadījumā\n• Ekrāna lasītāja lietotājiem\n• Brīvroku darbībai\n• Balss priekšrocībai\n\nPieskarieties mikrofona pogai un runājiet skaidri, kad tiek prasīts.";
"help_text_qr_scanning" = "QR koda skenēšana izmanto kameru, lai lasītu ātros atbildes kodus.\n\nKā skenēt:\n1. Vērsiet kameru uz QR kodu\n2. Novietojiet kodu rāmī\n3. Gaidiet automātisko atklāšanu\n\nPadomā:\n• Nodrošiniet labu apgaismojumu\n• Turiet ierīci stabili\n• Turiet QR kodu plakanu un bez šķēršļiem\n• Ja skenēšana neizdodas, izmēģiniet manuālo koda ievadi";
"help_text_age_verification" = "Vecuma verifikācija pierāda, ka atbilstat vecuma prasībai, neizpaužot faktisko vecumu vai dzimšanas datumu.\n\nKā tas darbojas:\n1. Verificētājs ģenerē izaicinājumu\n2. Jūs skenējat QR kodu vai ievadāt manuāli\n3. Lietotne izveido nulles zināšanu pierādījumu\n4. Verificētājs apstiprina, ka atbilstat prasībai\n\nPrivātums aizsargāts:\n• Jūsu dzimšanas datums nekad netiek kopīgots\n• Verificētājs tikai uzzina, vai atbilstat prasībai\n• Nav izsekošanas vai datu vākšanas";
"help_text_credentials" = "Digitālie akreditācijas dati ir kriptogrāfiski Jūsu vecuma pierādījumi, kas droši saglabāti Jūsu ierīcē.\n\nFunkcijas:\n• Saglabāti tikai Jūsu ierīcē\n• Nevar kopēt vai viltot\n• Izmantoti privātumu saglabājošai verifikācijai\n• Var dzēst jebkurā laikā\n\nJums jāiegūst akreditācijas dati no pilnvarotā izdevēja (piemēram, valdības iestādes), pirms varēsiet verificēt savu vecumu.";
"help_text_zero_knowledge" = "Nulles zināšanu pierādījumi ļauj pierādīt, ka kaut kas ir patiess, neizpaužot pamatā esošo informāciju.\n\nPiemērs:\n• Tradicionāls: Rādīt ID (atklāj precīzu dzimšanas dienu)\n• Nulles zināšanas: Pierādīt, ka esat vecāks par 18 gadiem, nerādot dzimšanas dienu\n\nIeguvumi:\n• Maksimāla privātuma aizsardzība\n• Nav kopīgotu personas datu\n• Kriptogrāfiski droši\n• Nevar viltot vai atkārtot\n\nTā ir pamattehnoloģija, kas padara Provii Wallet privātu.";
"help_text_credential_issuance" = "Akreditācijas datu izsniegšana ir process, kā iegūt digitālos vecuma akreditācijas datus no pilnvarotā izdevēja.\n\nSoļi:\n1. Apmeklējiet pilnvaroto izdevēju (piemēram, valdības iestādi)\n2. Pierādiet savu identitāti ar oficiālu ID\n3. Saņemiet QR kodu vai dziļo saiti no izdevēja\n4. Skenējiet QR kodu vai pieskarieties saitei\n5. Akreditācijas dati tiek aprēķināti lokāli un saglabāti Jūsu ierīcē\n\nAklā apliecinājuma process nodrošina, ka Jūsu dzimšanas datums nekad netiek pārsūtīts tīklā.\nJums to jādara tikai vienu reizi. Jūsu akreditācijas datus pēc tam var izmantot neierobežotām verifikācijām.";
"help_text_officer_mode" = "Amatpersonas režīms ir paredzēts pilnvarotiem izdevējiem, lai izveidotu akreditācijas datus lietotājiem.\n\nŠim režīmam nepieciešams:\n• Amatpersonas autentifikācija ar YubiKey\n• Atļauja no izdevēja iestādes\n• Fiziska lietotāja ID verifikācija\n\nProcess:\n1. Autentificēties kā amatpersona\n2. Verificēt lietotāja oficiālo ID\n3. Ievadīt lietotāja dzimšanas datumu\n4. Ģenerēt apliecinājuma QR kodu\n5. Lietotājs skenē kodu, lai saņemtu akreditācijas datus\n\nŠo režīmu drīkst izmantot tikai pilnvarotas personas.";
"help_text_extra_large_text_simplified" = "Palielina visu tekstu par 50%.\n\nPalīdz Jums, ja:\n• Ir grūti redzēt\n• Ir grūti lasīt\n• Vajag lielāku tekstu\n\nDarbojas ar tālruņa teksta izmēra iestatījumiem.";
"help_text_contrast_level_simplified" = "Maina teksta tumšumu.\n\nTrīs izvēles:\n• Standarta: Parasta krāsa\n• Augsts: Tumšāks teksts vieglai lasīšanai\n• Maksimālais: Ļoti tumšs teksts labākai lasīšanai\n\nTumšāks teksts ir vieglāk lasāms.";
"help_text_high_contrast_simplified" = "Padara tekstu vieglāk redzamu.\n\nPalīdz Jums, ja:\n• Ir grūti redzēt\n• Vajag tumšāku tekstu\n• Izmantojat lietotni spilgtā gaismā\n\nTeksts kļūst melns uz balta.";
"help_text_reduce_transparency_simplified" = "Noņem neskaidros efektus.\n\nTas palīdz:\n• Padarīt tekstu skaidrāku\n• Padarīt lietotni vienkāršāku\n• Paātrināt vecākas tālrunis\n\nViss izskatās masīvāks.";
"help_text_color_blind_mode_simplified" = "Maina krāsas, lai palīdzētu labāk redzēt.\n\nIzvēles:\n• Sarkanā akluma režīms\n• Zaļā akluma režīms\n• Zilā akluma režīms\n• Tikai pelēktoņi\n\nPalīdz redzēt svarīgas lietas.";
"help_text_line_spacing_simplified" = "Maina atstarpi starp teksta rindām.\n\nVar izvēlēties no 1.0x līdz 2.0x.\nNoklusējums ir 1.0x.\n\nLielāka atstarpe atvieglo lasīšanu.";
"help_text_paragraph_spacing_simplified" = "Maina atstarpi starp paragrāfiem.\n\nVar izvēlēties no 1.0x līdz 3.0x.\nNoklusējums ir 1.0x.\n\nLielāka atstarpe palīdz redzēt, kur sākas jaunas idejas.";
"help_text_letter_spacing_simplified" = "Maina atstarpi starp burtiem.\n\nVar izvēlēties no 0.0 līdz 0.2.\nNoklusējums ir 0.0.\n\nLielāka atstarpe padara burtus skaidrākus.";
"help_text_text_width_simplified" = "Kontrolē teksta platumu.\n\nIzvēles:\n• Pilns platums: Izmanto visu ekrānu\n• Vidējs: Labs lasīšanai\n• Šaurs: Labāks koncentrācijai\n\nVidējs platums ir vieglāk lasāms.";
"help_text_large_touch_targets_simplified" = "Padara visas pogas lielākas.\n\nPalīdz Jums, ja:\n• Ir grūti pieskarties mazām pogām\n• Rokas trīc\n• Nēsājat cimdus\n• Izmantojat vienu roku\n\nPogas kļūst 60pt lielas, nevis 44pt.";
"help_text_reduce_motion_simplified" = "Noņem kustīgās animācijas.\n\nPalīdz Jums, ja:\n• Kustība izraisa reiboni\n• Kustība izraisa galvassāpes\n• Dodat priekšroku klusumam\n\nLietas mainās uzreiz, nevis kustas.";
"help_text_timeout_behavior_simplified" = "Kontrolē, cik ilgi uzdevumi var ilgt.\n\nIzvēles:\n• Nav ierobežojuma: Uzdevumi nekad nebeidzas\n• Normāls: 30 sekundes\n• Ilgāks: 60 sekundes\n\nIzvēlieties 'Nav ierobežojuma', ja vajag vairāk laika.";
"help_text_simplified_gestures_simplified" = "Aizstāj sarežģītus žestus ar vienkāršiem pieskārieniem.\n\nPalīdz Jums, ja:\n• Ir grūti veikt sarežģītus skārienus\n• Dodat priekšroku vienkāršiem pieskārieniem\n• Izmantojat vienu roku\n\nViss izmanto vienkāršus pieskārienus.";
"help_text_haptic_feedback_simplified" = "Liek tālrunim vibrēt, kad pieskaraties.\n\nPalīdz Jums:\n• Zināt, kad nospiesta poga\n• Sajust kļūdas vai brīdinājumus\n• Saņemt atgriezenisko saiti, neskatoties\n\nIzslēdziet, ja vibrācijas traucē.";
"help_text_simplified_ui_simplified" = "Padara lietotni vienkāršāku.\n\nPalīdz Jums, ja:\n• Pārblīvēti ekrāni jauc\n• Dodat priekšroku vienkāršiem izkārtojumiem\n• Esat jauns lietotnē\n\nRāda mazāk lietu vienlaikus.";
"help_text_step_indicators_simplified" = "Rāda jūsu progresu soļos.\n\nPalīdz Jums:\n• Zināt, kur atrodaties\n• Redzēt, cik soļu atlicis\n• Palikt organizētam\n\nRāda 'Solis 1 no 3' ar punktiem.";
"help_text_verbose_descriptions_simplified" = "Sniedz vairāk skaidrojumu.\n\nPalīdz Jums:\n• Saprast funkcijas\n• Iemācīties lietot lietotni\n• Iegūt vairāk detaļu\n\nNodrošina papildu palīdzību visur.";
"help_text_confirm_actions_simplified" = "Lūdz apstiprināt svarīgas darbības.\n\nPalīdz novērst:\n• Nejaušas dzēšanas\n• Nevēlamas izmaiņas\n• Kļūdas\n\nVienmēr tiks jautāts 'Vai esat pārliecināts?'";
"help_text_manual_code_entry_simplified" = "Ļauj ievadīt kodus, nevis skenēt.\n\nIzmantojiet to, kad:\n• Kamera nedarbojas\n• Kodu ir grūti skenēt\n• Dodat priekšroku rakstīšanai\n\nPieskarieties 'Ievadīt kodu manuāli', lai rakstītu.";
"help_text_voice_input_simplified" = "Ļauj runāt kodus, nevis rakstīt.\n\nPalīdz Jums, ja:\n• Ir grūti rakstīt\n• Dodat priekšroku runāšanai\n• Vēlaties brīvroku lietošanu\n\nPieskarieties mikrofonam un runājiet skaidri.";
"help_text_qr_scanning_simplified" = "Izmanto kameru, lai lasītu kvadrātveida kodus.\n\nKā skenēt:\n1. Vērsiet kameru uz kodu\n2. Izlīdziniet kodu\n3. Gaidiet, kamēr tas tiks nolasīts\n\nPadomā:\n• Izmantojiet labu apgaismojumu\n• Turiet tālruni stabili\n• Turiet kodu plakanu";
"help_text_age_verification_simplified" = "Pierāda, ka esat pietiekami vecs, neizpaužot dzimšanas dienu.\n\nKā tas darbojas:\n1. Bizness izveido pieprasījumu\n2. Jūs skenējat viņu kodu\n3. Lietotne izveido pierādījumu\n4. Bizness apstiprina, ka esat pietiekami vecs\n\nJūsu dzimšanas diena paliek privāta.";
"help_text_credentials_simplified" = "Digitāls Jūsu vecuma pierādījums, saglabāts tālrunī.\n\nFunkcijas:\n• Tikai Jūsu tālrunī\n• Nevar kopēt\n• Saglabā privātumu\n• Varat dzēst jebkurā laikā\n\nTo iegūstat no valdības iestādes.";
"help_text_zero_knowledge_simplified" = "Pierāda kaut ko, neizpaužot detaļas.\n\nPiemērs:\n• Vecā metode: Rādīt ID (rāda precīzu dzimšanas dienu)\n• Jaunā metode: Pierādīt, ka esat vecāks par 18 gadiem (dzimšanas diena paliek privāta)\n\nTas saglabā Jūsu informāciju privātu.";
"help_text_credential_issuance_simplified" = "Digitālā vecuma pierādījuma iegūšana.\n\nSoļi:\n1. Dodieties uz valdības iestādi\n2. Uzrādiet ID\n3. Saņemiet kodu\n4. Skenējiet kodu\n5. Pierādījums tiek saglabāts tālrunī\n\nDariet to vienu reizi. Tad izmantojiet daudzas reizes.";
"help_text_officer_mode_simplified" = "Valdības darbiniekiem, lai izveidotu pierādījumus.\n\nNepieciešams:\n• Amatpersonas parole\n• Atļauja lietot\n• Lietotāja ID pārbaudei\n\nSoļi:\n1. Pierakstīties kā amatpersona\n2. Pārbaudīt lietotāja ID\n3. Ievadīt dzimšanas datumu\n4. Izveidot kodu\n5. Lietotājs skenē kodu\n\nTikai pilnvarotiem darbiniekiem.";
