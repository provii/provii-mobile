/* Help Text Descriptions */
"help_text_extra_large_text" = "Το πολύ μεγάλο κείμενο αυξάνει όλο το κείμενο στην εφαρμογή κατά 50%.\n\nΑυτό βοηθά χρήστες με:\n• Μειωμένη όραση\n• Δυσκολίες ανάγνωσης\n• Αλλαγές όρασης λόγω ηλικίας\n\nΛειτουργεί με Dynamic Type του iOS για ακόμα μεγαλύτερα μεγέθη.";
"help_text_contrast_level" = "Το επίπεδο αντίθεσης ελέγχει την αντίθεση χρωμάτων μεταξύ κειμένου και φόντου.\n\nΤρία επίπεδα διαθέσιμα:\n• Τυπική: Προεπιλεγμένα χρώματα\n• Υψηλή (AA): Αναλογία 4,5:1 - πληροί πρότυπα AA\n• Μέγιστη (AAA): Αναλογία 7:1 - πληροί ανώτατα πρότυπα AAA\n\nΥψηλότερη αντίθεση κάνει το κείμενο πιο ευανάγνωστο σε όλες τις συνθήκες φωτισμού.";
"help_text_high_contrast" = "Η λειτουργία υψηλής αντίθεσης αυξάνει την αντίθεση μεταξύ κειμένου και φόντου.\n\nΒοηθά χρήστες με:\n• Μειωμένη όραση\n• Ευαισθησία στα χρώματα\n• Φωτεινά περιβάλλοντα οθόνης\n\nΌταν ενεργοποιηθεί:\n• Το κείμενο γίνεται μαύρο σε λευκό\n• Προστίθενται περιγράμματα στα στοιχεία\n• Τα χρώματα απλοποιούνται";
"help_text_reduce_transparency" = "Η μείωση διαφάνειας αφαιρεί εφέ θολώματος και διαφάνειας από την εφαρμογή.\n\nΑυτό βοηθά:\n• Βελτίωση αναγνωσιμότητας κειμένου\n• Μείωση οπτικής πολυπλοκότητας\n• Αύξηση απόδοσης σε παλαιότερες συσκευές\n• Πιο προβλέψιμο περιεχόμενο";
"help_text_color_blind_mode" = "Οι λειτουργίες αχρωματοψίας προσαρμόζουν τα χρώματα για διαφορετικούς τύπους έλλειψης χρωματικής όρασης.\n\nΔιαθέσιμες λειτουργίες:\n• Πρωτανοπία: Αδυναμία στο κόκκινο\n• Δευτερανοπία: Αδυναμία στο πράσινο\n• Τριτανοπία: Αδυναμία στο μπλε\n• Μονοχρωματική: Μόνο κλίμακα γκρι\n\nΑυτές οι λειτουργίες διασφαλίζουν ότι οι σημαντικές πληροφορίες δεν μεταδίδονται μόνο μέσω χρώματος.";
"help_text_line_spacing" = "Το διάστιχο ελέγχει τον χώρο μεταξύ γραμμών κειμένου.\n\n• Εύρος: 1,0x έως 2,0x\n• Πρότυπο AAA: ελάχιστο 1,5x\n• Προεπιλογή: 1,0x\n\nΑυξημένο διάστιχο κάνει το κείμενο πιο ευανάγνωστο και βοηθά στην αποφυγή παράλειψης γραμμών.";
"help_text_paragraph_spacing" = "Η απόσταση παραγράφων ελέγχει τον χώρο μεταξύ παραγράφων.\n\n• Εύρος: 1,0x έως 3,0x\n• Πρότυπο AAA: ελάχιστο 2,0x\n• Προεπιλογή: 1,0x\n\nΑυξημένη απόσταση παραγράφων βοηθά στη διάκριση μεταξύ διαφορετικών τμημάτων κειμένου.";
"help_text_letter_spacing" = "Η απόσταση γραμμάτων ελέγχει τον χώρο μεταξύ μεμονωμένων χαρακτήρων.\n\n• Εύρος: 0,0em έως 0,2em\n• Πρότυπο AAA: ελάχιστο 0,12em\n• Προεπιλογή: 0,0em\n\nΑυξημένη απόσταση γραμμάτων βελτιώνει την αναγνώριση χαρακτήρων και αναγνωσιμότητα.";
"help_text_text_width" = "Το πλάτος κειμένου ελέγχει το μέγιστο μήκος γραμμής για άνετη ανάγνωση.\n\nΕπιλογές:\n• Πλήρες πλάτος: Χωρίς μέγιστο\n• Άνετο (80 χαρ.): Βέλτιστο για ανάγνωση\n• Στενό (60 χαρ.): Για συγκεντρωμένη ανάγνωση\n\nΟι οδηγίες AAA συνιστούν μέγιστο 80 χαρακτήρες ανά γραμμή.";
"help_text_large_touch_targets" = "Οι μεγαλύτεροι στόχοι αφής κάνουν όλα τα κουμπιά και διαδραστικά στοιχεία τουλάχιστον 60pt.\n\nΒοηθά για:\n• Κινητικές αναπηρίες\n• Τρέμουλο\n• Χρήση με γάντια\n• Μονόχειρη χρήση\n\nΤο τυπικό ελάχιστο είναι 44pt. Αυτή η ρύθμιση αυξάνει σε 60pt.";
"help_text_reduce_motion" = "Η μείωση κίνησης ελαχιστοποιεί ή αφαιρεί κινούμενα σχέδια από την εφαρμογή.\n\nΒοηθά χρήστες με:\n• Ευαισθησία στην κίνηση\n• Αιθουσαίες διαταραχές\n• Επιληψία\n• Εκκινητές ημικρανίας\n\nΌταν ενεργοποιηθεί, τα κινούμενα σχέδια αντικαθίστανται με άμεσες μεταβάσεις.";
"help_text_timeout_behavior" = "Η συμπεριφορά χρονικού ορίου ελέγχει πόσο καιρό μπορούν να διαρκέσουν οι λειτουργίες.\n\nΕπιλογές:\n• Χωρίς χρονικό όριο (AAA): Οι λειτουργίες δεν λήγουν ποτέ\n• Τυπικό (30 δευτ.): Προεπιλεγμένο χρονικό όριο\n• Παρατεταμένο (60 δευτ.): Διπλάσιος χρόνος\n\nΗ λειτουργία χωρίς χρονικό όριο πληροί πρότυπα AAA προσβασιμότητας.";
"help_text_simplified_gestures" = "Οι απλοποιημένες χειρονομίες αντικαθιστούν σύνθετες πολυαφής χειρονομίες με απλά πατήματα.\n\nΒοηθά για:\n• Κινητικές αναπηρίες\n• Περιορισμένη επιδεξιότητα\n• Χρήση βοηθητικών συσκευών\n• Μονόχειρη λειτουργία\n\nΟι σύνθετες χειρονομίες αντικαθίστανται με κουμπιά και απλά πατήματα.";
"help_text_haptic_feedback" = "Η απτική ανάδραση παρέχει δόνηση για ενέργειες και ειδοποιήσεις.\n\nΒοηθά για:\n• Επιβεβαίωση πατημάτων κουμπιών\n• Ειδοποίηση για σφάλματα ή προειδοποιήσεις\n• Παροχή μη οπτικής ανάδρασης\n• Χρήστες με αναπηρίες ακοής ή όρασης\n\nΜπορείτε να την απενεργοποιήσετε αν οι δονήσεις ενοχλούν.";
"help_text_simplified_ui" = "Η απλοποιημένη διεπαφή μειώνει την οπτική πολυπλοκότητα στην εφαρμογή.\n\nΒοηθά για:\n• Γνωστικές αναπηρίες\n• Μαθησιακές δυσκολίες\n• Διαταραχές προσοχής\n• Νέους ή άπειρους χρήστες\n\nΌταν ενεργοποιηθεί:\n• Λιγότερα στοιχεία στην οθόνη\n• Μεγαλύτερα, σαφέστερα στοιχεία ελέγχου\n• Λιγότερος οπτικός θόρυβος";
"help_text_step_indicators" = "Οι δείκτες βημάτων δείχνουν την πρόοδό σας σε διαδικασίες πολλαπλών βημάτων.\n\nΑυτό βοηθά:\n• Κατανόηση της θέσης σας στη διαδικασία\n• Γνώση πόσα βήματα απομένουν\n• Μείωση γνωστικού φορτίου\n• Παροχή σαφούς δομής\n\nΔείχνει «Βήμα Χ από Υ» με οπτικές κουκίδες προόδου.";
"help_text_verbose_descriptions" = "Οι αναλυτικές περιγραφές παρέχουν πρόσθετο επεξηγηματικό κείμενο στην εφαρμογή.\n\nΒοηθά για:\n• Κατανόηση σύνθετων λειτουργιών\n• Εκμάθηση χρήσης εφαρμογής\n• Γνωστική υποστήριξη\n• Χρήστες αναγνώστη οθόνης\n\nΠαρέχει πλαίσιο και οδηγίες για όλες τις λειτουργίες.";
"help_text_confirm_actions" = "Η επιβεβαίωση ενεργειών ζητά επιβεβαίωση πριν από σημαντικές ενέργειες.\n\nΑυτό βοηθά στην αποφυγή:\n• Τυχαίων διαγραφών\n• Ακούσιων αλλαγών\n• Πρόωρων υποβολών\n• Απώλειας δεδομένων\n\nΣημείωση: Οι καταστροφικές ενέργειες πάντα απαιτούν επιβεβαίωση (απαίτηση AAA).";
"help_text_manual_code_entry" = "Η χειροκίνητη εισαγωγή κωδικού σας επιτρέπει να πληκτρολογείτε κωδικούς αντί να σαρώνετε κωδικούς QR.\n\nΒοηθά όταν:\n• Η κάμερα δεν λειτουργεί\n• Ο κωδικός QR είναι κατεστραμμένος ή ασαφής\n• Χρησιμοποιείτε αναγνώστη οθόνης\n• Προτιμάτε την πληκτρολόγηση αντί της σάρωσης\n\nΑπλώς πατήστε «Χειροκίνητη εισαγωγή κωδικού» για να πληκτρολογήσετε τον κωδικό.";
"help_text_voice_input" = "Η φωνητική εισαγωγή σας επιτρέπει να εκφωνείτε κωδικούς αντί να σαρώνετε ή να πληκτρολογείτε.\n\nΒοηθά για:\n• Περιορισμένη κινητικότητα\n• Χρήστες αναγνώστη οθόνης\n• Λειτουργία χωρίς χέρια\n• Προτίμηση φωνής\n\nΠατήστε το κουμπί μικροφώνου και μιλήστε καθαρά όταν σας ζητηθεί.";
"help_text_qr_scanning" = "Η σάρωση κωδικών QR χρησιμοποιεί την κάμερά σας για ανάγνωση κωδικών γρήγορης απόκρισης.\n\nΤρόπος σάρωσης:\n1. Στρέψτε κάμερα στον κωδικό QR\n2. Ευθυγραμμίστε τον κωδικό στο πλαίσιο\n3. Αναμείνετε αυτόματη ανίχνευση\n\nΣυμβουλές:\n• Εξασφαλίστε καλό φωτισμό\n• Κρατήστε τη συσκευή σταθερή\n• Κρατήστε τον κωδικό QR επίπεδο και ελεύθερο\n• Αν η σάρωση αποτύχει, δοκιμάστε χειροκίνητη εισαγωγή";
"help_text_age_verification" = "Η επαλήθευση ηλικίας αποδεικνύει ότι πληροίτε απαίτηση ηλικίας χωρίς να αποκαλύψετε την πραγματική σας ηλικία.\n\nΠώς λειτουργεί:\n1. Ο επαληθευτής δημιουργεί πρόκληση\n2. Σαρώνετε τον κωδικό QR ή εισάγετε χειροκίνητα\n3. Η εφαρμογή δημιουργεί απόδειξη μηδενικής γνώσης\n4. Ο επαληθευτής επιβεβαιώνει ότι πληροίτε την απαίτηση\n\nΠροστασία απορρήτου:\n• Η ημερομηνία γέννησής σας δεν κοινοποιείται ποτέ\n• Ο επαληθευτής μαθαίνει μόνο αν πληροίτε την απαίτηση\n• Χωρίς παρακολούθηση ή συλλογή δεδομένων";
"help_text_credentials" = "Τα ψηφιακά διαπιστευτήρια είναι κρυπτογραφικές αποδείξεις της ηλικίας σας αποθηκευμένες με ασφάλεια στη συσκευή σας.\n\nΧαρακτηριστικά:\n• Αποθηκευμένα μόνο στη συσκευή σας\n• Δεν μπορούν να αντιγραφούν ή πλαστογραφηθούν\n• Χρησιμοποιούνται για επαλήθευση με προστασία απορρήτου\n• Μπορούν να διαγραφούν ανά πάσα στιγμή\n\nΠρέπει να αποκτήσετε διαπιστευτήριο από εξουσιοδοτημένο εκδότη πριν επαληθεύσετε την ηλικία σας.";
"help_text_zero_knowledge" = "Οι αποδείξεις μηδενικής γνώσης σας επιτρέπουν να αποδείξετε ότι κάτι είναι αληθές χωρίς να αποκαλύψετε τις υποκείμενες πληροφορίες.\n\nΠαράδειγμα:\n• Παραδοσιακός τρόπος: Επίδειξη ταυτότητας (αποκαλύπτει ακριβή ημερομηνία γέννησης)\n• Μηδενική γνώση: Απόδειξη ότι είστε άνω των 18 χωρίς επίδειξη ημερομηνίας\n\nΠλεονεκτήματα:\n• Μέγιστη προστασία απορρήτου\n• Χωρίς κοινοποίηση προσωπικών δεδομένων\n• Κρυπτογραφικά ασφαλές\n• Δεν μπορεί να πλαστογραφηθεί ή επαναχρησιμοποιηθεί\n\nΑυτή είναι η βασική τεχνολογία που κάνει το Provii Wallet ιδιωτικό.";
"help_text_credential_issuance" = "Η έκδοση διαπιστευτηρίου είναι η διαδικασία απόκτησης ψηφιακού διαπιστευτηρίου ηλικίας από εξουσιοδοτημένο εκδότη.\n\nΒήματα:\n1. Επισκεφθείτε εξουσιοδοτημένο εκδότη\n2. Αποδείξτε την ταυτότητά σας\n3. Λάβετε κωδικό QR ή βαθύ σύνδεσμο\n4. Σαρώστε τον κωδικό ή πατήστε τον σύνδεσμο\n5. Το διαπιστευτήριο υπολογίζεται τοπικά στη συσκευή σας\n\nΗ διαδικασία τυφλής βεβαίωσης διασφαλίζει ότι η ημερομηνία γέννησής σας δεν μεταδίδεται ποτέ μέσω δικτύου.\nΑρκεί να το κάνετε μία φορά. Το διαπιστευτήριό σας μπορεί να χρησιμοποιηθεί για απεριόριστες επαληθεύσεις.";
"help_text_officer_mode" = "Η λειτουργία υπαλλήλου είναι για εξουσιοδοτημένους εκδότες για δημιουργία διαπιστευτηρίων για χρήστες.\n\nΑυτή η λειτουργία απαιτεί:\n• Ταυτοποίηση υπαλλήλου με YubiKey\n• Εξουσιοδότηση από εκδούσα αρχή\n• Φυσική επαλήθευση ταυτότητας χρήστη\n\nΔιαδικασία:\n1. Ταυτοποίηση ως υπάλληλος\n2. Επαλήθευση επίσημης ταυτότητας χρήστη\n3. Εισαγωγή ημερομηνίας γέννησης χρήστη\n4. Δημιουργία κωδικού QR βεβαίωσης\n5. Ο χρήστης σαρώνει τον κωδικό για λήψη διαπιστευτηρίου\n\nΜόνο εξουσιοδοτημένο προσωπικό πρέπει να χρησιμοποιεί αυτή τη λειτουργία.";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "Κάνει όλο το κείμενο 50% μεγαλύτερο.\n\nΒοηθά αν:\n• Δυσκολεύεστε να δείτε\n• Δυσκολεύεστε στην ανάγνωση\n• Χρειάζεστε μεγαλύτερο κείμενο\n\nΛειτουργεί με τις ρυθμίσεις μεγέθους κειμένου του τηλεφώνου σας.";
"help_text_contrast_level_simplified" = "Αλλάζει πόσο σκούρο είναι το κείμενο.\n\nΤρεις επιλογές:\n• Τυπική: Κανονικά χρώματα\n• Υψηλή: Σκουρότερο κείμενο για εύκολη ανάγνωση\n• Μέγιστη: Πολύ σκούρο κείμενο για καλύτερη ανάγνωση\n\nΤο σκουρότερο κείμενο είναι πιο εύκολο να διαβαστεί.";
"help_text_high_contrast_simplified" = "Κάνει το κείμενο πιο εύκολο να δει κανείς.\n\nΒοηθά αν:\n• Δυσκολεύεστε να δείτε\n• Χρειάζεστε σκουρότερο κείμενο\n• Χρησιμοποιείτε την εφαρμογή σε φωτεινό χώρο\n\nΤο κείμενο γίνεται μαύρο σε λευκό φόντο.";
"help_text_reduce_transparency_simplified" = "Αφαιρεί θολά εφέ.\n\nΑυτό βοηθά:\n• Το κείμενο να φαίνεται πιο καθαρό\n• Την εφαρμογή να είναι πιο απλή\n• Να επιταχυνθούν παλαιότερα τηλέφωνα\n\nΤα πάντα φαίνονται πιο συμπαγή.";
"help_text_color_blind_mode_simplified" = "Αλλάζει χρώματα για να βλέπετε καλύτερα.\n\nΕπιλογές:\n• Λειτουργία αδυναμίας κόκκινου\n• Λειτουργία αδυναμίας πράσινου\n• Λειτουργία αδυναμίας μπλε\n• Λειτουργία μόνο γκρι\n\nΣας βοηθά να βλέπετε σημαντικά πράγματα.";
"help_text_line_spacing_simplified" = "Αλλάζει τον χώρο μεταξύ γραμμών κειμένου.\n\nΜπορείτε να επιλέξετε από 1,0x έως 2,0x.\nΠροεπιλογή: 1,0x.\n\nΠερισσότερος χώρος κάνει την ανάγνωση πιο εύκολη.";
"help_text_paragraph_spacing_simplified" = "Αλλάζει τον χώρο μεταξύ παραγράφων.\n\nΜπορείτε να επιλέξετε από 1,0x έως 3,0x.\nΠροεπιλογή: 1,0x.\n\nΠερισσότερος χώρος βοηθά να δείτε πού αρχίζουν νέες ιδέες.";
"help_text_letter_spacing_simplified" = "Αλλάζει τον χώρο μεταξύ γραμμάτων.\n\nΜπορείτε να επιλέξετε από 0,0 έως 0,2.\nΠροεπιλογή: 0,0.\n\nΠερισσότερος χώρος κάνει τα γράμματα πιο ευκρινή.";
"help_text_text_width_simplified" = "Ελέγχει πόσο φαρδύ είναι το κείμενο.\n\nΕπιλογές:\n• Πλήρες πλάτος: Χρησιμοποιεί ολόκληρη την οθόνη\n• Μεσαίο: Καλό για ανάγνωση\n• Στενό: Καλύτερο για συγκέντρωση\n\nΤο μεσαίο πλάτος είναι πιο εύκολο να διαβαστεί.";
"help_text_large_touch_targets_simplified" = "Κάνει όλα τα κουμπιά μεγαλύτερα.\n\nΒοηθά αν:\n• Δυσκολεύεστε να πατήσετε μικρά κουμπιά\n• Τα χέρια σας τρέμουν\n• Φοράτε γάντια\n• Χρησιμοποιείτε ένα χέρι\n\nΤα κουμπιά γίνονται 60pt αντί 44pt.";
"help_text_reduce_motion_simplified" = "Αφαιρεί κινούμενα σχέδια.\n\nΒοηθά αν:\n• Η κίνηση σας προκαλεί ζάλη\n• Σας πονάει το κεφάλι από κίνηση\n• Προτιμάτε τα πράγματα να παραμένουν ακίνητα\n\nΤα πράγματα αλλάζουν αμέσως αντί να κινούνται.";
"help_text_timeout_behavior_simplified" = "Ελέγχει πόσο χρόνο μπορούν να διαρκέσουν εργασίες.\n\nΕπιλογές:\n• Χωρίς όριο: Οι εργασίες δεν σταματούν ποτέ\n• Κανονικό: 30 δευτερόλεπτα\n• Παρατεταμένο: 60 δευτερόλεπτα\n\nΕπιλέξτε «Χωρίς όριο» αν χρειάζεστε περισσότερο χρόνο.";
"help_text_simplified_gestures_simplified" = "Αντικαθιστά δύσκολες χειρονομίες με απλά πατήματα.\n\nΒοηθά αν:\n• Δυσκολεύεστε με σύνθετες αφές\n• Προτιμάτε απλά πατήματα\n• Χρησιμοποιείτε ένα χέρι\n\nΤα πάντα χρησιμοποιούν απλά πατήματα.";
"help_text_haptic_feedback_simplified" = "Κάνει το τηλέφωνό σας να δονείται όταν πατάτε.\n\nΒοηθά:\n• Να ξέρετε ότι πατήσατε κουμπί\n• Να αισθανθείτε σφάλματα ή προειδοποιήσεις\n• Να λαμβάνετε ανάδραση χωρίς να κοιτάτε\n\nΑπενεργοποιήστε αν οι δονήσεις σας ενοχλούν.";
"help_text_simplified_ui_simplified" = "Κάνει την εφαρμογή πιο απλή.\n\nΒοηθά αν:\n• Σας μπερδεύουν πολυσύχναστες οθόνες\n• Προτιμάτε απλές διατάξεις\n• Είστε νέος στην εφαρμογή\n\nΔείχνει λιγότερα πράγματα ταυτόχρονα.";
"help_text_step_indicators_simplified" = "Δείχνει την πρόοδό σας στα βήματα.\n\nΒοηθά:\n• Να ξέρετε πού βρίσκεστε\n• Να βλέπετε πόσα βήματα απομένουν\n• Να παραμένετε οργανωμένοι\n\nΔείχνει «Βήμα 1 από 3» με κουκίδες.";
"help_text_verbose_descriptions_simplified" = "Σας δίνει περισσότερες εξηγήσεις.\n\nΒοηθά:\n• Να κατανοείτε λειτουργίες\n• Να μαθαίνετε πώς να χρησιμοποιείτε την εφαρμογή\n• Να λαμβάνετε περισσότερες λεπτομέρειες\n\nΠαρέχει επιπλέον βοήθεια παντού.";
"help_text_confirm_actions_simplified" = "Σας ζητά να επιβεβαιώσετε σημαντικές ενέργειες.\n\nΒοηθά στην αποφυγή:\n• Τυχαίων διαγραφών\n• Ανεπιθύμητων αλλαγών\n• Λαθών\n\nΘα σας ρωτά πάντα «Είστε σίγουροι;»";
"help_text_manual_code_entry_simplified" = "Σας επιτρέπει να πληκτρολογείτε κωδικούς αντί να σαρώνετε.\n\nΧρησιμοποιήστε το όταν:\n• Η κάμερά σας δεν λειτουργεί\n• Ο κωδικός είναι δύσκολο να σαρωθεί\n• Προτιμάτε την πληκτρολόγηση\n\nΠατήστε «Χειροκίνητη εισαγωγή κωδικού» για πληκτρολόγηση.";
"help_text_voice_input_simplified" = "Σας επιτρέπει να εκφωνείτε κωδικούς αντί να πληκτρολογείτε.\n\nΒοηθά αν:\n• Δυσκολεύεστε να πληκτρολογείτε\n• Προτιμάτε να μιλάτε\n• Θέλετε λειτουργία χωρίς χέρια\n\nΠατήστε το μικρόφωνο και μιλήστε καθαρά.";
"help_text_qr_scanning_simplified" = "Χρησιμοποιεί την κάμερά σας για ανάγνωση τετράγωνων κωδικών.\n\nΤρόπος σάρωσης:\n1. Στρέψτε κάμερα στον κωδικό\n2. Ευθυγραμμίστε τον κωδικό\n3. Αναμείνετε να τον διαβάσει\n\nΣυμβουλές:\n• Χρησιμοποιήστε καλό φωτισμό\n• Κρατήστε σταθερά το τηλέφωνό σας\n• Κρατήστε τον κωδικό επίπεδο";
"help_text_age_verification_simplified" = "Αποδεικνύει ότι είστε αρκετά μεγάλοι χωρίς να κοινοποιείτε τα γενέθλιά σας.\n\nΠώς λειτουργεί:\n1. Η επιχείρηση δημιουργεί αίτημα\n2. Σαρώνετε τον κωδικό τους\n3. Η εφαρμογή δημιουργεί απόδειξη\n4. Η επιχείρηση επιβεβαιώνει ότι είστε αρκετά μεγάλοι\n\nΤα γενέθλιά σας παραμένουν ιδιωτικά.";
"help_text_credentials_simplified" = "Ψηφιακή απόδειξη της ηλικίας σας αποθηκευμένη στο τηλέφωνό σας.\n\nΧαρακτηριστικά:\n• Μόνο στο τηλέφωνό σας\n• Δεν μπορεί να αντιγραφεί\n• Σας κρατά ιδιωτικούς\n• Μπορείτε να τη διαγράψετε ανά πάσα στιγμή\n\nΤη λαμβάνετε από κυβερνητική υπηρεσία.";
"help_text_zero_knowledge_simplified" = "Αποδεικνύει κάτι χωρίς να κοινοποιεί λεπτομέρειες.\n\nΠαράδειγμα:\n• Παλιός τρόπος: Επίδειξη ταυτότητας (δείχνει ακριβή ημερομηνία γέννησης)\n• Νέος τρόπος: Απόδειξη ότι είστε άνω των 18 (η ημερομηνία γέννησης παραμένει ιδιωτική)\n\nΑυτό κρατά τις πληροφορίες σας ιδιωτικές.";
"help_text_credential_issuance_simplified" = "Απόκτηση ψηφιακής απόδειξης ηλικίας σας.\n\nΒήματα:\n1. Πηγαίνετε σε κυβερνητική υπηρεσία\n2. Επιδείξτε ταυτότητα\n3. Λάβετε κωδικό\n4. Σαρώστε τον κωδικό\n5. Η απόδειξη αποθηκεύεται στο τηλέφωνό σας\n\nΚάντε το μία φορά. Μετά χρησιμοποιήστε το πολλές φορές.";
"help_text_officer_mode_simplified" = "Για κυβερνητικούς υπαλλήλους για δημιουργία αποδείξεων.\n\nΑπαιτεί:\n• Κωδικός υπαλλήλου\n• Άδεια χρήσης\n• Ταυτότητα χρήστη για έλεγχο\n\nΒήματα:\n1. Σύνδεση ως υπάλληλος\n2. Έλεγχος ταυτότητας χρήστη\n3. Εισαγωγή ημερομηνίας γέννησης\n4. Δημιουργία κωδικού\n5. Ο χρήστης σαρώνει τον κωδικό\n\nΜόνο για εξουσιοδοτημένους υπαλλήλους.";

