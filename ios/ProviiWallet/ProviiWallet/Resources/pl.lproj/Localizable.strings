/* Help Text Descriptions */
"help_text_extra_large_text" = "Bardzo duży tekst powiększa cały tekst w aplikacji o 50%.\n\nPomaga użytkownikom z:\n• Słabym wzrokiem\n• Trudnościami w czytaniu\n• Zmianami wzroku związanymi z wiekiem\n\nDziała z iOS Dynamic Type dla jeszcze większych rozmiarów.";
"help_text_contrast_level" = "Poziom kontrastu kontroluje kontrast kolorów między tekstem a tłem.\n\nTrzy poziomy:\n• Standardowy: Domyślne kolory\n• Wysoki (AA): Współczynnik kontrastu 4,5:1\n• Maksymalny (AAA): Współczynnik kontrastu 7:1\n\nWyższy kontrast ułatwia czytanie w każdym oświetleniu.";
"help_text_high_contrast" = "Tryb wysokiego kontrastu zwiększa kontrast między tekstem a tłem.\n\nPomaga użytkownikom z:\n• Słabym wzrokiem\n• Wrażliwością na kolory\n• Jasnym otoczeniem\n\nPo włączeniu:\n• Tekst staje się czarny na białym\n• Dodawane są obramowania elementów\n• Kolory są uproszczone";
"help_text_reduce_transparency" = "Zmniejsz przezroczystość usuwa efekty rozmycia i przezroczystości.\n\nPomaga:\n• Poprawić czytelność tekstu\n• Zmniejszyć złożoność wizualną\n• Zwiększyć wydajność na starszych urządzeniach\n• Uczynić treść bardziej przewidywalną";
"help_text_color_blind_mode" = "Tryby dla daltonistów dostosowują kolory dla różnych typów zaburzeń widzenia barwnego.\n\nDostępne tryby:\n• Protanopia: Ślepota na czerwień\n• Deuteranopia: Ślepota na zieleń\n• Tritanopia: Ślepota na niebieskość\n• Monochromatyczny: Tylko skala szarości\n\nTryby zapewniają, że ważne informacje nie są przekazywane tylko przez kolor.";
"help_text_line_spacing" = "Odstęp między wierszami kontroluje odstęp między liniami tekstu.\n\n• Zakres: 1,0x do 2,0x\n• Standard AAA: minimum 1,5x\n• Domyślny: 1,0x\n\nZwiększony odstęp ułatwia czytanie i zapobiega pomijaniu wierszy.";
"help_text_paragraph_spacing" = "Odstęp między akapitami kontroluje odstęp między akapitami.\n\n• Zakres: 1,0x do 3,0x\n• Standard AAA: minimum 2,0x\n• Domyślny: 1,0x\n\nZwiększony odstęp pomaga odróżniać różne sekcje tekstu.";
"help_text_letter_spacing" = "Odstęp między literami kontroluje odstęp między poszczególnymi znakami.\n\n• Zakres: 0,0 em do 0,2 em\n• Standard AAA: minimum 0,12 em\n• Domyślny: 0,0 em\n\nZwiększony odstęp poprawia rozpoznawanie znaków i czytelność.";
"help_text_text_width" = "Szerokość tekstu kontroluje maksymalną długość wiersza.\n\nOpcje:\n• Pełna szerokość: Bez maksimum\n• Komfortowa (80 znaków): Optymalna do czytania\n• Wąska (60 znaków): Do skupionego czytania\n\nZalecenia AAA: maksymalnie 80 znaków na wiersz.";
"help_text_large_touch_targets" = "Większe obszary dotykowe powiększają przyciski i elementy do co najmniej 60 pkt.\n\nPomaga:\n• Osobom z niepełnosprawnością ruchową\n• Przy drżeniu rąk\n• Przy korzystaniu w rękawiczkach\n• Przy obsłudze jedną ręką\n\nStandardowe minimum to 44 pkt; ustawienie zwiększa do 60 pkt.";
"help_text_reduce_motion" = "Zmniejsz ruch minimalizuje lub usuwa animacje.\n\nPomaga użytkownikom z:\n• Wrażliwością na ruch\n• Zaburzeniami przedsionkowymi\n• Epilepsją\n• Migrenami\n\nPo włączeniu animacje zastępowane są natychmiastowymi przejściami.";
"help_text_timeout_behavior" = "Zachowanie limitu czasu kontroluje czas operacji przed przekroczeniem limitu.\n\nOpcje:\n• Bez limitu czasu (AAA): Operacje nigdy nie przekraczają limitu\n• Standardowy (30 s): Domyślny limit\n• Rozszerzony (60 s): Dwa razy więcej niż standardowy\n\nTryb bez limitu spełnia standardy dostępności AAA.";
"help_text_simplified_gestures" = "Uproszczone gesty zastępują złożone gesty wielodotykowe prostymi stuknięciami.\n\nPomaga:\n• Osobom z niepełnosprawnością ruchową\n• Przy ograniczonej sprawności rąk\n• Przy korzystaniu z urządzeń wspomagających\n• Przy obsłudze jedną ręką\n\nZłożone gesty zastępowane są przyciskami.";
"help_text_haptic_feedback" = "Sprzężenie dotykowe zapewnia wibracje przy akcjach.\n\nPomaga:\n• Potwierdzać naciśnięcia przycisków\n• Sygnalizować błędy\n• Dostarczać informacji zwrotnej bez patrzenia\n• Użytkownikom z wadami słuchu lub wzroku\n\nMożna wyłączyć, jeśli wibracje są uciążliwe.";
"help_text_simplified_ui" = "Uproszczony interfejs zmniejsza złożoność wizualną.\n\nPomaga:\n• Osobom z niepełnosprawnościami poznawczymi\n• Przy trudnościach w nauce\n• Przy zaburzeniach uwagi\n• Nowym lub niedoświadczonym użytkownikom\n\nPo włączeniu:\n• Mniej elementów na ekranie\n• Większe, wyraźniejsze elementy\n• Mniej zakłóceń wizualnych";
"help_text_step_indicators" = "Wskaźniki kroków pokazują postęp w procesach wieloetapowych.\n\nPomaga:\n• Wiedzieć, gdzie jesteś w procesie\n• Wiedzieć, ile kroków pozostało\n• Zmniejszyć obciążenie poznawcze\n• Zapewnić wyraźną strukturę\n\nWyświetla „Krok X z Y” z wizualnymi kropkami postępu.";
"help_text_verbose_descriptions" = "Szczegółowe opisy zapewniają dodatkowy tekst objaśniający.\n\nPomaga:\n• Rozumieć złożone funkcje\n• Uczyć się korzystania z aplikacji\n• Wsparciu poznawczemu\n• Użytkownikom czytnika ekranu\n\nDostarcza kontekst i instrukcje dla wszystkich funkcji.";
"help_text_confirm_actions" = "Potwierdzaj akcje pyta o potwierdzenie przed ważnymi akcjami.\n\nZapobiega:\n• Przypadkowym usunięciom\n• Niezamierzonym zmianom\n• Przedwczesnym przesłaniom\n• Utracie danych\n\nUwaga: Destrukcyjne akcje zawsze wymagają potwierdzenia (wymóg AAA).";
"help_text_manual_code_entry" = "Ręczne wprowadzanie kodu umożliwia wpisywanie kodów zamiast skanowania QR.\n\nPrzydatne gdy:\n• Aparat nie działa\n• Kod QR jest uszkodzony lub nieczytelny\n• Korzystasz z czytnika ekranu\n• Wolisz pisać niż skanować\n\nStuknij „Wprowadź kod ręcznie”, aby wpisać kod widoczny na ekranie.";
"help_text_voice_input" = "Wprowadzanie głosowe umożliwia mówienie kodów zamiast skanowania lub pisania.\n\nPomaga:\n• Przy ograniczonej mobilności\n• Użytkownikom czytnika ekranu\n• Przy obsłudze bez użycia rąk\n• Osobom preferującym głos\n\nStuknij przycisk mikrofonu i mów wyraźnie po wyświetleniu monitu.";
"help_text_qr_scanning" = "Skanowanie kodu QR używa aparatu do odczytu kodów szybkiej odpowiedzi.\n\nJak skanować:\n1. Skieruj aparat na kod QR\n2. Wyrównaj kod w kadrze\n3. Poczekaj na automatyczne wykrycie\n\nWskazówki:\n• Zapewnij dobre oświetlenie\n• Trzymaj urządzenie stabilnie\n• Upewnij się, że kod QR jest płaski i widoczny\n• Jeśli skanowanie nie powiedzie się, spróbuj ręcznego wprowadzania";
"help_text_age_verification" = "Weryfikacja wieku udowadnia spełnienie wymogu wiekowego bez ujawniania rzeczywistego wieku.\n\nJak to działa:\n1. Weryfikator generuje wyzwanie\n2. Skanujesz kod QR lub wprowadzasz ręcznie\n3. Aplikacja tworzy dowód z wiedzą zerową\n4. Weryfikator potwierdza spełnienie wymogu\n\nOchrona prywatności:\n• Twoja data urodzenia nigdy nie jest udostępniana\n• Weryfikator dowiaduje się tylko, czy spełniasz wymóg\n• Brak śledzenia ani gromadzenia danych";
"help_text_credentials" = "Cyfrowe poświadczenia to kryptograficzne dowody wieku bezpiecznie przechowywane na urządzeniu.\n\nFunkcje:\n• Przechowywane tylko na urządzeniu\n• Nie można ich skopiować ani sfałszować\n• Używane do weryfikacji z zachowaniem prywatności\n• Można je usunąć w dowolnym momencie\n\nPoświadczenie należy uzyskać od autoryzowanego wystawcy przed weryfikacją wieku.";
"help_text_zero_knowledge" = "Dowody z wiedzą zerową umożliwiają udowodnienie prawdziwości czegoś bez ujawniania szczegółów.\n\nPrzykład:\n• Tradycyjnie: Pokazujesz dowód (ujawnia dokładną datę urodzenia)\n• Dowód z wiedzą zerową: Udowadniasz, że masz ponad 18 lat bez pokazywania daty urodzenia\n\nKorzyści:\n• Maksymalna ochrona prywatności\n• Brak udostępniania danych osobowych\n• Bezpieczeństwo kryptograficzne\n• Nie można sfałszować ani odtworzyć\n\nTo jest główna technologia zapewniająca prywatność Provii Wallet.";
"help_text_credential_issuance" = "Wydawanie poświadczeń to proces uzyskiwania cyfrowego poświadczenia wieku od autoryzowanego wystawcy.\n\nKroki:\n1. Odwiedź autoryzowanego wystawcę (np. urząd rządowy)\n2. Udowodnij tożsamość oficjalnym dokumentem\n3. Otrzymaj kod QR lub link bezpośredni od wystawcy\n4. Zeskanuj kod QR lub stuknij link\n5. Poświadczenie jest obliczane lokalnie i zapisywane na urządzeniu\n\nProces ślepego zaświadczenia zapewnia, że data urodzenia nigdy nie jest przesyłana przez sieć.\nWystarczy to zrobić raz. Poświadczenie można następnie używać do nieograniczonej liczby weryfikacji.";
"help_text_officer_mode" = "Tryb funkcjonariusza przeznaczony jest dla autoryzowanych wystawców tworzących poświadczenia.\n\nTryb wymaga:\n• Uwierzytelniania funkcjonariusza z YubiKey\n• Autoryzacji od organu wydającego\n• Fizycznej weryfikacji dokumentu użytkownika\n\nProces:\n1. Uwierzytelnij się jako funkcjonariusz\n2. Zweryfikuj oficjalny dokument użytkownika\n3. Wprowadź datę urodzenia użytkownika\n4. Wygeneruj kod QR zaświadczenia\n5. Użytkownik skanuje kod, aby otrzymać poświadczenie\n\nTylko autoryzowany personel powinien używać tego trybu.";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "Powiększa cały tekst o 50%.\n\nPomaga gdy:\n• Masz problemy z widzeniem\n• Trudno Ci czytać\n• Potrzebujesz większego tekstu\n\nDziała z ustawieniami rozmiaru tekstu telefonu.";
"help_text_contrast_level_simplified" = "Zmienia ciemność tekstu.\n\nTrzy opcje:\n• Standardowy: Normalne kolory\n• Wysoki: Ciemniejszy tekst, łatwiejszy do czytania\n• Maksymalny: Bardzo ciemny tekst, najlepszy do czytania\n\nCiemniejszy tekst jest łatwiejszy do czytania.";
"help_text_high_contrast_simplified" = "Ułatwia widzenie tekstu.\n\nPomaga gdy:\n• Masz problemy z widzeniem\n• Potrzebujesz ciemniejszego tekstu\n• Używasz aplikacji w jasnym świetle\n\nTekst staje się czarny na białym.";
"help_text_reduce_transparency_simplified" = "Usuwa rozmyte efekty.\n\nPomaga:\n• Uczynić tekst wyraźniejszym\n• Uprościć aplikację\n• Przyspieszyć starsze telefony\n\nWszystko wygląda bardziej wyraźnie.";
"help_text_color_blind_mode_simplified" = "Zmienia kolory, aby lepiej widzieć.\n\nOpcje:\n• Tryb ślepoty na czerwień\n• Tryb ślepoty na zieleń\n• Tryb ślepoty na niebieskość\n• Tryb szarości\n\nPomaga widzieć ważne rzeczy.";
"help_text_line_spacing_simplified" = "Zmienia odstęp między liniami tekstu.\n\nMożna wybrać od 1,0x do 2,0x.\nDomyślny: 1,0x.\n\nWiększy odstęp ułatwia czytanie.";
"help_text_paragraph_spacing_simplified" = "Zmienia odstęp między akapitami.\n\nMożna wybrać od 1,0x do 3,0x.\nDomyślny: 1,0x.\n\nWiększy odstęp pomaga zobaczyć, gdzie zaczynają się nowe myśli.";
"help_text_letter_spacing_simplified" = "Zmienia odstęp między literami.\n\nMożna wybrać od 0,0 do 0,2.\nDomyślny: 0,0.\n\nWiększy odstęp sprawia, że litery są wyraźniejsze.";
"help_text_text_width_simplified" = "Kontroluje szerokość tekstu.\n\nOpcje:\n• Pełna szerokość: Cały ekran\n• Średnia: Dobra do czytania\n• Wąska: Najlepsza do skupienia\n\nŚrednia szerokość jest najłatwiejsza do czytania.";
"help_text_large_touch_targets_simplified" = "Powiększa wszystkie przyciski.\n\nPomaga gdy:\n• Masz problemy z dotykaniem małych przycisków\n• Masz drżące ręce\n• Nosisz rękawiczki\n• Używasz jednej ręki\n\nPrzyciski powiększają się do 60 pkt zamiast 44 pkt.";
"help_text_reduce_motion_simplified" = "Usuwa poruszające się animacje.\n\nPomaga gdy:\n• Ruch powoduje zawroty głowy\n• Masz bóle głowy od ruchu\n• Wolisz, gdy wszystko pozostaje w miejscu\n\nRzeczy zmieniają się natychmiast zamiast się poruszać.";
"help_text_timeout_behavior_simplified" = "Kontroluje jak długo zadania mogą trwać.\n\nOpcje:\n• Bez limitu: Zadania nigdy nie kończą się\n• Normalny: 30 sekund\n• Dłuższy: 60 sekund\n\nWybierz „Bez limitu”, jeśli potrzebujesz więcej czasu.";
"help_text_simplified_gestures_simplified" = "Zastępuje trudne gesty prostymi stuknięciami.\n\nPomaga gdy:\n• Masz problemy ze złożonymi dotknięciami\n• Wolisz proste stuknięcia\n• Używasz jednej ręki\n\nWszystko używa prostych stuknięć.";
"help_text_haptic_feedback_simplified" = "Sprawia, że telefon wibruje po stuknięciu.\n\nPomaga:\n• Wiedzieć, że stuknięto przycisk\n• Odczuć błędy lub ostrzeżenia\n• Uzyskać informacje zwrotne bez patrzenia\n\nWyłącz, jeśli wibracje przeszkadzają.";
"help_text_simplified_ui_simplified" = "Upraszcza aplikację.\n\nPomaga gdy:\n• Zagubisz się w zatłoczonych ekranach\n• Wolisz proste układy\n• Jesteś nowy w aplikacji\n\nPokazuje mniej rzeczy naraz.";
"help_text_step_indicators_simplified" = "Pokazuje postęp przez kolejne kroki.\n\nPomaga:\n• Wiedzieć, gdzie jesteś\n• Zobaczyć, ile kroków pozostało\n• Zachować porządek\n\nWyświetla „Krok 1 z 3” z kropkami.";
"help_text_verbose_descriptions_simplified" = "Daje więcej wyjaśnień.\n\nPomaga:\n• Rozumieć funkcje\n• Uczyć się korzystania z aplikacji\n• Uzyskać więcej szczegółów\n\nDostarcza dodatkowej pomocy wszędzie.";
"help_text_confirm_actions_simplified" = "Pyta o potwierdzenie ważnych akcji.\n\nZapobiega:\n• Przypadkowym usunięciom\n• Niechcianym zmianom\n• Błędom\n\nZawsze będziesz pytany „Czy na pewno?”";
"help_text_manual_code_entry_simplified" = "Pozwala wpisywać kody zamiast skanować.\n\nUżyj gdy:\n• Aparat nie działa\n• Kod jest trudny do skanowania\n• Wolisz pisać\n\nStuknij „Wprowadź kod ręcznie”, aby pisać.";
"help_text_voice_input_simplified" = "Pozwala mówić kody zamiast pisać.\n\nPomaga gdy:\n• Masz problemy z pisaniem\n• Wolisz mówić\n• Chcesz obsługi bez rąk\n\nStuknij mikrofon i mów wyraźnie.";
"help_text_qr_scanning_simplified" = "Używa aparatu do odczytu kwadratowych kodów.\n\nJak skanować:\n1. Skieruj aparat na kod\n2. Wyrównaj kod\n3. Poczekaj na odczyt\n\nWskazówki:\n• Użyj dobrego oświetlenia\n• Trzymaj telefon stabilnie\n• Upewnij się, że kod jest płaski";
"help_text_age_verification_simplified" = "Udowadnia, że jesteś wystarczająco dorosły bez ujawniania daty urodzenia.\n\nJak to działa:\n1. Firma tworzy żądanie\n2. Skanujesz jej kod\n3. Aplikacja tworzy dowód\n4. Firma potwierdza, że jesteś wystarczająco dorosły\n\nTwoja data urodzenia pozostaje prywatna.";
"help_text_credentials_simplified" = "Cyfrowy dowód wieku przechowywany na telefonie.\n\nFunkcje:\n• Tylko na telefonie\n• Nie można skopiować\n• Zachowuje prywatność\n• Można usunąć w dowolnym momencie\n\nOtrzymujesz je w urzędzie rządowym.";
"help_text_zero_knowledge_simplified" = "Udowadnia coś bez ujawniania szczegółów.\n\nPrzykład:\n• Stary sposób: Pokazujesz dowód (ujawnia datę urodzenia)\n• Nowy sposób: Udowadniasz, że masz ponad 18 lat (data urodzenia pozostaje prywatna)\n\nTo chroni Twoje informacje.";
"help_text_credential_issuance_simplified" = "Uzyskiwanie cyfrowego dowodu wieku.\n\nKroki:\n1. Idź do urzędu rządowego\n2. Pokaż dowód tożsamości\n3. Otrzymaj kod\n4. Zeskanuj kod\n5. Dowód jest zapisany na telefonie\n\nZrób to raz. Potem używaj wielokrotnie.";
"help_text_officer_mode_simplified" = "Dla pracowników rządowych tworzących poświadczenia.\n\nWymaga:\n• Hasła funkcjonariusza\n• Uprawnień do użycia\n• Dokumentu użytkownika do sprawdzenia\n\nKroki:\n1. Zaloguj się jako funkcjonariusz\n2. Sprawdź dokument użytkownika\n3. Wprowadź datę urodzenia\n4. Utwórz kod\n5. Użytkownik skanuje kod\n\nTylko dla autoryzowanych pracowników.";

