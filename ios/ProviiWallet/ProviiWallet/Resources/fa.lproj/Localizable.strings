/* متن‌های راهنمای توضیحی */
"help_text_extra_large_text" = "متن بسیار بزرگ همه متن‌های برنامه را ۵۰٪ افزایش می‌دهد.\n\nبرای کاربران زیر مفید است:\n• بینایی ضعیف\n• مشکلات خواندن\n• تغییرات بینایی مرتبط با سن\n\nبا Dynamic Type سیستم ⁨iOS⁩ برای اندازه‌های بزرگ‌تر کار می‌کند.";
"help_text_contrast_level" = "سطح کنتراست کنتراست رنگ بین متن و پس‌زمینه را کنترل می‌کند.\n\nسه سطح موجود:\n• استاندارد: رنگ‌های پیش‌فرض\n• بالا (⁨AA⁩): نسبت کنتراست ۴٫۵:۱\n• حداکثر (⁨AAA⁩): نسبت کنتراست ۷:۱\n\nکنتراست بالاتر متن را در همه شرایط نوری آسان‌تر می‌خواند.";
"help_text_high_contrast" = "حالت کنتراست بالا کنتراست بین متن و پس‌زمینه را افزایش می‌دهد.\n\nبرای کاربران زیر مفید است:\n• بینایی ضعیف\n• حساسیت رنگی\n• محیط‌های صفحه روشن\n\nهنگام فعال بودن:\n• متن سیاه روی سفید می‌شود\n• به عناصر حاشیه اضافه می‌شود\n• رنگ‌ها ساده می‌شوند";
"help_text_reduce_transparency" = "کاهش شفافیت جلوه‌های تار و شفافیت را در سراسر برنامه حذف می‌کند.\n\nکمک می‌کند:\n• خوانایی متن را بهبود بخشد\n• پیچیدگی بصری را کاهش دهد\n• عملکرد دستگاه‌های قدیمی را افزایش دهد\n• محتوا را قابل پیش‌بینی‌تر کند";
"help_text_color_blind_mode" = "حالت‌های کوررنگی رنگ‌ها را برای انواع مختلف نقص بینایی رنگی تنظیم می‌کنند.\n\nحالت‌های موجود:\n• پروتانوپیا: کوررنگی قرمز\n• دوترانوپیا: کوررنگی سبز\n• تریتانوپیا: کوررنگی آبی\n• تک‌رنگ: فقط مقیاس خاکستری\n\nاین حالت‌ها اطمینان می‌دهند اطلاعات مهم فقط از طریق رنگ منتقل نمی‌شود.";
"help_text_line_spacing" = "فاصله خطوط فاصله بین سطرهای متن را کنترل می‌کند.\n\n• محدوده: ۱٫۰ تا ۲٫۰ برابر\n• استاندارد ⁨AAA⁩: حداقل ۱٫۵ برابر\n• پیش‌فرض: ۱٫۰ برابر\n\nافزایش فاصله سطر خواندن را آسان‌تر کرده و از جا افتادن سطر جلوگیری می‌کند.";
"help_text_paragraph_spacing" = "فاصله پاراگراف فاصله بین پاراگراف‌ها را کنترل می‌کند.\n\n• محدوده: ۱٫۰ تا ۳٫۰ برابر\n• استاندارد ⁨AAA⁩: حداقل ۲٫۰ برابر\n• پیش‌فرض: ۱٫۰ برابر\n\nافزایش فاصله پاراگراف به تمایز بین بخش‌های مختلف متن کمک می‌کند.";
"help_text_letter_spacing" = "فاصله حروف فاصله بین کاراکترهای منفرد را کنترل می‌کند.\n\n• محدوده: ۰٫۰ تا ۰٫۲ em\n• استاندارد ⁨AAA⁩: حداقل ۰٫۱۲ em\n• پیش‌فرض: ۰٫۰ em\n\nافزایش فاصله حروف تشخیص کاراکتر و خوانایی را بهبود می‌بخشد.";
"help_text_text_width" = "عرض متن حداکثر طول سطر را برای خواندن راحت‌تر کنترل می‌کند.\n\nگزینه‌ها:\n• عرض کامل: بدون حداکثر\n• راحت (۸۰ کاراکتر): بهینه برای خواندن\n• باریک (۶۰ کاراکتر): برای خواندن متمرکز\n\nدستورالعمل‌های ⁨AAA⁩ حداکثر ۸۰ کاراکتر در هر سطر را توصیه می‌کند.";
"help_text_large_touch_targets" = "اهداف لمسی بزرگ‌تر تمام دکمه‌ها و عناصر تعاملی را حداقل ۶۰ نقطه می‌کند.\n\nبرای موارد زیر مفید است:\n• اختلالات حرکتی\n• لرزش یا تکان\n• استفاده با دستکش\n• استفاده با یک دست\n\nحداقل استاندارد ۴۴ نقطه است؛ این تنظیم به ۶۰ نقطه افزایش می‌دهد.";
"help_text_reduce_motion" = "کاهش حرکت انیمیشن‌ها را در سراسر برنامه به حداقل می‌رساند یا حذف می‌کند.\n\nبرای کاربران زیر مفید است:\n• حساسیت به حرکت\n• اختلالات دهلیزی\n• صرع\n• عوامل تحریک‌کننده میگرن\n\nهنگام فعال بودن، انیمیشن‌ها با انتقال‌های فوری جایگزین می‌شوند.";
"help_text_timeout_behavior" = "رفتار مهلت زمانی کنترل می‌کند عملیات چقدر می‌تواند طول بکشد.\n\nگزینه‌ها:\n• بدون مهلت (⁨AAA⁩): عملیات هرگز مهلت ندارد\n• استاندارد (۳۰ ثانیه): مهلت پیش‌فرض\n• طولانی (۶۰ ثانیه): دو برابر زمان استاندارد\n\nحالت بدون مهلت با استانداردهای دسترس‌پذیری ⁨AAA⁩ مطابقت دارد.";
"help_text_simplified_gestures" = "حرکات ساده‌شده حرکات چندلمسی پیچیده را به ضربه‌های ساده کاهش می‌دهد.\n\nبرای موارد زیر مفید است:\n• اختلالات حرکتی\n• مهارت محدود\n• استفاده از دستگاه‌های کمکی\n• عملکرد با یک دست\n\nحرکات پیچیده با دکمه‌ها و ضربه‌های ساده جایگزین می‌شوند.";
"help_text_haptic_feedback" = "بازخورد لمسی برای اقدامات و اعلان‌ها لرزش ارائه می‌دهد.\n\nبرای موارد زیر مفید است:\n• تأیید فشار دکمه\n• هشدار درباره خطاها\n• ارائه بازخورد غیربصری\n• کاربران دارای اختلال شنوایی یا بینایی\n\nاگر لرزش ناراحت‌کننده است می‌توانید آن را غیرفعال کنید.";
"help_text_simplified_ui" = "رابط ساده‌شده پیچیدگی بصری را در سراسر برنامه کاهش می‌دهد.\n\nبرای موارد زیر مفید است:\n• معلولیت‌های شناختی\n• مشکلات یادگیری\n• اختلالات توجه\n• کاربران جدید یا کم‌تجربه\n\nهنگام فعال بودن:\n• عناصر کمتری روی صفحه\n• کنترل‌های بزرگ‌تر و واضح‌تر\n• سر و صدای بصری کمتر";
"help_text_step_indicators" = "نشانگرهای مرحله پیشرفت شما را از طریق فرآیندهای چندمرحله‌ای نشان می‌دهند.\n\nکمک می‌کند:\n• بفهمید کجا هستید\n• بدانید چند مرحله باقی مانده\n• بار شناختی را کاهش دهد\n• ساختار واضح ارائه دهد\n\n«مرحله X از Y» را با نقاط پیشرفت بصری نشان می‌دهد.";
"help_text_verbose_descriptions" = "توضیحات مفصل در سراسر برنامه متن توضیحی اضافه فراهم می‌کند.\n\nبرای موارد زیر مفید است:\n• درک ویژگی‌های پیچیده\n• یادگیری نحوه استفاده از برنامه\n• پشتیبانی شناختی\n• کاربران صفحه‌خوان\n\nزمینه و دستورالعمل برای همه ویژگی‌ها فراهم می‌کند.";
"help_text_confirm_actions" = "تأیید اقدامات قبل از اقدامات مهم تأییدیه می‌خواهد.\n\nجلوگیری می‌کند از:\n• حذف‌های تصادفی\n• تغییرات ناخواسته\n• ارسال زودهنگام\n• از دست دادن داده\n\nتوجه: اقدامات مخرب همیشه نیاز به تأیید دارند (الزام ⁨AAA⁩).";
"help_text_manual_code_entry" = "ورود دستی کد به شما اجازه می‌دهد کدها را به جای اسکن کدهای ⁨QR⁩ تایپ کنید.\n\nهنگامی مفید است:\n• دوربین کار نمی‌کند\n• کد ⁨QR⁩ آسیب دیده یا نامشخص است\n• از صفحه‌خوان استفاده می‌کنید\n• تایپ را به اسکن ترجیح می‌دهید\n\nکافی است روی «ورود دستی کد» ضربه بزنید تا کد نمایش داده‌شده را تایپ کنید.";
"help_text_voice_input" = "ورودی صوتی به شما اجازه می‌دهد کدها را به جای اسکن یا تایپ بگویید.\n\nبرای موارد زیر مفید است:\n• تحرک محدود\n• کاربران صفحه‌خوان\n• عملکرد بدون دست\n• ترجیح برای صدا\n\nروی دکمه میکروفون ضربه بزنید و هنگام درخواست به وضوح صحبت کنید.";
"help_text_qr_scanning" = "اسکن کد ⁨QR⁩ از دوربین شما برای خواندن کدهای پاسخ سریع استفاده می‌کند.\n\nنحوه اسکن:\n‏۱. دوربین را به سمت کد ⁨QR⁩ بگیرید\n‏۲. کد را در قاب تنظیم کنید\n‏۳. منتظر تشخیص خودکار باشید\n\nنکات:\n• نور کافی باشد\n• دستگاه را ثابت نگه دارید\n• کد ⁨QR⁩ را صاف و بدون مانع نگه دارید\n• اگر اسکن ناموفق بود، ورود دستی کد را امتحان کنید";
"help_text_age_verification" = "تأیید سن ثابت می‌کند که یک شرط سنی را برآورده می‌کنید بدون اینکه سن واقعی یا تاریخ تولد شما فاش شود.\n\nنحوه کارکرد:\n‏۱. تأییدکننده یک چالش ایجاد می‌کند\n‏۲. کد ⁨QR⁩ را اسکن می‌کنید یا دستی وارد می‌کنید\n‏۳. برنامه یک اثبات دانش صفر ایجاد می‌کند\n‏۴. تأییدکننده تأیید می‌کند که شرط را برآورده می‌کنید\n\nحریم خصوصی محافظت شده:\n• تاریخ تولد شما هرگز به اشتراک گذاشته نمی‌شود\n• تأییدکننده فقط می‌فهمید شرط را برآورده می‌کنید\n• بدون ردیابی یا جمع‌آوری داده";
"help_text_credentials" = "مدارک دیجیتال اثبات‌های رمزنگاری‌شده از سن شما هستند که به‌طور امن روی دستگاهتان ذخیره شده‌اند.\n\nویژگی‌ها:\n• فقط روی دستگاه شما ذخیره شده\n• نمی‌توان کپی یا جعل کرد\n• برای تأیید حفظ‌کننده حریم خصوصی استفاده می‌شود\n• می‌توان در هر زمان حذف کرد\n\nباید مدرک را از یک صادرکننده مجاز (مانند یک اداره دولتی) قبل از تأیید سن دریافت کنید.";
"help_text_zero_knowledge" = "اثبات‌های دانش صفر به شما اجازه می‌دهند ثابت کنید چیزی درست است بدون اینکه اطلاعات زیربنایی را فاش کنید.\n\nمثال:\n• سنتی: نشان دادن شناسه (تاریخ تولد دقیق را فاش می‌کند)\n• دانش صفر: ثابت کردن بالای ۱۸ سال بودن بدون نشان دادن تاریخ تولد\n\nمزایا:\n• حداکثر حفاظت از حریم خصوصی\n• بدون اشتراک‌گذاری داده شخصی\n• امنیت رمزنگاری\n• نمی‌توان جعل یا تکرار کرد\n\nاین فناوری اصلی است که Provii Wallet را خصوصی می‌کند.";
"help_text_credential_issuance" = "صدور مدرک فرآیند دریافت مدرک سنی دیجیتال از یک صادرکننده مجاز است.\n\nمراحل:\n‏۱. از صادرکننده مجاز بازدید کنید (مثلاً یک اداره دولتی)\n‏۲. با شناسه رسمی هویت خود را ثابت کنید\n‏۳. کد ⁨QR⁩ یا لینک عمیق از صادرکننده دریافت کنید\n‏۴. کد ⁨QR⁩ را اسکن کنید یا روی لینک ضربه بزنید\n‏۵. مدرک به صورت محلی محاسبه و روی دستگاهتان ذخیره می‌شود\n\nفرآیند تأییدیه کور اطمینان می‌دهد تاریخ تولد شما هرگز از طریق شبکه منتقل نمی‌شود.\nفقط یک بار این کار را انجام دهید. سپس می‌توانید از مدرک برای تأییدهای نامحدود استفاده کنید.";
"help_text_officer_mode" = "حالت مسئول برای صادرکنندگان مجاز است تا مدارک برای کاربران ایجاد کنند.\n\nاین حالت نیاز دارد به:\n• احراز هویت مسئول با ⁨YubiKey⁩\n• مجوز از مرجع صدور\n• تأیید فیزیکی شناسه کاربر\n\nفرآیند:\n‏۱. به عنوان مسئول احراز هویت کنید\n‏۲. شناسه رسمی کاربر را تأیید کنید\n‏۳. تاریخ تولد کاربر را وارد کنید\n‏۴. کد ⁨QR⁩ تأییدیه ایجاد کنید\n‏۵. کاربر کد را اسکن می‌کند تا مدرک دریافت کند\n\nفقط پرسنل مجاز باید از این حالت استفاده کنند.";

/* متن‌های راهنمای ساده‌شده */
"help_text_extra_large_text_simplified" = "همه متن‌ها را ۵۰٪ بزرگ‌تر می‌کند.\n\nاگر موارد زیر را دارید کمک می‌کند:\n• مشکل دیدن\n• مشکل خواندن\n• نیاز به متن بزرگ‌تر\n\nبا تنظیمات اندازه متن گوشی کار می‌کند.";
"help_text_contrast_level_simplified" = "تیرگی متن را تغییر می‌دهد.\n\nسه انتخاب:\n• استاندارد: رنگ‌های معمولی\n• بالا: متن تیره‌تر برای خواندن آسان\n• حداکثر: متن بسیار تیره برای بهترین خواندن\n\nمتن تیره‌تر آسان‌تر خوانده می‌شود.";
"help_text_high_contrast_simplified" = "متن را آسان‌تر می‌کند ببینید.\n\nاگر موارد زیر را دارید کمک می‌کند:\n• مشکل دیدن\n• نیاز به متن تیره‌تر\n• استفاده از برنامه در نور روشن\n\nمتن سیاه روی سفید می‌شود.";
"help_text_reduce_transparency_simplified" = "جلوه‌های تار را حذف می‌کند.\n\nکمک می‌کند:\n• متن واضح‌تر شود\n• برنامه ساده‌تر شود\n• گوشی‌های قدیمی سریع‌تر شوند\n\nهمه چیز محکم‌تر به نظر می‌رسد.";
"help_text_color_blind_mode_simplified" = "رنگ‌ها را تغییر می‌دهد تا بهتر ببینید.\n\nانتخاب‌ها:\n• حالت کوررنگی قرمز\n• حالت کوررنگی سبز\n• حالت کوررنگی آبی\n• فقط خاکستری\n\nکمک می‌کند چیزهای مهم را ببینید.";
"help_text_line_spacing_simplified" = "فاصله بین سطرهای متن را تغییر می‌دهد.\n\nمی‌توانید از ۱٫۰ تا ۲٫۰ برابر انتخاب کنید.\nپیش‌فرض ۱٫۰ برابر است.\n\nفاصله بیشتر خواندن را آسان‌تر می‌کند.";
"help_text_paragraph_spacing_simplified" = "فاصله بین پاراگراف‌ها را تغییر می‌دهد.\n\nمی‌توانید از ۱٫۰ تا ۳٫۰ برابر انتخاب کنید.\nپیش‌فرض ۱٫۰ برابر است.\n\nفاصله بیشتر کمک می‌کند ببینید ایده‌های جدید کجا شروع می‌شوند.";
"help_text_letter_spacing_simplified" = "فاصله بین حروف را تغییر می‌دهد.\n\nمی‌توانید از ۰٫۰ تا ۰٫۲ انتخاب کنید.\nپیش‌فرض ۰٫۰ است.\n\nفاصله بیشتر حروف را واضح‌تر می‌کند.";
"help_text_text_width_simplified" = "عرض متن را کنترل می‌کند.\n\nانتخاب‌ها:\n• عرض کامل: از کل صفحه استفاده می‌کند\n• متوسط: برای خواندن مناسب\n• باریک: برای تمرکز بهتر\n\nعرض متوسط آسان‌ترین برای خواندن است.";
"help_text_large_touch_targets_simplified" = "همه دکمه‌ها را بزرگ‌تر می‌کند.\n\nاگر موارد زیر را دارید کمک می‌کند:\n• مشکل ضربه زدن به دکمه‌های کوچک\n• لرزش دست\n• دستکش پوشیده‌اید\n• با یک دست استفاده می‌کنید\n\nدکمه‌ها به جای ۴۴ نقطه ۶۰ نقطه می‌شوند.";
"help_text_reduce_motion_simplified" = "انیمیشن‌های متحرک را حذف می‌کند.\n\nاگر موارد زیر را دارید کمک می‌کند:\n• حرکت باعث سرگیجه می‌شود\n• حرکت سردرد ایجاد می‌کند\n• ترجیح می‌دهید چیزها ثابت بمانند\n\nچیزها به جای حرکت کردن فوری تغییر می‌کنند.";
"help_text_timeout_behavior_simplified" = "کنترل می‌کند وظایف چقدر می‌توانند طول بکشند.\n\nانتخاب‌ها:\n• بدون محدودیت: وظایف هرگز متوقف نمی‌شوند\n• معمولی: ۳۰ ثانیه\n• طولانی‌تر: ۶۰ ثانیه\n\n«بدون محدودیت» را انتخاب کنید اگر به زمان بیشتری نیاز دارید.";
"help_text_simplified_gestures_simplified" = "حرکات سخت را با ضربه‌های ساده جایگزین می‌کند.\n\nاگر موارد زیر را دارید کمک می‌کند:\n• مشکل با لمس‌های پیچیده\n• ترجیح دارید ضربه‌های ساده بزنید\n• با یک دست استفاده می‌کنید\n\nهمه چیز از ضربه‌های ساده استفاده می‌کند.";
"help_text_haptic_feedback_simplified" = "گوشی را هنگام ضربه زدن به لرزش در می‌آورد.\n\nکمک می‌کند:\n• بدانید به دکمه ضربه زده‌اید\n• خطاها یا هشدارها را حس کنید\n• بدون نگاه کردن بازخورد دریافت کنید\n\nاگر لرزش آزاردهنده است آن را خاموش کنید.";
"help_text_simplified_ui_simplified" = "برنامه را ساده‌تر می‌کند.\n\nاگر موارد زیر را دارید کمک می‌کند:\n• صفحات شلوغ گیج‌کننده است\n• طرح‌بندی‌های ساده را ترجیح می‌دهید\n• تازه‌وارد برنامه هستید\n\nچیزهای کمتری در یک بار نشان می‌دهد.";
"help_text_step_indicators_simplified" = "پیشرفت شما را از طریق مراحل نشان می‌دهد.\n\nکمک می‌کند:\n• بدانید کجا هستید\n• ببینید چند مرحله باقی مانده\n• سازمان‌یافته بمانید\n\n«مرحله ۱ از ۳» را با نقاط نشان می‌دهد.";
"help_text_verbose_descriptions_simplified" = "توضیحات بیشتری می‌دهد.\n\nکمک می‌کند:\n• ویژگی‌ها را بفهمید\n• نحوه استفاده از برنامه را یاد بگیرید\n• جزئیات بیشتری دریافت کنید\n\nدر همه جا کمک اضافی فراهم می‌کند.";
"help_text_confirm_actions_simplified" = "برای اقدامات مهم تأییدیه می‌خواهد.\n\nجلوگیری می‌کند از:\n• حذف‌های تصادفی\n• تغییرات ناخواسته\n• اشتباهات\n\nهمیشه پرسیده می‌شود «آیا مطمئن هستید؟»";
"help_text_manual_code_entry_simplified" = "اجازه می‌دهد کدها را به جای اسکن تایپ کنید.\n\nاز این استفاده کنید وقتی:\n• دوربین کار نمی‌کند\n• اسکن کد سخت است\n• تایپ را ترجیح می‌دهید\n\n«ورود دستی کد» را ضربه بزنید تا تایپ کنید.";
"help_text_voice_input_simplified" = "اجازه می‌دهد کدها را به جای تایپ بگویید.\n\nاگر موارد زیر را دارید کمک می‌کند:\n• مشکل تایپ کردن\n• صحبت کردن را ترجیح می‌دهید\n• بدون دست استفاده می‌کنید\n\nروی میکروفون ضربه بزنید و به وضوح صحبت کنید.";
"help_text_qr_scanning_simplified" = "از دوربین شما برای خواندن کدهای مربعی استفاده می‌کند.\n\nنحوه اسکن:\n‏۱. دوربین را به سمت کد بگیرید\n‏۲. کد را تنظیم کنید\n‏۳. منتظر بمانید تا خوانده شود\n\nنکات:\n• نور خوب داشته باشید\n• گوشی را ثابت نگه دارید\n• کد را صاف نگه دارید";
"help_text_age_verification_simplified" = "ثابت می‌کند به اندازه کافی بزرگ هستید بدون اشتراک‌گذاری تاریخ تولد.\n\nنحوه کارکرد:\n‏۱. کسب‌وکار یک درخواست ایجاد می‌کند\n‏۲. کد آن‌ها را اسکن می‌کنید\n‏۳. برنامه یک اثبات ایجاد می‌کند\n‏۴. کسب‌وکار تأیید می‌کند به اندازه کافی بزرگ هستید\n\nتاریخ تولد شما خصوصی می‌ماند.";
"help_text_credentials_simplified" = "اثبات دیجیتال سن شما روی گوشی ذخیره شده.\n\nویژگی‌ها:\n• فقط روی گوشی شما\n• نمی‌توان کپی کرد\n• خصوصی می‌ماند\n• می‌توانید هر زمان حذف کنید\n\nاز یک اداره دولتی دریافت می‌کنید.";
"help_text_zero_knowledge_simplified" = "چیزی را ثابت می‌کند بدون اشتراک‌گذاری جزئیات.\n\nمثال:\n• روش قدیمی: نشان دادن شناسه (تاریخ تولد دقیق را نشان می‌دهد)\n• روش جدید: ثابت کردن بالای ۱۸ سال بودن (تاریخ تولد خصوصی می‌ماند)\n\nاطلاعات شما را خصوصی نگه می‌دارد.";
"help_text_credential_issuance_simplified" = "دریافت اثبات سنی دیجیتال.\n\nمراحل:\n‏۱. به اداره دولتی بروید\n‏۲. شناسه خود را نشان دهید\n‏۳. یک کد دریافت کنید\n‏۴. کد را اسکن کنید\n‏۵. اثبات روی گوشی شما ذخیره می‌شود\n\nیک بار این کار را انجام دهید. سپس بارها از آن استفاده کنید.";
"help_text_officer_mode_simplified" = "برای کارمندان دولتی برای ایجاد اثبات.\n\nنیاز دارد:\n• رمز عبور مسئول\n• مجوز استفاده\n• شناسه کاربر برای بررسی\n\nمراحل:\n‏۱. به عنوان مسئول وارد شوید\n‏۲. شناسه کاربر را بررسی کنید\n‏۳. تاریخ تولد آن‌ها را وارد کنید\n‏۴. کد ایجاد کنید\n‏۵. کاربر کد را اسکن می‌کند\n\nفقط برای کارمندان مجاز.";

