// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Çok Büyük Metin, uygulamadaki tüm metni %50 artırır.\n\nBu şu kullanıcılara yardımcı olur:\n• Düşük görüşlüler\n• Okuma güçlüğü çekenler\n• Yaşa bağlı görme değişikliği yaşayanlar\n\nDaha büyük boyutlar için iOS Dinamik Tipi ile çalışır.";
"help_text_contrast_level" = "Kontrast Düzeyi, metin ile arka planlar arasındaki renk kontrastını kontrol eder.\n\nÜç düzey mevcut:\n• Standart: Varsayılan renkler\n• Yüksek (AA): 4,5:1 kontrast oranı - AA standartlarını karşılar\n• Maksimum (AAA): 7:1 kontrast oranı - En yüksek AAA standartlarını karşılar\n\nDaha yüksek kontrast, tüm aydınlatma koşullarında metni daha kolay okunur kılar.";
"help_text_high_contrast" = "Yüksek Kontrast Modu, metin ile arka plan arasındaki kontrastı artırarak okumayı kolaylaştırır.\n\nBu şu kullanıcılara yardımcı olur:\n• Düşük görüşlüler\n• Renk hassasiyeti olanlar\n• Parlak ekran ortamlarındakiler\n\nEtkinleştirildiğinde:\n• Metin beyaz üzerine siyah olur\n• Ögelere kenarlık eklenir\n• Renkler basitleştirilir";
"help_text_reduce_transparency" = "Saydamlığı Azalt, uygulama genelinde bulanıklık ve saydamlık efektlerini kaldırır.\n\nBu şunlara yardımcı olur:\n• Metin okunabilirliğini iyileştirme\n• Görsel karmaşıklığı azaltma\n• Eski cihazlarda performansı artırma\n• İçeriği daha öngörülebilir hale getirme";
"help_text_color_blind_mode" = "Renk Körlüğü Modları, farklı renk görme bozukluğu türleri için renkleri ayarlar.\n\nMevcut modlar:\n• Protanopi: Kırmızı körlüğü (kırmızı görme güçlüğü)\n• Deuteranopi: Yeşil körlüğü (yeşil görme güçlüğü)\n• Tritanopi: Mavi körlüğü (mavi görme güçlüğü)\n• Tek Renk: Yalnızca gri tonlamalı\n\nBu modlar, önemli bilgilerin yalnızca renk ile iletilmemesini sağlar.";
"help_text_line_spacing" = "Satır Aralığı, metin satırları arasındaki boşluğu kontrol eder.\n\n• Aralık: 1,0x - 2,0x\n• AAA standardı: Minimum 1,5x\n• Varsayılan: 1,0x\n\nArtırılmış satır aralığı metni okumayı kolaylaştırır ve satır atlama önler.";
"help_text_paragraph_spacing" = "Paragraf Aralığı, paragraflar arasındaki boşluğu kontrol eder.\n\n• Aralık: 1,0x - 3,0x\n• AAA standardı: Minimum 2,0x\n• Varsayılan: 1,0x\n\nArtırılmış paragraf aralığı, farklı metin bölümleri arasında ayrım yapmaya yardımcı olur.";
"help_text_letter_spacing" = "Harf Aralığı, tek tek karakterler arasındaki boşluğu kontrol eder.\n\n• Aralık: 0,0em - 0,2em\n• AAA standardı: Minimum 0,12em\n• Varsayılan: 0,0em\n\nArtırılmış harf aralığı karakter tanımayı ve okunabilirliği iyileştirir.";
"help_text_text_width" = "Metin Genişliği, rahat okuma için maksimum satır uzunluğunu kontrol eder.\n\nSeçenekler:\n• Tam Genişlik: Maksimum yok\n• Rahat (80 karakter): Okuma için optimal\n• Dar (60 karakter): Yoğun okuma için\n\nAAA kılavuzları, satır başına maksimum 80 karakter önerir.";
"help_text_large_touch_targets" = "Daha Büyük Dokunma Hedefleri, tüm düğmeleri ve etkileşimli ögeleri en az 60 punto boyutuna getirir.\n\nBu şunlara yardımcı olur:\n• Motor bozuklukları\n• Titreme veya sarsılma\n• Eldivenle uygulamayı kullanma\n• Tek elle kullanım\n\nStandart minimum 44 puntodur; bu ayar 60 puntoya çıkarır.";
"help_text_reduce_motion" = "Hareketi Azalt, uygulama genelinde animasyonları en aza indirir veya kaldırır.\n\nBu şu kullanıcılara yardımcı olur:\n• Hareket hassasiyeti olanlar\n• Vestibüler bozuklukları olanlar\n• Epilepsi hastaları\n• Migren tetikleyicisi olanlar\n\nEtkinleştirildiğinde, animasyonlar anlık geçişlerle değiştirilir.";
"help_text_timeout_behavior" = "Zaman Aşımı Davranışı, işlemlerin zaman aşımına uğramadan önce ne kadar sürebileceğini kontrol eder.\n\nSeçenekler:\n• Zaman Aşımı Yok (AAA): İşlemler asla zaman aşımına uğramaz\n• Standart (30 saniye): Varsayılan zaman aşımı\n• Uzatılmış (60 saniye): Standart sürenin iki katı\n\nZaman aşımı olmayan mod AAA erişilebilirlik standartlarını karşılar.";
"help_text_simplified_gestures" = "Basitleştirilmiş Hareketler, karmaşık çok dokunuşlu hareketleri basit dokunuşlara indirger.\n\nBu şunlara yardımcı olur:\n• Motor bozuklukları\n• Kısıtlı el becerisi\n• Yardımcı cihaz kullanımı\n• Tek elle işlem yapma\n\nKarmaşık hareketler düğmeler ve basit dokunuşlarla değiştirilir.";
"help_text_haptic_feedback" = "Dokunsal Geri Bildirim, işlemler ve bildirimler için titreşimli geri bildirim sağlar.\n\nBu şunlara yardımcı olur:\n• Düğme basışlarını onaylama\n• Hatalara veya uyarılara dikkat çekme\n• Görsel olmayan geri bildirim sağlama\n• İşitme veya görme bozukluğu olan kullanıcılar\n\nTitreşimler rahatsız edici geliyorsa devre dışı bırakabilirsiniz.";
"help_text_simplified_ui" = "Basitleştirilmiş Arayüz, uygulama genelinde görsel karmaşıklığı azaltır.\n\nBu şunlara yardımcı olur:\n• Bilişsel engeller\n• Öğrenme güçlükleri\n• Dikkat bozuklukları\n• Yeni veya deneyimsiz kullanıcılar\n\nEtkinleştirildiğinde:\n• Ekranda daha az öge\n• Daha büyük, daha net kontroller\n• Daha az görsel gürültü";
"help_text_step_indicators" = "Adım Göstergeleri, çok adımlı süreçlerdeki ilerlemenizi gösterir.\n\nBu şunlara yardımcı olur:\n• Bir süreçte nerede olduğunuzu anlama\n• Kaç adım kaldığını bilme\n• Bilişsel yükü azaltma\n• Net yapı sağlama\n\nGörsel ilerleme noktalarıyla 'Adım X / Y' gösterir.";
"help_text_verbose_descriptions" = "Ayrıntılı Açıklamalar, uygulama genelinde ek açıklayıcı metin sağlar.\n\nBu şunlara yardımcı olur:\n• Karmaşık özellikleri anlama\n• Uygulamayı kullanmayı öğrenme\n• Bilişsel destek\n• Ekran okuyucu kullanıcıları\n\nTüm özellikler için bağlam ve talimatlar sağlar.";
"help_text_confirm_actions" = "İşlemleri Onayla, önemli işlemlerden önce onay ister.\n\nBunları önlemeye yardımcı olur:\n• Yanlışlıkla silme\n• İstenmeyen değişiklikler\n• Erken gönderme\n• Veri kaybı\n\nNot: Yıkıcı işlemler her zaman onay gerektirir (AAA gereksinimi).";
"help_text_manual_code_entry" = "Manuel Kod Girişi, QR kodlarını taramak yerine kod yazmanıza olanak tanır.\n\nBu şu durumlarda yardımcı olur:\n• Kamera çalışmıyor\n• QR kodu hasarlı veya belirsiz\n• Ekran okuyucu kullanımı\n• Taramak yerine yazmayı tercih etme\n\nEkranda gösterilen kodu yazmak için 'Kodu Manuel Olarak Girin'e dokunun.";
"help_text_voice_input" = "Sesli Giriş, taramak veya yazmak yerine kod söylemenize olanak tanır.\n\nBu şunlara yardımcı olur:\n• Sınırlı hareketlilik\n• Ekran okuyucu kullanıcıları\n• Eller serbest işlem yapma\n• Ses tercihi\n\nMikrofon düğmesine dokunun ve istendiğinde açıkça konuşun.";
"help_text_qr_scanning" = "QR Kodu Tarama, Hızlı Yanıt kodlarını okumak için kameranızı kullanır.\n\nNasıl taranır:\n1. Kamerayı QR koduna doğrultun\n2. Kodu çerçeveye hizalayın\n3. Otomatik algılamayı bekleyin\n\nİpuçları:\n• İyi aydınlatma sağlayın\n• Cihazı sabit tutun\n• QR kodunu düz ve engelsiz tutun\n• Tarama başarısız olursa Manuel Kod Girişini deneyin";
"help_text_age_verification" = "Yaş Doğrulama, gerçek yaşınızı veya doğum tarihinizi açıklamadan yaş şartını karşıladığınızı kanıtlar.\n\nNasıl çalışır:\n1. Doğrulayıcı bir sınama oluşturur\n2. QR kodu tarayın veya manuel girin\n3. Uygulama bir sıfır bilgi kanıtı oluşturur\n4. Doğrulayıcı şartı karşıladığınızı onaylar\n\nGizlilik koruması:\n• Doğum tarihiniz asla paylaşılmaz\n• Doğrulayıcı yalnızca şartı karşılayıp karşılamadığınızı öğrenir\n• İzleme veya veri toplama yok";
"help_text_credentials" = "Dijital Kimlik Belgeleri, cihazınızda güvenle saklanan yaşınızın kriptografik kanıtlarıdır.\n\nÖzellikler:\n• Yalnızca cihazınızda saklanır\n• Kopyalanamaz veya taklit edilemez\n• Gizliliği koruyan doğrulama için kullanılır\n• İstediğiniz zaman silinebilir\n\nYaşınızı doğrulayabilmek için önce yetkili bir veren kuruluştan (örneğin devlet ofisi) kimlik belgesi edinmeniz gerekir.";
"help_text_zero_knowledge" = "Sıfır Bilgi Kanıtları, temel bilgileri açıklamadan bir şeyin doğru olduğunu kanıtlamanıza olanak tanır.\n\nÖrnek:\n• Geleneksel: Kimliği göster (tam doğum günü açıklanır)\n• Sıfır Bilgi: Doğum gününü göstermeden 18 yaşın üzerinde olduğunu kanıtla\n\nFaydaları:\n• Maksimum gizlilik koruması\n• Kişisel veri paylaşılmaz\n• Kriptografik olarak güvenli\n• Taklit edilemez veya tekrar oynatılamaz\n\nBu, Provii Wallet'ı özel kılan temel teknolojidir.";
"help_text_credential_issuance" = "Kimlik Belgesi Düzenleme, yetkili bir veren kuruluştan dijital yaş kimlik belgenizi edinme sürecidir.\n\nAdımlar:\n1. Yetkili veren kuruluşu ziyaret edin (örneğin devlet ofisi)\n2. Resmi kimlikle kimliğinizi kanıtlayın\n3. Veren kuruluştan QR kodu veya derin bağlantı alın\n4. QR kodu tarayın veya bağlantıya dokunun\n5. Kimlik belgesi cihazınızda yerel olarak hesaplanır ve saklanır\n\nKör onay süreci, doğum tarihinizin ağ üzerinden asla iletilmemesini sağlar.\nBunu yalnızca bir kez yapmanız gerekir. Kimlik belgeniz daha sonra sınırsız doğrulama için kullanılabilir.";
"help_text_officer_mode" = "Yetkili Modu, yetkili veren kuruluşların kullanıcılar için kimlik belgesi oluşturması içindir.\n\nBu mod şunları gerektirir:\n• YubiKey ile yetkili kimlik doğrulaması\n• Düzenleme makamından yetkilendirme\n• Kullanıcının kimliğinin fiziksel doğrulaması\n\nSüreç:\n1. Yetkili olarak kimlik doğrulayın\n2. Kullanıcının resmi kimliğini doğrulayın\n3. Kullanıcının doğum tarihini girin\n4. Onay QR kodu oluşturun\n5. Kullanıcı kimlik belgesini almak için kodu tarar\n\nBu modu yalnızca yetkili personel kullanmalıdır.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Tüm metni %50 daha büyük yapar.\n\nŞu durumlarda yardımcı olur:\n• Görmede güçlük çekiyorsanız\n• Okumayı zor buluyorsanız\n• Daha büyük metin gerekiyorsa\n\nTelefonunuzun metin boyutu ayarlarıyla çalışır.";

"help_text_contrast_level_simplified" = "Metnin ne kadar koyu olduğunu değiştirir.\n\nÜç seçenek:\n• Standart: Normal renkler\n• Yüksek: Kolay okuma için daha koyu metin\n• Maksimum: En iyi okuma için çok koyu metin\n\nDaha koyu metin okumayı kolaylaştırır.";

"help_text_high_contrast_simplified" = "Metni daha kolay görünür yapar.\n\nŞu durumlarda yardımcı olur:\n• Görmede güçlük çekiyorsanız\n• Daha koyu metne ihtiyacınız varsa\n• Parlak ışıkta uygulamayı kullanıyorsanız\n\nMetin beyaz üzerine siyah olur.";

"help_text_reduce_transparency_simplified" = "Bulanık efektleri kaldırır.\n\nBu şunlara yardımcı olur:\n• Metni daha net yapma\n• Uygulamayı daha sade yapma\n• Eski telefonları hızlandırma\n\nHer şey daha katı görünür.";

"help_text_color_blind_mode_simplified" = "Daha iyi görebilmeniz için renkleri değiştirir.\n\nSeçenekler:\n• Kırmızı körlüğü modu\n• Yeşil körlüğü modu\n• Mavi körlüğü modu\n• Yalnızca gri mod\n\nÖnemli şeyleri görmenize yardımcı olur.";

"help_text_line_spacing_simplified" = "Metin satırları arasındaki boşluğu değiştirir.\n\n1,0x ile 2,0x arasında seçim yapabilirsiniz.\nVarsayılan 1,0x'tir.\n\nDaha fazla boşluk okumayı kolaylaştırır.";

"help_text_paragraph_spacing_simplified" = "Paragraflar arasındaki boşluğu değiştirir.\n\n1,0x ile 3,0x arasında seçim yapabilirsiniz.\nVarsayılan 1,0x'tir.\n\nDaha fazla boşluk yeni fikirlerin nerede başladığını görmenizi sağlar.";

"help_text_letter_spacing_simplified" = "Harfler arasındaki boşluğu değiştirir.\n\n0,0 ile 0,2 arasında seçim yapabilirsiniz.\nVarsayılan 0,0'dır.\n\nDaha fazla boşluk harfleri daha net yapar.";

"help_text_text_width_simplified" = "Metnin ne kadar geniş olduğunu kontrol eder.\n\nSeçenekler:\n• Tam genişlik: Tüm ekranı kullanır\n• Orta: Okuma için iyi\n• Dar: Odaklanmak için en iyi\n\nOrta genişlik okumayı en kolay kılar.";

"help_text_large_touch_targets_simplified" = "Tüm düğmeleri daha büyük yapar.\n\nŞu durumlarda yardımcı olur:\n• Küçük düğmelere dokunmada güçlük çekiyorsanız\n• Elleriniz titriyor\n• Eldiven giyiyorsunuz\n• Tek el kullanıyorsunuz\n\nDüğmeler 44 punto yerine 60 punto olur.";

"help_text_reduce_motion_simplified" = "Hareketli animasyonları kaldırır.\n\nŞu durumlarda yardımcı olur:\n• Hareket sizi rahatsız ediyorsa\n• Hareketten baş ağrısı yaşıyorsanız\n• Şeylerin sabit kalmasını tercih ediyorsanız\n\nŞeyler hareket etmek yerine anında değişir.";

"help_text_timeout_behavior_simplified" = "Görevlerin ne kadar sürebileceğini kontrol eder.\n\nSeçenekler:\n• Sınır yok: Görevler asla durmaz\n• Normal: 30 saniye\n• Daha uzun: 60 saniye\n\nDaha fazla zamana ihtiyacınız varsa 'Sınır yok'u seçin.";

"help_text_simplified_gestures_simplified" = "Zor hareketleri basit dokunuşlarla değiştirir.\n\nŞu durumlarda yardımcı olur:\n• Karmaşık dokunuşlarda güçlük çekiyorsanız\n• Basit dokunuşları tercih ediyorsanız\n• Tek el kullanıyorsanız\n\nHer şey basit dokunuşları kullanır.";

"help_text_haptic_feedback_simplified" = "Dokunduğunuzda telefonunuzun titremesini sağlar.\n\nŞu konularda yardımcı olur:\n• Bir düğmeye dokunduğunuzu bilmek\n• Hataları veya uyarıları hissetmek\n• Bakmadan geri bildirim almak\n\nTitreşimler rahatsız ediyorsa kapatın.";

"help_text_simplified_ui_simplified" = "Uygulamayı daha sade yapar.\n\nŞu durumlarda yardımcı olur:\n• Kalabalık ekranlarda kafanız karışıyorsa\n• Basit düzenleri tercih ediyorsanız\n• Uygulamayı yeni kullanıyorsanız\n\nAynı anda daha az şey gösterir.";

"help_text_step_indicators_simplified" = "Adımlardaki ilerlemenizi gösterir.\n\nŞu konularda yardımcı olur:\n• Nerede olduğunuzu bilmek\n• Kaç adım kaldığını görmek\n• Düzenli kalmak\n\nNoktalarla 'Adım 1 / 3' gösterir.";

"help_text_verbose_descriptions_simplified" = "Size daha fazla açıklama verir.\n\nŞu konularda yardımcı olur:\n• Özellikleri anlama\n• Uygulamayı kullanmayı öğrenme\n• Daha fazla ayrıntı alma\n\nHer yerde ekstra yardım sağlar.";

"help_text_confirm_actions_simplified" = "Önemli işlemler için onaylamanızı ister.\n\nŞunları önlemeye yardımcı olur:\n• Yanlışlıkla silme\n• İstenmeyen değişiklikler\n• Hatalar\n\nHer zaman 'Emin misiniz?' sorulacaktır.";

"help_text_manual_code_entry_simplified" = "Taramak yerine kod yazmanıza olanak tanır.\n\nŞu durumlarda kullanın:\n• Kameranız çalışmıyor\n• Kodu taramak zor\n• Yazmayı tercih ediyorsunuz\n\nYazmak için 'Kodu Manuel Olarak Girin'e dokunun.";

"help_text_voice_input_simplified" = "Yazmak yerine kod söylemenize olanak tanır.\n\nŞu durumlarda yardımcı olur:\n• Yazmada güçlük çekiyorsanız\n• Konuşmayı tercih ediyorsanız\n• Eller serbest kullanım istiyorsanız\n\nMikrofona dokunun ve açıkça konuşun.";

"help_text_qr_scanning_simplified" = "Kare kodları okumak için kameranızı kullanır.\n\nNasıl taranır:\n1. Kamerayı koda doğrultun\n2. Kodu hizalayın\n3. Okunmasını bekleyin\n\nİpuçları:\n• İyi aydınlatma kullanın\n• Telefonunuzu sabit tutun\n• Kodu düz tutun";

"help_text_age_verification_simplified" = "Doğum gününüzü paylaşmadan yeterince büyük olduğunuzu kanıtlar.\n\nNasıl çalışır:\n1. İşletme bir istek oluşturur\n2. Kodunu tarayın\n3. Uygulama bir kanıt oluşturur\n4. İşletme yeterince büyük olduğunuzu onaylar\n\nDoğum gününüz gizli kalır.";

"help_text_credentials_simplified" = "Telefonunuzda saklanan dijital yaş kanıtınız.\n\nÖzellikler:\n• Yalnızca telefonunuzda\n• Kopyalanamaz\n• Sizi gizli tutar\n• İstediğiniz zaman silebilirsiniz\n\nBir devlet ofisinden alınır.";

"help_text_zero_knowledge_simplified" = "Ayrıntıları paylaşmadan bir şeyi kanıtlar.\n\nÖrnek:\n• Eski yol: Kimliği göster (tam doğum günü görünür)\n• Yeni yol: 18 yaşın üzerinde olduğunu kanıtla (doğum günü gizli kalır)\n\nBu, bilgilerinizi gizli tutar.";

"help_text_credential_issuance_simplified" = "Dijital yaş kanıtınızı alma.\n\nAdımlar:\n1. Devlet ofisine gidin\n2. Kimliğinizi gösterin\n3. Bir kod alın\n4. Kodu tarayın\n5. Kanıt telefonunuza kaydedilir\n\nBunu bir kez yapın. Sonra defalarca kullanın.";

"help_text_officer_mode_simplified" = "Devlet çalışanlarının kanıt oluşturması için.\n\nGerekenler:\n• Yetkili şifresi\n• Kullanım izni\n• Kontrol edilecek kullanıcı kimliği\n\nAdımlar:\n1. Yetkili olarak giriş yapın\n2. Kullanıcının kimliğini kontrol edin\n3. Doğum günlerini girin\n4. Kod oluşturun\n5. Kullanıcı kodu tarar\n\nYalnızca yetkili çalışanlar için.";

