/* InfoPlist.strings - Polish */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet potrzebuje dostępu do aparatu, aby skanować kody QR w celu odbioru poświadczeń i weryfikacji wieku.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet używa NFC do komunikacji z YubiKey w celu bezpiecznego uwierzytelnienia funkcjonariusza.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet używa rozpoznawania mowy do poleceń głosowych w trybie dostępności, umożliwiając sterowanie aplikacją bez użycia rąk.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet potrzebuje dostępu do mikrofonu, aby korzystać z funkcji sterowania głosem po włączeniu trybu dostępności.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet używa Face ID do bezpiecznego dostępu do poświadczeń wieku i weryfikacji tożsamości.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet może korzystać z sieci lokalnej w celu wykrywania pobliskich wystawców poświadczeń.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet może używać Bluetooth do komunikacji z urządzeniami YubiKey.";
