// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "అదనపు పెద్ద వచనం యాప్‌లో అన్ని వచనాన్ని 50% పెంచుతుంది.\n\nఇది ఉపకరిస్తుంది:\n• తక్కువ దృష్టి ఉన్నవారికి\n• చదవడంలో ఇబ్బంది ఉన్నవారికి\n• వయస్సు-సంబంధిత దృష్టి మార్పులు ఉన్నవారికి\n\nమరింత పెద్ద పరిమాణాల కోసం iOS డైనమిక్ టైప్‌తో పని చేస్తుంది.";
"help_text_contrast_level" = "కాంట్రాస్ట్ స్థాయి వచనం మరియు నేపథ్యాల మధ్య రంగు కాంట్రాస్ట్‌ను నియంత్రిస్తుంది.\n\nమూడు స్థాయిలు అందుబాటులో ఉన్నాయి:\n• ప్రామాణిక: డిఫాల్ట్ రంగులు\n• అధిక (AA): 4.5:1 కాంట్రాస్ట్ నిష్పత్తి - AA ప్రమాణాలు తీర్చుతుంది\n• గరిష్ట (AAA): 7:1 కాంట్రాస్ట్ నిష్పత్తి - అత్యధిక AAA ప్రమాణాలు తీర్చుతుంది\n\nఎక్కువ కాంట్రాస్ట్ అన్ని లైటింగ్ పరిస్థితులలో వచనాన్ని చదవడం సులభతరం చేస్తుంది.";
"help_text_high_contrast" = "అధిక కాంట్రాస్ట్ మోడ్ వచనం మరియు నేపథ్యం మధ్య కాంట్రాస్ట్ పెంచుతుంది, చదవడం సులభతరం చేస్తుంది.\n\nఇది ఉపకరిస్తుంది:\n• తక్కువ దృష్టి ఉన్నవారికి\n• రంగు సంవేదనత ఉన్నవారికి\n• ప్రకాశవంతమైన స్క్రీన్ పరిసరాలు\n\nప్రారంభించినప్పుడు:\n• వచనం తెలుపు పై నల్లగా అవుతుంది\n• అంశాలకు సరిహద్దులు జోడించబడతాయి\n• రంగులు సరళీకరించబడతాయి";
"help_text_reduce_transparency" = "పారదర్శకతను తగ్గించండి యాప్ అంతటా బ్లర్ మరియు పారదర్శకత ప్రభావాలను తీసివేస్తుంది.\n\nఇది సహాయపడుతుంది:\n• వచన చదవగలిగే తనం మెరుగుపరచడానికి\n• దృశ్య సంక్లిష్టతను తగ్గించడానికి\n• పాత పరికరాలలో పనితీరు పెంచడానికి\n• కంటెంట్‌ను మరింత అంచనా వేయదగినదిగా చేయడానికి";
"help_text_color_blind_mode" = "వర్ణాంధత్వ మోడులు వివిధ రకాల వర్ణ దృష్టి లోపాల కోసం రంగులను సర్దుబాటు చేస్తాయి.\n\nఅందుబాటులో ఉన్న మోడులు:\n• ప్రొటానోపియా: ఎరుపు-అంధత్వం (ఎరుపు చూడడంలో ఇబ్బంది)\n• డ్యూటెరానోపియా: ఆకుపచ్చ-అంధత్వం (ఆకుపచ్చ చూడడంలో ఇబ్బంది)\n• ట్రిటానోపియా: నీలం-అంధత్వం (నీలం చూడడంలో ఇబ్బంది)\n• మోనోక్రోమ్: గ్రేస్కేల్ మాత్రమే\n\nఈ మోడులు ముఖ్యమైన సమాచారం రంగు మాత్రమే ద్వారా తెలియజేయబడదని నిర్ధారిస్తాయి.";
"help_text_line_spacing" = "లైన్ స్పేసింగ్ వచన పంక్తుల మధ్య స్థలాన్ని నియంత్రిస్తుంది.\n\n• పరిధి: 1.0x నుండి 2.0x\n• AAA ప్రమాణం: కనీసం 1.5x\n• డిఫాల్ట్: 1.0x\n\nపెరిగిన లైన్ స్పేసింగ్ వచనాన్ని చదవడం సులభతరం చేస్తుంది మరియు లైన్ దాటడాన్ని నివారించడంలో సహాయపడుతుంది.";
"help_text_paragraph_spacing" = "పేరా స్పేసింగ్ పేరాల మధ్య స్థలాన్ని నియంత్రిస్తుంది.\n\n• పరిధి: 1.0x నుండి 3.0x\n• AAA ప్రమాణం: కనీసం 2.0x\n• డిఫాల్ట్: 1.0x\n\nపెరిగిన పేరా స్పేసింగ్ వివిధ వచన విభాగాల మధ్య వ్యత్యాసాన్ని గుర్తించడంలో సహాయపడుతుంది.";
"help_text_letter_spacing" = "అక్షర స్పేసింగ్ అక్షరాల మధ్య స్థలాన్ని నియంత్రిస్తుంది.\n\n• పరిధి: 0.0em నుండి 0.2em\n• AAA ప్రమాణం: కనీసం 0.12em\n• డిఫాల్ట్: 0.0em\n\nపెరిగిన అక్షర స్పేసింగ్ అక్షర గుర్తింపు మరియు చదవగలిగే తనం మెరుగుపరుస్తుంది.";
"help_text_text_width" = "వచన వెడల్పు సౌకర్యవంతమైన చదవడానికి గరిష్ట పంక్తి పొడవును నియంత్రిస్తుంది.\n\nఎంపికలు:\n• పూర్తి వెడల్పు: గరిష్టం లేదు\n• సౌకర్యవంతమైన (80 అక్షరాలు): చదవడానికి ఉత్తమం\n• సన్నని (60 అక్షరాలు): కేంద్రీకృత చదవడానికి\n\nAAA మార్గదర్శకాలు పంక్తికి గరిష్టంగా 80 అక్షరాలు సిఫార్సు చేస్తున్నాయి.";
"help_text_large_touch_targets" = "పెద్ద టచ్ లక్ష్యాలు అన్ని బటన్లు మరియు ఇంటరాక్టివ్ అంశాలను కనీసం 60pt పరిమాణంలో చేస్తుంది.\n\nఇది ఉపకరిస్తుంది:\n• చలన లోపాలు ఉన్నవారికి\n• వణుకు లేదా కంపనం ఉన్నవారికి\n• చేతి తొడుగులతో యాప్ ఉపయోగించేవారికి\n• ఒక చేత్తో ఉపయోగించేవారికి\n\nప్రామాణిక కనీసం 44pt; ఈ సెట్టింగ్ 60pt కి పెంచుతుంది.";
"help_text_reduce_motion" = "చలనాన్ని తగ్గించండి యాప్ అంతటా యానిమేషన్లను తగ్గిస్తుంది లేదా తీసివేస్తుంది.\n\nఇది ఉపకరిస్తుంది:\n• చలన సంవేదనత ఉన్నవారికి\n• వెస్టిబ్యులార్ వ్యాధులు ఉన్నవారికి\n• మూర్ఛ ఉన్నవారికి\n• మైగ్రేన్ ట్రిగర్స్ ఉన్నవారికి\n\nప్రారంభించినప్పుడు, యానిమేషన్లు తక్షణ మార్పులతో భర్తీ చేయబడతాయి.";
"help_text_timeout_behavior" = "గడువు ప్రవర్తన కార్యకలాపాలు గడువు ముగియడానికి ముందు ఎంత సమయం తీసుకోవచ్చో నియంత్రిస్తుంది.\n\nఎంపికలు:\n• టైమ్‌అవుట్ లేదు (AAA): కార్యకలాపాలు ఎన్నటికీ గడువు ముగియవు\n• ప్రామాణిక (30సె): డిఫాల్ట్ గడువు\n• పొడిగించిన (60సె): ప్రామాణిక సమయం రెట్టింపు\n\nటైమ్‌అవుట్ లేని మోడ్ AAA అందుబాటు ప్రమాణాలు తీర్చుతుంది.";
"help_text_simplified_gestures" = "సరళీకృత సంజ్ఞలు సంక్లిష్ట మల్టీ-టచ్ సంజ్ఞలను సాధారణ నొక్కడాలకు తగ్గిస్తుంది.\n\nఇది ఉపకరిస్తుంది:\n• చలన లోపాలు ఉన్నవారికి\n• పరిమిత నైపుణ్యం ఉన్నవారికి\n• సహాయక పరికరాలు ఉపయోగించేవారికి\n• ఒక చేత్తో ఉపయోగించేవారికి\n\nసంక్లిష్ట సంజ్ఞలు బటన్లు మరియు సాధారణ నొక్కడాలతో భర్తీ చేయబడతాయి.";
"help_text_haptic_feedback" = "హ్యాప్టిక్ అభిప్రాయం చర్యలు మరియు నోటిఫికేషన్ల కోసం వైబ్రేషన్ అభిప్రాయం అందిస్తుంది.\n\nఇది ఉపకరిస్తుంది:\n• బటన్ నొక్కడాన్ని నిర్ధారించడానికి\n• లోపాలు లేదా హెచ్చరికలను అప్రమత్తం చేయడానికి\n• దృశ్యేతర అభిప్రాయం అందించడానికి\n• వినికిడి లేదా దృష్టి లోపాలు ఉన్నవారికి\n\nవైబ్రేషన్లు అసహ్యంగా ఉంటే మీరు దీన్ని నిలిపివేయవచ్చు.";
"help_text_simplified_ui" = "సరళీకృత ఇంటర్‌ఫేస్ యాప్ అంతటా దృశ్య సంక్లిష్టతను తగ్గిస్తుంది.\n\nఇది ఉపకరిస్తుంది:\n• అభిజ్ఞాన వికలాంగులకు\n• నేర్చుకోవడంలో ఇబ్బందులు ఉన్నవారికి\n• శ్రద్ధ సమస్యలు ఉన్నవారికి\n• కొత్త లేదా అనుభవం లేని వినియోగదారులకు\n\nప్రారంభించినప్పుడు:\n• స్క్రీన్‌పై తక్కువ అంశాలు\n• పెద్ద, స్పష్టమైన కంట్రోల్స్\n• తక్కువ దృశ్య శబ్దం";
"help_text_step_indicators" = "దశ సూచికలు బహుళ-దశ ప్రక్రియల ద్వారా మీ పురోగతిని చూపిస్తాయి.\n\nఇది సహాయపడుతుంది:\n• మీరు ప్రక్రియలో ఎక్కడ ఉన్నారో అర్థం చేసుకోవడానికి\n• ఎన్ని దశలు మిగిలి ఉన్నాయో తెలుసుకోవడానికి\n• అభిజ్ఞా భారాన్ని తగ్గించడానికి\n• స్పష్టమైన నిర్మాణం అందించడానికి\n\nదృశ్య పురోగతి చుక్కలతో 'Y లో X దశ' చూపిస్తుంది.";
"help_text_verbose_descriptions" = "వివరణాత్మక వివరణలు యాప్ అంతటా అదనపు వివరణాత్మక వచనాన్ని అందిస్తుంది.\n\nఇది ఉపకరిస్తుంది:\n• సంక్లిష్ట ఫీచర్లను అర్థం చేసుకోవడానికి\n• యాప్‌ను ఎలా ఉపయోగించాలో నేర్చుకోవడానికి\n• అభిజ్ఞాన మద్దతు కోసం\n• స్క్రీన్ రీడర్ వినియోగదారులకు\n\nఅన్ని ఫీచర్లకు సందర్భం మరియు సూచనలు అందిస్తుంది.";
"help_text_confirm_actions" = "చర్యలను నిర్ధారించండి ముఖ్యమైన చర్యలకు ముందు నిర్ధారణ అడుగుతుంది.\n\nఇది నివారించడంలో సహాయపడుతుంది:\n• ప్రమాదవశాత్తు తొలగింపులు\n• అనాలోచిత మార్పులు\n• అకాల సమర్పణలు\n• డేటా నష్టం\n\nగమనిక: విధ్వంసకర చర్యలు ఎల్లప్పుడూ నిర్ధారణ అవసరం (AAA అవసరం).";
"help_text_manual_code_entry" = "మాన్యువల్ కోడ్ ఎంట్రీ QR కోడ్‌లను స్కాన్ చేయడానికి బదులు కోడ్‌లను టైప్ చేయడానికి వీలు కల్పిస్తుంది.\n\nఇది ఉపకరిస్తుంది:\n• కెమెరా పని చేయనప్పుడు\n• QR కోడ్ దెబ్బతిన్నప్పుడు లేదా స్పష్టంగా లేనప్పుడు\n• స్క్రీన్ రీడర్ ఉపయోగించేవారికి\n• స్కాన్ చేయడానికి బదులు టైప్ చేయాలనుకునేవారికి\n\nస్క్రీన్‌పై చూపించిన కోడ్‌ను టైప్ చేయడానికి 'కోడ్‌ను మాన్యువల్‌గా నమోదు చేయండి' నొక్కండి.";
"help_text_voice_input" = "వాయిస్ ఇన్‌పుట్ స్కాన్ చేయడానికి లేదా టైప్ చేయడానికి బదులు కోడ్‌లను మాట్లాడటానికి వీలు కల్పిస్తుంది.\n\nఇది ఉపకరిస్తుంది:\n• పరిమిత చలనం ఉన్నవారికి\n• స్క్రీన్ రీడర్ వినియోగదారులకు\n• చేతులు-విముక్తమైన కార్యకలాపం కోసం\n• వాయిస్ ప్రాధాన్యత ఇచ్చేవారికి\n\nమైక్రోఫోన్ బటన్ నొక్కి అడిగినప్పుడు స్పష్టంగా మాట్లాడండి.";
"help_text_qr_scanning" = "QR కోడ్ స్కానింగ్ త్వరిత ప్రతిస్పందన కోడ్‌లను చదవడానికి మీ కెమెరాను ఉపయోగిస్తుంది.\n\nఎలా స్కాన్ చేయాలి:\n1. QR కోడ్ వైపు కెమెరా గురిపెట్టండి\n2. ఫ్రేమ్‌లో కోడ్‌ను సమలేఖనం చేయండి\n3. స్వయంచాలక గుర్తింపు కోసం వేచి ఉండండి\n\nచిట్కాలు:\n• మంచి లైటింగ్ నిర్ధారించుకోండి\n• పరికరాన్ని స్థిరంగా పట్టుకోండి\n• QR కోడ్‌ను చదునుగా మరియు అడ్డంకులు లేకుండా ఉంచండి\n• స్కానింగ్ విఫలమైతే, మాన్యువల్ కోడ్ ఎంట్రీ ప్రయత్నించండి";
"help_text_age_verification" = "వయస్సు ధృవీకరణ మీ వాస్తవ వయస్సు లేదా పుట్టిన తేదీ వెల్లడించకుండా మీరు వయస్సు అవసరాన్ని నెరవేర్చారని నిరూపిస్తుంది.\n\nఇది ఎలా పని చేస్తుంది:\n1. ధృవీకరిస్తున్న వారు సవాల్ రూపొందిస్తారు\n2. మీరు QR కోడ్ స్కాన్ చేస్తారు లేదా మాన్యువల్‌గా నమోదు చేస్తారు\n3. యాప్ జీరో నాలెడ్జ్ ప్రూఫ్ సృష్టిస్తుంది\n4. ధృవీకరిస్తున్న వారు మీరు అవసరాన్ని నెరవేర్చారని నిర్ధారిస్తారు\n\nగోప్యత రక్షించబడింది:\n• మీ పుట్టిన తేదీ ఎన్నటికీ పంచుకోబడదు\n• ధృవీకరిస్తున్న వారికి మీరు అవసరాన్ని నెరవేర్చారో లేదో మాత్రమే తెలుస్తుంది\n• ట్రాకింగ్ లేదా డేటా సేకరణ లేదు";
"help_text_credentials" = "డిజిటల్ ధృవీకరణ పత్రాలు మీ పరికరంలో సురక్షితంగా నిల్వ చేయబడిన మీ వయస్సు యొక్క గుప్తలిపి నిరూపణలు.\n\nఫీచర్లు:\n• మీ పరికరంలో మాత్రమే నిల్వ చేయబడతాయి\n• కాపీ చేయడం లేదా నకిలీ చేయడం సాధ్యం కాదు\n• గోప్యత-కాపాడే ధృవీకరణ కోసం ఉపయోగించబడతాయి\n• ఎప్పుడైనా తొలగించవచ్చు\n\nమీరు వయస్సు ధృవీకరించడానికి ముందు అధికారిక జారీదారు (ప్రభుత్వ కార్యాలయం వంటి) నుండి ధృవీకరణ పత్రం పొందాలి.";
"help_text_zero_knowledge" = "జీరో నాలెడ్జ్ ప్రూఫ్‌లు అంతర్లీన సమాచారం వెల్లడించకుండా ఏదైనా నిజమని నిరూపించడానికి వీలు కల్పిస్తాయి.\n\nఉదాహరణ:\n• సాంప్రదాయిక: ID చూపించండి (ఖచ్చితమైన పుట్టిన తేదీ వెల్లడిస్తుంది)\n• జీరో నాలెడ్జ్: పుట్టిన తేదీ చూపించకుండా మీరు 18 కంటే ఎక్కువ అని నిరూపించండి\n\nప్రయోజనాలు:\n• గరిష్ట గోప్యత రక్షణ\n• వ్యక్తిగత డేటా పంచుకోబడదు\n• గుప్తలిపి సురక్షితత\n• నకిలీ చేయడం లేదా మళ్ళీ ఆడటం సాధ్యం కాదు\n\nఇది Provii Wallet ని వ్యక్తిగతంగా చేసే ప్రధాన సాంకేతికత.";
"help_text_credential_issuance" = "ధృవీకరణ పత్రం జారీ అనేది అధికారిక జారీదారు నుండి మీ డిజిటల్ వయస్సు ధృవీకరణ పత్రాన్ని పొందే ప్రక్రియ.\n\nదశలు:\n1. అధికారిక జారీదారును సందర్శించండి (ఉదా., ప్రభుత్వ కార్యాలయం)\n2. అధికారిక ID తో మీ గుర్తింపు నిరూపించండి\n3. జారీదారు నుండి QR కోడ్ లేదా డీప్ లింక్ స్వీకరించండి\n4. QR కోడ్ స్కాన్ చేయండి లేదా లింక్ నొక్కండి\n5. ధృవీకరణ పత్రం స్థానికంగా గణించబడి మీ పరికరంలో నిల్వ చేయబడుతుంది\n\nగుప్త సాక్ష్యపత్రం ప్రక్రియ మీ పుట్టిన తేదీ నెట్‌వర్క్ పై ఎన్నటికీ పంపించబడదని నిర్ధారిస్తుంది.\nమీరు ఇది ఒకసారి మాత్రమే చేయాలి. మీ ధృవీకరణ పత్రం పరిమితం లేకుండా ధృవీకరణలకు ఉపయోగించవచ్చు.";
"help_text_officer_mode" = "అధికారి మోడ్ అనేది అధికారిక జారీదారులు వినియోగదారుల కోసం ధృవీకరణ పత్రాలు సృష్టించడానికి ఉద్దేశించబడింది.\n\nఈ మోడ్ అవసరం:\n• YubiKey తో అధికారి ప్రామాణీకరణ\n• జారీ అధికారం నుండి అనుమతి\n• వినియోగదారు ID యొక్క భౌతిక ధృవీకరణ\n\nప్రక్రియ:\n1. అధికారిగా ప్రామాణీకరించండి\n2. వినియోగదారు అధికారిక ID ధృవీకరించండి\n3. వినియోగదారు పుట్టిన తేదీని నమోదు చేయండి\n4. సాక్ష్యపత్రం QR కోడ్ రూపొందించండి\n5. వినియోగదారు ధృవీకరణ పత్రం స్వీకరించడానికి కోడ్ స్కాన్ చేస్తారు\n\nఈ మోడ్‌ను అధికారిక సిబ్బంది మాత్రమే ఉపయోగించాలి.";

