/* InfoPlist.strings - Indonesian */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet memerlukan akses kamera untuk memindai kode QR guna pengambilan kredensial dan verifikasi usia.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet menggunakan NFC untuk berkomunikasi dengan YubiKey Anda guna autentikasi petugas yang aman.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet menggunakan pengenalan ucapan untuk perintah suara dalam mode aksesibilitas, sehingga Anda dapat mengontrol aplikasi tanpa menggunakan tangan.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet memerlukan akses mikrofon untuk fitur kontrol suara saat mode aksesibilitas diaktifkan.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet menggunakan Face ID untuk mengakses kredensial usia Anda secara aman dan memverifikasi identitas Anda.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet dapat menggunakan jaringan lokal untuk menemukan penerbit kredensial di sekitar Anda.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet dapat menggunakan Bluetooth untuk berkomunikasi dengan perangkat YubiKey.";
