"help_text_extra_large_text" = "Chữ cực lớn tăng tất cả chữ trong ứng dụng thêm 50%.\n\nTính năng này giúp chữ dễ đọc hơn cho người:\n• Khiếm thị\n• Khó khăn khi đọc\n• Thị lực suy giảm theo tuổi\n\nHoạt động với iOS Dynamic Type để có kích thước lớn hơn nữa.";
"help_text_contrast_level" = "Mức tương phản điều chỉnh tương phản màu sắc giữa chữ và nền.\n\nCó ba mức:\n• Tiêu chuẩn: Màu mặc định\n• Cao (AA): Tỷ lệ tương phản 4.5:1 - đạt chuẩn AA\n• Tối đa (AAA): Tỷ lệ tương phản 7:1 - đạt chuẩn AAA cao nhất\n\nTương phản cao hơn giúp chữ dễ đọc hơn trong mọi điều kiện ánh sáng.";
"help_text_high_contrast" = "Chế độ tương phản cao tăng tương phản giữa chữ và nền, giúp dễ đọc hơn.\n\nTính năng này giúp người:\n• Khiếm thị\n• Nhạy cảm màu sắc\n• Môi trường màn hình sáng\n\nKhi bật:\n• Chữ trở thành đen trên trắng\n• Thêm viền vào các thành phần\n• Màu sắc được đơn giản hóa";
"help_text_reduce_transparency" = "Giảm độ trong suốt xóa hiệu ứng mờ và trong suốt trong toàn ứng dụng.\n\nTính năng này giúp:\n• Cải thiện khả năng đọc chữ\n• Giảm độ phức tạp hiển thị\n• Tăng hiệu năng trên thiết bị cũ\n• Làm nội dung dễ dự đoán hơn";
"help_text_color_blind_mode" = "Chế độ mù màu điều chỉnh màu sắc cho các loại khiếm khuyết thị lực màu khác nhau.\n\nCác chế độ có sẵn:\n• Mù đỏ (Protanopia): Khó nhìn thấy màu đỏ\n• Mù xanh lá (Deuteranopia): Khó nhìn thấy màu xanh lá\n• Mù xanh dương (Tritanopia): Khó nhìn thấy màu xanh dương\n• Đơn sắc: Chỉ thang xám\n\nCác chế độ này đảm bảo thông tin quan trọng không chỉ được truyền đạt qua màu sắc.";
"help_text_line_spacing" = "Khoảng cách dòng điều chỉnh khoảng cách giữa các dòng chữ.\n\n• Phạm vi: 1.0x đến 2.0x\n• Chuẩn AAA: tối thiểu 1.5x\n• Mặc định: 1.0x\n\nTăng khoảng cách dòng giúp chữ dễ đọc hơn và giảm bỏ dòng.";
"help_text_paragraph_spacing" = "Khoảng cách đoạn điều chỉnh khoảng cách giữa các đoạn văn.\n\n• Phạm vi: 1.0x đến 3.0x\n• Chuẩn AAA: tối thiểu 2.0x\n• Mặc định: 1.0x\n\nTăng khoảng cách đoạn giúp phân biệt các phần nội dung khác nhau.";
"help_text_letter_spacing" = "Khoảng cách chữ cái điều chỉnh khoảng cách giữa các ký tự.\n\n• Phạm vi: 0.0em đến 0.2em\n• Chuẩn AAA: tối thiểu 0.12em\n• Mặc định: 0.0em\n\nTăng khoảng cách chữ cái cải thiện nhận dạng ký tự và khả năng đọc.";
"help_text_text_width" = "Chiều rộng văn bản điều chỉnh độ dài dòng tối đa để đọc thoải mái.\n\nTùy chọn:\n• Toàn bộ chiều rộng: Không giới hạn\n• Thoải mái (80 ký tự): Tối ưu để đọc\n• Hẹp (60 ký tự): Để đọc tập trung\n\nHướng dẫn AAA khuyến nghị tối đa 80 ký tự mỗi dòng.";
"help_text_large_touch_targets" = "Vùng chạm lớn hơn làm tất cả nút và thành phần tương tác ít nhất 60pt.\n\nTính năng này giúp:\n• Khó khăn vận động\n• Run tay\n• Dùng ứng dụng với găng tay\n• Dùng một tay\n\nKích thước tối thiểu tiêu chuẩn là 44pt; cài đặt này tăng lên 60pt.";
"help_text_reduce_motion" = "Giảm chuyển động giảm thiểu hoặc xóa hoạt ảnh trong toàn ứng dụng.\n\nTính năng này giúp người:\n• Nhạy cảm với chuyển động\n• Rối loạn tiền đình\n• Động kinh\n• Nguyên nhân gây đau nửa đầu\n\nKhi bật, hoạt ảnh được thay thế bằng chuyển cảnh tức thì.";
"help_text_timeout_behavior" = "Hành vi hết thời gian điều chỉnh thời gian các thao tác có thể thực hiện trước khi hết thời gian.\n\nTùy chọn:\n• Không hết thời gian (AAA): Thao tác không bao giờ hết thời gian\n• Tiêu chuẩn (30 giây): Thời gian chờ mặc định\n• Kéo dài (60 giây): Gấp đôi thời gian tiêu chuẩn\n\nChế độ không hết thời gian đáp ứng tiêu chuẩn hỗ trợ tiếp cận AAA.";
"help_text_simplified_gestures" = "Cử chỉ đơn giản giảm cử chỉ đa điểm chạm phức tạp thành các cú chạm đơn giản.\n\nTính năng này giúp:\n• Khó khăn vận động\n• Hạn chế khéo léo\n• Dùng thiết bị hỗ trợ\n• Thao tác một tay\n\nCử chỉ phức tạp được thay thế bằng nút và cú chạm đơn giản.";
"help_text_haptic_feedback" = "Phản hồi rung cung cấp phản hồi rung cho các hành động và thông báo.\n\nTính năng này giúp:\n• Xác nhận nhấn nút\n• Cảnh báo lỗi hoặc cảnh báo\n• Cung cấp phản hồi không trực quan\n• Người dùng khiếm thính hoặc khiếm thị\n\nBạn có thể tắt tính năng này nếu rung gây khó chịu.";
"help_text_simplified_ui" = "Giao diện đơn giản hóa giảm độ phức tạp hiển thị trong toàn ứng dụng.\n\nTính năng này giúp:\n• Khuyết tật nhận thức\n• Khó học\n• Rối loạn tập trung\n• Người dùng mới hoặc chưa có kinh nghiệm\n\nKhi bật:\n• Ít thành phần hơn trên màn hình\n• Điều khiển lớn hơn, rõ ràng hơn\n• Ít nhiễu hiển thị hơn";
"help_text_step_indicators" = "Chỉ báo bước hiển thị tiến trình của bạn qua các quy trình nhiều bước.\n\nTính năng này giúp:\n• Hiểu bạn đang ở đâu trong quy trình\n• Biết còn bao nhiêu bước\n• Giảm tải nhận thức\n• Cung cấp cấu trúc rõ ràng\n\nHiển thị 'Bước X trong Y' với các chấm tiến trình trực quan.";
"help_text_verbose_descriptions" = "Mô tả chi tiết cung cấp thêm văn bản giải thích trong toàn ứng dụng.\n\nTính năng này giúp:\n• Hiểu các tính năng phức tạp\n• Học cách sử dụng ứng dụng\n• Hỗ trợ nhận thức\n• Người dùng trình đọc màn hình\n\nCung cấp ngữ cảnh và hướng dẫn cho tất cả tính năng.";
"help_text_confirm_actions" = "Xác nhận hành động yêu cầu xác nhận trước các hành động quan trọng.\n\nTính năng này giúp ngăn:\n• Xóa nhầm\n• Thay đổi không mong muốn\n• Gửi sớm\n• Mất dữ liệu\n\nLưu ý: Các hành động phá hủy luôn yêu cầu xác nhận (yêu cầu AAA).";
"help_text_manual_code_entry" = "Nhập mã thủ công cho phép bạn gõ mã thay vì quét mã QR.\n\nTính năng này giúp khi:\n• Camera không hoạt động\n• Mã QR bị hỏng hoặc không rõ\n• Dùng trình đọc màn hình\n• Thích gõ hơn quét\n\nChỉ cần chạm 'Nhập mã thủ công' để gõ mã hiển thị trên màn hình.";
"help_text_voice_input" = "Nhập bằng giọng nói cho phép bạn đọc mã thay vì quét hoặc gõ.\n\nTính năng này giúp:\n• Hạn chế vận động\n• Người dùng trình đọc màn hình\n• Thao tác rảnh tay\n• Ưu thích giọng nói\n\nChạm nút micro và đọc rõ ràng khi được nhắc.";
"help_text_qr_scanning" = "Quét mã QR dùng camera của bạn để đọc mã QR (Mã phản hồi nhanh).\n\nCách quét:\n1. Hướng camera vào mã QR\n2. Căn chỉnh mã trong khung\n3. Chờ phát hiện tự động\n\nMẹo:\n• Đảm bảo đủ ánh sáng\n• Giữ thiết bị ổn định\n• Giữ mã QR phẳng và không bị che khuất\n• Nếu quét thất bại, thử Nhập mã thủ công";
"help_text_age_verification" = "Xác minh độ tuổi chứng minh bạn đáp ứng yêu cầu độ tuổi mà không tiết lộ tuổi thực hoặc ngày sinh.\n\nCách thức hoạt động:\n1. Bên xác minh tạo thử thách\n2. Bạn quét mã QR hoặc nhập thủ công\n3. Ứng dụng tạo bằng chứng không tiết lộ\n4. Bên xác minh xác nhận bạn đáp ứng yêu cầu\n\nQuyền riêng tư được bảo vệ:\n• Ngày sinh của bạn không bao giờ được chia sẻ\n• Bên xác minh chỉ biết bạn đáp ứng yêu cầu\n• Không theo dõi hay thu thập dữ liệu";
"help_text_credentials" = "Chứng chỉ kỹ thuật số là bằng chứng mật mã về độ tuổi của bạn được lưu trữ an toàn trên thiết bị.\n\nTính năng:\n• Chỉ lưu trên thiết bị của bạn\n• Không thể sao chép hoặc giả mạo\n• Dùng để xác minh bảo vệ quyền riêng tư\n• Có thể xóa bất cứ lúc nào\n\nBạn phải nhận chứng chỉ từ tổ chức phát hành được ủy quyền (như văn phòng chính phủ) trước khi xác minh độ tuổi.";
"help_text_zero_knowledge" = "Bằng chứng không tiết lộ cho phép bạn chứng minh điều gì đó là đúng mà không tiết lộ thông tin cơ bản.\n\nVí dụ:\n• Truyền thống: Xuất trình ID (tiết lộ ngày sinh chính xác)\n• Không tiết lộ: Chứng minh trên 18 tuổi mà không cần xuất trình ngày sinh\n\nLợi ích:\n• Bảo vệ quyền riêng tư tối đa\n• Không chia sẻ dữ liệu cá nhân\n• Bảo mật mật mã\n• Không thể giả mạo hoặc phát lại\n\nĐây là công nghệ cốt lõi làm cho Provii Wallet riêng tư.";
"help_text_credential_issuance" = "Phát hành chứng chỉ là quy trình nhận chứng chỉ độ tuổi kỹ thuật số từ tổ chức phát hành được ủy quyền.\n\nCác bước:\n1. Đến tổ chức phát hành được ủy quyền (ví dụ: văn phòng chính phủ)\n2. Chứng minh danh tính bằng giấy tờ tùy thân chính thức\n3. Nhận mã QR hoặc deeplink từ tổ chức phát hành\n4. Quét mã QR hoặc chạm vào liên kết\n5. Chứng chỉ được tính toán trên thiết bị của bạn và lưu trữ\n\nQuy trình chứng thực mù đảm bảo ngày sinh của bạn không bao giờ được truyền qua mạng.\nBạn chỉ cần làm điều này một lần. Chứng chỉ của bạn có thể được dùng cho xác minh không giới hạn.";
"help_text_officer_mode" = "Chế độ nhân viên dành cho tổ chức phát hành được ủy quyền để tạo chứng chỉ cho người dùng.\n\nChế độ này yêu cầu:\n• Xác thực nhân viên với YubiKey\n• Ủy quyền từ cơ quan phát hành\n• Xác minh trực tiếp giấy tờ của người dùng\n\nQuy trình:\n1. Xác thực với tư cách nhân viên\n2. Xác minh giấy tờ tùy thân chính thức của người dùng\n3. Nhập ngày sinh của người dùng\n4. Tạo mã QR chứng thực\n5. Người dùng quét mã để nhận chứng chỉ\n\nChỉ nhân viên được ủy quyền mới nên sử dụng chế độ này.";

"help_text_extra_large_text_simplified" = "Tăng tất cả chữ thêm 50%.\n\nGiúp bạn nếu bạn:\n• Khó nhìn\n• Thấy khó đọc\n• Cần chữ lớn hơn\n\nHoạt động với cài đặt cỡ chữ trên điện thoại.";
"help_text_contrast_level_simplified" = "Thay đổi độ tối của chữ.\n\nBa lựa chọn:\n• Tiêu chuẩn: Màu bình thường\n• Cao: Chữ tối hơn để dễ đọc\n• Tối đa: Chữ rất tối để đọc tốt nhất\n\nChữ tối hơn dễ đọc hơn.";
"help_text_high_contrast_simplified" = "Làm chữ dễ nhìn hơn.\n\nGiúp bạn nếu bạn:\n• Khó nhìn\n• Cần chữ tối hơn\n• Dùng ứng dụng trong ánh sáng mạnh\n\nChữ trở thành đen trên trắng.";
"help_text_reduce_transparency_simplified" = "Xóa hiệu ứng mờ.\n\nTính năng này giúp:\n• Làm chữ rõ ràng hơn\n• Làm ứng dụng đơn giản hơn\n• Tăng tốc điện thoại cũ\n\nMọi thứ trông đặc hơn.";
"help_text_color_blind_mode_simplified" = "Thay đổi màu sắc để giúp bạn nhìn rõ hơn.\n\nLựa chọn:\n• Chế độ mù đỏ\n• Chế độ mù xanh lá\n• Chế độ mù xanh dương\n• Chỉ thang xám\n\nGiúp bạn nhìn thấy những điều quan trọng.";
"help_text_line_spacing_simplified" = "Thay đổi khoảng cách giữa các dòng chữ.\n\nBạn có thể chọn từ 1.0x đến 2.0x.\nMặc định là 1.0x.\n\nKhoảng cách nhiều hơn giúp đọc dễ hơn.";
"help_text_paragraph_spacing_simplified" = "Thay đổi khoảng cách giữa các đoạn văn.\n\nBạn có thể chọn từ 1.0x đến 3.0x.\nMặc định là 1.0x.\n\nKhoảng cách nhiều hơn giúp bạn thấy ý mới bắt đầu ở đâu.";
"help_text_letter_spacing_simplified" = "Thay đổi khoảng cách giữa các chữ cái.\n\nBạn có thể chọn từ 0.0 đến 0.2.\nMặc định là 0.0.\n\nKhoảng cách nhiều hơn làm chữ cái rõ ràng hơn.";
"help_text_text_width_simplified" = "Kiểm soát độ rộng của chữ.\n\nLựa chọn:\n• Toàn bộ chiều rộng: Dùng toàn màn hình\n• Trung bình: Tốt để đọc\n• Hẹp: Tốt nhất để tập trung\n\nĐộ rộng trung bình dễ đọc nhất.";
"help_text_large_touch_targets_simplified" = "Làm tất cả nút lớn hơn.\n\nGiúp bạn nếu bạn:\n• Khó chạm nút nhỏ\n• Run tay\n• Đeo găng tay\n• Dùng một tay\n\nNút trở thành 60pt thay vì 44pt.";
"help_text_reduce_motion_simplified" = "Xóa hoạt ảnh chuyển động.\n\nGiúp bạn nếu:\n• Chuyển động làm bạn chóng mặt\n• Bạn bị đau đầu do chuyển động\n• Bạn muốn mọi thứ đứng yên\n\nMọi thứ thay đổi ngay lập tức thay vì chuyển động.";
"help_text_timeout_behavior_simplified" = "Kiểm soát thời gian thao tác có thể mất.\n\nLựa chọn:\n• Không giới hạn: Thao tác không bao giờ dừng\n• Bình thường: 30 giây\n• Dài hơn: 60 giây\n\nChọn 'Không giới hạn' nếu bạn cần thêm thời gian.";
"help_text_simplified_gestures_simplified" = "Thay thế cử chỉ khó bằng cú chạm đơn giản.\n\nGiúp bạn nếu bạn:\n• Khó thực hiện cử chỉ phức tạp\n• Thích cú chạm đơn giản\n• Dùng một tay\n\nMọi thứ dùng cú chạm đơn giản.";
"help_text_haptic_feedback_simplified" = "Làm điện thoại rung khi bạn chạm.\n\nGiúp bạn:\n• Biết khi bạn chạm nút\n• Cảm nhận lỗi hoặc cảnh báo\n• Nhận phản hồi mà không cần nhìn\n\nTắt nếu rung làm bạn khó chịu.";
"help_text_simplified_ui_simplified" = "Làm ứng dụng đơn giản hơn.\n\nGiúp bạn nếu bạn:\n• Bị nhầm lẫn bởi màn hình bận rộn\n• Thích bố cục đơn giản\n• Mới dùng ứng dụng\n\nHiển thị ít thứ hơn cùng một lúc.";
"help_text_step_indicators_simplified" = "Hiển thị tiến trình của bạn qua các bước.\n\nGiúp bạn:\n• Biết bạn đang ở đâu\n• Xem còn bao nhiêu bước\n• Giữ tổ chức\n\nHiển thị 'Bước 1 trong 3' với các chấm.";
"help_text_verbose_descriptions_simplified" = "Cho bạn thêm giải thích.\n\nGiúp bạn:\n• Hiểu các tính năng\n• Học cách dùng ứng dụng\n• Nhận thêm chi tiết\n\nCung cấp trợ giúp thêm ở khắp nơi.";
"help_text_confirm_actions_simplified" = "Yêu cầu bạn xác nhận các hành động quan trọng.\n\nGiúp ngăn:\n• Xóa nhầm\n• Thay đổi không mong muốn\n• Sai lầm\n\nBạn luôn được hỏi 'Bạn có chắc không?'";
"help_text_manual_code_entry_simplified" = "Cho phép bạn gõ mã thay vì quét.\n\nDùng khi:\n• Camera của bạn không hoạt động\n• Mã khó quét\n• Bạn thích gõ\n\nChạm 'Nhập mã thủ công' để gõ.";
"help_text_voice_input_simplified" = "Cho phép bạn đọc mã thay vì gõ.\n\nGiúp bạn nếu bạn:\n• Khó gõ\n• Thích nói chuyện\n• Muốn dùng rảnh tay\n\nChạm micro và đọc rõ ràng.";
"help_text_qr_scanning_simplified" = "Dùng camera để đọc mã vuông.\n\nCách quét:\n1. Hướng camera vào mã\n2. Căn chỉnh mã\n3. Chờ mã được đọc\n\nMẹo:\n• Dùng ánh sáng tốt\n• Giữ điện thoại ổn định\n• Giữ mã phẳng";
"help_text_age_verification_simplified" = "Chứng minh bạn đủ tuổi mà không chia sẻ ngày sinh.\n\nCách thức hoạt động:\n1. Doanh nghiệp tạo yêu cầu\n2. Bạn quét mã của họ\n3. Ứng dụng tạo bằng chứng\n4. Doanh nghiệp xác nhận bạn đủ tuổi\n\nNgày sinh của bạn được giữ kín.";
"help_text_credentials_simplified" = "Bằng chứng kỹ thuật số về độ tuổi lưu trên điện thoại.\n\nTính năng:\n• Chỉ trên điện thoại của bạn\n• Không thể sao chép\n• Giữ bạn riêng tư\n• Bạn có thể xóa bất cứ lúc nào\n\nBạn nhận từ văn phòng chính phủ.";
"help_text_zero_knowledge_simplified" = "Chứng minh điều gì đó mà không chia sẻ chi tiết.\n\nVí dụ:\n• Cách cũ: Xuất trình ID (hiện ngày sinh chính xác)\n• Cách mới: Chứng minh trên 18 tuổi (ngày sinh được giữ kín)\n\nĐiều này giữ thông tin của bạn riêng tư.";
"help_text_credential_issuance_simplified" = "Nhận bằng chứng độ tuổi kỹ thuật số của bạn.\n\nCác bước:\n1. Đến văn phòng chính phủ\n2. Xuất trình ID của bạn\n3. Nhận mã\n4. Quét mã\n5. Bằng chứng được lưu trên điện thoại của bạn\n\nLàm điều này một lần. Sau đó dùng nhiều lần.";
"help_text_officer_mode_simplified" = "Dành cho nhân viên chính phủ để tạo bằng chứng.\n\nCần:\n• Mật khẩu nhân viên\n• Quyền sử dụng\n• ID người dùng để kiểm tra\n\nCác bước:\n1. Đăng nhập với tư cách nhân viên\n2. Kiểm tra ID người dùng\n3. Nhập ngày sinh của họ\n4. Tạo mã\n5. Người dùng quét mã\n\nChỉ dành cho nhân viên được ủy quyền.";

