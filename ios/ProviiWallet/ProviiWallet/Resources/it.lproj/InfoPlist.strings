/* InfoPlist.strings - Italian (it) */
/* Descrizioni dei permessi localizzate per Provii Wallet */

/* Accesso alla fotocamera */
"NSCameraUsageDescription" = "Provii Wallet richiede l'accesso alla fotocamera per scansionare i codici QR durante il ritiro delle credenziali e la verifica dell'età.";

/* Accesso NFC */
"NFCReaderUsageDescription" = "Provii Wallet utilizza NFC per comunicare con la YubiKey dell'utente per l'autenticazione sicura degli operatori.";

/* Riconoscimento vocale */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet utilizza il riconoscimento vocale per i comandi vocali in modalità accessibilità, consentendo di controllare l'app senza usare le mani.";

/* Accesso al microfono */
"NSMicrophoneUsageDescription" = "Provii Wallet richiede l'accesso al microfono per le funzioni di controllo vocale quando la modalità accessibilità è attiva.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet utilizza Face ID per accedere in modo sicuro alle credenziali di età e verificare l'identità.";

/* Rete locale */
"NSLocalNetworkUsageDescription" = "Provii Wallet può utilizzare la rete locale per rilevare gli enti emittenti di credenziali nelle vicinanze.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet può utilizzare il Bluetooth per comunicare con i dispositivi YubiKey.";
