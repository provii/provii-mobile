    </array>
    
    <!-- ============================= -->
    <!-- Privacy Permissions           -->
    <!-- ============================= -->
    
    <!-- Camera for QR code scanning -->
    <key>NSCameraUsageDescription</key>
    <string>Provii Wallet needs camera access to scan QR codes for credential pickup and age verification.</string>
    
    <!-- NFC for YubiKey communication -->
    <key>NFCReaderUsageDescription</key>
    <string>Provii Wallet uses NFC to communicate with your YubiKey for secure officer authentication.</string>
    
    <!-- Speech Recognition -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Provii Wallet uses speech recognition for voice commands in accessibility mode, allowing you to control the app hands-free.</string>

    <!-- Microphone for Voice Input -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Provii Wallet needs microphone access for voice control features when accessibility mode is enabled.</string>

    <!-- Face ID / Touch ID for biometric authentication -->
    <key>NSFaceIDUsageDescription</key>
    <string>Provii Wallet uses Face ID to securely access your age credentials and verify your identity.</string>
    
    <!-- Local Network (optional - for mDNS/Bonjour if needed) -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Provii Wallet may use local network to discover nearby credential issuers.</string>
    
    <!-- Bluetooth (optional - if using Bluetooth YubiKey) -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Provii Wallet may use Bluetooth to communicate with YubiKey devices.</string>
    
    <!-- ============================= -->
    <!-- YubiKey External Accessory    -->
    <!-- ============================= -->
    <key>UISupportedExternalAccessoryProtocols</key>
    <array>
        <string>com.yubico.yubikey.accessory.otp</string>
        <string>com.yubico.yubikey.accessory.u2f</string>
        <string>com.yubico.yubikey.accessory.fido2</string>
    </array>
    
    <!-- ============================= -->
    <!-- URL Scheme Queries            -->
    <!-- ============================= -->
    <!-- Required for JailbreakDetector URL scheme checks (iOS 9+) -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>cydia</string>
        <string>sileo</string>
        <string>zbra</string>
        <string>filza</string>
        <string>undecimus</string>
    </array>

    <!-- ============================= -->
    <!-- App Transport Security        -->
    <!-- ============================= -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- Disable arbitrary loads by default for security -->
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        
        <!-- Allow localhost for development/testing -->
        <key>NSAllowsLocalNetworking</key>
        <true/>
        
        <!-- Allowed API domains -->
        <key>NSExceptionDomains</key>
        <dict>
            <!-- Production APIs -->
            <key>provii.app</key>
            <dict>
                <key>NSIncludesSubdomains</key>
                <true/>
                <key>NSExceptionRequiresForwardSecrecy</key>
                <true/>
                <key>NSExceptionMinimumTLSVersion</key>
                <string>TLSv1.2</string>
            </dict>
            
            <!-- ZeroKP Verification -->
            <key>verify.provii.app</key>
            <dict>
