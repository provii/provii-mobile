/* InfoPlist.strings - Ukrainian */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet потребує доступу до камери для сканування QR-кодів під час отримання посвідчення та верифікації віку.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet використовує NFC для зв'язку з YubiKey при безпечній автентифікації службовця.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet використовує розпізнавання мовлення для голосових команд у режимі доступності, дозволяючи Вам керувати додатком без використання рук.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet потребує доступу до мікрофона для функцій голосового керування при увімкненому режимі доступності.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet використовує Face ID для безпечного доступу до Ваших вікових посвідчень та верифікації Вашої особи.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet може використовувати локальну мережу для виявлення найближчих видавців посвідчень.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet може використовувати Bluetooth для зв'язку з пристроями YubiKey.";
