/* Help Text Descriptions */
"help_text_extra_large_text" = "ძალიან დიდი ტექსტი აპის ყველა ტექსტს 50%-ით ზრდის.\n\nსასარგებლოა:\n• სუსტი მხედველობისთვის\n• კითხვის სირთულეებისთვის\n• ასაკთან დაკავშირებული მხედველობის ცვლილებებისთვის\n\nიOS Dynamic Type-თან ერთად მუშაობს კიდევ უფრო დიდი ზომებისთვის.";
"help_text_contrast_level" = "კონტრასტის დონე აკონტროლებს ტექსტსა და ფონს შორის ფერების კონტრასტს.\n\nხელმისაწვდომია სამი დონე:\n• სტანდარტული: ნაგულისხმევი ფერები\n• მაღალი (AA): 4.5:1 კონტრასტის თანაფარდობა\n• მაქსიმალური (AAA): 7:1 კონტრასტის თანაფარდობა\n\nმაღალი კონტრასტი ყველა განათების პირობებში ტექსტს კითხვადს ხდის.";
"help_text_high_contrast" = "მაღალი კონტრასტის რეჟიმი ტექსტსა და ფონს შორის კონტრასტს ზრდის.\n\nსასარგებლოა:\n• სუსტი მხედველობისთვის\n• ფერების მგრძნობელობისთვის\n• კაშკაშა ეკრანის გარემოსთვის\n\nჩართვისას:\n• ტექსტი თეთრ ფონზე შავი ხდება\n• ელემენტებს საზღვრები ემატება\n• ფერები გამარტივდება";
"help_text_reduce_transparency" = "გამჭვირვალობის შემცირება ბუნდოვან და გამჭვირვალე ეფექტებს აპიდან ამოიღებს.\n\nსასარგებლოა:\n• ტექსტის კითხვადობის გასაუმჯობესებლად\n• ვიზუალური სირთულის შესამცირებლად\n• ძველ მოწყობილობებზე შესრულების გასაუმჯობესებლად";
"help_text_color_blind_mode" = "ფერის სიბრმავის რეჟიმები ფერებს ფერის ხედვის სხვადასხვა დეფიციტისთვის ადაპტირებს.\n\nხელმისაწვდომი რეჟიმები:\n• პროტანოპია: წითელი სიბრმავე\n• დეიტერანოპია: მწვანე სიბრმავე\n• ტრიტანოპია: ლურჯი სიბრმავე\n• მონოქრომი: მხოლოდ ნაცრისფერი\n\nეს რეჟიმები უზრუნველყოფს, რომ მნიშვნელოვანი ინფორმაცია მხოლოდ ფერით არ გადაიცეს.";
"help_text_line_spacing" = "სტრიქონების დაშორება ტექსტის სტრიქონებს შორის სივრცეს აკონტროლებს.\n\n• დიაპაზონი: 1.0x-2.0x\n• AAA სტანდარტი: მინიმუმ 1.5x\n• ნაგულისხმევი: 1.0x\n\nგაზრდილი დაშორება ტექსტის კითხვას ამარტივებს.";
"help_text_paragraph_spacing" = "აბზაცების დაშორება აბზაცებს შორის სივრცეს აკონტროლებს.\n\n• დიაპაზონი: 1.0x-3.0x\n• AAA სტანდარტი: მინიმუმ 2.0x\n• ნაგულისხმევი: 1.0x\n\nგაზრდილი დაშორება ტექსტის სხვადასხვა სექციების განსხვავებას ეხმარება.";
"help_text_letter_spacing" = "ასოების დაშორება ცალკეულ სიმბოლოებს შორის სივრცეს აკონტროლებს.\n\n• დიაპაზონი: 0.0em-0.2em\n• AAA სტანდარტი: მინიმუმ 0.12em\n• ნაგულისხმევი: 0.0em\n\nგაზრდილი დაშორება სიმბოლოების ამოცნობას და კითხვადობას აუმჯობესებს.";
"help_text_text_width" = "ტექსტის სიგანე კომფორტული კითხვისთვის სტრიქონის მაქსიმალურ სიგრძეს აკონტროლებს.\n\nვარიანტები:\n• სრული სიგანე: მაქსიმუმი არ არის\n• კომფორტული (80 სიმბოლო): კითხვისთვის ოპტიმალური\n• ვიწრო (60 სიმბოლო): ფოკუსირებული კითხვისთვის\n\nAAA სახელმძღვანელო მაქსიმუმ 80 სიმბოლოს სტრიქონზე რეკომენდებს.";
"help_text_large_touch_targets" = "გაზრდილი შეხების სამიზნეები ყველა ღილაკს და ინტერაქტიულ ელემენტს მინიმუმ 60pt ზომამდე ზრდის.\n\nსასარგებლოა:\n• მოტორიკის სირთულეებისთვის\n• ტრემორის ან ხელის კანკალისთვის\n• ხელთათმანებით გამოყენებისთვის\n• ერთხელხიანი გამოყენებისთვის\n\nსტანდარტული მინიმუმია 44pt; ეს პარამეტრი 60pt-მდე ზრდის.";
"help_text_reduce_motion" = "მოძრაობის შემცირება ანიმაციებს მთელ აპში ამცირებს ან ამოიღებს.\n\nსასარგებლოა:\n• მოძრაობის მგრძნობელობისთვის\n• ვესტიბულური დარღვევებისთვის\n• ეპილეფსიისთვის\n• მიგრენის გამომწვევებისთვის\n\nჩართვისას ანიმაციები მყისიერ გადასვლებით იცვლება.";
"help_text_timeout_behavior" = "ვადის ქცევა ოპერაციების ვადის ამოწურვამდე ხანგრძლივობას აკონტროლებს.\n\nვარიანტები:\n• ვადა არ არის (AAA): ოპერაციებს ვადა არ ეწესება\n• სტანდარტული (30წ): ნაგულისხმევი ვადა\n• გაგრძელებული (60წ): სტანდარტულის ორმაგი დრო\n\nვადის გარეშე რეჟიმი AAA ხელმისაწვდომობის სტანდარტებს აკმაყოფილებს.";
"help_text_simplified_gestures" = "გამარტივებული ჟესტები რთულ მრავალ-შეხების ჟესტებს მარტივ შეხებებით ცვლის.\n\nსასარგებლოა:\n• მოტორიკის სირთულეებისთვის\n• შეზღუდული მოქნილობისთვის\n• დამხმარე მოწყობილობების გამოყენებისთვის\n• ერთხელხიანი ოპერაციისთვის\n\nრთული ჟესტები ღილაკებით და მარტივი შეხებებით იცვლება.";
"help_text_haptic_feedback" = "ჰაპტური გამოხმაურება მოქმედებებზე და შეტყობინებებზე ვიბრაციულ გამოხმაურებას უზრუნველყოფს.\n\nსასარგებლოა:\n• ღილაკების დაჭერის დასადასტურებლად\n• შეცდომებისა და გაფრთხილებებზე გასაფრთხილებლად\n• არარეოლური გამოხმაურებისთვის\n• სმენისა ან მხედველობის სირთულის მქონე მომხმარებლებისთვის\n\nთუ ვიბრაცია შეუფერებელია, შეგიძლიათ გამორთოთ.";
"help_text_simplified_ui" = "გამარტივებული ინტერფეისი ყველა ეკრანზე ვიზუალურ სირთულეს ამცირებს.\n\nსასარგებლოა:\n• კოგნიტური შეზღუდვებისთვის\n• სწავლის სირთულეებისთვის\n• ყურადღების დარღვევებისთვის\n• ახალი ან გამოუცდელი მომხმარებლებისთვის\n\nჩართვისას:\n• ეკრანზე ნაკლები ელემენტია\n• კონტროლები გაზრდილი და მკაფიოა\n• ვიზუალური ხმაური ნაკლებია";
"help_text_step_indicators" = "ნაბიჯის ინდიკატორები მრავალ-ნაბიჯიანი პროცესებით თქვენს პროგრესს გვიჩვენებს.\n\nეხმარება:\n• გაიგოთ, სად ხართ პროცესში\n• იცოდეთ, რამდენი ნაბიჯი რჩება\n• კოგნიტური დატვირთვა შეამციროთ\n\nაჩვენებს „ნაბიჯი X Y-დან” ვიზუალური პროგრეს-წერტილებით.";
"help_text_verbose_descriptions" = "დეტალური აღწერები მთელ აპში დამატებით განმარტებით ტექსტს გვაწვდის.\n\nსასარგებლოა:\n• რთული ფუნქციების გასაგებად\n• აპის გამოყენების შესასწავლად\n• კოგნიტური მხარდაჭერისთვის\n• ეკრანის წამკითხველის მომხმარებლებისთვის\n\nყველა ფუნქციაზე კონტექსტს და ინსტრუქციებს გვაწვდის.";
"help_text_confirm_actions" = "მოქმედებების დადასტურება მნიშვნელოვანი მოქმედებებამდე დადასტურებას ითხოვს.\n\nეხმარება:\n• შემთხვევითი წაშლების თავიდან ასაცილებლად\n• გაუთვლელი ცვლილებების თავიდან ასაცილებლად\n• ნაადრევი გაგზავნების თავიდან ასაცილებლად\n• მონაცემების დაკარგვის თავიდან ასაცილებლად\n\nშენიშვნა: განადგურებადი მოქმედებები ყოველთვის დადასტურებას მოითხოვს (AAA მოთხოვნა).";
"help_text_manual_code_entry" = "კოდის ხელით შეყვანა QR კოდების სკანირების ნაცვლად კოდების ჩაწერის საშუალებას გაძლევთ.\n\nსასარგებლოა:\n• კამერა რომ არ მუშაობს\n• QR კოდი დაზიანებული ან გაურკვეველია\n• ეკრანის წამკითხველის გამოყენებისას\n• სკანირებაზე ჩაწერის უპირატესობისას\n\nუბრალოდ შეეხეთ „კოდის ხელით შეყვანას” ეკრანზე ნაჩვენები კოდის ჩასაწერად.";
"help_text_voice_input" = "ხმოვანი შეყვანა სკანირების ან ჩაწერის ნაცვლად კოდების წარმოთქმის საშუალებას გაძლევთ.\n\nსასარგებლოა:\n• შეზღუდული მოძრაობისთვის\n• ეკრანის წამკითხველის მომხმარებლებისთვის\n• ხელის გარეშე ოპერაციისთვის\n• ხმის პრეფერენციისთვის\n\nშეეხეთ მიკროფონის ღილაკს და ნათლად ილაპარაკეთ, როდესაც მოგთხოვენ.";
"help_text_qr_scanning" = "QR კოდის სკანირება კამერას გამოიყენებს სწრაფი გამოხმაურების კოდების წასაკითხად.\n\nსკანირების ინსტრუქცია:\n1. მიუმართეთ კამერა QR კოდს\n2. კოდი ჩარჩოში გასწორეთ\n3. ავტომატური გამოვლინების მოლოდინი\n\nრჩევები:\n• კარგი განათება\n• მოწყობილობა გაუნძრევლად\n• QR კოდი ბრტყელი და გაუბრტყელებელი\n• სკანირების მარცხის შემთხვევაში სცადეთ კოდის ხელით შეყვანა";
"help_text_age_verification" = "ასაკის ვერიფიკაცია ფაქტობრივი ასაკის ან დაბადების თარიღის გამჟღავნების გარეშე ასაკის მოთხოვნის დაკმაყოფილებას ადასტურებს.\n\nმუშაობის პრინციპი:\n1. ვერიფიკატორი გამოწვევას ქმნის\n2. QR კოდი სკანირება გაუკეთეთ ან ხელით შეიყვანეთ\n3. აპი ნულოვანი ცოდნის მტკიცებულებას ქმნის\n4. ვერიფიკატორი ადასტურებს მოთხოვნის შესრულებას\n\nკონფიდენციალურობა დაცულია:\n• თქვენი დაბადების თარიღი არასოდეს გაზიარდება\n• ვერიფიკატორი მხოლოდ მოთხოვნის შესრულებას იგებს\n• თვალთვალი ან მონაცემთა შეგროვება არ ხდება";
"help_text_credentials" = "ციფრული სერტიფიკატები თქვენი ასაკის კრიპტოგრაფიული მტკიცებულებებია, რომლებიც მოწყობილობაზე ინახება.\n\nმახასიათებლები:\n• მხოლოდ მოწყობილობაზე ინახება\n• კოპირება ან გაყალბება შეუძლებელია\n• კონფიდენციალური ვერიფიკაციისთვის გამოიყენება\n• ნებისმიერ დროს წაშლა შეიძლება\n\nასაკის ვერიფიკაციამდე ავტორიზებული გამცემისგან სერტიფიკატი უნდა მიიღოთ.";
"help_text_zero_knowledge" = "ნულოვანი ცოდნის მტკიცებულებები საშუალებას გაძლევთ დაამტკიცოთ, რომ რაღაც მართალია ძირითადი ინფორმაციის გამჟღავნების გარეშე.\n\nმაგალითი:\n• ტრადიციული: ID-ის ჩვენება (ზუსტი დაბადების თარიღი ჩანს)\n• ნულოვანი ცოდნა: 18 წელს გადაჭარბება დაამტკიცეთ დაბადების თარიღის გამჟღავნების გარეშე\n\nUPrეimüstaVorteil:\n• მაქსიმალური კონფიდენციალური დაცვა\n• პირადი მონაცემები არ გაზიარდება\n• კრიპტოგრაფიულად უსაფრთხო\n• გაყალბება ან გამეორება შეუძლებელია\n\nეს არის ძირეული ტექნოლოგია, რომელიც Provii Wallet-ს კონფიდენციალურს ხდის.";
"help_text_credential_issuance" = "სერტიფიკატის გაცემა ავტორიზებული გამცემისგან ციფრული ასაკის სერტიფიკატის მიღების პროცესია.\n\nნაბიჯები:\n1. ეწვიეთ ავტორიზებულ გამცემს\n2. დაამტკიცეთ ვინაობა ოფიციალური ID-ით\n3. მიიღეთ QR კოდი ან ღრმა ბმული გამცემისგან\n4. QR კოდი სკანირება გაუკეთეთ ან ბმულს შეეხეთ\n5. სერტიფიკატი ლოკალურად გამოიქნება და მოწყობილობაზე შეინახება\n\nბრმა ატესტაციის პროცესი უზრუნველყოფს, რომ დაბადების თარიღი ქსელში არასოდეს გადაიცეს.\nეს მხოლოდ ერთხელ გჭირდებათ. შემდეგ სერტიფიკატი შეუზღუდავი ვერიფიკაციისთვის გამოიყენება.";
"help_text_officer_mode" = "თანამშრომლის რეჟიმი ავტორიზებული გამცემებისთვისაა მომხმარებლებისთვის სერტიფიკატების შესაქმნელად.\n\nამ რეჟიმს სჭირდება:\n• თანამშრომლის ავთენტიფიკაცია YubiKey-ით\n• გამცემი ორგანოს ავტორიზაცია\n• მომხმარებლის ID-ის ფიზიკური ვერიფიკაცია\n\nპროცესი:\n1. ავთენტიფიცირება, როგორც თანამშრომელი\n2. მომხმარებლის ოფიციალური ID-ის ვერიფიკაცია\n3. მომხმარებლის დაბადების თარიღის შეყვანა\n4. ატესტაციის QR კოდის გენერაცია\n5. მომხმარებელი QR კოდს სკანირება უკეთებს სერტიფიკატის მისაღებად\n\nმხოლოდ ავტორიზებული პერსონალი უნდა გამოიყენოს ეს რეჟიმი.";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "ყველა ტექსტს 50%-ით ზრდის.\n\nსასარგებლოა:\n• სუსტი მხედველობისთვის\n• კითხვის სირთულეებისთვის\n• დიდი ტექსტის საჭიროებისთვის\n\nტელეფონის ტექსტის ზომის პარამეტრებთან ერთად მუშაობს.";
"help_text_contrast_level_simplified" = "ტექსტის სიბნელეს ცვლის.\n\nსამი არჩევანია:\n• სტანდარტული: ნორმალური ფერები\n• მაღალი: მუქი ტექსტი კითხვისთვის\n• მაქსიმალური: ძალიან მუქი ტექსტი\n\nმუქი ტექსტი უფრო ადვილი საკითხავია.";
"help_text_high_contrast_simplified" = "ტექსტს კითხვად ხდის.\n\nსასარგებლოა:\n• სუსტი მხედველობისთვის\n• მუქი ტექსტის საჭიროებისთვის\n• კაშკაშა განათებაში\n\nტექსტი თეთრ ფონზე შავი ხდება.";
"help_text_reduce_transparency_simplified" = "ბუნდოვან ეფექტებს ამოიღებს.\n\nეხმარება:\n• ტექსტი მკაფიო გახდეს\n• აპი გამარტივდეს\n• ძველი ტელეფონი სწრაფდეს\n\nყველაფერი მყარი გამოიყურება.";
"help_text_color_blind_mode_simplified" = "ფერებს ცვლის, რომ უკეთ დაინახოთ.\n\nარჩევანი:\n• წითელი სიბრმავის რეჟიმი\n• მწვანე სიბრმავის რეჟიმი\n• ლურჯი სიბრმავის რეჟიმი\n• მხოლოდ ნაცრისფერი\n\nეხმარება მნიშვნელოვანი სანახავებლად.";
"help_text_line_spacing_simplified" = "ტექსტის სტრიქონებს შორის სივრცეს ცვლის.\n\n1.0x-2.0x-ს შორის შეგიძლიათ აირჩიოთ.\nნაგულისხმევია 1.0x.\n\nმეტი სივრცე კითხვას ამარტივებს.";
"help_text_paragraph_spacing_simplified" = "აბზაცებს შორის სივრცეს ცვლის.\n\n1.0x-3.0x-ს შორის შეგიძლიათ აირჩიოთ.\nნაგულისხმევია 1.0x.\n\nმეტი სივრცე ახალი იდეების დასაწყისის დანახვაში ეხმარება.";
"help_text_letter_spacing_simplified" = "ასოებს შორის სივრცეს ცვლის.\n\n0.0-0.2-ს შორის შეგიძლიათ აირჩიოთ.\nნაგულისხმევია 0.0.\n\nმეტი სივრცე ასოებს მკაფიოს ხდის.";
"help_text_text_width_simplified" = "ტექსტის სიგანეს აკონტროლებს.\n\nარჩევანი:\n• სრული სიგანე: მთელ ეკრანს იყენებს\n• საშუალო: კარგია კითხვისთვის\n• ვიწრო: ფოკუსისთვის\n\nსაშუალო სიგანე ყველაზე ადვილი საკითხავია.";
"help_text_large_touch_targets_simplified" = "ყველა ღილაკს ზრდის.\n\nსასარგებლოა:\n• მცირე ღილაკების შეხების სირთულის შემთხვევაში\n• კანკალის შემთხვევაში\n• ხელთათმანებით\n• ერთი ხელით\n\nღილაკები 44pt-ის ნაცვლად 60pt ხდება.";
"help_text_reduce_motion_simplified" = "მოძრაო ანიმაციებს ამოიღებს.\n\nსასარგებლოა:\n• მოძრაობა თავბრუს ახვევს\n• მოძრაობისგან თავი გტკივა\n• სიმშვიდე გირჩევნიათ\n\nყველაფერი მოძრაობის ნაცვლად მყისიერად იცვლება.";
"help_text_timeout_behavior_simplified" = "ამოცანების ხანგრძლივობას აკონტროლებს.\n\nარჩევანი:\n• ლიმიტი არ არის: ამოცანები არ ჩერდება\n• ნორმალური: 30 წამი\n• გრძელი: 60 წამი\n\nუფრო მეტი დრო გჭირდებათ? „ლიმიტის გარეშე” აირჩიეთ.";
"help_text_simplified_gestures_simplified" = "რთული ჟესტებს მარტივი შეხებებით ცვლის.\n\nსასარგებლოა:\n• რთული შეხებების სირთულის შემთხვევაში\n• მარტივი შეხებების გამოყენება გირჩევნიათ\n• ერთი ხელით\n\nყველაფერი მარტივ შეხებებს იყენებს.";
"help_text_haptic_feedback_simplified" = "ღილაკზე შეხებისას ტელეფონი ვიბრირებს.\n\nეხმარება:\n• ღილაკზე დაჭერის შემოწმება\n• შეცდომების ან გაფრთხილებების შეგრძნება\n• ყურება-ის გარეშე გამოხმაურება\n\nგამორთეთ, თუ ვიბრაცია შეუფერებელია.";
"help_text_simplified_ui_simplified" = "აპს გამარტივებს.\n\nსასარგებლოა:\n• ბიზი ეკრანები ართულებს\n• გამარტივებული განლაგება გირჩევნიათ\n• ახალი ხართ\n\nერთდროულად ნაკლებ ნივთს აჩვენებს.";
"help_text_step_indicators_simplified" = "ნაბიჯებით თქვენს პროგრესს გვიჩვენებს.\n\nეხმარება:\n• სად ხართ იცოდეთ\n• რამდენი ნაბიჯი რჩება\n• ორგანიზებული იყოთ\n\nაჩვენებს „ნაბიჯი 1 3-დან” წერტილებით.";
"help_text_verbose_descriptions_simplified" = "მეტ განმარტებებს გაძლევთ.\n\nეხმარება:\n• ფუნქციების გასაგებად\n• გამოყენების სასწავლად\n• მეტი დეტალის მისაღებად\n\nყველგან დამატებით დახმარებას გაძლევთ.";
"help_text_confirm_actions_simplified" = "მნიშვნელოვანი მოქმედებების დადასტურებას ითხოვს.\n\nეხმარება:\n• შემთხვევითი წაშლების თავიდან\n• გაუთვლელი ცვლილებების თავიდან\n• შეცდომების თავიდან\n\nყოველთვის გეკითხება „დარწმუნებული ხართ?”";
"help_text_manual_code_entry_simplified" = "სკანირების ნაცვლად კოდების ჩაწერის საშუალებას გაძლევთ.\n\nამ შემთხვევაში გამოიყენეთ:\n• კამერა არ მუშაობს\n• კოდი სკანირება ძნელია\n• ჩაწერა გირჩევნიათ\n\nშეეხეთ „კოდის ხელით შეყვანას” ჩასაწერად.";
"help_text_voice_input_simplified" = "ჩაწერის ნაცვლად კოდების წარმოთქმის საშუალებას გაძლევთ.\n\nსასარგებლოა:\n• ჩაწერა გჭირდებათ\n• ლაპარაკი გირჩევნიათ\n• ხელის გარეშე\n\nმიკროფონს შეეხეთ და ნათლად ილაპარაკეთ.";
"help_text_qr_scanning_simplified" = "კამერას კვადრატული კოდების წასაკითხად გამოიყენებს.\n\nსკანირება:\n1. კოდისკენ კამერა მიუმართეთ\n2. კოდი გასწორეთ\n3. წაკითხვის მოლოდინი\n\nრჩევები:\n• კარგი განათება\n• ტელეფონი გაუნძრევლად\n• კოდი ბრტყელი";
"help_text_age_verification_simplified" = "დაბადების თარიღის გაზიარების გარეშე ასაკის შესაბამისობას ადასტურებს.\n\nმუშაობა:\n1. ბიზნესი მოთხოვნას ქმნის\n2. მათი კოდი სკანირება გაუკეთეთ\n3. აპი მტკიცებულებას ქმნის\n4. ბიზნესი ადასტურებს ასაკის შესაბამისობას\n\nდაბადების თარიღი კონფიდენციალური რჩება.";
"help_text_credentials_simplified" = "ტელეფონზე შენახული ასაკის ციფრული მტკიცებულება.\n\nმახასიათებლები:\n• მხოლოდ ტელეფონზე\n• კოპირება შეუძლებელია\n• კონფიდენციალური\n• ნებისმიერ დროს წაშლა შეიძლება\n\nსახელმწიფო სამსახურიდან ღებულობთ.";
"help_text_zero_knowledge_simplified" = "დეტალების გაზიარების გარეშე რაღაცის დამტკიცება.\n\nმაგალითი:\n• ძველი გზა: ID-ის ჩვენება (ზუსტი დაბადების თარიღი ჩანს)\n• ახალი გზა: 18 წელს გადაჭარბება (თარიღი კონფიდენციალური)\n\nეს ინფორმაციას კონფიდენციალურს ინახავს.";
"help_text_credential_issuance_simplified" = "ასაკის ციფრული მტკიცებულების მიღება.\n\nნაბიჯები:\n1. სახელმწიფო სამსახურში გაიარეთ\n2. ID-ი გაჩვენეთ\n3. კოდი მიიღეთ\n4. კოდი სკანირება გაუკეთეთ\n5. მტკიცებულება ტელეფონზე ინახება\n\nერთხელ გაიარეთ. შემდეგ ბევრჯერ გამოიყენეთ.";
"help_text_officer_mode_simplified" = "სახელმწიფო მოხელეებისთვის მტკიცებულებების შესაქმნელად.\n\nსჭირდება:\n• თანამშრომლის პაროლი\n• გამოყენების ნებართვა\n• მომხმარებლის ID-ის შემოწმება\n\nნაბიჯები:\n1. შედით, როგორც თანამშრომელი\n2. მომხმარებლის ID-ი შეამოწმეთ\n3. დაბადების თარიღი შეიყვანეთ\n4. კოდი შექმენით\n5. მომხმარებელი კოდს სკანირება უკეთებს\n\nმხოლოდ ავტორიზებული მოხელეებისთვის.";

