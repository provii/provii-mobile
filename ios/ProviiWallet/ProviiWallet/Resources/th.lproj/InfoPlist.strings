/* InfoPlist.strings - Thai */
/* Localised permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet ต้องการการเข้าถึงกล้องเพื่อสแกนรหัส QR สำหรับการรับข้อมูลรับรองและการยืนยันอายุ";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet ใช้ NFC เพื่อสื่อสารกับ YubiKey ของท่านสำหรับการยืนยันตัวตนเจ้าหน้าที่ที่ปลอดภัย";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet ใช้การรู้จำเสียงพูดสำหรับคำสั่งเสียงในโหมดการช่วยเหลือการเข้าถึง ซึ่งช่วยให้ท่านควบคุมแอปได้แบบมือเปล่า";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet ต้องการการเข้าถึงไมโครโฟนสำหรับคุณสมบัติการควบคุมด้วยเสียงเมื่อเปิดใช้งานโหมดการช่วยเหลือการเข้าถึง";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet ใช้ Face ID เพื่อเข้าถึงข้อมูลรับรองอายุของท่านอย่างปลอดภัยและยืนยันตัวตนของท่าน";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet อาจใช้เครือข่ายท้องถิ่นเพื่อค้นหาผู้ออกข้อมูลรับรองในบริเวณใกล้เคียง";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet อาจใช้ Bluetooth เพื่อสื่อสารกับอุปกรณ์ YubiKey";
