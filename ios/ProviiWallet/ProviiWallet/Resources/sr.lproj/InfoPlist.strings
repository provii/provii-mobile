/* InfoPlist.strings - Serbian (Cyrillic) */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet захтева приступ камери за скенирање QR кодова приликом преузимања акредитива и верификације старости.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet користи NFC за комуникацију са Вашим YubiKey уређајем ради безбедне аутентификације службеника.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet користи препознавање говора за гласовне команде у режиму приступачности, омогућавајући Вам да управљате апликацијом без употребе руку.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet захтева приступ микрофону за функције гласовне контроле када је режим приступачности омогућен.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet користи Face ID за безбедан приступ Вашим акредитивима за верификацију старости и потврду Вашег идентитета.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet може користити локалну мрежу за откривање оближњих издавалаца акредитива.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet може користити Bluetooth за комуникацију са YubiKey уређајима.";
