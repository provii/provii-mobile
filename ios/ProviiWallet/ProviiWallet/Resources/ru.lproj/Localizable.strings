// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Очень крупный текст увеличивает весь текст в приложении на 50%.\n\nЭто полезно для пользователей:\n• Со слабым зрением\n• С затруднённым чтением\n• С возрастными изменениями зрения\n\nРаботает с настройками Dynamic Type iOS для ещё большего размера.";
"help_text_contrast_level" = "Уровень контрастности управляет цветовым контрастом между текстом и фоном.\n\nДоступны три уровня:\n• Стандартный: цвета по умолчанию\n• Высокий (AA): коэффициент контрастности 4,5:1 , соответствует стандартам AA\n• Максимальный (AAA): коэффициент контрастности 7:1 , соответствует высшим стандартам AAA\n\nБолее высокий контраст облегчает чтение текста в любых условиях освещения.";
"help_text_high_contrast" = "Режим высокой контрастности увеличивает контраст между текстом и фоном, облегчая чтение.\n\nЭто полезно для пользователей:\n• Со слабым зрением\n• С чувствительностью к цвету\n• В условиях яркого освещения\n\nПри включении:\n• Текст становится чёрным на белом\n• К элементам добавляются рамки\n• Цвета упрощаются";
"help_text_reduce_transparency" = "Уменьшение прозрачности убирает эффекты размытия и прозрачности в приложении.\n\nЭто помогает:\n• Улучшить читаемость текста\n• Снизить визуальную сложность\n• Повысить производительность на старых устройствах\n• Сделать контент более предсказуемым";
"help_text_color_blind_mode" = "Режимы для людей с нарушением цветовосприятия настраивают цвета для различных типов нарушения цветового зрения.\n\nДоступные режимы:\n• Протанопия: слепота к красному\n• Дейтеранопия: слепота к зелёному\n• Тританопия: слепота к синему\n• Монохромный: только оттенки серого\n\nЭти режимы гарантируют, что важная информация не передаётся только через цвет.";
"help_text_line_spacing" = "Межстрочный интервал управляет расстоянием между строками текста.\n\n• Диапазон: от 1,0x до 2,0x\n• Стандарт AAA: минимум 1,5x\n• По умолчанию: 1,0x\n\nУвеличенный межстрочный интервал облегчает чтение и помогает избежать пропуска строк.";
"help_text_paragraph_spacing" = "Межабзацный интервал управляет расстоянием между абзацами.\n\n• Диапазон: от 1,0x до 3,0x\n• Стандарт AAA: минимум 2,0x\n• По умолчанию: 1,0x\n\nУвеличенный межабзацный интервал помогает различать разные разделы текста.";
"help_text_letter_spacing" = "Межбуквенный интервал управляет расстоянием между отдельными символами.\n\n• Диапазон: от 0,0 em до 0,2 em\n• Стандарт AAA: минимум 0,12 em\n• По умолчанию: 0,0 em\n\nУвеличенный межбуквенный интервал улучшает распознавание символов и читаемость.";
"help_text_text_width" = "Ширина текста управляет максимальной длиной строки для комфортного чтения.\n\nПараметры:\n• Полная ширина: без максимума\n• Удобный (80 симв.): оптимально для чтения\n• Узкий (60 симв.): для сосредоточенного чтения\n\nРекомендации AAA: максимум 80 символов в строке.";
"help_text_large_touch_targets" = "Увеличенные области касания делают все кнопки и интерактивные элементы размером не менее 60 точек.\n\nЭто полезно при:\n• Нарушениях моторики\n• Треморе или дрожании\n• Использовании приложения в перчатках\n• Работе одной рукой\n\nСтандартный минимум , 44 точки; эта настройка увеличивает его до 60 точек.";
"help_text_reduce_motion" = "Уменьшение движения минимизирует или убирает анимацию в приложении.\n\nЭто полезно для пользователей:\n• Чувствительных к движению\n• С вестибулярными нарушениями\n• С эпилепсией\n• Склонных к мигрени\n\nПри включении анимация заменяется мгновенными переходами.";
"help_text_timeout_behavior" = "Поведение тайм-аута управляет временем ожидания операций до истечения срока.\n\nПараметры:\n• Без тайм-аута (AAA): операции никогда не истекают\n• Стандартный (30 с): тайм-аут по умолчанию\n• Расширенный (60 с): вдвое больше стандартного времени\n\nРежим без тайм-аута соответствует стандартам специальных возможностей AAA.";
"help_text_simplified_gestures" = "Упрощённые жесты заменяют сложные многоточечные жесты простыми нажатиями.\n\nЭто полезно при:\n• Нарушениях моторики\n• Ограниченной ловкости\n• Использовании вспомогательных устройств\n• Работе одной рукой\n\nСложные жесты заменяются кнопками и простыми нажатиями.";
"help_text_haptic_feedback" = "Тактильный отклик обеспечивает вибрационную обратную связь для действий и уведомлений.\n\nЭто полезно для:\n• Подтверждения нажатий кнопок\n• Предупреждения об ошибках\n• Невизуальной обратной связи\n• Пользователей с нарушениями слуха или зрения\n\nВы можете отключить это, если вибрация неудобна.";
"help_text_simplified_ui" = "Упрощённый интерфейс снижает визуальную сложность в приложении.\n\nЭто полезно при:\n• Когнитивных нарушениях\n• Трудностях с обучением\n• Нарушениях внимания\n• Новых или неопытных пользователях\n\nПри включении:\n• Меньше элементов на экране\n• Более крупные и чёткие элементы управления\n• Меньше визуального шума";
"help_text_step_indicators" = "Индикаторы шагов показывают прогресс в многошаговых процессах.\n\nЭто помогает:\n• Понять, где вы находитесь в процессе\n• Знать, сколько шагов осталось\n• Снизить когнитивную нагрузку\n• Обеспечить чёткую структуру\n\nОтображает «Шаг X из Y» с визуальными точками прогресса.";
"help_text_verbose_descriptions" = "Подробные описания предоставляют дополнительный пояснительный текст в приложении.\n\nЭто полезно для:\n• Понимания сложных функций\n• Освоения приложения\n• Когнитивной поддержки\n• Пользователей экранных дикторов\n\nПредоставляет контекст и инструкции для всех функций.";
"help_text_confirm_actions" = "Подтверждение действий запрашивает подтверждение перед важными действиями.\n\nЭто помогает предотвратить:\n• Случайные удаления\n• Непреднамеренные изменения\n• Преждевременные отправки\n• Потерю данных\n\nПримечание: деструктивные действия всегда требуют подтверждения (требование AAA).";
"help_text_manual_code_entry" = "Ручной ввод кода позволяет вводить коды вместо сканирования QR-кодов.\n\nЭто полезно когда:\n• Камера не работает\n• QR-код повреждён или нечёток\n• Используется экранный диктор\n• Вы предпочитаете ввод сканированию\n\nПросто нажмите «Ввести код вручную» для ввода кода, отображаемого на экране.";
"help_text_voice_input" = "Голосовой ввод позволяет произносить коды вместо сканирования или ввода.\n\nЭто полезно при:\n• Ограниченной подвижности\n• Использовании экранных дикторов\n• Работе без рук\n• Предпочтении голоса\n\nНажмите кнопку микрофона и говорите чётко по запросу.";
"help_text_qr_scanning" = "Сканирование QR-кода использует камеру для чтения QR-кодов.\n\nКак сканировать:\n1. Наведите камеру на QR-код\n2. Выровняйте код в кадре\n3. Дождитесь автоматического обнаружения\n\nСоветы:\n• Обеспечьте хорошее освещение\n• Держите устройство неподвижно\n• Держите QR-код ровно и без препятствий\n• Если сканирование не удаётся, попробуйте ручной ввод кода";
"help_text_age_verification" = "Проверка возраста подтверждает соответствие возрастным требованиям без раскрытия фактического возраста или даты рождения.\n\nКак это работает:\n1. Верификатор генерирует запрос\n2. Вы сканируете QR-код или вводите вручную\n3. Приложение создаёт доказательство с нулевым разглашением\n4. Верификатор подтверждает соответствие требованиям\n\nЗащита конфиденциальности:\n• Ваша дата рождения никогда не передаётся\n• Верификатор узнаёт только о соответствии требованиям\n• Без слежки или сбора данных";
"help_text_credentials" = "Цифровые удостоверения , это криптографические подтверждения вашего возраста, надёжно хранящиеся на вашем устройстве.\n\nОсобенности:\n• Хранятся только на вашем устройстве\n• Нельзя скопировать или подделать\n• Используются для проверки с сохранением конфиденциальности\n• Можно удалить в любое время\n\nВам необходимо получить удостоверение у уполномоченного эмитента (например, в государственном учреждении), прежде чем вы сможете проверить свой возраст.";
"help_text_zero_knowledge" = "Доказательства с нулевым разглашением позволяют вам подтвердить истинность чего-либо без раскрытия исходной информации.\n\nПример:\n• Традиционный способ: показать удостоверение личности (раскрывает точную дату рождения)\n• С нулевым разглашением: подтвердить, что вам более 18 лет, без показа даты рождения\n\nПреимущества:\n• Максимальная защита конфиденциальности\n• Личные данные не передаются\n• Криптографическая надёжность\n• Нельзя подделать или воспроизвести\n\nЭто основная технология, делающая Provii Wallet конфиденциальным.";
"help_text_credential_issuance" = "Выдача удостоверений , это процесс получения вашего цифрового возрастного удостоверения у уполномоченного эмитента.\n\nШаги:\n1. Посетите уполномоченного эмитента (например, государственное учреждение)\n2. Подтвердите свою личность официальным удостоверением личности\n3. Получите QR-код или глубокую ссылку от эмитента\n4. Отсканируйте QR-код или нажмите на ссылку\n5. Удостоверение вычисляется локально и сохраняется на вашем устройстве\n\nПроцесс слепой аттестации гарантирует, что ваша дата рождения никогда не передаётся по сети.\nВам нужно сделать это только один раз. Затем ваше удостоверение можно использовать для неограниченного количества проверок.";
"help_text_officer_mode" = "Режим сотрудника предназначен для уполномоченных эмитентов для создания удостоверений пользователям.\n\nДля этого режима требуются:\n• Аутентификация сотрудника с YubiKey\n• Авторизация от органа-эмитента\n• Физическая проверка удостоверения личности пользователя\n\nПроцесс:\n1. Аутентифицироваться как сотрудник\n2. Проверить официальное удостоверение личности пользователя\n3. Ввести дату рождения пользователя\n4. Сгенерировать QR-код аттестации\n5. Пользователь сканирует код для получения удостоверения\n\nЭтот режим должен использоваться только уполномоченным персоналом.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Увеличивает весь текст на 50%.\n\nПомогает вам если вы:\n• С трудом видите\n• Затрудняетесь с чтением\n• Нуждаетесь в более крупном тексте\n\nРаботает с настройками размера текста телефона.";

"help_text_contrast_level_simplified" = "Изменяет насколько тёмным является текст.\n\nТри варианта:\n• Стандартный: обычные цвета\n• Высокий: более тёмный текст для лёгкого чтения\n• Максимальный: очень тёмный текст для наилучшего чтения\n\nБолее тёмный текст легче читать.";

"help_text_high_contrast_simplified" = "Делает текст более заметным.\n\nПомогает вам если вы:\n• С трудом видите\n• Нуждаетесь в более тёмном тексте\n• Используете приложение при ярком свете\n\nТекст становится чёрным на белом.";

"help_text_reduce_transparency_simplified" = "Убирает размытые эффекты.\n\nЭто помогает:\n• Сделать текст более чётким\n• Упростить приложение\n• Ускорить работу старых телефонов\n\nВсё выглядит более чётко.";

"help_text_color_blind_mode_simplified" = "Меняет цвета для улучшения видимости.\n\nВарианты:\n• Режим слепоты к красному\n• Режим слепоты к зелёному\n• Режим слепоты к синему\n• Только серый\n\nПомогает видеть важные вещи.";

"help_text_line_spacing_simplified" = "Меняет расстояние между строками текста.\n\nВы можете выбрать от 1,0x до 2,0x.\nПо умолчанию 1,0x.\n\nБольше пространства облегчает чтение.";

"help_text_paragraph_spacing_simplified" = "Меняет расстояние между абзацами.\n\nВы можете выбрать от 1,0x до 3,0x.\nПо умолчанию 1,0x.\n\nБольше пространства помогает видеть начало новых мыслей.";

"help_text_letter_spacing_simplified" = "Меняет расстояние между буквами.\n\nВы можете выбрать от 0,0 до 0,2.\nПо умолчанию 0,0.\n\nБольше пространства делает буквы более чёткими.";

"help_text_text_width_simplified" = "Управляет шириной текста.\n\nВарианты:\n• Полная ширина: занимает весь экран\n• Средний: подходит для чтения\n• Узкий: для сосредоточенного чтения\n\nСредняя ширина наиболее удобна для чтения.";

"help_text_large_touch_targets_simplified" = "Увеличивает все кнопки.\n\nПомогает вам если вы:\n• С трудом нажимаете маленькие кнопки\n• Имеете дрожащие руки\n• Носите перчатки\n• Работаете одной рукой\n\nКнопки становятся 60 точек вместо 44 точек.";

"help_text_reduce_motion_simplified" = "Убирает движущиеся анимации.\n\nПомогает вам если:\n• Движение вызывает головокружение\n• У вас болит голова от движения\n• Вы предпочитаете неподвижность\n\nВещи меняются мгновенно без движения.";

"help_text_timeout_behavior_simplified" = "Управляет временем выполнения задач.\n\nВарианты:\n• Без ограничений: задачи никогда не останавливаются\n• Обычный: 30 секунд\n• Длиннее: 60 секунд\n\nВыберите «Без ограничений» если вам нужно больше времени.";

"help_text_simplified_gestures_simplified" = "Заменяет сложные жесты простыми нажатиями.\n\nПомогает вам если вы:\n• Затрудняетесь со сложными касаниями\n• Предпочитаете простые нажатия\n• Работаете одной рукой\n\nВсё управляется простыми нажатиями.";

"help_text_haptic_feedback_simplified" = "Заставляет телефон вибрировать при нажатии.\n\nПомогает вам:\n• Знать, что вы нажали кнопку\n• Чувствовать ошибки или предупреждения\n• Получать обратную связь без взгляда на экран\n\nОтключите, если вибрация беспокоит вас.";

"help_text_simplified_ui_simplified" = "Упрощает приложение.\n\nПомогает вам если вы:\n• Теряетесь на загруженных экранах\n• Предпочитаете простые макеты\n• Только начинаете пользоваться приложением\n\nОтображает меньше элементов одновременно.";

"help_text_step_indicators_simplified" = "Показывает прогресс через шаги.\n\nПомогает вам:\n• Знать, где вы находитесь\n• Видеть, сколько шагов осталось\n• Оставаться организованными\n\nОтображает «Шаг 1 из 3» с точками.";

"help_text_verbose_descriptions_simplified" = "Даёт вам больше объяснений.\n\nПомогает вам:\n• Понять функции\n• Научиться пользоваться приложением\n• Получить больше деталей\n\nПредоставляет дополнительную помощь везде.";

"help_text_confirm_actions_simplified" = "Просит вас подтвердить важные действия.\n\nПомогает предотвратить:\n• Случайные удаления\n• Нежелательные изменения\n• Ошибки\n\nВас всегда спросят «Вы уверены?»";

"help_text_manual_code_entry_simplified" = "Позволяет вводить коды вместо сканирования.\n\nИспользуйте это когда:\n• Камера не работает\n• Код сложно отсканировать\n• Вы предпочитаете вводить\n\nНажмите «Ввести код вручную» для ввода.";

"help_text_voice_input_simplified" = "Позволяет произносить коды вместо ввода.\n\nПомогает вам если вы:\n• Затрудняетесь с вводом\n• Предпочитаете говорить\n• Хотите работать без рук\n\nНажмите микрофон и говорите чётко.";

"help_text_qr_scanning_simplified" = "Использует камеру для чтения квадратных кодов.\n\nКак сканировать:\n1. Наведите камеру на код\n2. Выровняйте код\n3. Дождитесь считывания\n\nСоветы:\n• Используйте хорошее освещение\n• Держите телефон неподвижно\n• Держите код ровно";

"help_text_age_verification_simplified" = "Подтверждает, что вы достаточно взрослые, без раскрытия дня рождения.\n\nКак это работает:\n1. Организация создаёт запрос\n2. Вы сканируете их код\n3. Приложение создаёт доказательство\n4. Организация подтверждает, что вы достаточно взрослые\n\nВаш день рождения остаётся конфиденциальным.";

"help_text_credentials_simplified" = "Цифровое подтверждение вашего возраста, хранящееся на телефоне.\n\nОсобенности:\n• Только на вашем телефоне\n• Нельзя скопировать\n• Сохраняет конфиденциальность\n• Можно удалить в любое время\n\nВы получаете его в государственном учреждении.";

"help_text_zero_knowledge_simplified" = "Подтверждает что-то без раскрытия деталей.\n\nПример:\n• Старый способ: показать удостоверение личности (показывает точный день рождения)\n• Новый способ: подтвердить, что вам более 18 лет (день рождения остаётся конфиденциальным)\n\nЭто сохраняет вашу информацию конфиденциальной.";

"help_text_credential_issuance_simplified" = "Получение вашего цифрового подтверждения возраста.\n\nШаги:\n1. Посетите государственное учреждение\n2. Покажите удостоверение личности\n3. Получите код\n4. Отсканируйте код\n5. Подтверждение сохраняется на телефоне\n\nСделайте это один раз. Затем используйте много раз.";

"help_text_officer_mode_simplified" = "Для государственных работников для создания подтверждений.\n\nТребуется:\n• Пароль сотрудника\n• Разрешение на использование\n• Удостоверение личности пользователя для проверки\n\nШаги:\n1. Войдите как сотрудник\n2. Проверьте удостоверение личности пользователя\n3. Введите его день рождения\n4. Создайте код\n5. Пользователь сканирует код\n\nТолько для уполномоченных работников.";

