// MARK: - Descripcions del text d'ajuda
"help_text_extra_large_text" = "Text molt gran augmenta tot el text de l'aplicació un 50%.\n\nÉs útil per a usuaris amb:\n• Baixa visió\n• Dificultats de lectura\n• Canvis de visió relacionats amb l'edat\n\nFunciona amb iOS Dynamic Type per a mides encara més grans.";
"help_text_contrast_level" = "El nivell de contrast controla el contrast del color entre el text i els fons.\n\nTres nivells disponibles:\n• Estàndard: colors predeterminats\n• Alt (AA): relació de contrast de 4,5:1 - compleix els estàndards AA\n• Màxim (AAA): relació de contrast de 7:1 - compleix els estàndards AAA més alts\n\nUn contrast més alt fa que el text sigui més fàcil de llegir en qualsevol condició d'il·luminació.";
"help_text_high_contrast" = "El mode d'alt contrast augmenta el contrast entre el text i el fons, fent-lo més fàcil de llegir.\n\nÉs útil per a usuaris amb:\n• Baixa visió\n• Sensibilitat al color\n• Entorns de pantalla brillant\n\nQuan està activat:\n• El text es torna negre sobre blanc\n• S'afegeixen vores als elements\n• Els colors es simplifiquen";
"help_text_reduce_transparency" = "Reduir la transparència elimina els efectes de difuminat i transparència a tota l'aplicació.\n\nAixò ajuda a:\n• Millorar la llegibilitat del text\n• Reduir la complexitat visual\n• Augmentar el rendiment en dispositius antics\n• Fer el contingut més predictible";
"help_text_color_blind_mode" = "Els modes per a daltonisme ajusten els colors per als diferents tipus de deficiència de la visió del color.\n\nModes disponibles:\n• Protanopia: ceguesa al vermell\n• Deuteranopia: ceguesa al verd\n• Tritanopia: ceguesa al blau\n• Monocrom: escala de grisos\n\nAquests modes garanteixen que la informació important no es transmeti només per color.";
"help_text_line_spacing" = "L'interlineat controla l'espai entre les línies de text.\n\n• Rang: 1,0x a 2,0x\n• Estàndard AAA: mínim 1,5x\n• Predeterminat: 1,0x\n\nUn interlineat augmentat facilita la lectura i ajuda a evitar saltar línies.";
"help_text_paragraph_spacing" = "L'espaiat de paràgraf controla l'espai entre paràgrafs.\n\n• Rang: 1,0x a 3,0x\n• Estàndard AAA: mínim 2,0x\n• Predeterminat: 1,0x\n\nUn espaiat de paràgraf augmentat ajuda a distingir entre les diferents seccions del text.";
"help_text_letter_spacing" = "L'espaiat de lletres controla l'espai entre els caràcters individuals.\n\n• Rang: 0,0 em a 0,2 em\n• Estàndard AAA: mínim 0,12 em\n• Predeterminat: 0,0 em\n\nUn espaiat de lletres augmentat millora el reconeixement de caràcters i la llegibilitat.";
"help_text_text_width" = "L'amplada del text controla la longitud màxima de línia per a una lectura còmoda.\n\nOpcions:\n• Amplada completa: sense màxim\n• Còmode (80 caràcters): òptim per a la lectura\n• Estret (60 caràcters): per a una lectura concentrada\n\nLes directrius AAA recomanen un màxim de 80 caràcters per línia.";
"help_text_large_touch_targets" = "Àrees tàctils més grans fa que tots els botons i elements interactius tinguin almenys 60 punts de mida.\n\nÉs útil per a:\n• Discapacitats motores\n• Tremolors o moviment\n• Fer servir l'aplicació amb guants\n• Ús amb una sola mà\n\nEl mínim estàndard és de 44 punts; aquest paràmetre augmenta a 60 punts.";
"help_text_reduce_motion" = "Reduir el moviment minimitza o elimina les animacions a tota l'aplicació.\n\nÉs útil per a usuaris amb:\n• Sensibilitat al moviment\n• Trastorns vestibulars\n• Epilèpsia\n• Desencadenants de migranya\n\nQuan està activat, les animacions se substitueixen per transicions instantànies.";
"help_text_timeout_behavior" = "El comportament del temps d'espera controla durant quant de temps poden durar les operacions abans d'expirar.\n\nOpcions:\n• Sense temps d'espera (AAA): les operacions mai expiren\n• Estàndard (30 s): temps d'espera predeterminat\n• Ampliat (60 s): el doble del temps estàndard\n\nEl mode sense temps d'espera compleix els estàndards d'accessibilitat AAA.";
"help_text_simplified_gestures" = "Gestos simplificats redueix els gestos complexos de múltiples tocs a tocs senzills.\n\nÉs útil per a:\n• Discapacitats motores\n• Destresa limitada\n• Fer servir dispositius d'assistència\n• Operació amb una sola mà\n\nEls gestos complexos se substitueixen per botons i tocs senzills.";
"help_text_haptic_feedback" = "El retorn hàptic proporciona vibració per a les accions i les notificacions.\n\nÉs útil per a:\n• Confirmar les pulsacions dels botons\n• Alertar sobre errors o avisos\n• Proporcionar retorn no visual\n• Usuaris amb discapacitats auditives o visuals\n\nPodeu desactivar-lo si les vibracions us molesten.";
"help_text_simplified_ui" = "La interfície simplificada redueix la complexitat visual a tota l'aplicació.\n\nÉs útil per a:\n• Discapacitats cognitives\n• Dificultats d'aprenentatge\n• Trastorns d'atenció\n• Usuaris nous o sense experiència\n\nQuan està activada:\n• Menys elements a la pantalla\n• Controls més grans i clars\n• Menys soroll visual";
"help_text_step_indicators" = "Els indicadors de pas mostren el vostre progrés a través dels processos de múltiples passos.\n\nAixò ajuda a:\n• Entendre on sou en un procés\n• Saber quants passos queden\n• Reduir la càrrega cognitiva\n• Proporcionar una estructura clara\n\nMostra «Pas X de Y» amb punts de progrés visuals.";
"help_text_verbose_descriptions" = "Descripcions detallades proporciona text explicatiu addicional a tota l'aplicació.\n\nÉs útil per a:\n• Entendre funcions complexes\n• Aprendre a fer servir l'aplicació\n• Suport cognitiu\n• Usuaris de lectors de pantalla\n\nProporciona context i instruccions per a totes les funcions.";
"help_text_confirm_actions" = "Confirmar accions demana confirmació abans de les accions importants.\n\nAixò ajuda a prevenir:\n• Eliminacions accidentals\n• Canvis no desitjats\n• Enviaments prematurs\n• Pèrdua de dades\n\nNota: Les accions destructives sempre requereixen confirmació (requisit AAA).";
"help_text_manual_code_entry" = "L'entrada manual del codi us permet escriure codis en lloc d'escanejar codis QR.\n\nÉs útil quan:\n• La càmera no funciona\n• El codi QR està danyat o poc clar\n• S'usa un lector de pantalla\n• Es prefereix escriure a escanejar\n\nSimplament toqueu «Introduir el codi manualment» per escriure el codi que es mostra a la pantalla.";
"help_text_voice_input" = "L'entrada de veu us permet parlar codis en lloc d'escanejar o escriure.\n\nÉs útil per a:\n• Mobilitat limitada\n• Usuaris de lectors de pantalla\n• Operació sense mans\n• Preferència per la veu\n\nToqueu el botó del micròfon i parleu clarament quan se us demani.";
"help_text_qr_scanning" = "L'escaneig del codi QR usa la càmera per llegir codis de resposta ràpida.\n\nCom escanejar:\n1. Apunteu la càmera al codi QR\n2. Alineeu el codi dins del marc\n3. Espereu la detecció automàtica\n\nConsells:\n• Assegureu-vos que hi ha bona il·luminació\n• Manteniu el dispositiu quiet\n• Manteniu el codi QR pla i sense obstacles\n• Si l'escaneig falla, proveu l'entrada manual del codi";
"help_text_age_verification" = "La verificació d'edat demostra que compliu un requisit d'edat sense revelar la vostra edat real ni la data de naixement.\n\nCom funciona:\n1. El verificador genera un repte\n2. Escanegeu el codi QR o introduïu el codi manualment\n3. L'aplicació crea una prova de coneixement zero\n4. El verificador confirma que compliu el requisit\n\nPrivadesa protegida:\n• La vostra data de naixement no es comparteix mai\n• El verificador només sap si compliu el requisit\n• Sense seguiment ni recollida de dades";
"help_text_credentials" = "Les credencials digitals són proves criptogràfiques de la vostra edat emmagatzemades de manera segura al vostre dispositiu.\n\nCaracterístiques:\n• Emmagatzemades només al vostre dispositiu\n• No es poden copiar ni falsificar\n• S'usen per a la verificació que preserva la privadesa\n• Es poden eliminar en qualsevol moment\n\nHeu d'obtenir una credencial d'un emissor autoritzat (com una oficina del govern) abans de poder verificar la vostra edat.";
"help_text_zero_knowledge" = "Les proves de coneixement zero us permeten demostrar que alguna cosa és certa sense revelar la informació subjacent.\n\nExemple:\n• Traditional: Mostreu la ID (revela l'aniversari exacte)\n• Coneixement zero: Demostreu que teniu més de 18 sense mostrar l'aniversari\n\nAvantatges:\n• Màxima protecció de la privadesa\n• Sense dades personals compartides\n• Seguretat criptogràfica\n• No es pot falsificar ni reproduir\n\nAquesta és la tecnologia principal que fa que Provii Wallet sigui privada.";
"help_text_credential_issuance" = "L'emissió de credencials és el procés d'obtenir la vostra credencial d'edat digital d'un emissor autoritzat.\n\nPassos:\n1. Visiteu un emissor autoritzat (p. ex., oficina del govern)\n2. Demostreu la vostra identitat amb una ID oficial\n3. Rebeu el codi QR o l'enllaç profund de l'emissor\n4. Escanegeu el codi QR o toqueu l'enllaç\n5. La credencial es calcula localment i s'emmagatzema al vostre dispositiu\n\nEl procés d'atestació cega garanteix que la vostra data de naixement mai es transmeti per la xarxa.\nNomés heu de fer-ho una vegada. La vostra credencial es pot fer servir per a verificacions il·limitades.";
"help_text_officer_mode" = "El mode oficial és per als emissors autoritzats per crear credencials per als usuaris.\n\nAquest mode requereix:\n• Autenticació de l'oficial amb YubiKey\n• Autorització de l'autoritat emissora\n• Verificació física de la ID de l'usuari\n\nProcés:\n1. Autentiqueu-vos com a oficial\n2. Verifiqueu la ID oficial de l'usuari\n3. Introduïu la data de naixement de l'usuari\n4. Genereu el codi QR d'atestació\n5. L'usuari escaneja el codi per rebre la credencial\n\nNomés el personal autoritzat ha d'fer servir aquest mode.";

// MARK: - Text d'ajuda simplificat (Nivell de lectura: graus 6-8)

"help_text_extra_large_text_simplified" = "Fa tot el text un 50% més gran.\n\nUs ajuda si:\n• Teniu dificultats per veure\n• Trobeu la lectura difícil\n• Necessiteu text més gran\n\nFunciona amb la configuració de mida de text del vostre telèfon.";

"help_text_contrast_level_simplified" = "Canvia com de fosc és el text.\n\nTres opcions:\n• Estàndard: colors normals\n• Alt: text més fosc per a una lectura fàcil\n• Màxim: text molt fosc per a la millor lectura\n\nEl text més fosc és més fàcil de llegir.";

"help_text_high_contrast_simplified" = "Fa que el text sigui més fàcil de veure.\n\nUs ajuda si:\n• Teniu dificultats per veure\n• Necessiteu text més fosc\n• Useu l'aplicació en llum brillant\n\nEl text es torna negre sobre blanc.";

"help_text_reduce_transparency_simplified" = "Elimina els efectes borrosos.\n\nAixò ajuda a:\n• Fer el text més clar\n• Fer l'aplicació més senzilla\n• Accelerar els telèfons antics\n\nTot sembla més sòlid.";

"help_text_color_blind_mode_simplified" = "Canvia els colors per ajudar-vos a veure millor.\n\nOpcions:\n• Mode ceguesa al vermell\n• Mode ceguesa al verd\n• Mode ceguesa al blau\n• Mode només gris\n\nUs ajuda a veure les coses importants.";

"help_text_line_spacing_simplified" = "Canvia l'espai entre les línies de text.\n\nPodeu triar entre 1,0x i 2,0x.\nEl predeterminat és 1,0x.\n\nMés espai facilita la lectura.";

"help_text_paragraph_spacing_simplified" = "Canvia l'espai entre paràgrafs.\n\nPodeu triar entre 1,0x i 3,0x.\nEl predeterminat és 1,0x.\n\nMés espai ajuda a veure on comencen les noves idees.";

"help_text_letter_spacing_simplified" = "Canvia l'espai entre lletres.\n\nPodeu triar entre 0,0 i 0,2.\nEl predeterminat és 0,0.\n\nMés espai fa les lletres més clares.";

"help_text_text_width_simplified" = "Controla l'amplada del text.\n\nOpcions:\n• Amplada completa: usa tota la pantalla\n• Mitjana: bona per llegir\n• Estreta: millor per concentrar-se\n\nL'amplada mitjana és la més fàcil de llegir.";

"help_text_large_touch_targets_simplified" = "Fa tots els botons més grans.\n\nUs ajuda si:\n• Teniu dificultats per tocar botons petits\n• Teniu les mans tremoloses\n• Porteu guants\n• Useu una sola mà\n\nEls botons es fan de 60 punts en lloc de 44.";

"help_text_reduce_motion_simplified" = "Elimina les animacions en moviment.\n\nUs ajuda si:\n• El moviment us mareja\n• El moviment us causa mal de cap\n• Preferiu que les coses estiguin quietes\n\nLes coses canvien instantàniament en lloc de moure's.";

"help_text_timeout_behavior_simplified" = "Controla durant quant de temps poden durar les tasques.\n\nOpcions:\n• Sense límit: les tasques mai s'aturen\n• Normal: 30 segons\n• Més llarg: 60 segons\n\nTrieu «Sense límit» si necessiteu més temps.";

"help_text_simplified_gestures_simplified" = "Substitueix els gestos difícils per tocs senzills.\n\nUs ajuda si:\n• Teniu dificultats amb els tocs complexos\n• Preferiu els tocs senzills\n• Useu una sola mà\n\nTot usa tocs senzills.";

"help_text_haptic_feedback_simplified" = "Fa que el vostre telèfon vibri quan toqueu.\n\nUs ajuda a:\n• Saber quan heu tocat un botó\n• Sentir errors o avisos\n• Obtenir retorn sense mirar\n\nDesactiveu-lo si les vibracions us molesten.";

"help_text_simplified_ui_simplified" = "Fa l'aplicació més senzilla.\n\nUs ajuda si:\n• Us confonen les pantalles ocupades\n• Preferiu dissenys senzills\n• Sou nous a l'aplicació\n\nMostra menys coses alhora.";

"help_text_step_indicators_simplified" = "Mostra el vostre progrés pels passos.\n\nUs ajuda a:\n• Saber on esteu\n• Veure quants passos queden\n• Mantenir-vos organitzats\n\nMostra «Pas 1 de 3» amb punts.";

"help_text_verbose_descriptions_simplified" = "Us dona més explicacions.\n\nUs ajuda a:\n• Entendre les funcions\n• Aprendre a fer servir l'aplicació\n• Obtenir més detalls\n\nProporciona ajuda addicional a tot arreu.";

"help_text_confirm_actions_simplified" = "Us demana que confirmeu les accions importants.\n\nAjuda a prevenir:\n• Eliminacions accidentals\n• Canvis no desitjats\n• Errors\n\nSempre se us preguntarà «Esteu segur?»";

"help_text_manual_code_entry_simplified" = "Us permet escriure codis en lloc d'escanejar.\n\nUseu-ho quan:\n• La vostra càmera no funciona\n• El codi és difícil d'escanejar\n• Preferiu escriure\n\nToqueu «Introduir el codi manualment» per escriure.";

"help_text_voice_input_simplified" = "Us permet parlar codis en lloc d'escriure.\n\nUs ajuda si:\n• Teniu dificultats per escriure\n• Preferiu parlar\n• Voleu l'ús sense mans\n\nToqueu el micròfon i parleu clarament.";

"help_text_qr_scanning_simplified" = "Usa la càmera per llegir codis quadrats.\n\nCom escanejar:\n1. Apunteu la càmera al codi\n2. Alineeu el codi\n3. Espereu que es llegeixi\n\nConsells:\n• Useu bona il·luminació\n• Manteniu el telèfon quiet\n• Manteniu el codi pla";

"help_text_age_verification_simplified" = "Demostra que sou prou gran sense compartir el vostre aniversari.\n\nCom funciona:\n1. El negoci crea una sol·licitud\n2. Escanegeu el seu codi\n3. L'aplicació crea una prova\n4. El negoci confirma que sou prou gran\n\nEl vostre aniversari roman privat.";

"help_text_credentials_simplified" = "Prova digital de la vostra edat emmagatzemada al vostre telèfon.\n\nCaracterístiques:\n• Només al vostre telèfon\n• No es pot copiar\n• Us manté privat\n• Podeu eliminar-la en qualsevol moment\n\nL'obteniu d'una oficina del govern.";

"help_text_zero_knowledge_simplified" = "Demostra alguna cosa sense compartir detalls.\n\nExemple:\n• Manera antiga: Mostreu la vostra ID (mostra l'aniversari exacte)\n• Manera nova: Demostreu que teniu més de 18 (l'aniversari roman privat)\n\nAixò manté la vostra informació privada.";

"help_text_credential_issuance_simplified" = "Obtenir la vostra prova d'edat digital.\n\nPassos:\n1. Aneu a l'oficina del govern\n2. Mostreu la vostra ID\n3. Obteniu un codi\n4. Escanegeu el codi\n5. La prova es desa al vostre telèfon\n\nFeu-ho una vegada. Després feu servir-la moltes vegades.";

"help_text_officer_mode_simplified" = "Per als funcionaris del govern per crear proves.\n\nNecessita:\n• Contrasenya de l'oficial\n• Permís per fer servir-ho\n• ID de l'usuari per comprovar\n\nPassos:\n1. Inicieu sessió com a oficial\n2. Comproveu la ID de l'usuari\n3. Introduïu el seu aniversari\n4. Creeu el codi\n5. L'usuari escaneja el codi\n\nNomés per al personal autoritzat.";

