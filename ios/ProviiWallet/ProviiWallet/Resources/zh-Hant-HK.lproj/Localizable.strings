/* MARK: - Help Text Descriptions */
"help_text_extra_large_text" = "特大文字可將應用程式中的所有文字增大 50%。\n\n以下用戶有所幫助：\n• 低視力\n• 閱讀困難\n• 因年齡引致的視力變化\n\n與 iOS Dynamic Type 配合使用，可設置更大的字體大小。";
"help_text_contrast_level" = "對比度級別控制文字與背景之間的顏色對比度。\n\n三個級別：\n• 標準：預設顏色\n• 高（AA）：4.5:1 對比度 , 符合 AA 標準\n• 最高（AAA）：7:1 對比度 , 符合最高 AAA 標準\n\n較高的對比度使文字在所有光線條件下都更易閱讀。";
"help_text_high_contrast" = "高對比度模式增加文字與背景之間的對比度，使文字更易閱讀。\n\n以下用戶有所幫助：\n• 低視力\n• 顏色敏感\n• 光線充足的螢幕環境\n\n啟用後：\n• 文字變為白底黑字\n• 元素加上邊框\n• 顏色簡化";
"help_text_reduce_transparency" = "減少透明度移除整個應用程式的模糊和透明效果。\n\n有助於：\n• 改善文字可讀性\n• 減少視覺複雜度\n• 提高舊裝置的效能\n• 讓內容更可預測";
"help_text_color_blind_mode" = "色覺障礙模式針對不同類型的色覺缺陷調整顏色。\n\n可用模式：\n• 紅色盲：難以看到紅色\n• 綠色盲：難以看到綠色\n• 藍色盲：難以看到藍色\n• 全色盲：只有灰階\n\n這些模式確保重要資訊不只靠顏色傳達。";
"help_text_line_spacing" = "行距控制文字行之間的間距。\n\n• 範圍：1.0 至 2.0 倍\n• AAA 標準：最少 1.5 倍\n• 預設：1.0 倍\n\n增加行距使文字更易閱讀，有助防止跳行。";
"help_text_paragraph_spacing" = "段距控制段落之間的間距。\n\n• 範圍：1.0 至 3.0 倍\n• AAA 標準：最少 2.0 倍\n• 預設：1.0 倍\n\n增加段距有助區分不同文字段落。";
"help_text_letter_spacing" = "字距控制個別字元之間的間距。\n\n• 範圍：0.0em 至 0.2em\n• AAA 標準：最少 0.12em\n• 預設：0.0em\n\n增加字距改善字元識別和可讀性。";
"help_text_text_width" = "文字寬度控制舒適閱讀的最大行長度。\n\n選項：\n• 全寬：無最大值\n• 舒適（80 字元）：最佳閱讀\n• 窄（60 字元）：集中閱讀\n\nAAA 指南建議每行最多 80 個字元。";
"help_text_large_touch_targets" = "加大觸控目標使所有按鈕和互動元素至少達到 60 點大小。\n\n以下情況有所幫助：\n• 肢體障礙\n• 震顫或顫抖\n• 戴手套使用應用程式\n• 單手操作\n\n標準最小值為 44 點；此設定增加至 60 點。";
"help_text_reduce_motion" = "減少動態效果可最大程度減少或移除應用程式中的動畫。\n\n以下用戶有所幫助：\n• 對動態效果敏感\n• 前庭功能障礙\n• 癲癇\n• 偏頭痛觸發因素\n\n啟用後，動畫會替換為即時過渡。";
"help_text_timeout_behavior" = "逾時行為控制操作在逾時前可花費的時間。\n\n選項：\n• 不設逾時（AAA）：操作不設逾時\n• 標準（30 秒）：預設逾時\n• 延長（60 秒）：雙倍標準時間\n\n不設逾時模式符合 AAA 無障礙標準。";
"help_text_simplified_gestures" = "簡化手勢將複雜的多點觸控手勢簡化為簡單的點按。\n\n以下情況有所幫助：\n• 肢體障礙\n• 靈活度有限\n• 使用輔助裝置\n• 單手操作\n\n複雜手勢替換為按鈕和簡單點按。";
"help_text_haptic_feedback" = "觸覺回饋為操作和通知提供震動回饋。\n\n以下情況有所幫助：\n• 確認按鈕已按下\n• 提示錯誤或警告\n• 提供非視覺回饋\n• 有聽覺或視覺障礙的用戶\n\n如果震動令你不舒服，你可以停用此功能。";
"help_text_simplified_ui" = "簡化介面減少整個應用程式的視覺複雜度。\n\n以下用戶有所幫助：\n• 認知障礙\n• 學習困難\n• 注意力障礙\n• 新手或經驗不足的用戶\n\n啟用後：\n• 螢幕上的元素更少\n• 更大、更清晰的控制項\n• 較少視覺雜訊";
"help_text_step_indicators" = "步驟指示器顯示你在多步驟流程中的進度。\n\n有助於：\n• 了解你在流程中的位置\n• 知道還有多少步驟\n• 減少認知負荷\n• 提供清晰結構\n\n顯示「第 X 步，共 Y 步」以及視覺進度點。";
"help_text_verbose_descriptions" = "詳細描述在整個應用程式中提供額外的說明文字。\n\n以下用戶有所幫助：\n• 了解複雜功能\n• 學習如何使用應用程式\n• 認知支援\n• 螢幕閱讀器用戶\n\n為所有功能提供上下文和指示。";
"help_text_confirm_actions" = "確認操作在重要操作前要求確認。\n\n有助於防止：\n• 意外刪除\n• 無意更改\n• 過早提交\n• 資料遺失\n\n注意：破壞性操作始終需要確認（AAA 要求）。";
"help_text_manual_code_entry" = "手動輸入代碼讓你輸入代碼代替掃描 QR 碼。\n\n以下情況有所幫助：\n• 鏡頭無法正常工作\n• QR 碼損壞或不清晰\n• 使用螢幕閱讀器\n• 偏好輸入代替掃描\n\n只需點按「手動輸入代碼」即可輸入螢幕上顯示的代碼。";
"help_text_voice_input" = "語音輸入讓你說出代碼代替掃描或輸入。\n\n以下情況有所幫助：\n• 行動能力有限\n• 螢幕閱讀器用戶\n• 免提操作\n• 偏好語音\n\n點按麥克風按鈕，在提示時清晰說出代碼。";
"help_text_qr_scanning" = "QR 碼掃描使用你的鏡頭讀取快速回應碼。\n\n掃描方法：\n1. 將鏡頭對準 QR 碼\n2. 在框架中對齊代碼\n3. 等待自動偵測\n\n提示：\n• 確保光線充足\n• 保持裝置穩定\n• 保持 QR 碼平整且無遮擋\n• 如果掃描失敗，請嘗試手動輸入代碼";
"help_text_age_verification" = "年齡驗證可在不揭露你的實際年齡或出生日期的情況下，證明你符合年齡要求。\n\n運作方式：\n1. 驗證方產生挑戰\n2. 你掃描 QR 碼或手動輸入\n3. 應用程式建立零知識證明\n4. 驗證方確認你符合要求\n\n私隱保護：\n• 你的出生日期不會被分享\n• 驗證方只會得知你是否符合要求\n• 無追蹤或資料收集";
"help_text_credentials" = "數碼憑證是安全儲存在你裝置上的年齡密碼學證明。\n\n功能：\n• 只儲存在你的裝置上\n• 無法複製或偽造\n• 用於保護私隱的驗證\n• 可隨時刪除\n\n你必須先從授權簽發機構（如政府辦事處）取得憑證，才能驗證你的年齡。";
"help_text_zero_knowledge" = "零知識證明讓你在不揭露底層資訊的情況下，證明某事為真。\n\n例子：\n• 傳統方式：出示身份證（揭露確切出生日期）\n• 零知識方式：證明你年滿 18 歲，無需出示出生日期\n\n好處：\n• 最大程度的私隱保護\n• 不分享個人資料\n• 密碼學安全\n• 無法偽造或重播\n\n這是使 Provii Wallet 保護私隱的核心技術。";
"help_text_credential_issuance" = "憑證簽發是從授權簽發機構取得你的數碼年齡憑證的過程。\n\n步驟：\n1. 前往授權簽發機構（例如政府辦事處）\n2. 用官方身份證明文件證明你的身份\n3. 從簽發機構收到 QR 碼或深層連結\n4. 掃描 QR 碼或點按連結\n5. 憑證在本地計算並儲存在你的裝置上\n\n盲目證明流程確保你的出生日期不會透過網絡傳輸。\n你只需執行此操作一次。之後你的憑證可用於無限次驗證。";
"help_text_officer_mode" = "工作人員模式供授權簽發機構為用戶建立憑證。\n\n此模式需要：\n• 使用 YubiKey 進行工作人員驗證\n• 來自簽發機構的授權\n• 親身核實用戶的身份證明文件\n\n流程：\n1. 以工作人員身份驗證\n2. 核實用戶的官方身份證明文件\n3. 輸入用戶的出生日期\n4. 產生證明 QR 碼\n5. 用戶掃描代碼以接收憑證\n\n只有授權人員才可使用此模式。";

/* MARK: - Simplified Help Text (Reading Level: Grade 6-8) */

"help_text_extra_large_text_simplified" = "將所有文字放大 50%。\n\n以下情況有所幫助：\n• 看不清楚\n• 閱讀困難\n• 需要更大的文字\n\n與你手機的文字大小設定配合使用。";

"help_text_contrast_level_simplified" = "更改文字的深淺。\n\n三個選擇：\n• 標準：正常顏色\n• 高：較深的文字，易於閱讀\n• 最高：非常深的文字，最佳閱讀\n\n較深的文字更易閱讀。";

"help_text_high_contrast_simplified" = "使文字更易看清楚。\n\n以下情況有所幫助：\n• 看不清楚\n• 需要較深的文字\n• 在光線充足環境使用應用程式\n\n文字變為白底黑字。";

"help_text_reduce_transparency_simplified" = "移除模糊效果。\n\n有助於：\n• 使文字更清晰\n• 使應用程式更簡單\n• 加快舊手機的速度\n\n一切看起來更實心。";

"help_text_color_blind_mode_simplified" = "更改顏色以幫助你看得更清楚。\n\n選擇：\n• 紅色盲模式\n• 綠色盲模式\n• 藍色盲模式\n• 只顯示灰色模式\n\n幫助你看清楚重要事物。";

"help_text_line_spacing_simplified" = "更改文字行之間的間距。\n\n可選擇 1.0 至 2.0 倍。\n預設為 1.0 倍。\n\n更多間距使閱讀更容易。";

"help_text_paragraph_spacing_simplified" = "更改段落之間的間距。\n\n可選擇 1.0 至 3.0 倍。\n預設為 1.0 倍。\n\n更多間距有助你看到新想法從哪裡開始。";

"help_text_letter_spacing_simplified" = "更改字母之間的間距。\n\n可選擇 0.0 至 0.2。\n預設為 0.0。\n\n更多間距使字母更清晰。";

"help_text_text_width_simplified" = "控制文字的寬度。\n\n選擇：\n• 全寬：使用整個螢幕\n• 中等：適合閱讀\n• 窄：最佳專注\n\n中等寬度最易閱讀。";

"help_text_large_touch_targets_simplified" = "使所有按鈕更大。\n\n以下情況有所幫助：\n• 難以點按小按鈕\n• 手部顫抖\n• 戴手套\n• 單手使用\n\n按鈕從 44 點變為 60 點。";

"help_text_reduce_motion_simplified" = "移除移動動畫。\n\n以下情況有所幫助：\n• 移動讓你頭暈\n• 動作使你頭痛\n• 你希望事物保持靜止\n\n事物即時改變而不是移動。";

"help_text_timeout_behavior_simplified" = "控制任務可花費的時間。\n\n選擇：\n• 不設限制：任務永不停止\n• 正常：30 秒\n• 較長：60 秒\n\n如果你需要更多時間，選擇「不設限制」。";

"help_text_simplified_gestures_simplified" = "以簡單點按替換困難的手勢。\n\n以下情況有所幫助：\n• 難以進行複雜觸控\n• 偏好簡單點按\n• 單手使用\n\n一切使用簡單點按。";

"help_text_haptic_feedback_simplified" = "點按時使手機震動。\n\n有助於：\n• 知道你何時點按了按鈕\n• 感受錯誤或警告\n• 在不看螢幕的情況下獲得回饋\n\n如果震動令你不舒服，請關閉。";

"help_text_simplified_ui_simplified" = "使應用程式更簡單。\n\n以下情況有所幫助：\n• 複雜的螢幕令你困惑\n• 偏好簡單佈局\n• 初次使用應用程式\n\n一次顯示較少事物。";

"help_text_step_indicators_simplified" = "顯示你在步驟中的進度。\n\n有助於：\n• 知道你在哪裡\n• 看到還有多少步驟\n• 保持有條理\n\n顯示「第 1 步，共 3 步」以及點。";

"help_text_verbose_descriptions_simplified" = "給你更多解釋。\n\n有助於：\n• 了解功能\n• 學習如何使用應用程式\n• 獲取更多詳情\n\n到處提供額外幫助。";

"help_text_confirm_actions_simplified" = "要求你確認重要操作。\n\n有助於防止：\n• 意外刪除\n• 不需要的更改\n• 錯誤\n\n你將始終被詢問「你確定嗎？」";

"help_text_manual_code_entry_simplified" = "讓你輸入代碼代替掃描。\n\n以下情況使用：\n• 你的鏡頭無法正常工作\n• 代碼難以掃描\n• 你偏好輸入\n\n點按「手動輸入代碼」以輸入。";

"help_text_voice_input_simplified" = "讓你說出代碼代替輸入。\n\n以下情況有所幫助：\n• 輸入困難\n• 偏好說話\n• 免提使用\n\n點按麥克風並清晰說出。";

"help_text_qr_scanning_simplified" = "使用你的鏡頭讀取方形代碼。\n\n掃描方法：\n1. 將鏡頭對準代碼\n2. 對齊代碼\n3. 等待讀取\n\n提示：\n• 使用良好光線\n• 保持手機穩定\n• 保持代碼平整";

"help_text_age_verification_simplified" = "在不分享你的生日的情況下，證明你已夠年齡。\n\n運作方式：\n1. 商戶建立請求\n2. 你掃描他們的代碼\n3. 應用程式建立證明\n4. 商戶確認你已夠年齡\n\n你的生日保持私密。";

"help_text_credentials_simplified" = "儲存在你手機上的年齡數碼證明。\n\n功能：\n• 只在你的手機上\n• 無法複製\n• 保護你的私隱\n• 你可以隨時刪除\n\n你從政府辦事處取得。";

"help_text_zero_knowledge_simplified" = "在不分享詳情的情況下，證明某事。\n\n例子：\n• 舊方式：出示你的身份證（顯示確切生日）\n• 新方式：證明你年滿 18 歲（生日保持私密）\n\n這保護你的資訊私隱。";

"help_text_credential_issuance_simplified" = "取得你的數碼年齡證明。\n\n步驟：\n1. 前往政府辦事處\n2. 出示你的身份證\n3. 取得代碼\n4. 掃描代碼\n5. 證明儲存在你的手機上\n\n執行一次。然後多次使用。";

"help_text_officer_mode_simplified" = "供政府工作人員建立證明。\n\n需要：\n• 工作人員密碼\n• 使用許可\n• 用戶的身份證以供核查\n\n步驟：\n1. 以工作人員身份登入\n2. 核查用戶的身份證\n3. 輸入其生日\n4. 建立代碼\n5. 用戶掃描代碼\n\n只供授權工作人員使用。";

