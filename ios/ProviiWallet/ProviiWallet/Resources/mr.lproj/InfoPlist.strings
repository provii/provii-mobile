/* InfoPlist.strings - Marathi */
/* स्थानिक परवानगी वर्णने Provii Wallet साठी */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet ला ओळखपत्र घेण्यासाठी आणि वय पडताळणीसाठी QR कोड स्कॅन करण्यासाठी कॅमेरा प्रवेश आवश्यक आहे.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet सुरक्षित अधिकारी प्रमाणीकरणासाठी तुमच्या YubiKey शी संवाद साधण्यासाठी NFC वापरते.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet प्रवेशयोग्यता मोडमध्ये व्हॉइस कमांडसाठी भाषण ओळख वापरते, ज्यामुळे तुम्ही हात मुक्त ठेवून अॅप नियंत्रित करू शकता.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet ला प्रवेशयोग्यता मोड सक्षम असताना व्हॉइस नियंत्रण वैशिष्ट्यांसाठी मायक्रोफोन प्रवेश आवश्यक आहे.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet तुमच्या वय ओळखपत्रांमध्ये सुरक्षितपणे प्रवेश करण्यासाठी आणि तुमची ओळख सत्यापित करण्यासाठी Face ID वापरते.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet जवळील ओळखपत्र जारीकर्ते शोधण्यासाठी स्थानिक नेटवर्क वापरू शकते.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet YubiKey डिव्हाइससह संवाद साधण्यासाठी Bluetooth वापरू शकते.";
