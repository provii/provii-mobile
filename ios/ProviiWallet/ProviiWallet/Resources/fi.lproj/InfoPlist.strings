/* InfoPlist.strings - Finnish */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet tarvitsee kameran käyttöoikeuden QR-koodien skannaamiseen tunnisteiden noutoa ja iänvarmennusta varten.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet käyttää NFC:tä kommunikoidakseen YubiKey-avaimesi kanssa turvallista virkailijan todennusta varten.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet käyttää puheentunnistusta ääniohjauksen komentoihin esteettömyystilassa, jolloin voit ohjata sovellusta kädet vapaana.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet tarvitsee mikrofonin käyttöoikeuden ääniohjausominaisuuksia varten, kun esteettömyystila on käytössä.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet käyttää Face ID:tä ikätunnisteidesi turvalliseen käyttöön ja henkilöllisyytesi varmistamiseen.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet saattaa käyttää paikallista verkkoa löytääkseen lähellä olevia tunnisteen myöntäjiä.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet saattaa käyttää Bluetoothia kommunikoidakseen YubiKey-laitteiden kanssa.";
