# Auto-detect text files and normalise line endings
* text=auto

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.webp binary
*.aab binary
*.apk binary
*.ipa binary
*.xcarchive binary
*.p12 binary
*.mobileprovision binary
*.keystore binary
*.jks binary

# Lock files, generated, do not diff
Podfile.lock linguist-generated
*.lock linguist-generated

# Linguist overrides
*.swift linguist-language=Swift
*.kt linguist-language=Kotlin
