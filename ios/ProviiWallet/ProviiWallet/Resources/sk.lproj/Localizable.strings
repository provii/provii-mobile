"help_text_extra_large_text" = "Extra veľký text zväčší všetok text v aplikácii o 50 %.\n\nPomáha používateľom:\n• so slabým zrakom\n• s ťažkosťami pri čítaní\n• so zrakovými zmenami súvisiacimi s vekom\n\nFunguje s dynamickým typom iOS pre ešte väčšie veľkosti.";
"help_text_contrast_level" = "Úroveň kontrastu riadi farebný kontrast medzi textom a pozadím.\n\nDostupné sú tri úrovne:\n• Štandardná: Predvolené farby\n• Vysoká (AA): Kontrastný pomer 4,5:1 – spĺňa štandardy AA\n• Maximálna (AAA): Kontrastný pomer 7:1 – spĺňa najvyššie štandardy AAA\n\nVyšší kontrast uľahčuje čítanie textu vo všetkých svetelných podmienkach.";
"help_text_high_contrast" = "Režim vysokého kontrastu zvyšuje kontrast medzi textom a pozadím, čo uľahčuje čítanie.\n\nPomáha používateľom:\n• so slabým zrakom\n• s citlivosťou na farby\n• v jasnom prostredí obrazovky\n\nPo zapnutí:\n• Text sa stane čiernym na bielom\n• Ku prvkom sa pridajú orámovanie\n• Farby sa zjednodušia";
"help_text_reduce_transparency" = "Zníženie priehľadnosti odstráni efekty rozostrenia a priehľadnosti v celej aplikácii.\n\nPomáha:\n• zlepšiť čitateľnosť textu\n• znížiť vizuálnu zložitosť\n• zvýšiť výkon na starších zariadeniach\n• spraviť obsah predvídateľnejším";
"help_text_color_blind_mode" = "Režimy pre farboslepých upravujú farby pre rôzne typy poruchy farebného videnia.\n\nDostupné režimy:\n• Protanopia: Slepota na červenú (ťažkosti s videním červenej)\n• Deuteranopia: Slepota na zelenú (ťažkosti s videním zelenej)\n• Tritanopia: Slepota na modrú (ťažkosti s videním modrej)\n• Monochromatické: Iba odtiene sivej\n\nTieto režimy zabezpečujú, že dôležité informácie nie sú sprostredkované iba farbou.";
"help_text_line_spacing" = "Riadkovanie riadi priestor medzi riadkami textu.\n\n• Rozsah: 1,0× až 2,0×\n• Štandard AAA: Minimum 1,5×\n• Predvolené: 1,0×\n\nVäčšie riadkovanie uľahčuje čítanie a pomáha zabrániť preskakovaniu riadkov.";
"help_text_paragraph_spacing" = "Odsekovanie riadi priestor medzi odsekmi.\n\n• Rozsah: 1,0× až 3,0×\n• Štandard AAA: Minimum 2,0×\n• Predvolené: 1,0×\n\nVäčšie odsekovanie pomáha rozlišovať rôzne časti textu.";
"help_text_letter_spacing" = "Medzery medzi písmenami riadia priestor medzi jednotlivými znakmi.\n\n• Rozsah: 0,0 em až 0,2 em\n• Štandard AAA: Minimum 0,12 em\n• Predvolené: 0,0 em\n\nVäčšie medzery zlepšujú rozpoznávanie znakov a čitateľnosť.";
"help_text_text_width" = "Šírka textu riadi maximálnu dĺžku riadka pre pohodlné čítanie.\n\nMožnosti:\n• Celá šírka: Bez maxima\n• Pohodlná (80 znakov): Optimálna na čítanie\n• Úzka (60 znakov): Na sústredené čítanie\n\nSmernice AAA odporúčajú maximálne 80 znakov na riadok.";
"help_text_large_touch_targets" = "Väčšie dotykové ciele spraví všetky tlačidlá a interaktívne prvky aspoň 60 bodov.\n\nPomáha:\n• pri motorických postihnutiach\n• pri trasení alebo chvení\n• pri používaní aplikácie s rukavicami\n• pri používaní jednou rukou\n\nŠtandardné minimum je 44 bodov; toto nastavenie zvyšuje na 60 bodov.";
"help_text_reduce_motion" = "Zníženie pohybu minimalizuje alebo odstraňuje animácie v celej aplikácii.\n\nPomáha používateľom:\n• s citlivosťou na pohyb\n• s vestibulárnou poruchou\n• s epilepsiou\n• s migrénou\n\nPo zapnutí sú animácie nahradené okamžitými prechodmi.";
"help_text_timeout_behavior" = "Správanie pri časovom limite riadi, ako dlho môžu operácie trvať pred vypršaním.\n\nMožnosti:\n• Bez časového limitu (AAA): Operácie nikdy nevypršia\n• Štandardná (30 s): Predvolený časový limit\n• Predĺžená (60 s): Dvojnásobok štandardného času\n\nRežim bez časového limitu spĺňa štandardy prístupnosti AAA.";
"help_text_simplified_gestures" = "Zjednodušené gestá znižujú komplexné viacprstové gestá na jednoduché klepnutia.\n\nPomáha:\n• pri motorických postihnutiach\n• pri obmedzenej obratnosti\n• pri používaní asistenčných zariadení\n• pri obsluhe jednou rukou\n\nKomplexné gestá sú nahradené tlačidlami a jednoduchými klepnutiami.";
"help_text_haptic_feedback" = "Haptická odozva poskytuje vibračnú odozvu pre akcie a oznámenia.\n\nPomáha:\n• pri potvrdzovaní stlačenia tlačidiel\n• pri upozorneniach na chyby alebo varovania\n• pri poskytovaní nevizuálnej odozvy\n• používateľom so sluchovým alebo zrakovým postihnutím\n\nMôžete to vypnúť, ak sú vibrácie nepohodlné.";
"help_text_simplified_ui" = "Zjednodušené rozhranie znižuje vizuálnu zložitosť celej aplikácie.\n\nPomáha:\n• pri kognitívnych postihnutiach\n• pri poruchách učenia\n• pri poruchách pozornosti\n• novým alebo neskúseným používateľom\n\nPo zapnutí:\n• Na obrazovke menej prvkov\n• Väčšie, jasnejšie ovládacie prvky\n• Menej vizuálneho šumu";
"help_text_step_indicators" = "Indikátory krokov zobrazujú váš postup pri procesoch s viacerými krokmi.\n\nPomáha:\n• pochopiť, kde sa v procese nachádzate\n• vedieť, koľko krokov zostáva\n• znížiť kognitívnu záťaž\n• poskytnúť jasnú štruktúru\n\nZobrazuje 'Krok X z Y' s vizuálnymi bodkami postupu.";
"help_text_verbose_descriptions" = "Podrobné popisy poskytujú ďalší vysvetľujúci text v celej aplikácii.\n\nPomáha:\n• pri porozumení zložitým funkciám\n• pri učení sa používať aplikáciu\n• pri kognitívnej podpore\n• používateľom čítačiek obrazovky\n\nPoskytuje kontext a pokyny pre všetky funkcie.";
"help_text_confirm_actions" = "Potvrdenie akcií žiada potvrdenie pred dôležitými akciami.\n\nPomáha predchádzať:\n• náhodným odstráneniam\n• neúmyselným zmenám\n• predčasným odoslaniam\n• strate dát\n\nPoznámka: Deštruktívne akcie vždy vyžadujú potvrdenie (požiadavka AAA).";
"help_text_manual_code_entry" = "Ručné zadanie kódu vám umožňuje zadávať kódy namiesto skenovania QR kódov.\n\nPomáha, keď:\n• Fotoaparát nefunguje\n• QR kód je poškodený alebo nejasný\n• Používate čítačku obrazovky\n• Preferujete písanie pred skenovaním\n\nJednoducho klepnite na 'Zadať kód ručne' a napíšte kód zobrazený na obrazovke.";
"help_text_voice_input" = "Hlasový vstup vám umožňuje hovoriť kódy namiesto skenovania alebo písania.\n\nPomáha:\n• pri obmedzenom pohybe\n• používateľom čítačiek obrazovky\n• pri bezručnej prevádzke\n• pri preferovaní hlasu\n\nKlepnite na tlačidlo mikrofóna a jasne hovorte, keď vás vyzvú.";
"help_text_qr_scanning" = "Skenovanie QR kódu používa fotoaparát na čítanie kódov rýchlej odozvy.\n\nAko skenovať:\n1. Nasmerujte kameru na QR kód\n2. Zarovnajte kód v rámčeku\n3. Čakajte na automatické zistenie\n\nTipy:\n• Zabezpečte dobré osvetlenie\n• Držte zariadenie stabilne\n• Udržujte QR kód rovný a bez prekážok\n• Ak skenovanie zlyhá, skúste ručné zadanie kódu";
"help_text_age_verification" = "Overenie veku dokazuje, že spĺňate vekovú požiadavku bez odhalenia skutočného veku alebo dátumu narodenia.\n\nAko funguje:\n1. Overovateľ vygeneruje výzvu\n2. Naskenujete QR kód alebo ho zadáte ručne\n3. Aplikácia vytvorí dôkaz s nulovými znalosťami\n4. Overovateľ potvrdí, že spĺňate požiadavku\n\nOchrana súkromia:\n• Váš dátum narodenia sa nikdy nezdieľa\n• Overovateľ sa dozvie iba to, či spĺňate požiadavku\n• Žiadne sledovanie ani zhromažďovanie dát";
"help_text_credentials" = "Digitálne poverenia sú kryptografické dôkazy veku bezpečne uložené na vašom zariadení.\n\nFunkcie:\n• Uložené iba na vašom zariadení\n• Nemožno ich kopírovať ani falšovať\n• Používajú sa na overenie s ochranou súkromia\n• Možno ich kedykoľvek odstrániť\n\nPoverenie musíte získať od oprávneného vydavateľa (napríklad vládneho úradu) pred tým, ako môžete overiť vek.";
"help_text_zero_knowledge" = "Dôkazy s nulovými znalosťami vám umožňujú preukázať, že niečo je pravda, bez odhalenia podkladových informácií.\n\nPríklad:\n• Tradičný spôsob: Ukázať preukaz (odhalí presný dátum narodenia)\n• Nulovoznalostný spôsob: Preukázať, že máte viac ako 18 rokov, bez ukázania dátumu narodenia\n\nVýhody:\n• Maximálna ochrana súkromia\n• Žiadne zdieľanie osobných dát\n• Kryptograficky zabezpečené\n• Nemožno falšovať ani prehrávať\n\nToto je základná technológia, ktorá robí Provii Wallet súkromným.";
"help_text_credential_issuance" = "Vydanie poverenia je proces získania digitálneho poverenia veku od oprávneného vydavateľa.\n\nKroky:\n1. Navštívte oprávneného vydavateľa (napr. vládny úrad)\n2. Preukážte totožnosť platným dokladom\n3. Prijmite QR kód alebo hlboký odkaz od vydavateľa\n4. Naskenujte QR kód alebo klepnite na odkaz\n5. Poverenie sa vypočíta lokálne a uloží na zariadenie\n\nProces slepej atestácie zabezpečuje, že dátum narodenia sa nikdy neodošle cez sieť.\nStačí to urobiť raz. Poverenie potom možno použiť na neobmedzený počet overení.";
"help_text_officer_mode" = "Režim úradníka je pre oprávnených vydavateľov na vytváranie poverení pre používateľov.\n\nTento režim vyžaduje:\n• Overenie úradníka pomocou YubiKey\n• Oprávnenie od vydávajúceho orgánu\n• Fyzické overenie dokladu totožnosti používateľa\n\nProces:\n1. Overte sa ako úradník\n2. Skontrolujte platný doklad totožnosti používateľa\n3. Zadajte dátum narodenia používateľa\n4. Vygenerujte atestačný QR kód\n5. Používateľ naskenuje kód na prijatie poverenia\n\nTento režim smú používať iba oprávnené osoby.";

/* Simplified Help Text (Reading Level: Grade 6-8) */
"help_text_extra_large_text_simplified" = "Zväčší všetok text o 50 %.\n\nPomáha vám, ak:\n• Máte ťažkosti so zrakom\n• Ťažko čítate\n• Potrebujete väčší text\n\nFunguje s nastavením veľkosti textu vášho telefónu.";
"help_text_contrast_level_simplified" = "Zmení, ako tmavý je text.\n\nTri možnosti:\n• Štandardná: Normálne farby\n• Vysoká: Tmavší text pre ľahké čítanie\n• Maximálna: Veľmi tmavý text pre najlepšie čítanie\n\nTmavší text sa ľahšie číta.";
"help_text_high_contrast_simplified" = "Urobí text ľahšie čitateľným.\n\nPomáha vám, ak:\n• Máte ťažkosti so zrakom\n• Potrebujete tmavší text\n• Používate aplikáciu na jasnom svetle\n\nText sa stane čiernym na bielom.";
"help_text_reduce_transparency_simplified" = "Odstráni rozostrené efekty.\n\nToto pomáha:\n• Spraviť text jasnejší\n• Zjednodušiť aplikáciu\n• Zrýchliť staršie telefóny\n\nVšetko vyzerá pevnejšie.";
"help_text_color_blind_mode_simplified" = "Zmení farby, aby ste lepšie videli.\n\nMožnosti:\n• Režim pre slepotu na červenú\n• Režim pre slepotu na zelenú\n• Režim pre slepotu na modrú\n• Režim iba v odtieňoch sivej\n\nPomáha vám vidieť dôležité veci.";
"help_text_line_spacing_simplified" = "Zmení priestor medzi riadkami textu.\n\nMôžete si vybrať od 1,0× do 2,0×.\nPredvolené je 1,0×.\n\nViacej priestoru uľahčuje čítanie.";
"help_text_paragraph_spacing_simplified" = "Zmení priestor medzi odsekmi.\n\nMôžete si vybrať od 1,0× do 3,0×.\nPredvolené je 1,0×.\n\nViacej priestoru pomáha vidieť, kde začínajú nové myšlienky.";
"help_text_letter_spacing_simplified" = "Zmení priestor medzi písmenami.\n\nMôžete si vybrať od 0,0 do 0,2.\nPredvolené je 0,0.\n\nViacej priestoru urobí písmená jasnejšími.";
"help_text_text_width_simplified" = "Riadi, ako široký je text.\n\nMožnosti:\n• Celá šírka: Používa celú obrazovku\n• Stredná: Dobrá na čítanie\n• Úzka: Najlepšia na sústredenie\n\nStredná šírka sa číta najľahšie.";
"help_text_large_touch_targets_simplified" = "Zväčší všetky tlačidlá.\n\nPomáha vám, ak:\n• Máte ťažkosti s klepnutím na malé tlačidlá\n• Máte trasúce ruky\n• Nosíte rukavice\n• Používate jednu ruku\n\nTlačidlá sa stanú 60 bodmi namiesto 44 bodov.";
"help_text_reduce_motion_simplified" = "Odstráni pohyblivé animácie.\n\nPomáha vám, ak:\n• Pohyb vám spôsobuje závraty\n• Dostávate bolesti hlavy z pohybu\n• Preferujete, keď veci zostávajú na mieste\n\nVeci sa menia okamžite namiesto pohybu.";
"help_text_timeout_behavior_simplified" = "Riadi, ako dlho môžu úlohy trvať.\n\nMožnosti:\n• Bez limitu: Úlohy nikdy neskončia\n• Normálna: 30 sekúnd\n• Dlhšia: 60 sekúnd\n\nVyberte 'Bez limitu', ak potrebujete viac času.";
"help_text_simplified_gestures_simplified" = "Nahradí ťažké gestá jednoduchými klepnutiami.\n\nPomáha vám, ak:\n• Máte ťažkosti so zložitými dotykami\n• Preferujete jednoduché klepnutia\n• Používate jednu ruku\n\nVšetko používa jednoduché klepnutia.";
"help_text_haptic_feedback_simplified" = "Nechá váš telefón vibrovať, keď klepnete.\n\nPomáha vám:\n• Vedieť, keď ste klepli na tlačidlo\n• Cítiť chyby alebo varovania\n• Získať odozvu bez pozerania\n\nVypnite, ak vám vibrácie prekážajú.";
"help_text_simplified_ui_simplified" = "Zjednoduší aplikáciu.\n\nPomáha vám, ak:\n• Vás mätú preplnené obrazovky\n• Preferujete jednoduché rozloženia\n• Ste nový v aplikácii\n\nNaraz zobrazuje menej vecí.";
"help_text_step_indicators_simplified" = "Zobrazuje váš postup v krokoch.\n\nPomáha vám:\n• Vedieť, kde sa nachádzate\n• Vidieť, koľko krokov zostáva\n• Zostať organizovaný\n\nZobrazuje 'Krok 1 z 3' s bodkami.";
"help_text_verbose_descriptions_simplified" = "Dáva vám viac vysvetlení.\n\nPomáha vám:\n• Pochopiť funkcie\n• Naučiť sa používať aplikáciu\n• Získať viac podrobností\n\nPoskytuje extra pomoc všade.";
"help_text_confirm_actions_simplified" = "Žiada vás potvrdiť dôležité akcie.\n\nPomáha predchádzať:\n• Náhodným odstráneniam\n• Nechceným zmenám\n• Chybám\n\nVždy sa vás opýta 'Ste si istý?'";
"help_text_manual_code_entry_simplified" = "Umožňuje zadávať kódy namiesto skenovania.\n\nPoužite, keď:\n• Váš fotoaparát nefunguje\n• Kód sa ťažko skenuje\n• Preferujete písanie\n\nKlepnite na 'Zadať kód ručne' a píšte.";
"help_text_voice_input_simplified" = "Umožňuje hovoriť kódy namiesto písania.\n\nPomáha vám, ak:\n• Máte ťažkosti s písaním\n• Preferujete rozprávanie\n• Chcete bezručné použitie\n\nKlepnite na mikrofón a jasne hovorte.";
"help_text_qr_scanning_simplified" = "Používa fotoaparát na čítanie štvorcových kódov.\n\nAko skenovať:\n1. Nasmerujte kameru na kód\n2. Zarovnajte kód\n3. Počkajte, kým sa prečíta\n\nTipy:\n• Použite dobré osvetlenie\n• Držte telefón stabilne\n• Udržujte kód rovný";
"help_text_age_verification_simplified" = "Dokazuje, že ste dosť starý, bez zdieľania dátumu narodenia.\n\nAko funguje:\n1. Firma vytvorí žiadosť\n2. Naskenujete ich kód\n3. Aplikácia vytvorí dôkaz\n4. Firma potvrdí, že ste dosť starý\n\nVáš dátum narodenia zostáva súkromný.";
"help_text_credentials_simplified" = "Digitálny dôkaz veku uložený vo vašom telefóne.\n\nFunkcie:\n• Iba vo vašom telefóne\n• Nemožno ho kopírovať\n• Chráni vaše súkromie\n• Môžete ho kedykoľvek odstrániť\n\nDostanete ho od vládneho úradu.";
"help_text_zero_knowledge_simplified" = "Dokazuje niečo bez zdieľania podrobností.\n\nPríklad:\n• Starý spôsob: Ukázať preukaz (zobrazí presný dátum narodenia)\n• Nový spôsob: Preukázať, že máte viac ako 18 rokov (dátum narodenia zostáva súkromný)\n\nToto chráni vaše informácie ako súkromné.";
"help_text_credential_issuance_simplified" = "Získanie digitálneho dôkazu veku.\n\nKroky:\n1. Choďte na vládny úrad\n2. Ukážte preukaz totožnosti\n3. Získajte kód\n4. Naskenujte kód\n5. Dôkaz sa uloží do vášho telefónu\n\nRobte to raz. Potom ho používajte viackrát.";
"help_text_officer_mode_simplified" = "Pre vládnych pracovníkov na vytváranie dôkazov.\n\nPotrebuje:\n• Heslo úradníka\n• Oprávnenie na použitie\n• Preukaz totožnosti používateľa na kontrolu\n\nKroky:\n1. Prihláste sa ako úradník\n2. Skontrolujte preukaz totožnosti používateľa\n3. Zadajte ich dátum narodenia\n4. Vytvorte kód\n5. Používateľ naskenuje kód\n\nIba pre oprávnených pracovníkov.";

