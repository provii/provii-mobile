<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- High Contrast Dark Theme for Maximum Accessibility (WCAG AAA 7:1+ contrast) -->
    <style name="Theme.ProviiWallet.HighContrast" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors with high contrast for dark backgrounds -->
        <item name="colorPrimary">@color/high_contrast_primary</item>
        <item name="colorOnPrimary">@color/high_contrast_on_primary</item>
        <item name="colorPrimaryContainer">@color/high_contrast_primary</item>
        <item name="colorOnPrimaryContainer">@color/high_contrast_on_primary</item>
        <item name="colorPrimaryInverse">@color/high_contrast_text</item>

        <!-- Secondary colors with high contrast for dark backgrounds -->
        <item name="colorSecondary">@color/high_contrast_secondary</item>
        <item name="colorOnSecondary">@color/high_contrast_on_secondary</item>
        <item name="colorSecondaryContainer">@color/high_contrast_secondary</item>
        <item name="colorOnSecondaryContainer">@color/high_contrast_on_secondary</item>

        <!-- Background colors - pure black for maximum contrast -->
        <item name="android:colorBackground">@color/high_contrast_background</item>
        <item name="colorSurface">@color/high_contrast_surface</item>
        <item name="colorOnSurface">@color/high_contrast_text</item>
        <item name="colorOnBackground">@color/high_contrast_text</item>

        <!-- Error colors with high contrast for dark backgrounds -->
        <item name="colorError">@color/high_contrast_error</item>
        <item name="colorOnError">@color/high_contrast_on_error</item>
        <item name="colorErrorContainer">@color/high_contrast_error</item>
        <item name="colorOnErrorContainer">@color/high_contrast_on_error</item>

        <!-- Surface variants for clear differentiation -->
        <item name="colorSurfaceVariant">@color/high_contrast_surface</item>
        <item name="colorOnSurfaceVariant">@color/high_contrast_text</item>

        <!-- Outline colors for bold borders on interactive elements -->
        <item name="colorOutline">@color/high_contrast_border</item>
        <item name="colorOutlineVariant">@color/high_contrast_border</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/high_contrast_background</item>
        <item name="android:navigationBarColor">@color/high_contrast_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/high_contrast_background</item>

        <!-- Disable transparency for maximum clarity -->
        <item name="android:windowIsTranslucent">false</item>

        <!-- Focus indicator for keyboard navigation -->
        <item name="colorControlHighlight">@color/high_contrast_focus</item>
    </style>
</resources>
