/* Camera Access */
"NSCameraUsageDescription" = "يحتاج تطبيق Provii Wallet إلى الوصول إلى الكاميرا لمسح رموز \u2068QR\u2069 الخاصة باستلام بيانات الاعتماد والتحقق من العمر.";

/* NFC Access */
"NFCReaderUsageDescription" = "يستخدم تطبيق Provii Wallet تقنية \u2068NFC\u2069 للتواصل مع جهاز \u2068YubiKey\u2069 الخاص بك من أجل المصادقة الآمنة للموظف.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "يستخدم تطبيق Provii Wallet التعرف على الكلام للأوامر الصوتية في وضع إمكانية الوصول، مما يتيح لك التحكم في التطبيق بدون استخدام اليدين.";

/* Microphone Access */
