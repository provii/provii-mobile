"help_text_age_verification" = "आयु सत्यापन बिना असली आयु या जन्म तिथि बताए यह साबित करता है कि आप किसी आयु आवश्यकता को पूरा करते हैं।\n\nयह कैसे काम करता है:\n1. सत्यापनकर्ता एक चुनौती बनाता है\n2. आप QR कोड स्कैन करते हैं या मैन्युअल रूप से दर्ज करते हैं\n3. ऐप एक शून्य-ज्ञान प्रमाण बनाता है\n4. सत्यापनकर्ता पुष्टि करता है कि आप आवश्यकता पूरी करते हैं\n\nगोपनीयता सुरक्षित:\n• आपकी जन्म तिथि कभी साझा नहीं होती\n• सत्यापनकर्ता केवल यह जानता है कि आप आवश्यकता पूरी करते हैं\n• कोई ट्रैकिंग या डेटा संग्रह नहीं";
"help_text_age_verification_simplified" = "अपना जन्मदिन साझा किए बिना यह साबित करता है कि आप पर्याप्त उम्र के हैं।\n\nयह कैसे काम करता है:\n1. दुकान एक अनुरोध बनाती है\n2. आप उनका कोड स्कैन करते हैं\n3. ऐप एक प्रमाण बनाता है\n4. दुकान पुष्टि करती है कि आप काफी उम्र के हैं\n\nआपका जन्मदिन निजी रहता है।";
"help_text_color_blind_mode" = "कलर ब्लाइंड मोड विभिन्न प्रकार के रंग दृष्टि दोष के लिए रंग समायोजित करते हैं।\n\nउपलब्ध मोड:\n• प्रोटानोपिया: लाल-अंधापन (लाल देखने में कठिनाई)\n• ड्यूटेरानोपिया: हरा-अंधापन (हरा देखने में कठिनाई)\n• ट्रिटानोपिया: नीला-अंधापन (नीला देखने में कठिनाई)\n• मोनोक्रोम: केवल ग्रेस्केल\n\nये मोड सुनिश्चित करते हैं कि महत्वपूर्ण जानकारी केवल रंग से नहीं दी जाती।";
"help_text_color_blind_mode_simplified" = "बेहतर दिखने के लिए रंग बदलता है।\n\nविकल्प:\n• लाल-अंध मोड\n• हरा-अंध मोड\n• नीला-अंध मोड\n• केवल ग्रे मोड\n\nमहत्वपूर्ण चीज़ें देखने में मदद करता है।";
"help_text_confirm_actions" = "क्रियाएं पुष्टि करें महत्वपूर्ण क्रियाओं से पहले पुष्टि माँगता है।\n\nयह रोकने में मदद करता है:\n• आकस्मिक हटाना\n• अनचाहे बदलाव\n• जल्दबाजी में सबमिट करना\n• डेटा खोना\n\nनोट: विनाशकारी क्रियाओं के लिए हमेशा पुष्टि आवश्यक होती है (AAA आवश्यकता)।";
"help_text_confirm_actions_simplified" = "महत्वपूर्ण क्रियाओं से पहले पुष्टि माँगता है।\n\nरोकने में मदद करता है:\n• आकस्मिक हटाना\n• अनचाहे बदलाव\n• गलतियाँ\n\nआपसे हमेशा पूछा जाएगा 'क्या आप सुनिश्चित हैं?'";
"help_text_contrast_level" = "कंट्रास्ट स्तर टेक्स्ट और पृष्ठभूमि के बीच रंग कंट्रास्ट को नियंत्रित करता है।\n\nतीन स्तर उपलब्ध:\n• मानक: डिफ़ॉल्ट रंग\n• उच्च (AA): 4.5:1 कंट्रास्ट अनुपात - AA मानक पूरा करता है\n• अधिकतम (AAA): 7:1 कंट्रास्ट अनुपात - सर्वोच्च AAA मानक पूरा करता है\n\nउच्च कंट्रास्ट सभी प्रकाश स्थितियों में टेक्स्ट पढ़ना आसान बनाता है।";
"help_text_contrast_level_simplified" = "टेक्स्ट कितना गहरा है यह बदलता है।\n\nतीन विकल्प:\n• मानक: सामान्य रंग\n• उच्च: आसान पठन के लिए गहरा टेक्स्ट\n• अधिकतम: सबसे अच्छे पठन के लिए बहुत गहरा टेक्स्ट\n\nगहरा टेक्स्ट पढ़ना आसान होता है।";
"help_text_credential_issuance" = "प्रमाणपत्र जारी करना एक अधिकृत जारीकर्ता से आपका डिजिटल आयु प्रमाणपत्र प्राप्त करने की प्रक्रिया है।\n\nचरण:\n1. अधिकृत जारीकर्ता के पास जाएं (जैसे सरकारी कार्यालय)\n2. आधिकारिक पहचान पत्र से अपनी पहचान साबित करें\n3. जारीकर्ता से QR कोड या डीप लिंक प्राप्त करें\n4. QR कोड स्कैन करें या लिंक टैप करें\n5. प्रमाणपत्र आपके डिवाइस पर स्थानीय रूप से बनाया जाता है\n\nब्लाइंड अटेस्टेशन प्रक्रिया सुनिश्चित करती है कि आपकी जन्म तिथि नेटवर्क पर कभी नहीं भेजी जाती।\nआपको यह केवल एक बार करना होगा। फिर असीमित सत्यापन के लिए उपयोग करें।";
"help_text_credential_issuance_simplified" = "अपना डिजिटल आयु प्रमाण प्राप्त करना।\n\nचरण:\n1. सरकारी कार्यालय जाएं\n2. अपना पहचान पत्र दिखाएं\n3. एक कोड प्राप्त करें\n4. कोड स्कैन करें\n5. प्रमाण आपके फ़ोन पर सेव हो जाता है\n\nएक बार करें। फिर कई बार उपयोग करें।";
"help_text_credentials" = "डिजिटल प्रमाणपत्र आपकी आयु के क्रिप्टोग्राफ़िक प्रमाण हैं जो आपके डिवाइस पर सुरक्षित रूप से संग्रहीत होते हैं।\n\nविशेषताएं:\n• केवल आपके डिवाइस पर संग्रहीत\n• कॉपी या जालसाजी नहीं की जा सकती\n• गोपनीयता-संरक्षण सत्यापन के लिए उपयोग होते हैं\n• कभी भी हटाए जा सकते हैं\n\nआयु सत्यापित करने से पहले आपको किसी अधिकृत जारीकर्ता (जैसे सरकारी कार्यालय) से प्रमाणपत्र प्राप्त करना होगा।";
"help_text_credentials_simplified" = "आपके फ़ोन पर संग्रहीत आपकी आयु का डिजिटल प्रमाण।\n\nविशेषताएं:\n• केवल आपके फ़ोन पर\n• कॉपी नहीं की जा सकती\n• आपको निजी रखता है\n• आप इसे कभी भी हटा सकते हैं\n\nआप इसे सरकारी कार्यालय से प्राप्त करते हैं।";
"help_text_extra_large_text" = "अतिरिक्त बड़ा टेक्स्ट ऐप में सभी टेक्स्ट को 50% बड़ा करता है।\n\nयह इन उपयोगकर्ताओं के लिए उपयोगी है:\n• कम दृष्टि\n• पढ़ने में कठिनाई\n• उम्र से संबंधित दृष्टि परिवर्तन\n\nबड़े आकार के लिए iOS Dynamic Type के साथ काम करता है।";
"help_text_extra_large_text_simplified" = "सभी टेक्स्ट को 50% बड़ा करता है।\n\nमदद करता है अगर आप:\n• देखने में परेशानी हो\n• पढ़ना कठिन लगे\n• बड़े टेक्स्ट की जरूरत हो\n\nआपके फ़ोन की टेक्स्ट आकार सेटिंग्स के साथ काम करता है।";
"help_text_haptic_feedback" = "हैप्टिक फ़ीडबैक क्रियाओं और सूचनाओं के लिए कंपन प्रतिक्रिया देता है।\n\nयह इनके लिए उपयोगी है:\n• बटन दबाने की पुष्टि\n• त्रुटियों या चेतावनियों की सूचना\n• गैर-दृश्य प्रतिक्रिया देना\n• श्रवण या दृष्टि बाधित उपयोगकर्ता\n\nयदि कंपन असहज लगे तो आप इसे बंद कर सकते हैं।";
"help_text_haptic_feedback_simplified" = "टैप करने पर आपका फ़ोन कंपन करता है।\n\nमदद करता है:\n• जानना कि आपने बटन टैप किया\n• त्रुटियों या चेतावनियों को महसूस करना\n• बिना देखे प्रतिक्रिया पाना\n\nकंपन परेशान करे तो बंद करें।";
"help_text_high_contrast" = "हाई कंट्रास्ट मोड टेक्स्ट और पृष्ठभूमि के बीच कंट्रास्ट बढ़ाता है, पढ़ना आसान बनाता है।\n\nयह इनके लिए उपयोगी है:\n• कम दृष्टि\n• रंग संवेदनशीलता\n• तेज रोशनी वाले वातावरण\n\nचालू होने पर:\n• टेक्स्ट सफेद पर काला हो जाता है\n• तत्वों पर बॉर्डर जुड़ते हैं\n• रंग सरल होते हैं";
"help_text_high_contrast_simplified" = "टेक्स्ट देखना आसान बनाता है।\n\nमदद करता है अगर आप:\n• देखने में परेशानी हो\n• गहरे टेक्स्ट की जरूरत हो\n• तेज रोशनी में ऐप उपयोग करें\n\nटेक्स्ट सफेद पर काला हो जाता है।";
"help_text_large_touch_targets" = "बड़े टच टार्गेट सभी बटन और इंटरैक्टिव तत्वों को कम से कम 60pt आकार का बनाते हैं।\n\nयह इनके लिए उपयोगी है:\n• मोटर विकलांगता\n• कंपन या हिलना\n• दस्ताने पहनकर ऐप उपयोग\n• एक हाथ से उपयोग\n\nमानक न्यूनतम 44pt है; यह सेटिंग 60pt तक बढ़ाती है।";
"help_text_large_touch_targets_simplified" = "सभी बटन बड़े बनाता है।\n\nमदद करता है अगर आप:\n• छोटे बटन टैप करने में परेशानी हो\n• हाथ कांपते हों\n• दस्ताने पहनें\n• एक हाथ उपयोग करें\n\nबटन 44pt की जगह 60pt हो जाते हैं।";
"help_text_letter_spacing" = "अक्षर अंतर व्यक्तिगत अक्षरों के बीच की जगह नियंत्रित करता है।\n\n• सीमा: 0.0em से 0.2em\n• AAA मानक: न्यूनतम 0.12em\n• डिफ़ॉल्ट: 0.0em\n\nबढ़ा हुआ अक्षर अंतर अक्षर पहचान और पठनीयता में सुधार करता है।";
"help_text_letter_spacing_simplified" = "अक्षरों के बीच जगह बदलता है।\n\n0.0 से 0.2 तक चुन सकते हैं।\nडिफ़ॉल्ट 0.0 है।\n\nज़्यादा जगह से अक्षर स्पष्ट होते हैं।";
"help_text_line_spacing" = "पंक्ति अंतर टेक्स्ट की पंक्तियों के बीच की जगह नियंत्रित करता है।\n\n• सीमा: 1.0x से 2.0x\n• AAA मानक: न्यूनतम 1.5x\n• डिफ़ॉल्ट: 1.0x\n\nबढ़ा हुआ पंक्ति अंतर टेक्स्ट पढ़ना आसान बनाता है और पंक्ति छोड़ने से बचाता है।";
"help_text_line_spacing_simplified" = "टेक्स्ट की पंक्तियों के बीच जगह बदलता है।\n\n1.0x से 2.0x तक चुन सकते हैं।\nडिफ़ॉल्ट 1.0x है।\n\nज़्यादा जगह से पढ़ना आसान होता है।";
"help_text_manual_code_entry" = "मैन्युअल कोड एंट्री आपको QR कोड स्कैन करने की जगह कोड टाइप करने देती है।\n\nयह तब उपयोगी है जब:\n• कैमरा काम नहीं कर रहा\n• QR कोड क्षतिग्रस्त या अस्पष्ट है\n• स्क्रीन रीडर उपयोग कर रहे हों\n• स्कैन करने की जगह टाइप करना पसंद हो\n\nबस 'कोड मैन्युअल रूप से दर्ज करें' टैप करें।";
"help_text_manual_code_entry_simplified" = "स्कैन करने की जगह कोड टाइप करने देता है।\n\nयह उपयोग करें जब:\n• आपका कैमरा काम नहीं करता\n• कोड स्कैन करना मुश्किल हो\n• टाइप करना पसंद हो\n\n'कोड मैन्युअल रूप से दर्ज करें' टैप करें।";
"help_text_officer_mode" = "अधिकारी मोड अधिकृत जारीकर्ताओं के लिए उपयोगकर्ताओं के प्रमाणपत्र बनाने हेतु है।\n\nइस मोड के लिए आवश्यक है:\n• YubiKey के साथ अधिकारी प्रमाणीकरण\n• जारी करने वाली प्राधिकरण से अनुमति\n• उपयोगकर्ता के पहचान पत्र का भौतिक सत्यापन\n\nप्रक्रिया:\n1. अधिकारी के रूप में प्रमाणीकरण करें\n2. उपयोगकर्ता का आधिकारिक पहचान पत्र सत्यापित करें\n3. उपयोगकर्ता की जन्म तिथि दर्ज करें\n4. प्रमाणन QR कोड बनाएं\n5. उपयोगकर्ता प्रमाणपत्र प्राप्त करने के लिए कोड स्कैन करता है\n\nकेवल अधिकृत कर्मचारी इस मोड का उपयोग करें।";
"help_text_officer_mode_simplified" = "सरकारी कर्मचारियों के लिए प्रमाण बनाने हेतु।\n\nआवश्यकताएं:\n• अधिकारी पासवर्ड\n• उपयोग की अनुमति\n• जाँचने के लिए उपयोगकर्ता का पहचान पत्र\n\nचरण:\n1. अधिकारी के रूप में लॉग इन करें\n2. उपयोगकर्ता का पहचान पत्र जाँचें\n3. उनकी जन्म तिथि दर्ज करें\n4. कोड बनाएं\n5. उपयोगकर्ता कोड स्कैन करता है\n\nकेवल अधिकृत कर्मचारियों के लिए।";
"help_text_paragraph_spacing" = "अनुच्छेद अंतर अनुच्छेदों के बीच की जगह नियंत्रित करता है।\n\n• सीमा: 1.0x से 3.0x\n• AAA मानक: न्यूनतम 2.0x\n• डिफ़ॉल्ट: 1.0x\n\nबढ़ा हुआ अनुच्छेद अंतर टेक्स्ट के विभिन्न खंडों में अंतर करने में मदद करता है।";
"help_text_paragraph_spacing_simplified" = "अनुच्छेदों के बीच जगह बदलता है।\n\n1.0x से 3.0x तक चुन सकते हैं।\nडिफ़ॉल्ट 1.0x है।\n\nज़्यादा जगह से नए विचारों की शुरुआत देखने में मदद मिलती है।";
"help_text_qr_scanning" = "QR कोड स्कैनिंग Quick Response कोड पढ़ने के लिए आपके कैमरे का उपयोग करती है।\n\nकैसे स्कैन करें:\n1. कैमरा QR कोड की ओर करें\n2. फ़्रेम में कोड संरेखित करें\n3. स्वचालित पहचान की प्रतीक्षा करें\n\nसुझाव:\n• अच्छी रोशनी सुनिश्चित करें\n• डिवाइस स्थिर रखें\n• QR कोड सपाट और बाधारहित रखें\n• स्कैन विफल होने पर मैन्युअल कोड एंट्री आज़माएं";
"help_text_qr_scanning_simplified" = "चौकोर कोड पढ़ने के लिए कैमरे का उपयोग करता है।\n\nकैसे स्कैन करें:\n1. कैमरा कोड की ओर करें\n2. कोड लाइन में लगाएं\n3. पढ़ने का इंतज़ार करें\n\nसुझाव:\n• अच्छी रोशनी उपयोग करें\n• फ़ोन स्थिर रखें\n• कोड सपाट रखें";
"help_text_reduce_motion" = "गति कम करें ऐप में एनिमेशन को कम या हटाता है।\n\nयह इनके लिए उपयोगी है:\n• गति संवेदनशीलता\n• वेस्टिबुलर विकार\n• मिर्गी\n• माइग्रेन ट्रिगर\n\nचालू होने पर एनिमेशन तुरंत ट्रांजिशन से बदल जाते हैं।";
"help_text_reduce_motion_simplified" = "चलती एनिमेशन हटाता है।\n\nमदद करता है अगर:\n• हलचल से चक्कर आए\n• हलचल से सिरदर्द हो\n• चीज़ें स्थिर रहना पसंद हो\n\nचीज़ें हिलने की जगह तुरंत बदलती हैं।";
"help_text_reduce_transparency" = "पारदर्शिता कम करें ऐप में धुंधलाहट और पारदर्शिता प्रभाव हटाता है।\n\nइससे मदद मिलती है:\n• टेक्स्ट पठनीयता सुधारना\n• दृश्य जटिलता कम करना\n• पुराने डिवाइस पर प्रदर्शन बढ़ाना\n• सामग्री अधिक पूर्वानुमानित बनाना";
"help_text_reduce_transparency_simplified" = "धुंधले प्रभाव हटाता है।\n\nइससे मदद मिलती है:\n• टेक्स्ट स्पष्ट करना\n• ऐप सरल बनाना\n• पुराने फ़ोन तेज़ करना\n\nसब कुछ अधिक ठोस दिखता है।";
"help_text_simplified_gestures" = "सरलीकृत जेस्चर जटिल मल्टी-टच जेस्चर को साधारण टैप से बदलता है।\n\nयह इनके लिए उपयोगी है:\n• मोटर विकलांगता\n• सीमित निपुणता\n• सहायक उपकरण उपयोग\n• एक हाथ से संचालन\n\nजटिल जेस्चर बटन और साधारण टैप से बदल जाते हैं।";
"help_text_simplified_gestures_simplified" = "कठिन जेस्चर को साधारण टैप से बदलता है।\n\nमदद करता है अगर आप:\n• जटिल टच में परेशानी हो\n• साधारण टैप पसंद हों\n• एक हाथ उपयोग करें\n\nसब कुछ साधारण टैप से होता है।";
"help_text_simplified_ui" = "सरलीकृत इंटरफ़ेस ऐप में दृश्य जटिलता कम करता है।\n\nयह इनके लिए उपयोगी है:\n• संज्ञानात्मक विकलांगता\n• सीखने में कठिनाई\n• ध्यान विकार\n• नए या अनुभवहीन उपयोगकर्ता\n\nचालू होने पर:\n• स्क्रीन पर कम तत्व\n• बड़े, स्पष्ट नियंत्रण\n• कम दृश्य शोर";
"help_text_simplified_ui_simplified" = "ऐप सरल बनाता है।\n\nमदद करता है अगर आप:\n• व्यस्त स्क्रीन से भ्रमित हों\n• सरल लेआउट पसंद हो\n• ऐप में नए हों\n\nएक बार में कम चीज़ें दिखाता है।";
"help_text_step_indicators" = "चरण संकेतक बहु-चरण प्रक्रियाओं में आपकी प्रगति दिखाते हैं।\n\nइससे मदद मिलती है:\n• समझना कि आप प्रक्रिया में कहाँ हैं\n• जानना कि कितने चरण बाकी हैं\n• संज्ञानात्मक बोझ कम करना\n• स्पष्ट संरचना देना\n\nदृश्य प्रगति बिंदुओं के साथ \"चरण X में से Y\" दिखाता है।";
"help_text_step_indicators_simplified" = "चरणों में आपकी प्रगति दिखाता है।\n\nमदद करता है:\n• जानना कि आप कहाँ हैं\n• देखना कि कितने चरण बाकी हैं\n• व्यवस्थित रहना\n\nबिंदुओं के साथ 'चरण 1 में से 3' दिखाता है।";
"help_text_text_width" = "टेक्स्ट चौड़ाई आरामदायक पठन के लिए अधिकतम पंक्ति लंबाई नियंत्रित करती है।\n\nविकल्प:\n• पूरी चौड़ाई: कोई अधिकतम नहीं\n• आरामदायक (80 वर्ण): पठन के लिए इष्टतम\n• संकरी (60 वर्ण): केंद्रित पठन के लिए\n\nAAA दिशानिर्देश प्रति पंक्ति अधिकतम 80 वर्ण की सिफारिश करते हैं।";
"help_text_text_width_simplified" = "टेक्स्ट कितना चौड़ा है यह नियंत्रित करता है।\n\nविकल्प:\n• पूरी चौड़ाई: पूरी स्क्रीन उपयोग करता है\n• मध्यम: पढ़ने के लिए अच्छा\n• संकरा: ध्यान केंद्रित करने के लिए सबसे अच्छा\n\nमध्यम चौड़ाई पढ़ना सबसे आसान होता है।";
"help_text_timeout_behavior" = "टाइमआउट व्यवहार नियंत्रित करता है कि टाइमआउट से पहले ऑपरेशन कितना समय ले सकते हैं।\n\nविकल्प:\n• कोई टाइमआउट नहीं (AAA): ऑपरेशन कभी टाइमआउट नहीं होते\n• मानक (30s): डिफ़ॉल्ट टाइमआउट\n• विस्तारित (60s): मानक समय का दोगुना\n\nनो टाइमआउट मोड AAA एक्सेसिबिलिटी मानकों को पूरा करता है।";
"help_text_timeout_behavior_simplified" = "कार्यों को कितना समय लग सकता है यह नियंत्रित करता है।\n\nविकल्प:\n• कोई सीमा नहीं: कार्य कभी नहीं रुकते\n• सामान्य: 30 सेकंड\n• अधिक: 60 सेकंड\n\nयदि अधिक समय चाहिए तो 'कोई सीमा नहीं' चुनें।";
"help_text_verbose_descriptions" = "विस्तृत विवरण ऐप में अतिरिक्त व्याख्यात्मक टेक्स्ट प्रदान करता है।\n\nयह इनके लिए उपयोगी है:\n• जटिल सुविधाएं समझना\n• ऐप उपयोग करना सीखना\n• संज्ञानात्मक समर्थन\n• स्क्रीन रीडर उपयोगकर्ता\n\nसभी सुविधाओं के लिए संदर्भ और निर्देश प्रदान करता है।";
"help_text_verbose_descriptions_simplified" = "अधिक स्पष्टीकरण देता है।\n\nमदद करता है:\n• सुविधाएं समझना\n• ऐप उपयोग करना सीखना\n• अधिक विवरण पाना\n\nहर जगह अतिरिक्त सहायता देता है।";
"help_text_voice_input" = "वॉइस इनपुट आपको स्कैन या टाइप करने की जगह कोड बोलने देता है।\n\nयह इनके लिए उपयोगी है:\n• सीमित गतिशीलता\n• स्क्रीन रीडर उपयोगकर्ता\n• हैंड्स-फ्री संचालन\n• आवाज़ की प्राथमिकता\n\nमाइक्रोफ़ोन बटन टैप करें और संकेत पर स्पष्ट रूप से बोलें।";
"help_text_voice_input_simplified" = "टाइप करने की जगह कोड बोलने देता है।\n\nमदद करता है अगर आप:\n• टाइप करने में परेशानी हो\n• बात करना पसंद हो\n• हैंड्स-फ्री उपयोग चाहते हों\n\nमाइक्रोफ़ोन टैप करें और स्पष्ट रूप से बोलें।";
"help_text_zero_knowledge" = "शून्य-ज्ञान प्रमाण आपको अंतर्निहित जानकारी बताए बिना कुछ साबित करने देते हैं।\n\nउदाहरण:\n• परंपरागत: पहचान पत्र दिखाएं (सटीक जन्मदिन बताता है)\n• शून्य-ज्ञान: जन्मदिन दिखाए बिना 18+ होना साबित करें\n\nलाभ:\n• अधिकतम गोपनीयता सुरक्षा\n• कोई व्यक्तिगत डेटा साझा नहीं\n• क्रिप्टोग्राफ़िक रूप से सुरक्षित\n• जालसाजी या रिप्ले नहीं हो सकती\n\nयही वह मुख्य तकनीक है जो Provii Wallet को निजी बनाती है।";
"help_text_zero_knowledge_simplified" = "विवरण साझा किए बिना कुछ साबित करता है।\n\nउदाहरण:\n• पुराना तरीका: पहचान पत्र दिखाएं (सटीक जन्मदिन दिखाता है)\n• नया तरीका: 18+ होना साबित करें (जन्मदिन निजी रहता है)\n\nयह आपकी जानकारी निजी रखता है।";
