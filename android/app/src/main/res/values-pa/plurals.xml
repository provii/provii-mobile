<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ===== BATCH 10 FINAL: Plural Strings ===== -->
    <!-- Validated: 2026-03-21 -->
    <!-- No fixes required. All 11 plural groups passed review (I-02). -->

    <!-- Punjabi CLDR plural categories: "one" (n = 0 or n = 1), "other" (everything else) -->
    <!-- Note: In Punjabi CLDR, n=0 falls under "one", so quantity="zero" uses the "one" form for grammar. -->
    <!-- quantity="zero" is retained where the English source uses a distinct "No X" phrasing. -->

    <!-- DISPOSITION: ACCEPTED as-is. Invariant noun, correct. -->
    <!-- Credential Count -->
    <plurals name="credential_count">
        <item quantity="zero">ਕੋਈ ਪ੍ਰਮਾਣ ਪੱਤਰ ਨਹੀਂ</item>
        <item quantity="one">1 ਪ੍ਰਮਾਣ ਪੱਤਰ</item>
        <item quantity="other">%d ਪ੍ਰਮਾਣ ਪੱਤਰ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Invariant noun, correct. -->
    <!-- Session Count -->
    <plurals name="session_count">
        <item quantity="one">1 ਸਰਗਰਮ ਸੈਸ਼ਨ</item>
        <item quantity="other">%d ਸਰਗਰਮ ਸੈਸ਼ਨ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Invariant noun, correct. -->
    <!-- Days Ago -->
    <plurals name="days_ago">
        <item quantity="one">1 ਦਿਨ ਪਹਿਲਾਂ</item>
        <item quantity="other">%d ਦਿਨ ਪਹਿਲਾਂ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Correct oblique plural ਘੰਟਾ/ਘੰਟੇ. -->
    <!-- Hours Ago -->
    <plurals name="hours_ago">
        <item quantity="one">1 ਘੰਟਾ ਪਹਿਲਾਂ</item>
        <item quantity="other">%d ਘੰਟੇ ਪਹਿਲਾਂ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Invariant noun, correct. -->
    <!-- Minutes Ago -->
    <plurals name="minutes_ago">
        <item quantity="one">1 ਮਿੰਟ ਪਹਿਲਾਂ</item>
        <item quantity="other">%d ਮਿੰਟ ਪਹਿਲਾਂ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Correct singular/plural ਕੋਸ਼ਿਸ਼/ਕੋਸ਼ਿਸ਼ਾਂ. -->
    <!-- Attempts Left -->
    <plurals name="attempts_left">
        <item quantity="one">1 ਕੋਸ਼ਿਸ਼ ਬਾਕੀ</item>
        <item quantity="other">%d ਕੋਸ਼ਿਸ਼ਾਂ ਬਾਕੀ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Correct verb agreement ਕੀਤਾ/ਕੀਤੇ. -->
    <!-- Documents Uploaded -->
    <plurals name="documents_uploaded">
        <item quantity="zero">ਕੋਈ ਦਸਤਾਵੇਜ਼ ਅੱਪਲੋਡ ਨਹੀਂ ਕੀਤਾ</item>
        <item quantity="one">1 ਦਸਤਾਵੇਜ਼ ਅੱਪਲੋਡ ਕੀਤਾ</item>
        <item quantity="other">%d ਦਸਤਾਵੇਜ਼ ਅੱਪਲੋਡ ਕੀਤੇ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Correct singular/plural ਤਸਦੀਕ/ਤਸਦੀਕਾਂ. -->
    <!-- Verifications Remaining -->
    <plurals name="verifications_remaining">
        <item quantity="zero">ਕੋਈ ਤਸਦੀਕ ਬਾਕੀ ਨਹੀਂ</item>
        <item quantity="one">1 ਤਸਦੀਕ ਬਾਕੀ</item>
        <item quantity="other">%d ਤਸਦੀਕਾਂ ਬਾਕੀ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Correct noun + verb agreement. -->
    <!-- Items Selected -->
    <plurals name="items_selected">
        <item quantity="one">1 ਆਈਟਮ ਚੁਣੀ ਗਈ</item>
        <item quantity="other">%d ਆਈਟਮਾਂ ਚੁਣੀਆਂ ਗਈਆਂ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Correct noun + adjective agreement. -->
    <!-- Notifications Unread -->
    <plurals name="notifications_unread">
        <item quantity="zero">ਕੋਈ ਅਣਪੜ੍ਹੀ ਸੂਚਨਾ ਨਹੀਂ</item>
        <item quantity="one">1 ਅਣਪੜ੍ਹੀ ਸੂਚਨਾ</item>
        <item quantity="other">%d ਅਣਪੜ੍ਹੀਆਂ ਸੂਚਨਾਵਾਂ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Correct verb agreement ਕੀਤਾ/ਕੀਤੇ. -->
    <!-- Credentials Issued Today -->
    <plurals name="credentials_issued_today">
        <item quantity="zero">ਅੱਜ ਕੋਈ ਪ੍ਰਮਾਣ ਪੱਤਰ ਜਾਰੀ ਨਹੀਂ ਕੀਤਾ</item>
        <item quantity="one">ਅੱਜ 1 ਪ੍ਰਮਾਣ ਪੱਤਰ ਜਾਰੀ ਕੀਤਾ</item>
        <item quantity="other">ਅੱਜ %d ਪ੍ਰਮਾਣ ਪੱਤਰ ਜਾਰੀ ਕੀਤੇ</item>
    </plurals>

    <!-- DISPOSITION: ACCEPTED as-is. Correct suppletive pair ਵਿਅਕਤੀ/ਲੋਕ. -->
    <!-- People Waiting -->
    <plurals name="people_waiting">
        <item quantity="one">1 ਵਿਅਕਤੀ ਉਡੀਕ ਵਿੱਚ</item>
        <item quantity="other">%d ਲੋਕ ਉਡੀਕ ਵਿੱਚ</item>
    </plurals>
</resources>
