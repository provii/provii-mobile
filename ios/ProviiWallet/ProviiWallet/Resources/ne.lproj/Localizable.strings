/* Help Text Descriptions */
"help_text_extra_large_text" = "अति ठूलो पाठले एपमा सबै पाठ ५०% बढाउँछ।\n\nयो यिनका लागि उपयोगी छ:\n• कम दृष्टि भएका\n• पढ्न कठिनाइ भएका\n• उमेरसँग सम्बन्धित दृष्टि परिवर्तन भएका\n\nअझ ठूला आकारहरूका लागि iOS Dynamic Type सँग काम गर्छ।";
"help_text_contrast_level" = "कन्ट्रास्ट स्तरले पाठ र पृष्ठभूमिबीचको रङ कन्ट्रास्ट नियन्त्रण गर्छ।\n\nतीन स्तरहरू उपलब्ध:\n• मानक: पूर्वनिर्धारित रङहरू\n• उच्च (AA): ४.५:१ कन्ट्रास्ट अनुपात - AA मानकहरू पूरा गर्छ\n• अधिकतम (AAA): ७:१ कन्ट्रास्ट अनुपात - सर्वोच्च AAA मानकहरू पूरा गर्छ\n\nउच्च कन्ट्रास्टले सबै प्रकाश अवस्थाहरूमा पाठ पढ्न सजिलो बनाउँछ।";
"help_text_high_contrast" = "उच्च कन्ट्रास्ट मोडले पाठ र पृष्ठभूमिबीचको कन्ट्रास्ट बढाउँछ, पढ्न सजिलो बनाउँछ।\n\nयो यिनका लागि उपयोगी छ:\n• कम दृष्टि भएका\n• रङ संवेदनशीलता भएका\n• उज्यालो स्क्रिन वातावरण\n\nसक्षम भएमा:\n• पाठ सेतोमा कालो हुन्छ\n• तत्वहरूमा बोर्डरहरू थपिन्छन्\n• रङहरू सरल हुन्छन्";
"help_text_reduce_transparency" = "पारदर्शिता घटाउनुहोस्ले एपभरि धमिलो र पारदर्शिता प्रभावहरू हटाउँछ।\n\nयसले:\n• पाठ पठनीयता सुधार गर्छ\n• दृश्य जटिलता घटाउँछ\n• पुराना उपकरणहरूमा प्रदर्शन बढाउँछ\n• सामग्री बढी अनुमानयोग्य बनाउँछ";
"help_text_color_blind_mode" = "रङ अन्धो मोडहरूले रङ दृष्टि कमजोरीका विभिन्न प्रकारहरूका लागि रङहरू समायोजन गर्छन्।\n\nउपलब्ध मोडहरू:\n• Protanopia: रातो-अन्धो (रातो देख्न कठिनाइ)\n• Deuteranopia: हरियो-अन्धो (हरियो देख्न कठिनाइ)\n• Tritanopia: नीलो-अन्धो (नीलो देख्न कठिनाइ)\n• एकरङी: केवल खैरो स्केल\n\nयी मोडहरूले महत्वपूर्ण जानकारी केवल रङद्वारा मात्र व्यक्त नगरिएको सुनिश्चित गर्छन्।";
"help_text_line_spacing" = "पङ्क्ति अन्तरालले पाठका पङ्क्तिहरूबीचको खाली ठाउँ नियन्त्रण गर्छ।\n\n• दायरा: १.०x देखि २.०x\n• AAA मानक: न्यूनतम १.५x\n• पूर्वनिर्धारित: १.०x\n\nबढाइएको पङ्क्ति अन्तरालले पाठ पढ्न सजिलो बनाउँछ र पङ्क्ति छाड्न रोक्छ।";
"help_text_paragraph_spacing" = "अनुच्छेद अन्तरालले अनुच्छेदहरूबीचको खाली ठाउँ नियन्त्रण गर्छ।\n\n• दायरा: १.०x देखि ३.०x\n• AAA मानक: न्यूनतम २.०x\n• पूर्वनिर्धारित: १.०x\n\nबढाइएको अनुच्छेद अन्तरालले पाठका विभिन्न खण्डहरू छुट्याउन मद्दत गर्छ।";
"help_text_letter_spacing" = "अक्षर अन्तरालले व्यक्तिगत अक्षरहरूबीचको खाली ठाउँ नियन्त्रण गर्छ।\n\n• दायरा: ०.०em देखि ०.२em\n• AAA मानक: न्यूनतम ०.१२em\n• पूर्वनिर्धारित: ०.०em\n\nबढाइएको अक्षर अन्तरालले अक्षर पहिचान र पठनीयता सुधार गर्छ।";
"help_text_text_width" = "पाठ चौडाइले आरामदायी पढ्नका लागि अधिकतम रेखा लम्बाइ नियन्त्रण गर्छ।\n\nविकल्पहरू:\n• पूर्ण चौडाइ: कुनै अधिकतम छैन\n• आरामदायी (८० अक्षर): पढ्नका लागि उत्तम\n• साँघुरो (६० अक्षर): केन्द्रित पढ्नका लागि\n\nAAA दिशानिर्देशहरूले प्रति लाइन अधिकतम ८० अक्षर सिफारिस गर्छन्।";
"help_text_large_touch_targets" = "ठूला टच लक्ष्यहरूले सबै बटनहरू र अन्तरक्रियात्मक तत्वहरूलाई कम्तीमा ६०pt आकारमा बनाउँछ।\n\nयो यिनका लागि उपयोगी छ:\n• मोटर असक्षमता\n• कम्पन वा हल्लाउने\n• पन्जाले एप प्रयोग गर्दा\n• एकहाते प्रयोग\n\nमानक न्यूनतम ४४pt हो; यो सेटिङले ६०pt मा बढाउँछ।";
"help_text_reduce_motion" = "गति घटाउनुहोस्ले एपभरि एनिमेसनहरू न्यूनतम वा हटाउँछ।\n\nयो यिनका लागि उपयोगी छ:\n• गति संवेदनशीलता\n• वेस्टिबुलर विकारहरू\n• एपिलेप्सी\n• माइग्रेन ट्रिगरहरू\n\nसक्षम भएमा, एनिमेसनहरूलाई तत्काल संक्रमणहरूले प्रतिस्थापन गर्छन्।";
"help_text_timeout_behavior" = "समयसीमा व्यवहारले कार्यहरू समयसीमा समाप्त हुनु अघि कति समय लिन सक्छन् भन्ने नियन्त्रण गर्छ।\n\nविकल्पहरू:\n• कुनै समयसीमा छैन (AAA): कार्यहरूको समयसीमा कहिल्यै समाप्त हुँदैन\n• मानक (३०s): पूर्वनिर्धारित समयसीमा\n• विस्तारित (६०s): मानक समयको दोब्बर\n\nकुनै समयसीमा मोडले AAA पहुँचयोग्यता मानकहरू पूरा गर्छ।";
"help_text_simplified_gestures" = "सरलीकृत हाउभाउहरूले जटिल बहु-स्पर्श हाउभाउहरूलाई साधारण ट्यापमा घटाउँछ।\n\nयो यिनका लागि उपयोगी छ:\n• मोटर असक्षमता\n• सीमित निपुणता\n• सहायक उपकरणहरू प्रयोग गर्दा\n• एकहाते सञ्चालन\n\nजटिल हाउभाउहरूलाई बटनहरू र साधारण ट्यापहरूले प्रतिस्थापन गर्छन्।";
"help_text_haptic_feedback" = "हाप्टिक प्रतिक्रियाले कार्यहरू र सूचनाहरूका लागि कम्पन प्रतिक्रिया प्रदान गर्छ।\n\nयो यिनका लागि उपयोगी छ:\n• बटन थिच्नु पुष्टि गर्न\n• त्रुटिहरू वा चेतावनीहरूको सूचना\n• गैर-दृश्य प्रतिक्रिया प्रदान गर्न\n• श्रवण वा दृष्टि असक्षम प्रयोगकर्ताहरू\n\nकम्पनहरू असुविधाजनक भएमा यो असक्षम गर्न सक्नुहुन्छ।";
"help_text_simplified_ui" = "सरलीकृत इन्टरफेसले एपभरि दृश्य जटिलता घटाउँछ।\n\nयो यिनका लागि उपयोगी छ:\n• संज्ञानात्मक असक्षमता\n• सिकाइ कठिनाइहरू\n• ध्यान विकारहरू\n• नयाँ वा अनुभवहीन प्रयोगकर्ताहरू\n\nसक्षम भएमा:\n• स्क्रिनमा कम तत्वहरू\n• ठूला, स्पष्ट नियन्त्रणहरू\n• कम दृश्य ध्वनि";
"help_text_step_indicators" = "चरण सूचकहरूले बहु-चरण प्रक्रियाहरूमा तपाईंको प्रगति देखाउँछन्।\n\nयसले:\n• प्रक्रियामा तपाईं कहाँ हुनुहुन्छ बुझ्न\n• कति चरणहरू बाँकी छन् जान्न\n• संज्ञानात्मक बोझ घटाउन\n• स्पष्ट संरचना प्रदान गर्न मद्दत गर्छ\n\nदृश्य प्रगति बिन्दुहरूसहित 'चरण X मध्ये Y' देखाउँछ।";
"help_text_verbose_descriptions" = "विस्तृत विवरणहरूले एपभरि अतिरिक्त व्याख्यात्मक पाठ प्रदान गर्छ।\n\nयो यिनका लागि उपयोगी छ:\n• जटिल सुविधाहरू बुझ्न\n• एप कसरी प्रयोग गर्ने सिक्न\n• संज्ञानात्मक सहयोग\n• स्क्रिन रिडर प्रयोगकर्ताहरू\n\nसबै सुविधाहरूका लागि सन्दर्भ र निर्देशनहरू प्रदान गर्छ।";
"help_text_confirm_actions" = "कार्यहरू पुष्टि गर्नुहोस्ले महत्वपूर्ण कार्यहरू अघि पुष्टि माग्छ।\n\nयसले रोक्न मद्दत गर्छ:\n• आकस्मिक मेटाउने\n• अनपेक्षित परिवर्तनहरू\n• समयपूर्व पेश\n• डेटा हानि\n\nनोट: विनाशकारी कार्यहरूलाई सधैं पुष्टि चाहिन्छ (AAA आवश्यकता)।";
"help_text_manual_code_entry" = "म्यानुअल कोड प्रविष्टिले तपाईंलाई QR कोडहरू स्क्यान गर्नुको सट्टामा कोडहरू टाइप गर्न अनुमति दिन्छ।\n\nयो उपयोगी हुन्छ जब:\n• क्यामेरा काम गरिरहेको छैन\n• QR कोड क्षतिग्रस्त वा अस्पष्ट छ\n• स्क्रिन रिडर प्रयोग गर्दा\n• स्क्यान गर्नुभन्दा टाइप गर्न मन पर्छ\n\nस्क्रिनमा देखिएको कोड टाइप गर्न 'कोड म्यानुअल रूपमा प्रविष्ट गर्नुहोस्' ट्याप गर्नुहोस्।";
"help_text_voice_input" = "आवाज इनपुटले तपाईंलाई स्क्यान वा टाइप गर्नुको सट्टामा कोडहरू बोल्न अनुमति दिन्छ।\n\nयो यिनका लागि उपयोगी छ:\n• सीमित गतिशीलता\n• स्क्रिन रिडर प्रयोगकर्ताहरू\n• ह्यान्डस-फ्री सञ्चालन\n• आवाजको प्राथमिकता\n\nमाइक्रोफोन बटन ट्याप गर्नुहोस् र संकेत गर्दा स्पष्ट रूपमा बोल्नुहोस्।";
"help_text_qr_scanning" = "QR कोड स्क्यानिङले तपाईंको क्यामेरा प्रयोग गरेर द्रुत प्रतिक्रिया कोडहरू पढ्छ।\n\nकसरी स्क्यान गर्ने:\n१. QR कोडमा क्यामेरा तेर्स्याउनुहोस्\n२. फ्रेममा कोड मिलाउनुहोस्\n३. स्वतः पत्ता लाग्नको प्रतीक्षा गर्नुहोस्\n\nसुझावहरू:\n• राम्रो प्रकाश सुनिश्चित गर्नुहोस्\n• उपकरण स्थिर राख्नुहोस्\n• QR कोड सपाट र अवरोधरहित राख्नुहोस्\n• स्क्यान असफल भएमा म्यानुअल कोड प्रविष्टि प्रयास गर्नुहोस्";
"help_text_age_verification" = "उमेर प्रमाणीकरणले तपाईंको वास्तविक उमेर वा जन्म मिति नखुलाईकन उमेर आवश्यकता पूरा गर्नुहुन्छ भन्ने प्रमाणित गर्छ।\n\nयो कसरी काम गर्छ:\n१. प्रमाणकले चुनौती उत्पन्न गर्छ\n२. तपाईंले QR कोड स्क्यान गर्नुहुन्छ वा म्यानुअल रूपमा प्रविष्ट गर्नुहुन्छ\n३. एपले शून्य-ज्ञान प्रमाण बनाउँछ\n४. प्रमाणकले तपाईं आवश्यकता पूरा गर्नुहुन्छ भनी पुष्टि गर्छ\n\nगोपनीयता सुरक्षित:\n• तपाईंको जन्म मिति कहिल्यै साझा गरिँदैन\n• प्रमाणकले केवल तपाईं आवश्यकता पूरा गर्नुहुन्छ भन्ने जान्छ\n• कुनै ट्र्याकिङ वा डेटा संकलन छैन";
"help_text_credentials" = "डिजिटल प्रमाणपत्रहरू तपाईंको उपकरणमा सुरक्षित रूपमा भण्डारण गरिएका तपाईंको उमेरका क्रिप्टोग्राफिक प्रमाणहरू हुन्।\n\nसुविधाहरू:\n• केवल तपाईंको उपकरणमा भण्डारण गरिएका\n• प्रतिलिपि वा जाली बनाउन सकिँदैन\n• गोपनीयता-संरक्षण प्रमाणीकरणका लागि प्रयोग गरिन्छ\n• जुनसुकै बेला मेटाउन सकिन्छ\n\nतपाईं आफ्नो उमेर प्रमाणित गर्न सक्नु अघि अधिकृत जारीकर्ता (जस्तै सरकारी कार्यालय) बाट प्रमाणपत्र लिनु पर्छ।";
"help_text_zero_knowledge" = "शून्य-ज्ञान प्रमाणहरूले तपाईंलाई अन्तर्निहित जानकारी नखुलाईकन केही कुरा सत्य छ भनी प्रमाणित गर्न अनुमति दिन्छ।\n\nउदाहरण:\n• परम्परागत: पहिचान देखाउनुहोस् (सटीक जन्मदिन खुल्छ)\n• शून्य-ज्ञान: जन्मदिन नदेखाई १८ वर्षभन्दा माथि छ भनी प्रमाणित गर्नुहोस्\n\nफाइदाहरू:\n• अधिकतम गोपनीयता सुरक्षा\n• कुनै व्यक्तिगत डेटा साझा गरिँदैन\n• क्रिप्टोग्राफिक रूपमा सुरक्षित\n• जाली बनाउन वा पुनः खेल्न सकिँदैन\n\nयो Provii Wallet निजी बनाउने मूल प्रविधि हो।";
"help_text_credential_issuance" = "प्रमाणपत्र जारीकरण अधिकृत जारीकर्ताबाट तपाईंको डिजिटल उमेर प्रमाणपत्र प्राप्त गर्ने प्रक्रिया हो।\n\nचरणहरू:\n१. अधिकृत जारीकर्तामा जानुहोस् (जस्तै सरकारी कार्यालय)\n२. आधिकारिक पहिचानसँग आफ्नो पहिचान प्रमाणित गर्नुहोस्\n३. जारीकर्ताबाट QR कोड वा डिप लिङ्क प्राप्त गर्नुहोस्\n४. QR कोड स्क्यान गर्नुहोस् वा लिङ्क ट्याप गर्नुहोस्\n५. प्रमाणपत्र स्थानीय रूपमा गणना गरिन्छ र तपाईंको उपकरणमा भण्डारण गरिन्छ\n\nअन्ध प्रमाणीकरण प्रक्रियाले तपाईंको जन्म मिति नेटवर्कमार्फत कहिल्यै पठाइँदैन भनी सुनिश्चित गर्छ।\nतपाईंले यो एकपटक मात्र गर्न पर्छ। त्यसपछि तपाईंको प्रमाणपत्र असीमित प्रमाणीकरणहरूका लागि प्रयोग गर्न सकिन्छ।";
"help_text_officer_mode" = "अधिकारी मोड प्रयोगकर्ताहरूका लागि प्रमाणपत्रहरू बनाउन अधिकृत जारीकर्ताहरूका लागि हो।\n\nयस मोडका लागि आवश्यक:\n• YubiKey सँग अधिकारी प्रमाणीकरण\n• जारी गर्ने प्राधिकरणबाट अधिकार\n• प्रयोगकर्ताको पहिचानको भौतिक प्रमाणीकरण\n\nप्रक्रिया:\n१. अधिकारीको रूपमा प्रमाणित गर्नुहोस्\n२. प्रयोगकर्ताको आधिकारिक पहिचान प्रमाणित गर्नुहोस्\n३. प्रयोगकर्ताको जन्म मिति प्रविष्ट गर्नुहोस्\n४. प्रमाणीकरण QR कोड उत्पन्न गर्नुहोस्\n५. प्रयोगकर्ताले प्रमाणपत्र प्राप्त गर्न कोड स्क्यान गर्छ\n\nकेवल अधिकृत कर्मचारीहरूले यो मोड प्रयोग गर्नु पर्छ।";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "सबै पाठ ५०% ठूलो बनाउँछ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• देख्न कठिनाइ भएमा\n• पढ्न कठिन लाग्यो भने\n• ठूलो पाठ चाहिन्छ भने\n\nतपाईंको फोनको पाठ आकार सेटिङहरूसँग काम गर्छ।";
"help_text_contrast_level_simplified" = "पाठ कति गाढो छ भन्ने परिवर्तन गर्छ।\n\nतीन छनोटहरू:\n• मानक: सामान्य रङहरू\n• उच्च: सजिलो पढ्नका लागि गाढो पाठ\n• अधिकतम: सर्वोत्तम पढ्नका लागि अत्यन्त गाढो पाठ\n\nगाढो पाठ पढ्न सजिलो हुन्छ।";
"help_text_high_contrast_simplified" = "पाठ सजिलो देख्न बनाउँछ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• देख्न कठिनाइ भएमा\n• गाढो पाठ चाहिन्छ भने\n• उज्यालो प्रकाशमा एप प्रयोग गर्दा\n\nपाठ सेतोमा कालो हुन्छ।";
"help_text_reduce_transparency_simplified" = "धमिलो प्रभावहरू हटाउँछ।\n\nयसले:\n• पाठ स्पष्ट बनाउँछ\n• एप सरल बनाउँछ\n• पुराना फोनहरू छिटो बनाउँछ\n\nसबै कुरा बढी ठोस देखिन्छ।";
"help_text_color_blind_mode_simplified" = "तपाईंलाई राम्रो देख्न मद्दत गर्न रङहरू परिवर्तन गर्छ।\n\nछनोटहरू:\n• रातो-अन्धो मोड\n• हरियो-अन्धो मोड\n• नीलो-अन्धो मोड\n• केवल खैरो मोड\n\nमहत्वपूर्ण कुराहरू देख्न मद्दत गर्छ।";
"help_text_line_spacing_simplified" = "पाठका पङ्क्तिहरूबीचको खाली ठाउँ परिवर्तन गर्छ।\n\नतपाईं १.०x देखि २.०x सम्म छान्न सक्नुहुन्छ।\nपूर्वनिर्धारित १.०x हो।\n\nबढी खाली ठाउँले पढ्न सजिलो बनाउँछ।";
"help_text_paragraph_spacing_simplified" = "अनुच्छेदहरूबीचको खाली ठाउँ परिवर्तन गर्छ।\n\nतपाईं १.०x देखि ३.०x सम्म छान्न सक्नुहुन्छ।\nपूर्वनिर्धारित १.०x हो।\n\nबढी खाली ठाउँले नयाँ विचारहरू कहाँ सुरु हुन्छन् देख्न मद्दत गर्छ।";
"help_text_letter_spacing_simplified" = "अक्षरहरूबीचको खाली ठाउँ परिवर्तन गर्छ।\n\nतपाईं ०.० देखि ०.२ सम्म छान्न सक्नुहुन्छ।\nपूर्वनिर्धारित ०.० हो।\n\nबढी खाली ठाउँले अक्षरहरू स्पष्ट बनाउँछ।";
"help_text_text_width_simplified" = "पाठ कति चौडो छ भन्ने नियन्त्रण गर्छ।\n\nछनोटहरू:\n• पूर्ण चौडाइ: पूरा स्क्रिन प्रयोग गर्छ\n• मध्यम: पढ्नका लागि राम्रो\n• साँघुरो: ध्यान केन्द्रित गर्नका लागि सर्वोत्तम\n\nमध्यम चौडाइ पढ्न सबैभन्दा सजिलो छ।";
"help_text_large_touch_targets_simplified" = "सबै बटनहरू ठूला बनाउँछ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• साना बटनहरू ट्याप गर्न कठिनाइ भएमा\n• हातहरू हल्लाउँदा\n• पन्जा लगाउँदा\n• एक हात प्रयोग गर्दा\n\nबटनहरू ४४pt को सट्टामा ६०pt हुन्छन्।";
"help_text_reduce_motion_simplified" = "चल्ने एनिमेसनहरू हटाउँछ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• गतिले चक्कर लाग्छ भने\n• गतिबाट टाउको दुख्छ भने\n• कुराहरू स्थिर रहोस् भन्ने मन छ भने\n\nकुराहरू चल्नुको सट्टामा तत्काल परिवर्तन हुन्छन्।";
"help_text_timeout_behavior_simplified" = "कार्यहरू कति समय लिन सक्छन् भन्ने नियन्त्रण गर्छ।\n\nछनोटहरू:\n• कुनै सीमा छैन: कार्यहरू कहिल्यै रोकिँदैनन्\n• सामान्य: ३० सेकेन्ड\n• लामो: ६० सेकेन्ड\n\nबढी समय चाहिन्छ भने 'कुनै सीमा छैन' छान्नुहोस्।";
"help_text_simplified_gestures_simplified" = "कठिन हाउभाउहरूलाई साधारण ट्यापहरूले प्रतिस्थापन गर्छ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• जटिल स्पर्शहरूमा कठिनाइ भएमा\n• साधारण ट्याप मन पर्छ भने\n• एक हात प्रयोग गर्दा\n\nसबै कुरामा साधारण ट्याप प्रयोग हुन्छ।";
"help_text_haptic_feedback_simplified" = "ट्याप गर्दा फोन कम्पन गराउँछ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• बटन ट्याप गरेको कहिले जान्न\n• त्रुटिहरू वा चेतावनीहरू महसुस गर्न\n• नहेरीकन प्रतिक्रिया पाउन\n\nकम्पनहरू असुविधाजनक लाग्यो भने बन्द गर्नुहोस्।";
"help_text_simplified_ui_simplified" = "एप सरल बनाउँछ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• व्यस्त स्क्रिनहरूले भ्रम लाग्छ भने\n• सरल लेआउट मन पर्छ भने\n• एप नयाँ छ भने\n\nएकैचोटि कम कुराहरू देखाउँछ।";
"help_text_step_indicators_simplified" = "चरणहरूमा तपाईंको प्रगति देखाउँछ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• तपाईं कहाँ हुनुहुन्छ जान्न\n• कति चरणहरू बाँकी छन् हेर्न\n• व्यवस्थित रहन\n\nबिन्दुहरूसहित 'चरण १ मध्ये ३' देखाउँछ।";
"help_text_verbose_descriptions_simplified" = "तपाईंलाई बढी व्याख्याहरू दिन्छ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• सुविधाहरू बुझ्न\n• एप कसरी प्रयोग गर्ने सिक्न\n• बढी विवरणहरू चाहिन्छ भने\n\nहरतर्फ अतिरिक्त मद्दत प्रदान गर्छ।";
"help_text_confirm_actions_simplified" = "महत्वपूर्ण कार्यहरू पुष्टि गर्न सोध्छ।\n\nरोक्न मद्दत गर्छ:\n• आकस्मिक मेटाउने\n• अनपेक्षित परिवर्तनहरू\n• गल्तीहरू\n\nसधैं 'के तपाईं निश्चित हुनुहुन्छ?' सोधिनेछ।";
"help_text_manual_code_entry_simplified" = "स्क्यान गर्नुको सट्टामा कोडहरू टाइप गर्न दिन्छ।\n\nयो प्रयोग गर्नुहोस् जब:\n• तपाईंको क्यामेरा काम गर्दैन\n• कोड स्क्यान गर्न गाह्रो छ\n• टाइप गर्न मन पर्छ\n\nटाइप गर्न 'कोड म्यानुअल रूपमा प्रविष्ट गर्नुहोस्' ट्याप गर्नुहोस्।";
"help_text_voice_input_simplified" = "टाइप गर्नुको सट्टामा कोडहरू बोल्न दिन्छ।\n\nयदि तपाईंलाई मद्दत गर्छ:\n• टाइप गर्न कठिनाइ भएमा\n• बोल्न मन पर्छ भने\n• ह्यान्डस-फ्री प्रयोग चाहिन्छ भने\n\nमाइक्रोफोन ट्याप गर्नुहोस् र स्पष्ट रूपमा बोल्नुहोस्।";
"help_text_qr_scanning_simplified" = "वर्गाकार कोडहरू पढ्न तपाईंको क्यामेरा प्रयोग गर्छ।\n\nकसरी स्क्यान गर्ने:\n१. कोडमा क्यामेरा तेर्स्याउनुहोस्\n२. कोड लाइन अप गर्नुहोस्\n३. पढ्नको प्रतीक्षा गर्नुहोस्\n\nसुझावहरू:\n• राम्रो प्रकाश प्रयोग गर्नुहोस्\n• फोन स्थिर राख्नुहोस्\n• कोड सपाट राख्नुहोस्";
"help_text_age_verification_simplified" = "तपाईंको जन्मदिन साझा नगरी पर्याप्त उमेर भएको प्रमाणित गर्छ।\n\nयो कसरी काम गर्छ:\n१. व्यवसायले अनुरोध बनाउँछ\n२. तपाईंले कोड स्क्यान गर्नुहुन्छ\n३. एपले प्रमाण बनाउँछ\n४. व्यवसायले पर्याप्त उमेर भएको पुष्टि गर्छ\n\nतपाईंको जन्मदिन निजी रहन्छ।";
"help_text_credentials_simplified" = "तपाईंको फोनमा भण्डारण गरिएको उमेरको डिजिटल प्रमाण।\n\nसुविधाहरू:\n• केवल तपाईंको फोनमा\n• प्रतिलिपि गर्न सकिँदैन\n• तपाईंलाई निजी राख्छ\n• जुनसुकै बेला मेटाउन सकिन्छ\n\nसरकारी कार्यालयबाट प्राप्त गरिन्छ।";
"help_text_zero_knowledge_simplified" = "विवरणहरू साझा नगरी केही कुरा प्रमाणित गर्छ।\n\nउदाहरण:\n• पुरानो तरिका: पहिचान देखाउनुहोस् (सटीक जन्मदिन देखिन्छ)\n• नयाँ तरिका: १८ वर्षभन्दा माथि छ भनी प्रमाणित गर्नुहोस् (जन्मदिन निजी रहन्छ)\n\nयसले तपाईंको जानकारी निजी राख्छ।";
"help_text_credential_issuance_simplified" = "तपाईंको डिजिटल उमेर प्रमाण प्राप्त गर्दै।\n\nचरणहरू:\n१. सरकारी कार्यालयमा जानुहोस्\n२. पहिचान देखाउनुहोस्\n३. कोड पाउनुहोस्\n४. कोड स्क्यान गर्नुहोस्\n५. प्रमाण तपाईंको फोनमा सुरक्षित हुन्छ\n\nएकपटक गर्नुहोस्। त्यसपछि धेरैचोटि प्रयोग गर्नुहोस्।";
"help_text_officer_mode_simplified" = "सरकारी कामदारहरूका लागि प्रमाणहरू बनाउन।\n\nआवश्यकताहरू:\n• अधिकारी पासवर्ड\n• प्रयोग गर्ने अनुमति\n• जाँच गर्न प्रयोगकर्ताको पहिचान\n\nचरणहरू:\n१. अधिकारीको रूपमा लग इन गर्नुहोस्\n२. प्रयोगकर्ताको पहिचान जाँच गर्नुहोस्\n३. तिनीहरूको जन्मदिन प्रविष्ट गर्नुहोस्\n४. कोड बनाउनुहोस्\n५. प्रयोगकर्ताले कोड स्क्यान गर्छ\n\nकेवल अधिकृत कामदारहरूका लागि।";

