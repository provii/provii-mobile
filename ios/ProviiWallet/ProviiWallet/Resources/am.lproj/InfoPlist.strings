/* InfoPlist.strings - አማርኛ (Amharic) */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet ማረጋገጫ ሰነድ ለመቀበልና ዕድሜ ለማረጋገጥ QR ኮዶችን ለመቃኘት የካሜራ ተደራሽነት ያስፈልጋዋል።";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet ደህንነቱ የተጠበቀ የሹም ማረጋገጫ ለማድረግ YubiKey ዎ ጋር ለመገናኘት NFC ይጠቀማል።";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet የተደራሽነት ሁነታ ሲነቃ ድምፅ ትዕዛዞችን ለማስኬድ የንግግር ልየታ ይጠቀማል። ይህ አፕሊኬሽኑን ያለ ሁለቱ እጆች እርስዎ እንዲቆጣጠሩ ያስችላል።";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet የተደራሽነት ሁነታ ሲነቃ የድምፅ ቁጥጥር ባህሪያትን ለማስኬድ የማይክሮፎን ተደራሽነት ያስፈልጋዋል።";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet የዕድሜ ማረጋገጫ ሰነዶችዎን ደህንነቱ ተጠብቆ ለማግኘትና ማንነትዎን ለማረጋገጥ Face ID ይጠቀማል።";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet አቅራቢያ ያሉ ማረጋገጫ ሰነድ አሳዳሪዎችን ለማግኘት የአካባቢ ኔትወርክ ሊጠቀም ይችላል።";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet ከ YubiKey መሳሪያዎች ጋር ለመገናኘት Bluetooth ሊጠቀም ይችላል።";
