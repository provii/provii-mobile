/* InfoPlist.strings - Filipino (fil) */
/* Mga lokal na paglalarawan ng pahintulot para sa Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Kailangan po ng Provii Wallet ng access sa camera para mag-scan ng mga QR code para sa pagkuha ng kredensyal at beripikasyon ng edad.";

/* NFC Access */
"NFCReaderUsageDescription" = "Ginagamit po ng Provii Wallet ang NFC para makipag-ugnayan sa iyong YubiKey para sa ligtas na authentication ng opisyal.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Ginagamit po ng Provii Wallet ang speech recognition para sa mga voice command sa accessibility mode, na nagbibigay-daan sa iyo na kontrolin ang app nang hands-free.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Kailangan po ng Provii Wallet ng access sa mikropono para sa mga voice control feature kapag naka-enable ang accessibility mode.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Ginagamit po ng Provii Wallet ang Face ID para ligtas na ma-access ang iyong mga kredensyal ng edad at ma-verify ang iyong pagkakakilanlan.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Maaaring gumamit po ang Provii Wallet ng lokal na network para mahanap ang mga malapit na nagbibigay ng kredensyal.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Maaaring gumamit po ang Provii Wallet ng Bluetooth para makipag-ugnayan sa mga YubiKey device.";
