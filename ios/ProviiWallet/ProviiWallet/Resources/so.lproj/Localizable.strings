"help_text_extra_large_text" = "Qoraalka Aad u Weyn wuxuu korayaa dhammaan qoraalka app-ka 50%.\n\nTani waxay caawisaa isticmaalayaasha:\n• Aragga hoose\n• Dhibaatooyinka akhrinta\n• Isbeddelka aragga ee la xiriira da'da\n\nWaxay la shaqeysaa iOS Dynamic Type ee xajmiyada ka weyn.";
"help_text_contrast_level" = "Heerka Kala-duwanaanshaha wuxuu xukumaa kala-duwanaanshaha midabka u dhexeeya qoraalka iyo xagalka gadaashiisa.\n\nSaddex heer ayaa la heli karaa:\n• Caadi: Midabada default-ka\n• Sare (AA): Saamiga kala-duwanaanshaha 4.5:1 – waxay buuxineysaa heerarka AA\n• Ugu Sarreeya (AAA): Saamiga kala-duwanaanshaha 7:1 – waxay buuxineysaa heerarka ugu sarreeya AAA\n\nKala-duwanaanshaha sare wuxuu fududeeyaa akhrinta qoraalka xaaladaha iftiinka oo dhan.";
"help_text_high_contrast" = "Qaabka Kala-duwanaanshaha Sare wuxuu korayaa kala-duwanaanshaha u dhexeeya qoraalka iyo xagalka gadaashiisa, taas oo fududeynaysa akhrinta.\n\nTani waxay caawisaa isticmaalayaasha:\n• Aragga hoose\n• Xasaasiyadda midabka\n• Goobaha shaashadda ee iftiinka badan\n\nMarkaa la awood siiyay:\n• Qoraalku wuxuu noqdaa madow xigto cad\n• Xaddadaha ayaa lagu daraa curiyeyaasha\n• Midabada ayaa la fududeeyaa";
"help_text_reduce_transparency" = "Yaraynta Shafaafiyaanshaha waxay ka saartaa saameynta dhidibka iyo shafaafiyaanshaha app-ka oo dhan.\n\nTani waxay caawisaa:\n• Hormarinta akhrista qoraalka\n• Yareynta kharaashka muuqaalka\n• Korintaa waxsoosaarka aaladaha duqoobay\n• Ka dhigtaa macluumaadka wax fiicnaanshaha leh";
"help_text_color_blind_mode" = "Qaababka Indho-la'aanta Midabka waxay hagaajiyaan midabada noocyada kala duwan ee khaladka aragtida midabka.\n\nQaababka la heli karo:\n• Protanopia: Indho-la'aanta cas (dhibaato aragtida cas)\n• Deuteranopia: Indho-la'aanta cagaaran (dhibaato aragtida cagaaran)\n• Tritanopia: Indho-la'aanta buluug (dhibaato aragtida buluug)\n• Mid-midab: Carro-midab oo kaliya\n\nQaababkani waxay xaqiijinaan in macluumaadka muhiimka ah aan midab oo kaliya lagu gudbin.";
"help_text_line_spacing" = "Kala-fogaanshaha Safka wuxuu xukumaa meesha u dhexeeya safooyinka qoraalka.\n\n• Kala-duwanaanta: 1.0x ilaa 2.0x\n• Heerka AAA: 1.5x ugu yar\n• Default: 1.0x\n\nKala-fogaanshaha sare wuxuu fududeeyaa akhrinta wuxuuna ka hortagaa boocidda safka.";
"help_text_paragraph_spacing" = "Kala-fogaanshaha Cutubka wuxuu xukumaa meesha u dhexeeya cutubyadda.\n\n• Kala-duwanaanta: 1.0x ilaa 3.0x\n• Heerka AAA: 2.0x ugu yar\n• Default: 1.0x\n\nKala-fogaanshaha sare wuxuu caawisaa kala-soocista qeybaha kala duwan ee qoraalka.";
"help_text_letter_spacing" = "Kala-fogaanshaha Xarfaha wuxuu xukumaa meesha u dhexeeya xarfaha kala duwan.\n\n• Kala-duwanaanta: 0.0em ilaa 0.2em\n• Heerka AAA: 0.12em ugu yar\n• Default: 0.0em\n\nKala-fogaanshaha sare wuxuu hormariyaa aqoonsiga xarfaha iyo akhrista.";
"help_text_text_width" = "Ballaarada Qoraalka waxay xukumaanaa dhererka ugu badan ee safka ee akhrinta raaxada leh.\n\nDoorashooyin:\n• Ballaarada buuxda: Aan lahayn xad\n• Raaxo (80 xaraf): Ugu fiican akhrinta\n• Ciriiri (60 xaraf): Akhrinta xoojisan\n\nSharciyadda AAA waxay ku talinaan ugu badnaan 80 xaraf saff kasta.";
"help_text_large_touch_targets" = "Bartilmaameedyada Taabashada ee Waaweyn wuxuu dhammaan badhamo iyo curiyeyaasha isdhexgalka ugu yaraan 60 dhibicle.\n\nTani waxay caawisaa:\n• Naafada dhaqdhaqaaqa\n• Garaac ama gariirid\n• Isticmaalka app-ka oo leh gacmaha gashi\n• Isticmaalka hal gacmo\n\nKa yar ee caadiga ahu waa 44 dhibicle; dejintaan waxay korisaa 60 dhibicle.";
"help_text_reduce_motion" = "Yareynta Dhaqdhaqaaqa waxay yareeyaa ama ka saartaa dhaqdhaqaaqa app-ka oo dhan.\n\nTani waxay caawisaa isticmaalayaasha:\n• Xasaasiyadda dhaqdhaqaaqa\n• Cudurka vestibular\n• Epilepsy\n• Fara-xumo\n\nMarkaa la awood siiyay, dhaqdhaqaaqa ayaa lagu bedelaa wareeg degdeg ah.";
"help_text_timeout_behavior" = "Dabeecadda Waqtiga Dhammaadka waxay xukumaanaa mudada hawlgalinaha ka hor inta aysan dhicin.\n\nDoorashooyin:\n• Waqti Dhammaad Midna (AAA): Hawlgalinaha weligood kama dhammaanaan\n• Caadi (30s): Waqtiga dhammaadka default-ka\n• Balaarsan (60s): Laba jibaarka wakhtiga caadiga ah\n\nQaabka waqtiga dhammaadka la'aani wuxuu buuxineeyaa heerarka helitaanka AAA.";
"help_text_simplified_gestures" = "Geesinimada Fudud waxay yareeyaan geesinimada badan ee farta oo loo beddelaa taabashada fudud.\n\nTani waxay caawisaa:\n• Naafada dhaqdhaqaaqa\n• Xaddidnaanta xawaarada\n• Isticmaalka aaladaha caawinta\n• Hawlgalinta hal gacmo\n\nGeesinimada kharaashka badan ayaa lagu beddelaa badhamo iyo taabashada fudud.";
"help_text_haptic_feedback" = "Jawaabta Taabashada waxay bixisaa jawaabta gariirka ee ficilada iyo ogeysiisyada.\n\nTani waxay caawisaa:\n• Xaqiijinta riixidda badhanka\n• Ogeysiinta khaladaadka ama digniinaha\n• Bixinta jawaabta aan muuqaalka ahayn\n• Isticmaalayaasha qaba naafada maqalka ama aragga\n\nWaxaad dami kartaa haddii gariirku dhibaato yahay.";
"help_text_simplified_ui" = "Xudunta La Fududeeyay waxay yareysaa kharaashka muuqaalka app-ka oo dhan.\n\nTani waxay caawisaa:\n• Naafada garashada\n• Dhibaatooyinka barashada\n• Cudurka fekerida\n• Isticmaalayaasha cusub ama waaya-aragnimada yar\n\nMarkaa la awood siiyay:\n• Curiyeyaal yar oo shaashadda\n• Xukumaadka ka cad ee ka weyn\n• Cod muuqaal yar";
"help_text_step_indicators" = "Muuqaallada Tallaabada waxay muujiyaan horumarkaaga socdaalka badan ee tallaabada.\n\nTani waxay caawisaa:\n• Fahmida meesha aad ku jirto socodka\n• Garanaya tirada tallaabada hadhay\n• Yareynta kharaashka garashada\n• Bixinta qaab cad\n\nWaxay muujisaa 'Tallaabada X oo ka mid ah Y' oo leh dhibcaha horumarinta muuqaalka.";
"help_text_verbose_descriptions" = "Sharaxaadaha Faahfaahsan waxay bixisaa qoraalka sharaxaadda dheeraadka ah app-ka oo dhan.\n\nTani waxay caawisaa:\n• Fahmida astaamaha kharaashka badan\n• Barashada isticmaalka app-ka\n• Taageero garashada\n• Isticmaalayaasha akhristayaasha shaashadda\n\nWaxay bixisaa macluumaadka iyo tilmaamaha dhammaan astaamaha.";
"help_text_confirm_actions" = "Xaqiijinta Ficilada waxay waydiisaa xaqiijinta ka hor ficilada muhiimka ah.\n\nTani waxay ka hortagtaa:\n• Tirtiridda larbaadda\n• Isbeddelada aan la doonaynin\n• Gudbinta hore\n• Waayitaanka xogta\n\nXog-ogaynta: Ficilada burburinta had iyo jeer waxay u baahan tahay xaqiijin (shuruudda AAA).";
"help_text_manual_code_entry" = "Gelinta Koodhka Si Gacanta ah waxay kuu oggolaanaysaa inaad geliso koodhyada halkii aad ka sawiri lahayd koodhyada QR.\n\nTani waxay caawisaa marka:\n• Kamiradda kama shaqayneyso\n• Koodhka QR waa burburay ama aan cad ahayn\n• Isticmaalaya akhristaha shaashadda\n• Doorbidaya galkaa sawirista\n\nSahal ku taabo 'Gali koodhka si gacanta ah' oo geli koodhka muujiya shaashadda.";
"help_text_voice_input" = "Gelinta Codda waxay kuu oggolaanaysaa inaad ku hadashid koodhyada halkii aad ka sawiri lahayd ama gelin lahayd.\n\nTani waxay caawisaa:\n• Xaddidaanshaha dhaqdhaqaaqa\n• Isticmaalayaasha akhristayaasha shaashadda\n• Hawlgalinta gacanta ka xor\n• Doorbidhidda hadlida\n\nKu taabo badhanka maqaarka oo si cad u hadal marka la weydiiyoo.";
"help_text_qr_scanning" = "Sawirista Koodhka QR waxay isticmaashaa kamiradda si ay u akhriato koodhyada Jawaabta Degdegga ah.\n\nSida loo sawiro:\n1. U fiirso kamiradda koodhka QR\n2. Hagaaji koodhka fargeeyaha\n3. Sug ogaanshaha tooska ah\n\nTilmaamaha:\n• Xaqiiji iftiinka wanaagsan\n• Haysato aaladda si xasilloon\n• Haysato koodhka QR si toosan oo aan lahayn xadid\n• Haddii sawiristu fashilanto, isku day Gelinta Koodhka Si Gacanta ah";
"help_text_age_verification" = "Xaqiijinta Da'da waxay caddaysaa inaad buuxinayso shuruudda da'da adoon muujin da'daada dhab ah ama taariikhda dhalashadda.\n\nSida ay u shaqayso:\n1. Xaqiijiyuhu wuxuu abuuraa caqabad\n2. Waxaad sawirtaa koodhka QR ama si gacanta ah u gasho\n3. App-ku wuxuu abuuraa caddayn aqoon-la'aan\n4. Xaqiijiyuhu wuxuu xaqiijinayaa inaad buuxinayso shuruudda\n\nAsturnaanta la ilaalinayaa:\n• Taariikhda dhalashadda weligeed lama wadaagaan\n• Xaqiijiyuhu wuxuu ogaanayaa oo kaliya haddaad buuxinayso shuruudda\n• Raacidda ama ururinta xogta la'aan";
"help_text_credentials" = "Warqadaha Aqoonsiga ee Dijitaalka waa caddaymaha kriptograafi ee da'daada si ammaan ah loogu kaydiyay agabkaaga.\n\nAstaamaha:\n• Oo kaliya agabkaaga loo kaydiyay\n• Lama koobiyeeyan ama la been-abuuri karo\n• Loo isticmaalaa xaqiijinta xifaalinaysa asturnaanta\n• Waxaa tirtiri karo marka kasta\n\nWaa inaad hesho warqadda aqoonsiga bixiyaha la ogolaanshahay (sida xafiiska dowladda) ka hor inta aadan xaqiijin da'daada.";
"help_text_zero_knowledge" = "Caddaymaha Aqoon-la'aanu waxay kuu oggolaanaysaa inaad caddayso wax inay run tahay adoon muujin macluumaadka hoosta.\n\nTusaale:\n• Qaabka dhaqameed: Muuji ID (waxay muujisaa taariikhda dhalashadda saxda ah)\n• Nurowka aqoon-la'aanta: Caddee inaad ka weyn tahay 18 sano adoon muujin taariikhda dhalashadda\n\nFaa'iidooyinka:\n• Ilaalinta asturnaanta ugu sareysa\n• Xogta shakhsiga la'aan ee la wadaagay\n• Si kriptograafi ah loo ammaan yahay\n• Lama been-abuuri karo ama la ciyaari karo\n\nTani waa technologyada aasaasiga ah ee Provii Wallet gaarsiinaysa asturnaanta.";
"help_text_credential_issuance" = "Bixinta Warqadda Aqoonsiga waa socodka helista warqaddaada aqoonsiga da'da ee dijitaalka ah bixiyaha la ogolaanshahay.\n\nTallaabada:\n1. Booqo bixiyaha la ogolaanshahay (tusaale, xafiiska dowladda)\n2. Caddee aqoonsigaaga oo leh ID rasmi ah\n3. Hel koodh QR ama xiriir qoto dheer bixiyaha\n4. Sawir koodhka QR ama ku taabo xiriirka\n5. Warqadda aqoonsiga waxaa si maxalli ah loogu xisaabiyaa oo loogu kaydiyaa agabkaaga\n\nSocodka markhaatiga madaha wuxuu xaqiijiyaa in taariikhda dhalashadda aan weligeed la gudbinin shabakadda.\nMar kaliya oo kaliya ayaad u baahan tahay. Warqaddaada aqoonsiga ka dib waxaa loo isticmaali karaa xaqiijino aan xaddidnaynin.";
"help_text_officer_mode" = "Qaabka Sarkaalka waa bixiyeyaasha la ogolaanshahay ee abuuraya warqadaha aqoonsiga isticmaalayaasha.\n\nQaabkani wuxuu u baahan yahay:\n• Xaqiijinta sarkaalka oo leh YubiKey\n• Oggolaanshaha maamul bixinta\n• Xaqiijinta jireed ee ID isticmaalaha\n\nSocodka:\n1. Ku xaqiiji sarkaal\n2. Xaqiiji ID rasmi ah ee isticmaalaha\n3. Gali taariikhda dhalashadda isticmaalaha\n4. Samee koodhka QR ee markhaatiga\n5. Isticmaaluhu wuxuu sawiraa koodhka si uu u helayo warqadda aqoonsiga\n\nShakhsiyaadka la oggolaanshahay oo kaliya ayaa isticmaali kara qaabkan.";

/* Simplified Help Text (Reading Level: Grade 6-8) */
"help_text_extra_large_text_simplified" = "Waxay dhammaan qoraalka 50% ka weynaysiisaa.\n\nWaxay kaa caawisaa haddaad:\n• Dhibaato aragga ku qabto\n• Akhrinta adag u aragto\n• Qoraal weyn u baahan tahay\n\nWaxay la shaqeysaa goobaha cabbirka qoraalka telefoonkaaga.";
"help_text_contrast_level_simplified" = "Waxay beddeshaa gudna qoraalku yahay.\n\nSaddex doorasho:\n• Caadi: Midabada caadiga ah\n• Sare: Qoraal madow ee akhrinta fudud\n• Ugu Sarreeya: Qoraal aad u madow ee akhrinta ugu fiican\n\nQoraalka madow ayaa akhrinku ka fududahay.";
"help_text_high_contrast_simplified" = "Waxay fududeysaa aragga qoraalka.\n\nWaxay kaa caawisaa haddaad:\n• Dhibaato aragga ku qabto\n• Qoraal madow u baahan tahay\n• App-ka iftiinka badan ku isticmaasho\n\nQoraalku wuxuu noqdaa madow xigto cad.";
"help_text_reduce_transparency_simplified" = "Waxay ka saartaa saameynta dhidibka.\n\nTani waxay caawisaa:\n• Ka dhigida qoraalka cad\n• Fududeynta app-ka\n• Kor u qaadida telefoonada duqoobay\n\nWax walbaa si adag ayuu u muuqdaa.";
"help_text_color_blind_mode_simplified" = "Waxay beddeshaa midabada si aad si fiican u aragto.\n\nDoorashooyin:\n• Qaabka indho-la'aanta cas\n• Qaabka indho-la'aanta cagaaran\n• Qaabka indho-la'aanta buluug\n• Qaabka carro-midab oo kaliya\n\nWaxay kaa caawisaa aragtida waxyaabaha muhiimka ah.";
"help_text_line_spacing_simplified" = "Waxay beddeshaa meesha u dhexeysa safooyinka qoraalka.\n\nWaxaad u dhiibantahay 1.0x ilaa 2.0x.\nDefault waa 1.0x.\n\nMeel badan akhrista ayuu ka fududahay.";
"help_text_paragraph_spacing_simplified" = "Waxay beddeshaa meesha u dhexeysa cutubyadda.\n\nWaxaad u dhiibantahay 1.0x ilaa 3.0x.\nDefault waa 1.0x.\n\nMeel badan waxay kaa caawisaa aragtida meesha fikradda cusubi bilaabmayso.";
"help_text_letter_spacing_simplified" = "Waxay beddeshaa meesha u dhexeysa xarfaha.\n\nWaxaad u dhiibantahay 0.0 ilaa 0.2.\nDefault waa 0.0.\n\nMeel badan waxay xarfaha ka caddaysaa.";
"help_text_text_width_simplified" = "Waxay xukumaanaa gaaraanshaha qoraalka.\n\nDoorashooyin:\n• Ballaarada buuxda: Isticmaalaya shaashadda oo dhan\n• Dhexdhexaad: Ugu fiican akhrinta\n• Ciriiri: Ugu fiican xoojinta\n\nBallaarada dhexdhexaadku akhrinta ayuu ka fududahay.";
"help_text_large_touch_targets_simplified" = "Waxay dhammaan badhamo ka weynaysiisaa.\n\nWaxay kaa caawisaa haddaad:\n• Dhibaato ku qabto taabashada badhamo yar yar\n• Gacmo gariiraya leedahay\n• Gaashaanno gashatid\n• Hal gacmo isticmaalayso\n\nBadhamo waxay noqdaan 60 dhibicle halkii 44 dhibicle.";
"help_text_reduce_motion_simplified" = "Waxay ka saartaa dhaqdhaqaaqa dhaqdhaqaaqa.\n\nWaxay kaa caawisaa haddaad:\n• Dhaqdhaqaaqu ku xanuujiyaa\n• Madax xanuun kaa imanayaa dhaqdhaqaaqa\n• Doorbidayso waxyaabaha ku jira meesha\n\nWaxyaabuhu si degdeg ah ayay isu beddelaan halkii dhaqdhaqaaqa.";
"help_text_timeout_behavior_simplified" = "Waxay xukumaanaa mudada shaqooyinka qaadan karaan.\n\nDoorashooyin:\n• Xad la'aan: Shaqooyinhu weligood kama dhammaanaan\n• Caadi: 30 ilbiriqsi\n• Dheer: 60 ilbiriqsi\n\nDooro 'Xad la'aan' haddaad waqti dheeraad ah u baahan tahay.";
"help_text_simplified_gestures_simplified" = "Waxay ku beddelaa geesinimada adag taabashada fudud.\n\nWaxay kaa caawisaa haddaad:\n• Dhibaato ku qabto taabashada kharaashka badan\n• Doorbidayso taabashada fudud\n• Hal gacmo isticmaalayso\n\nWax walbaa isticmaala taabashada fudud.";
"help_text_haptic_feedback_simplified" = "Waxay telefoonkaaga gariirsiisaa marka aad taabato.\n\nWaxay kaa caawisaa:\n• Garanaysid marka aad taabatay badhan\n• Dareemista khaladaadka ama digniinaha\n• Hel jawaab adigoon eegaynin\n\nDami haddii gariirku kaa dhibayo.";
"help_text_simplified_ui_simplified" = "Waxay app-ka fududaysaa.\n\nWaxay kaa caawisaa haddaad:\n• Shaashadaha mashquulka ah adiga kaga xanuunsan tahay\n• Doorbidayso habdhismeedyada fudud\n• Cusub tahay app-ka\n\nMar waxay muujisaa waxyaabo yar.";
"help_text_step_indicators_simplified" = "Waxay muujisaa horumarkaaga tallaabada.\n\nWaxay kaa caawisaa:\n• Garanaysid meesha aad joogto\n• Aragtida tirada tallaabada hadhay\n• Ahaanshaha habaysan\n\nWaxay muujisaa 'Tallaabada 1 oo ka mid ah 3' oo leh dhibco.";
"help_text_verbose_descriptions_simplified" = "Waxay ku siin doontaa sharaxaadaha dheeraadka ah.\n\nWaxay kaa caawisaa:\n• Fahmida astaamaha\n• Barashada isticmaalka app-ka\n• Helista faahfaahinta dheeraadka ah\n\nWaxay bixisaa gargaarka dheeraadka ah meel kasta.";
"help_text_confirm_actions_simplified" = "Waxay kaa waydiisaa xaqiijinta ficilada muhiimka ah.\n\nWaxay ka hortagtaa:\n• Tirtiridda larbaadda\n• Isbeddelada aan la doonaynin\n• Khaladaadka\n\nWeligaa waxaa lagu waydiinayaa 'Ma hubtaa?'";
"help_text_manual_code_entry_simplified" = "Waxay kuu oggolaanaysaa galinta koodhyada halkii sawirista.\n\nIsticmaal marka:\n• Kamiradda kama shaqayneyso\n• Koodhka sawirka adag yahay\n• Doorbidayso galinta\n\nKu taabo 'Gali koodhka si gacanta ah' oo geli.";
"help_text_voice_input_simplified" = "Waxay kuu oggolaanaysaa inaad koodhyada ku hadashid halkii galinta.\n\nWaxay kaa caawisaa haddaad:\n• Dhibaato galinta ku qabto\n• Doorbidayso hadlida\n• Isticmaalka gacanta ka xor rabto\n\nKu taabo maqaarka oo si cad u hadal.";
"help_text_qr_scanning_simplified" = "Waxay isticmaashaa kamiradda si ay u akhriato koodhyada afarta geesha.\n\nSida loo sawiro:\n1. U fiirso kamiradda koodhka\n2. Hagaaji koodhka\n3. Sug inay akhriso\n\nTilmaamaha:\n• Isticmaal iftiinka wanaagsan\n• Telefoonka xasillo\n• Haysato koodhka si toosan";
"help_text_age_verification_simplified" = "Waxay caddaysaa inaad ku filan tahay da'da adoon wadaagaynin taariikhda dhalashadda.\n\nSida ay u shaqayso:\n1. Ganacsiyuhu wuxuu abuuraa codsiga\n2. Waxaad sawirtaa koodhkooda\n3. App-ku wuxuu abuuraa caddaynta\n4. Ganacsiyuhu wuxuu xaqiijinayaa inaad ku filan tahay da'da\n\nTaariikhda dhalashadda waxay ku jirtaa asturnaanta.";
"help_text_credentials_simplified" = "Caddaynta dijitaalka ah ee da'daada oo lagu kaydiyay telefoonkaaga.\n\nAstaamaha:\n• Oo kaliya telefoonkaaga ku jirta\n• Lama koobiyeyn karo\n• Asturnaantaada ilaalinaysa\n• Waxaad tirtiri kartaa marka kasta\n\nWaxaad ka heshaa xafiiska dowladda.";
"help_text_zero_knowledge_simplified" = "Waxay caddaysaa wax adoon wadaagaynin faahfaahinta.\n\nTusaale:\n• Qaabka duqoobay: Muuji ID-gaaga (waxay muujisaa taariikhda dhalashadda saxda ah)\n• Qaabka cusub: Caddee inaad ka weyn tahay 18 sano (taariikhda dhalashadda waxay ku jirtaa asturnaanta)\n\nTani waxay macluumaadkaaga ku ilaalinaysaa asturnaanta.";
"help_text_credential_issuance_simplified" = "Helista caddaynta dijitaalka ah ee da'daada.\n\nTallaabada:\n1. Tag xafiiska dowladda\n2. Muuji ID-gaaga\n3. Hel koodh\n4. Sawir koodhka\n5. Caddaynta waa lagu kaydiyay telefoonkaaga\n\nMar oo kaliya ku samee. Ka dib isticmaal mar badan.";
"help_text_officer_mode_simplified" = "Shaqaalaha dowladda ee abuuraya caddaymaha.\n\nU baahan yahay:\n• Erayga sirta sarkaalka\n• Oggolaanshaha isticmaalka\n• ID isticmaalaha si loo hubiyo\n\nTallaabada:\n1. Ku gal sarkaal\n2. Hubi ID isticmaalaha\n3. Gali taariikhda dhalashadda\n4. Samee koodh\n5. Isticmaaluhu wuxuu sawiraa koodhka\n\nShakhsiyaadka la oggolaanshahay oo kaliya.";

