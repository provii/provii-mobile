/* ==================== HELP TEXT DESCRIPTIONS ==================== */
"help_text_extra_large_text" = "Velmi velký text zvětší veškerý text v aplikaci o 50 %.\n\nUsnadňuje čtení textu uživatelům s:\n• Slabým zrakem\n• Obtížemi při čtení\n• Věkově podmíněnými změnami zraku\n\nFunguje s iOS Dynamic Type pro ještě větší velikosti.";
"help_text_contrast_level" = "Úroveň kontrastu ovládá kontrast barev mezi textem a pozadím.\n\nK dispozici jsou tři úrovně:\n• Standardní: Výchozí barvy\n• Vysoký (AA): Kontrastní poměr 4,5:1 – splňuje standardy AA\n• Maximální (AAA): Kontrastní poměr 7:1 – splňuje nejvyšší standardy AAA\n\nVyšší kontrast usnadňuje čtení textu ve všech světelných podmínkách.";
"help_text_high_contrast" = "Režim vysokého kontrastu zvyšuje kontrast mezi textem a pozadím, takže je snazší číst.\n\nUsnadňuje čtení uživatelům s:\n• Slabým zrakem\n• Citlivostí na barvy\n• Jasným prostředím obrazovky\n\nPo povolení:\n• Text je černý na bílém\n• K prvkům jsou přidány ohraničení\n• Barvy jsou zjednodušeny";
"help_text_reduce_transparency" = "Snížit průhlednost odebírá efekty rozostření a průhlednosti v celé aplikaci.\n\nPomáhá:\n• Zlepšit čitelnost textu\n• Snížit vizuální složitost\n• Zvýšit výkon na starších zařízeních\n• Učinit obsah předvídatelnějším";
"help_text_color_blind_mode" = "Režimy pro barvoslepé upravují barvy pro různé typy poruchy barvového vidění.\n\nDostupné režimy:\n• Protanopie: Červená slepota (obtíže s viděním červené)\n• Deuteranopie: Zelená slepota (obtíže s viděním zelené)\n• Tritanopie: Modrá slepota (obtíže s viděním modré)\n• Monochromatický: Pouze stupně šedé\n\nTyto režimy zajišťují, že důležité informace nejsou předávány pouze barvou.";
"help_text_line_spacing" = "Řádkování ovládá mezery mezi řádky textu.\n\n• Rozsah: 1,0× až 2,0×\n• Standard AAA: minimum 1,5×\n• Výchozí: 1,0×\n\nZvýšené řádkování usnadňuje čtení textu a pomáhá předcházet přeskakování řádků.";
"help_text_paragraph_spacing" = "Mezery odstavce ovládají mezery mezi odstavci.\n\n• Rozsah: 1,0× až 3,0×\n• Standard AAA: minimum 2,0×\n• Výchozí: 1,0×\n\nZvýšené mezery odstavce pomáhají rozlišovat mezi různými sekcemi textu.";
"help_text_letter_spacing" = "Prostrkání ovládá mezery mezi jednotlivými znaky.\n\n• Rozsah: 0,0 em až 0,2 em\n• Standard AAA: minimum 0,12 em\n• Výchozí: 0,0 em\n\nZvýšené prostrkání zlepšuje rozpoznávání znaků a čitelnost.";
"help_text_text_width" = "Šířka textu ovládá maximální délku řádku pro pohodlné čtení.\n\nMožnosti:\n• Plná šířka: Bez maxima\n• Pohodlná (80 znaků): Optimální pro čtení\n• Úzká (60 znaků): Pro soustředěné čtení\n\nPokyny AAA doporučují maximum 80 znaků na řádek.";
"help_text_large_touch_targets" = "Větší dotykové plochy zvětší všechna tlačítka a interaktivní prvky na velikost alespoň 60 bodů.\n\nUsnadňuje:\n• Motorická postižení\n• Třes nebo chvění\n• Používání aplikace s rukavicemi\n• Používání jednou rukou\n\nStandardní minimum je 44 bodů; toto nastavení zvyšuje na 60 bodů.";
"help_text_reduce_motion" = "Snížit pohyb minimalizuje nebo odstraňuje animace v celé aplikaci.\n\nUsnadňuje uživatelům s:\n• Citlivostí na pohyb\n• Vestibulárními poruchami\n• Epilepsií\n• Spouštěči migrény\n\nPo povolení jsou animace nahrazeny okamžitými přechody.";
"help_text_timeout_behavior" = "Chování časového limitu ovládá, jak dlouho mohou operace trvat před vypršením.\n\nMožnosti:\n• Bez časového limitu (AAA): Operace nikdy nevyprší\n• Standardní (30 s): Výchozí časový limit\n• Prodloužený (60 s): Dvojnásobek standardního času\n\nRežim bez časového limitu splňuje standardy přístupnosti AAA.";
"help_text_simplified_gestures" = "Zjednodušená gesta nahrazují složitá vícedotyková gesta jednoduchými klepnutími.\n\nUsnadňuje:\n• Motorická postižení\n• Omezenou obratnost\n• Používání asistenčních zařízení\n• Provoz jednou rukou\n\nSložitá gesta jsou nahrazena tlačítky a jednoduchými klepnutími.";
"help_text_haptic_feedback" = "Haptická zpětná vazba poskytuje vibrační zpětnou vazbu pro akce a oznámení.\n\nUsnadňuje:\n• Potvrzení stisknutí tlačítek\n• Upozornění na chyby nebo varování\n• Poskytování nevisuální zpětné vazby\n• Uživatele se sluchovým nebo zrakovým postižením\n\nMůžete to zakázat, pokud jsou vibrace nepříjemné.";
"help_text_simplified_ui" = "Zjednodušené rozhraní snižuje vizuální složitost v celé aplikaci.\n\nUsnadňuje:\n• Kognitivní postižení\n• Obtíže s učením\n• Poruchy pozornosti\n• Nové nebo nezkušené uživatele\n\nPo povolení:\n• Na obrazovce je méně prvků\n• Větší a čistší ovládací prvky\n• Méně vizuálního šumu";
"help_text_step_indicators" = "Indikátory kroků zobrazují průběh víceúrovňovými procesy.\n\nPomáhají:\n• Porozumět, kde v procesu se nacházíte\n• Vědět, kolik kroků zbývá\n• Snížit kognitivní zátěž\n• Poskytnout jasnou strukturu\n\nZobrazují „Krok X z Y” s vizuálními tečkami průběhu.";
"help_text_verbose_descriptions" = "Podrobné popisy poskytují doplňující vysvětlující text v celé aplikaci.\n\nUsnadňuje:\n• Porozumění složitým funkcím\n• Naučení se používat aplikaci\n• Kognitivní podporu\n• Uživatele čteček obrazovky\n\nPoskytuje kontext a pokyny pro všechny funkce.";
"help_text_confirm_actions" = "Potvrdit akce žádá o potvrzení před důležitými akcemi.\n\nPomáhá předcházet:\n• Náhodným smazáním\n• Nezamýšleným změnám\n• Předčasným odeslání\n• Ztrátě dat\n\nPoznámka: Destruktivní akce vždy vyžadují potvrzení (požadavek AAA).";
"help_text_manual_code_entry" = "Ruční zadání kódu umožňuje zadávat kódy místo skenování QR kódů.\n\nUsnadňuje, když:\n• Kamera nefunguje\n• QR kód je poškozený nebo nečitelný\n• Používáte čtečku obrazovky\n• Preferujete psaní před skenováním\n\nJednoduše klepněte na „Zadat kód ručně” a zadejte kód zobrazený na obrazovce.";
"help_text_voice_input" = "Hlasový vstup umožňuje mluvit kódy místo skenování nebo psaní.\n\nUsnadňuje:\n• Omezenou pohyblivost\n• Uživatele čteček obrazovky\n• Provoz bez rukou\n• Přednost hlasu\n\nKlepněte na tlačítko mikrofonu a mluvte zřetelně po výzvě.";
"help_text_qr_scanning" = "Skenování QR kódů používá kameru k čtení kódů Quick Response.\n\nJak skenovat:\n1. Namiřte kameru na QR kód\n2. Zarovnejte kód v rámečku\n3. Počkejte na automatické zjištění\n\nTipy:\n• Zajistěte dobré osvětlení\n• Držte zařízení v klidu\n• Udržujte QR kód plochý a bez překážek\n• Pokud skenování selže, zkuste ruční zadání kódu";
"help_text_age_verification" = "Ověření věku prokazuje, že splňujete věkový požadavek, aniž byste odhalili svůj skutečný věk nebo datum narození.\n\nJak to funguje:\n1. Ověřovatel vygeneruje výzvu\n2. Naskenujete QR kód nebo zadáte ručně\n3. Aplikace vytvoří důkaz s nulovou znalostí\n4. Ověřovatel potvrdí, že splňujete požadavek\n\nSoukromí chráněno:\n• Vaše datum narození není nikdy sdíleno\n• Ověřovatel se dozví pouze to, zda splňujete požadavek\n• Žádné sledování ani sběr dat";
"help_text_credentials" = "Digitální pověření jsou kryptografické důkazy vašeho věku bezpečně uložené ve vašem zařízení.\n\nVlastnosti:\n• Uloženo pouze ve vašem zařízení\n• Nelze kopírovat ani padělat\n• Používáno pro ověřování zachovávající soukromí\n• Lze kdykoli smazat\n\nPověření musíte získat od oprávněného vydavatele (například vládního úřadu), než budete moci ověřit svůj věk.";
"help_text_zero_knowledge" = "Důkazy s nulovou znalostí umožňují prokázat, že je něco pravda, aniž byste odhalili základní informace.\n\nPříklad:\n• Tradiční: Ukažte průkaz totožnosti (odhalí přesné datum narození)\n• Nulová znalost: Prokažte, že vám je přes 18 let bez ukázání data narození\n\nVýhody:\n• Maximální ochrana soukromí\n• Žádné osobní údaje nesdíleny\n• Kryptograficky zabezpečeno\n• Nelze padělat ani přehrát\n\nToto je základní technologie, která dělá Provii Wallet soukromým.";
"help_text_credential_issuance" = "Vydání pověření je proces získání digitálního věkového pověření od oprávněného vydavatele.\n\nKroky:\n1. Navštivte oprávněného vydavatele (například vládní úřad)\n2. Prokažte totožnost oficiálním průkazem\n3. Přijměte QR kód nebo přímý odkaz od vydavatele\n4. Naskenujte QR kód nebo klepněte na odkaz\n5. Pověření je vypočítáno lokálně a uloženo ve vašem zařízení\n\nProces slepého osvědčení zajišťuje, že vaše datum narození není nikdy přenášeno přes síť.\nStačí to udělat jednou. Pověření pak lze použít pro neomezený počet ověření.";
"help_text_officer_mode" = "Režim úředníka je určen pro oprávněné vydavatele k vytváření pověření pro uživatele.\n\nTento režim vyžaduje:\n• Ověřování úředníka pomocí YubiKey\n• Oprávnění od vydávajícího orgánu\n• Fyzické ověření průkazu totožnosti uživatele\n\nPostup:\n1. Ověřte se jako úředník\n2. Ověřte oficiální průkaz uživatele\n3. Zadejte datum narození uživatele\n4. Vygenerujte QR kód osvědčení\n5. Uživatel naskenuje kód pro přijetí pověření\n\nTento režim smí používat pouze oprávněný personál.";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "Zvětší veškerý text o 50 %.\n\nPomáhá vám, pokud:\n• Máte obtíže se zrakem\n• Čtení je pro vás těžké\n• Potřebujete větší text\n\nFunguje s nastavením velikosti textu vašeho telefonu.";
"help_text_contrast_level_simplified" = "Mění tmavost textu.\n\nTři možnosti:\n• Standardní: Normální barvy\n• Vysoký: Tmavší text pro snadné čtení\n• Maximální: Velmi tmavý text pro nejlepší čtení\n\nTmavší text se snadněji čte.";
"help_text_high_contrast_simplified" = "Usnadňuje čtení textu.\n\nPomáhá vám, pokud:\n• Máte obtíže se zrakem\n• Potřebujete tmavší text\n• Používáte aplikaci na jasném světle\n\nText je černý na bílém.";
"help_text_reduce_transparency_simplified" = "Odebírá rozmazané efekty.\n\nPomáhá:\n• Zpřehlednit text\n• Zjednodušit aplikaci\n• Zrychlit starší telefony\n\nVše vypadá pevněji.";
"help_text_color_blind_mode_simplified" = "Mění barvy, abyste lépe viděli.\n\nMožnosti:\n• Režim pro červenou slepotu\n• Režim pro zelenou slepotu\n• Režim pro modrou slepotu\n• Režim pouze stupně šedé\n\nPomáhá vám vidět důležité věci.";
"help_text_line_spacing_simplified" = "Mění mezery mezi řádky textu.\n\nMůžete vybrat od 1,0× do 2,0×.\nVýchozí je 1,0×.\n\nVíce mezer usnadňuje čtení.";
"help_text_paragraph_spacing_simplified" = "Mění mezery mezi odstavci.\n\nMůžete vybrat od 1,0× do 3,0×.\nVýchozí je 1,0×.\n\nVíce mezer pomáhá vidět, kde začínají nové myšlenky.";
"help_text_letter_spacing_simplified" = "Mění mezery mezi písmeny.\n\nMůžete vybrat od 0,0 do 0,2.\nVýchozí je 0,0.\n\nVíce mezer dělá písmena čitelnějšími.";
"help_text_text_width_simplified" = "Ovládá šířku textu.\n\nMožnosti:\n• Plná šířka: Využívá celou obrazovku\n• Střední: Dobré pro čtení\n• Úzká: Nejlepší pro soustředění\n\nStřední šířka se nejlépe čte.";
"help_text_large_touch_targets_simplified" = "Zvětší všechna tlačítka.\n\nPomáhá vám, pokud:\n• Máte obtíže s klepáním na malá tlačítka\n• Třesou se vám ruce\n• Nosíte rukavice\n• Používáte jednu ruku\n\nTlačítka se zvětší z 44 na 60 bodů.";
"help_text_reduce_motion_simplified" = "Odebírá pohyblivé animace.\n\nPomáhá vám, pokud:\n• Pohyb vám způsobuje závratě\n• Pohyb vám způsobuje bolesti hlavy\n• Preferujete klid\n\nVěci se mění okamžitě místo pohybu.";
"help_text_timeout_behavior_simplified" = "Ovládá, jak dlouho mohou úkoly trvat.\n\nMožnosti:\n• Bez limitu: Úkoly nikdy nevyprší\n• Normální: 30 sekund\n• Delší: 60 sekund\n\nVyberte „Bez limitu”, pokud potřebujete více času.";
"help_text_simplified_gestures_simplified" = "Nahrazuje těžká gesta jednoduchými klepnutími.\n\nPomáhá vám, pokud:\n• Máte obtíže se složitými dotyky\n• Preferujete jednoduchá klepnutí\n• Používáte jednu ruku\n\nVše používá jednoduchá klepnutí.";
"help_text_haptic_feedback_simplified" = "Při klepnutí vibruje telefon.\n\nPomáhá vám:\n• Vědět, že jste klepnuli na tlačítko\n• Cítit chyby nebo varování\n• Dostávat zpětnou vazbu bez pohledu\n\nVypněte, pokud vás vibrace ruší.";
"help_text_simplified_ui_simplified" = "Zjednodušuje aplikaci.\n\nPomáhá vám, pokud:\n• Vás matí přeplněné obrazovky\n• Preferujete jednoduché rozvržení\n• Jste nový uživatel aplikace\n\nNajednou zobrazuje méně věcí.";
"help_text_step_indicators_simplified" = "Zobrazuje váš průběh kroky.\n\nPomáhá vám:\n• Vědět, kde se nacházíte\n• Vidět, kolik kroků zbývá\n• Zůstat organizovaní\n\nZobrazuje „Krok 1 ze 3” s tečkami.";
"help_text_verbose_descriptions_simplified" = "Dává vám více vysvětlení.\n\nPomáhá vám:\n• Porozumět funkcím\n• Naučit se používat aplikaci\n• Získat více podrobností\n\nVšude poskytuje další pomoc.";
"help_text_confirm_actions_simplified" = "Ptá se vás na potvrzení důležitých akcí.\n\nPomáhá předcházet:\n• Náhodným smazáním\n• Nechtěným změnám\n• Chybám\n\nVždy se vás zeptáme „Jste si jisti?”";
"help_text_manual_code_entry_simplified" = "Umožňuje zadávat kódy místo skenování.\n\nPoužijte, když:\n• Vaše kamera nefunguje\n• Kód se těžko skenuje\n• Preferujete psaní\n\nKlepněte na „Zadat kód ručně” pro psaní.";
"help_text_voice_input_simplified" = "Umožňuje říkat kódy místo psaní.\n\nPomáhá vám, pokud:\n• Máte obtíže s psaním\n• Preferujete mluvení\n• Chcete používání bez rukou\n\nKlepněte na mikrofon a mluvte zřetelně.";
"help_text_qr_scanning_simplified" = "Používá kameru pro čtení čtvercových kódů.\n\nJak skenovat:\n1. Namiřte kameru na kód\n2. Zarovnejte kód\n3. Počkejte na přečtení\n\nTipy:\n• Použijte dobré osvětlení\n• Držte telefon v klidu\n• Udržujte kód plochý";
"help_text_age_verification_simplified" = "Prokazuje, že jste dostatečně staří bez sdílení data narození.\n\nJak to funguje:\n1. Podnik vytvoří žádost\n2. Naskenujete jejich kód\n3. Aplikace vytvoří důkaz\n4. Podnik potvrdí, že jste dostatečně staří\n\nVaše datum narození zůstane soukromé.";
"help_text_credentials_simplified" = "Digitální důkaz vašeho věku uložený ve vašem telefonu.\n\nVlastnosti:\n• Pouze ve vašem telefonu\n• Nelze kopírovat\n• Chrání vaše soukromí\n• Můžete kdykoli smazat\n\nZískáte ho od vládního úřadu.";
"help_text_zero_knowledge_simplified" = "Prokazuje něco bez sdílení podrobností.\n\nPříklad:\n• Starý způsob: Ukažte průkaz (ukáže přesné datum narození)\n• Nový způsob: Prokažte, že je vám přes 18 (datum narození zůstane soukromé)\n\nToto chrání vaše informace.";
"help_text_credential_issuance_simplified" = "Získání digitálního věkového důkazu.\n\nKroky:\n1. Jděte na vládní úřad\n2. Ukažte průkaz\n3. Získejte kód\n4. Naskenujte kód\n5. Důkaz se uloží do vašeho telefonu\n\nUdělejte to jednou. Pak to používejte mnohokrát.";
"help_text_officer_mode_simplified" = "Pro vládní pracovníky pro vytváření důkazů.\n\nVyžaduje:\n• Heslo úředníka\n• Oprávnění k použití\n• Průkaz totožnosti uživatele k ověření\n\nKroky:\n1. Přihlaste se jako úředník\n2. Ověřte průkaz uživatele\n3. Zadejte jeho datum narození\n4. Vytvořte kód\n5. Uživatel naskenuje kód\n\nPouze pro oprávněné pracovníky.";

