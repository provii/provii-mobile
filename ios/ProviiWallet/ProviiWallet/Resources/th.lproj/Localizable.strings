/* Help Text Descriptions */
"help_text_extra_large_text" = "ข้อความขนาดใหญ่พิเศษเพิ่มขนาดข้อความทั้งหมดในแอป 50%\n\nเป็นประโยชน์สำหรับผู้ใช้ที่มี:\n• สายตาบกพร่อง\n• ความยากในการอ่าน\n• การเปลี่ยนแปลงของสายตาตามวัย\n\nทำงานร่วมกับ iOS Dynamic Type สำหรับขนาดที่ใหญ่ขึ้น";
"help_text_contrast_level" = "ระดับคอนทราสต์ควบคุมคอนทราสต์สีระหว่างข้อความและพื้นหลัง\n\nมีสามระดับ:\n• มาตรฐาน: สีเริ่มต้น\n• สูง (AA): อัตราส่วนคอนทราสต์ 4.5:1\n• สูงสุด (AAA): อัตราส่วนคอนทราสต์ 7:1\n\nคอนทราสต์ที่สูงขึ้นทำให้อ่านข้อความได้ง่ายขึ้นในทุกสภาพแสง";
"help_text_high_contrast" = "โหมดคอนทราสต์สูงเพิ่มคอนทราสต์ระหว่างข้อความและพื้นหลัง ทำให้อ่านได้ง่ายขึ้น\n\nเป็นประโยชน์สำหรับผู้ใช้ที่มี:\n• สายตาบกพร่อง\n• ความไวต่อสี\n• สภาพแวดล้อมที่มีแสงสว่างจ้า\n\nเมื่อเปิดใช้งาน:\n• ข้อความกลายเป็นสีดำบนสีขาว\n• เพิ่มขอบให้กับองค์ประกอบ\n• สีถูกทำให้เรียบง่ายขึ้น";
"help_text_reduce_transparency" = "ลดความโปร่งใสลบเอฟเฟกต์เบลอและความโปร่งใสทั่วทั้งแอป\n\nช่วยในเรื่อง:\n• ปรับปรุงความสามารถในการอ่านข้อความ\n• ลดความซับซ้อนทางภาพ\n• เพิ่มประสิทธิภาพบนอุปกรณ์รุ่นเก่า\n• ทำให้เนื้อหาคาดเดาได้มากขึ้น";
"help_text_color_blind_mode" = "โหมดสำหรับผู้บกพร่องทางสีปรับสีสำหรับความบกพร่องในการมองเห็นสีประเภทต่างๆ\n\nโหมดที่มี:\n• Protanopia: บกพร่องสีแดง\n• Deuteranopia: บกพร่องสีเขียว\n• Tritanopia: บกพร่องสีน้ำเงิน\n• ขาวดำ: เฉพาะเฉดสีเทา\n\nโหมดเหล่านี้รับประกันว่าข้อมูลสำคัญจะไม่ถูกสื่อสารด้วยสีเพียงอย่างเดียว";
"help_text_line_spacing" = "ระยะห่างบรรทัดควบคุมระยะห่างระหว่างบรรทัดของข้อความ\n\n• ช่วง: 1.0x ถึง 2.0x\n• มาตรฐาน AAA: ขั้นต่ำ 1.5x\n• ค่าเริ่มต้น: 1.0x\n\nระยะห่างบรรทัดที่เพิ่มขึ้นทำให้อ่านข้อความได้ง่ายขึ้นและช่วยป้องกันการข้ามบรรทัด";
"help_text_paragraph_spacing" = "ระยะห่างย่อหน้าควบคุมระยะห่างระหว่างย่อหน้า\n\n• ช่วง: 1.0x ถึง 3.0x\n• มาตรฐาน AAA: ขั้นต่ำ 2.0x\n• ค่าเริ่มต้น: 1.0x\n\nระยะห่างย่อหน้าที่เพิ่มขึ้นช่วยแยกความแตกต่างระหว่างส่วนต่างๆ ของข้อความ";
"help_text_letter_spacing" = "ระยะห่างตัวอักษรควบคุมระยะห่างระหว่างตัวอักษรแต่ละตัว\n\n• ช่วง: 0.0em ถึง 0.2em\n• มาตรฐาน AAA: ขั้นต่ำ 0.12em\n• ค่าเริ่มต้น: 0.0em\n\nระยะห่างตัวอักษรที่เพิ่มขึ้นปรับปรุงการรู้จำตัวอักษรและความสามารถในการอ่าน";
"help_text_text_width" = "ความกว้างข้อความควบคุมความยาวบรรทัดสูงสุดสำหรับการอ่านที่สบาย\n\nตัวเลือก:\n• ความกว้างเต็ม: ไม่มีขีดจำกัด\n• สะดวกสบาย (80 ตัวอักษร): ดีที่สุดสำหรับการอ่าน\n• แคบ (60 ตัวอักษร): สำหรับการอ่านที่มีสมาธิ\n\nคำแนะนำ AAA แนะนำให้ใช้สูงสุด 80 ตัวอักษรต่อบรรทัด";
"help_text_large_touch_targets" = "เป้าหมายการสัมผัสที่ใหญ่ขึ้นทำให้ปุ่มและองค์ประกอบโต้ตอบทั้งหมดมีขนาดอย่างน้อย 60pt\n\nเป็นประโยชน์สำหรับ:\n• ความบกพร่องทางการเคลื่อนไหว\n• อาการสั่นหรือสั่นไหว\n• การใช้แอปกับถุงมือ\n• การใช้มือเดียว\n\nขั้นต่ำมาตรฐานคือ 44pt การตั้งค่านี้เพิ่มเป็น 60pt";
"help_text_reduce_motion" = "ลดการเคลื่อนไหวลดหรือลบแอนิเมชันทั่วทั้งแอป\n\nเป็นประโยชน์สำหรับผู้ใช้ที่มี:\n• ความไวต่อการเคลื่อนไหว\n• ความผิดปกติของระบบการทรงตัว\n• โรคลมชัก\n• ปัจจัยกระตุ้นไมเกรน\n\nเมื่อเปิดใช้งาน แอนิเมชันจะถูกแทนที่ด้วยการเปลี่ยนผ่านทันที";
"help_text_timeout_behavior" = "ลักษณะการหมดเวลาควบคุมระยะเวลาที่การดำเนินการสามารถทำได้ก่อนหมดเวลา\n\nตัวเลือก:\n• ไม่หมดเวลา (AAA): การดำเนินการไม่มีวันหมดเวลา\n• มาตรฐาน (30 วินาที): หมดเวลาเริ่มต้น\n• ขยาย (60 วินาที): สองเท่าของเวลามาตรฐาน\n\nโหมดไม่หมดเวลาตรงตามมาตรฐานการช่วยเหลือการเข้าถึง AAA";
"help_text_simplified_gestures" = "ท่าทางที่เรียบง่ายลดท่าทางที่ซับซ้อนหลายนิ้วให้เป็นการแตะง่ายๆ\n\nเป็นประโยชน์สำหรับ:\n• ความบกพร่องทางการเคลื่อนไหว\n• ความคล่องแคล่วจำกัด\n• การใช้อุปกรณ์ช่วยเหลือ\n• การใช้มือเดียว\n\nท่าทางที่ซับซ้อนจะถูกแทนที่ด้วยปุ่มและการแตะง่ายๆ";
"help_text_haptic_feedback" = "การสั่นสะเทือนตอบสนองให้การสั่นสำหรับการดำเนินการและการแจ้งเตือน\n\nเป็นประโยชน์สำหรับ:\n• ยืนยันการกดปุ่ม\n• แจ้งเตือนข้อผิดพลาดหรือคำเตือน\n• ให้การตอบสนองที่ไม่ใช่ภาพ\n• ผู้ใช้ที่มีความบกพร่องทางการได้ยินหรือการมองเห็น\n\nท่านสามารถปิดใช้งานได้หากการสั่นทำให้รู้สึกไม่สบาย";
"help_text_simplified_ui" = "อินเทอร์เฟซที่เรียบง่ายลดความซับซ้อนทางภาพทั่วทั้งแอป\n\nเป็นประโยชน์สำหรับ:\n• ความบกพร่องทางสมรรถนะการรับรู้\n• ความยากในการเรียนรู้\n• ความผิดปกติด้านความสนใจ\n• ผู้ใช้ใหม่หรือไม่มีประสบการณ์\n\nเมื่อเปิดใช้งาน:\n• องค์ประกอบน้อยลงบนหน้าจอ\n• ตัวควบคุมที่ใหญ่และชัดเจนกว่า\n• สิ่งรบกวนทางภาพน้อยลง";
"help_text_step_indicators" = "ตัวบ่งชี้ขั้นตอนแสดงความคืบหน้าของท่านผ่านกระบวนการหลายขั้นตอน\n\nช่วยในเรื่อง:\n• เข้าใจว่าท่านอยู่ที่ไหนในกระบวนการ\n• รู้ว่าเหลือขั้นตอนอีกกี่ขั้น\n• ลดภาระทางสมรรถนะการรับรู้\n• ให้โครงสร้างที่ชัดเจน\n\nแสดง 'ขั้นตอน X จาก Y' พร้อมจุดความคืบหน้าทางภาพ";
"help_text_verbose_descriptions" = "คำอธิบายโดยละเอียดให้ข้อความอธิบายเพิ่มเติมทั่วทั้งแอป\n\nเป็นประโยชน์สำหรับ:\n• เข้าใจคุณสมบัติที่ซับซ้อน\n• เรียนรู้วิธีใช้แอป\n• การสนับสนุนด้านสมรรถนะการรับรู้\n• ผู้ใช้โปรแกรมอ่านหน้าจอ\n\nให้บริบทและคำแนะนำสำหรับคุณสมบัติทั้งหมด";
"help_text_confirm_actions" = "ยืนยันการดำเนินการขอการยืนยันก่อนดำเนินการสำคัญ\n\nช่วยป้องกัน:\n• การลบโดยไม่ตั้งใจ\n• การเปลี่ยนแปลงที่ไม่ตั้งใจ\n• การส่งก่อนกำหนด\n• การสูญหายของข้อมูล\n\nหมายเหตุ: การดำเนินการที่ทำลายข้อมูลจะต้องยืนยันเสมอ (ข้อกำหนด AAA)";
"help_text_manual_code_entry" = "การกรอกรหัสด้วยตนเองช่วยให้ท่านพิมพ์รหัสแทนการสแกนรหัส QR\n\nเป็นประโยชน์เมื่อ:\n• กล้องไม่ทำงาน\n• รหัส QR เสียหายหรือไม่ชัดเจน\n• ใช้โปรแกรมอ่านหน้าจอ\n• ชอบพิมพ์มากกว่าการสแกน\n\nเพียงแตะ 'กรอกรหัสด้วยตนเอง' เพื่อพิมพ์รหัสที่แสดงบนหน้าจอ";
"help_text_voice_input" = "การป้อนด้วยเสียงช่วยให้ท่านพูดรหัสแทนการสแกนหรือพิมพ์\n\nเป็นประโยชน์สำหรับ:\n• การเคลื่อนไหวจำกัด\n• ผู้ใช้โปรแกรมอ่านหน้าจอ\n• การทำงานแบบมือเปล่า\n• ความชอบด้านเสียง\n\nแตะปุ่มไมโครโฟนและพูดให้ชัดเจนเมื่อได้รับการแจ้ง";
"help_text_qr_scanning" = "การสแกนรหัส QR ใช้กล้องของท่านเพื่ออ่านรหัสตอบสนองด่วน\n\nวิธีสแกน:\n1. หันกล้องไปที่รหัส QR\n2. จัดรหัสในกรอบ\n3. รอการตรวจจับอัตโนมัติ\n\nเคล็ดลับ:\n• ตรวจสอบให้แน่ใจว่ามีแสงสว่างเพียงพอ\n• ถืออุปกรณ์ให้นิ่ง\n• ทำให้รหัส QR แบนและไม่มีสิ่งกีดขวาง\n• หากการสแกนล้มเหลว ลองใช้การกรอกรหัสด้วยตนเอง";
"help_text_age_verification" = "การยืนยันอายุพิสูจน์ว่าท่านตรงตามข้อกำหนดด้านอายุโดยไม่เปิดเผยอายุจริงหรือวันเดือนปีเกิดของท่าน\n\nวิธีการทำงาน:\n1. ผู้ยืนยันสร้างชาเลนจ์\n2. ท่านสแกนรหัส QR หรือกรอกด้วยตนเอง\n3. แอปสร้างการพิสูจน์แบบไม่เปิดเผยความรู้\n4. ผู้ยืนยันยืนยันว่าท่านตรงตามข้อกำหนด\n\nการคุ้มครองความเป็นส่วนตัว:\n• วันเดือนปีเกิดของท่านจะไม่ถูกแบ่งปันเด็ดขาด\n• ผู้ยืนยันจะทราบเพียงว่าท่านตรงตามข้อกำหนดหรือไม่\n• ไม่มีการติดตามหรือเก็บรวบรวมข้อมูล";
"help_text_credentials" = "ข้อมูลรับรองดิจิทัลคือหลักฐานการเข้ารหัสของอายุท่านที่เก็บไว้อย่างปลอดภัยบนอุปกรณ์ของท่าน\n\nคุณสมบัติ:\n• เก็บไว้เฉพาะบนอุปกรณ์ของท่าน\n• ไม่สามารถคัดลอกหรือปลอมแปลงได้\n• ใช้สำหรับการยืนยันที่รักษาความเป็นส่วนตัว\n• สามารถลบได้ทุกเมื่อ\n\nท่านต้องขอรับข้อมูลรับรองจากผู้ออกที่ได้รับอนุญาต (เช่น สำนักงานรัฐบาล) ก่อนที่จะสามารถยืนยันอายุของท่านได้";
"help_text_zero_knowledge" = "การพิสูจน์แบบไม่เปิดเผยความรู้ช่วยให้ท่านพิสูจน์ว่าบางสิ่งเป็นความจริงโดยไม่เปิดเผยข้อมูลพื้นฐาน\n\nตัวอย่าง:\n• วิธีดั้งเดิม: แสดง ID (เปิดเผยวันเกิดที่แน่ชัด)\n• แบบไม่เปิดเผยความรู้: พิสูจน์ว่าอายุมากกว่า 18 ปีโดยไม่แสดงวันเกิด\n\nประโยชน์:\n• การคุ้มครองความเป็นส่วนตัวสูงสุด\n• ไม่มีการแบ่งปันข้อมูลส่วนตัว\n• ปลอดภัยด้วยการเข้ารหัส\n• ไม่สามารถปลอมแปลงหรือเล่นซ้ำได้\n\nนี่คือเทคโนโลยีหลักที่ทำให้ Provii Wallet เป็นส่วนตัว";
"help_text_credential_issuance" = "การออกข้อมูลรับรองคือกระบวนการรับข้อมูลรับรองอายุดิจิทัลจากผู้ออกที่ได้รับอนุญาต\n\nขั้นตอน:\n1. เยี่ยมชมผู้ออกที่ได้รับอนุญาต (เช่น สำนักงานรัฐบาล)\n2. พิสูจน์ตัวตนด้วยบัตรประจำตัวอย่างเป็นทางการ\n3. รับรหัส QR หรือ deep link จากผู้ออก\n4. สแกนรหัส QR หรือแตะลิงก์\n5. ข้อมูลรับรองจะถูกคำนวณในเครื่องและเก็บไว้บนอุปกรณ์ของท่าน\n\nกระบวนการรับรองแบบปิดตารับประกันว่าวันเดือนปีเกิดของท่านจะไม่ถูกส่งผ่านเครือข่าย\nท่านจำเป็นต้องทำสิ่งนี้เพียงครั้งเดียว จากนั้นข้อมูลรับรองของท่านสามารถใช้สำหรับการยืนยันได้ไม่จำกัดครั้ง";
"help_text_officer_mode" = "โหมดเจ้าหน้าที่สำหรับผู้ออกที่ได้รับอนุญาตในการสร้างข้อมูลรับรองสำหรับผู้ใช้\n\nโหมดนี้ต้องการ:\n• การยืนยันตัวตนเจ้าหน้าที่ด้วย YubiKey\n• การอนุญาตจากหน่วยงานออก\n• การยืนยันตัวตนทางกายภาพของ ID ผู้ใช้\n\nกระบวนการ:\n1. ยืนยันตัวตนในฐานะเจ้าหน้าที่\n2. ยืนยัน ID อย่างเป็นทางการของผู้ใช้\n3. กรอกวันเดือนปีเกิดของผู้ใช้\n4. สร้างรหัส QR สำหรับการรับรอง\n5. ผู้ใช้สแกนรหัสเพื่อรับข้อมูลรับรอง\n\nเฉพาะบุคลากรที่ได้รับอนุญาตเท่านั้นที่ควรใช้โหมดนี้";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "ทำให้ข้อความทั้งหมดใหญ่ขึ้น 50%\n\nช่วยท่านหากท่าน:\n• มีปัญหาในการมองเห็น\n• พบว่าการอ่านยาก\n• ต้องการข้อความที่ใหญ่กว่า\n\nทำงานร่วมกับการตั้งค่าขนาดข้อความของโทรศัพท์";
"help_text_contrast_level_simplified" = "เปลี่ยนความเข้มของข้อความ\n\nสามตัวเลือก:\n• มาตรฐาน: สีปกติ\n• สูง: ข้อความเข้มกว่าสำหรับการอ่านที่ง่าย\n• สูงสุด: ข้อความเข้มมากสำหรับการอ่านที่ดีที่สุด\n\nข้อความที่เข้มกว่าอ่านได้ง่ายกว่า";
"help_text_high_contrast_simplified" = "ทำให้มองเห็นข้อความได้ง่ายขึ้น\n\nช่วยท่านหากท่าน:\n• มีปัญหาในการมองเห็น\n• ต้องการข้อความที่เข้มกว่า\n• ใช้แอปในที่มีแสงสว่างจ้า\n\nข้อความกลายเป็นสีดำบนสีขาว";
"help_text_reduce_transparency_simplified" = "ลบเอฟเฟกต์เบลอ\n\nช่วยในเรื่อง:\n• ทำข้อความให้ชัดเจนขึ้น\n• ทำให้แอปเรียบง่ายขึ้น\n• เพิ่มความเร็วโทรศัพท์รุ่นเก่า\n\nทุกอย่างดูแข็งแกร่งกว่า";
"help_text_color_blind_mode_simplified" = "เปลี่ยนสีเพื่อช่วยให้มองเห็นได้ดีขึ้น\n\nตัวเลือก:\n• โหมดบกพร่องสีแดง\n• โหมดบกพร่องสีเขียว\n• โหมดบกพร่องสีน้ำเงิน\n• โหมดสีเทาเท่านั้น\n\nช่วยให้มองเห็นสิ่งสำคัญ";
"help_text_line_spacing_simplified" = "เปลี่ยนระยะห่างระหว่างบรรทัดของข้อความ\n\nท่านสามารถเลือกจาก 1.0x ถึง 2.0x\nค่าเริ่มต้นคือ 1.0x\n\nระยะห่างมากขึ้นทำให้อ่านได้ง่ายขึ้น";
"help_text_paragraph_spacing_simplified" = "เปลี่ยนระยะห่างระหว่างย่อหน้า\n\nท่านสามารถเลือกจาก 1.0x ถึง 3.0x\nค่าเริ่มต้นคือ 1.0x\n\nระยะห่างมากขึ้นช่วยให้เห็นว่าแนวคิดใหม่เริ่มต้นที่ไหน";
"help_text_letter_spacing_simplified" = "เปลี่ยนระยะห่างระหว่างตัวอักษร\n\nท่านสามารถเลือกจาก 0.0 ถึง 0.2\nค่าเริ่มต้นคือ 0.0\n\nระยะห่างมากขึ้นทำให้ตัวอักษรชัดเจนขึ้น";
"help_text_text_width_simplified" = "ควบคุมความกว้างของข้อความ\n\nตัวเลือก:\n• ความกว้างเต็ม: ใช้หน้าจอทั้งหมด\n• กลาง: ดีสำหรับการอ่าน\n• แคบ: ดีที่สุดสำหรับการมีสมาธิ\n\nความกว้างกลางอ่านได้ง่ายที่สุด";
"help_text_large_touch_targets_simplified" = "ทำให้ปุ่มทั้งหมดใหญ่ขึ้น\n\nช่วยท่านหากท่าน:\n• มีปัญหาในการแตะปุ่มเล็กๆ\n• มือสั่น\n• สวมถุงมือ\n• ใช้มือเดียว\n\nปุ่มกลายเป็น 60pt แทน 44pt";
"help_text_reduce_motion_simplified" = "ลบแอนิเมชันที่เคลื่อนไหว\n\nช่วยท่านหาก:\n• การเคลื่อนไหวทำให้ท่านมึนงง\n• ท่านปวดหัวจากการเคลื่อนไหว\n• ท่านต้องการให้สิ่งต่างๆ อยู่นิ่ง\n\nสิ่งต่างๆ เปลี่ยนทันทีแทนที่จะเคลื่อนไหว";
"help_text_timeout_behavior_simplified" = "ควบคุมว่างานสามารถใช้เวลานานเท่าไร\n\nตัวเลือก:\n• ไม่มีขีดจำกัด: งานไม่มีวันหยุด\n• ปกติ: 30 วินาที\n• นานกว่า: 60 วินาที\n\nเลือก 'ไม่มีขีดจำกัด' หากท่านต้องการเวลามากขึ้น";
"help_text_simplified_gestures_simplified" = "แทนที่ท่าทางยากด้วยการแตะง่ายๆ\n\nช่วยท่านหากท่าน:\n• มีปัญหากับการสัมผัสที่ซับซ้อน\n• ชอบการแตะง่ายๆ\n• ใช้มือเดียว\n\nทุกอย่างใช้การแตะง่ายๆ";
"help_text_haptic_feedback_simplified" = "ทำให้โทรศัพท์ของท่านสั่นเมื่อท่านแตะ\n\nช่วยท่าน:\n• รู้ว่าท่านแตะปุ่มหรือไม่\n• รู้สึกถึงข้อผิดพลาดหรือคำเตือน\n• รับการตอบสนองโดยไม่ต้องมอง\n\nปิดใช้งานหากการสั่นทำให้รู้สึกไม่สบาย";
"help_text_simplified_ui_simplified" = "ทำให้แอปเรียบง่ายขึ้น\n\nช่วยท่านหากท่าน:\n• สับสนกับหน้าจอที่ยุ่งเหยิง\n• ชอบเลย์เอาต์ที่เรียบง่าย\n• เพิ่งเริ่มใช้แอป\n\nแสดงสิ่งต่างๆ น้อยลงในคราวเดียว";
"help_text_step_indicators_simplified" = "แสดงความคืบหน้าของท่านผ่านขั้นตอน\n\nช่วยท่าน:\n• รู้ว่าท่านอยู่ที่ไหน\n• เห็นว่าเหลือขั้นตอนอีกกี่ขั้น\n• รักษาความเป็นระเบียบ\n\nแสดง 'ขั้นตอนที่ 1 จาก 3' พร้อมจุด";
"help_text_verbose_descriptions_simplified" = "ให้คำอธิบายเพิ่มเติม\n\nช่วยท่าน:\n• เข้าใจคุณสมบัติ\n• เรียนรู้วิธีใช้แอป\n• รับรายละเอียดเพิ่มเติม\n\nให้ความช่วยเหลือพิเศษทุกที่";
"help_text_confirm_actions_simplified" = "ถามให้ยืนยันการดำเนินการสำคัญ\n\nช่วยป้องกัน:\n• การลบโดยไม่ตั้งใจ\n• การเปลี่ยนแปลงที่ไม่ต้องการ\n• ความผิดพลาด\n\nท่านจะถูกถามเสมอว่า 'แน่ใจหรือไม่'";
"help_text_manual_code_entry_simplified" = "ให้ท่านพิมพ์รหัสแทนการสแกน\n\nใช้เมื่อ:\n• กล้องของท่านไม่ทำงาน\n• รหัสสแกนได้ยาก\n• ท่านชอบพิมพ์\n\nแตะ 'กรอกรหัสด้วยตนเอง' เพื่อพิมพ์";
"help_text_voice_input_simplified" = "ให้ท่านพูดรหัสแทนการพิมพ์\n\nช่วยท่านหากท่าน:\n• มีปัญหาในการพิมพ์\n• ชอบการพูด\n• ต้องการการใช้งานแบบมือเปล่า\n\nแตะไมโครโฟนและพูดให้ชัดเจน";
"help_text_qr_scanning_simplified" = "ใช้กล้องของท่านเพื่ออ่านรหัสสี่เหลี่ยม\n\nวิธีสแกน:\n1. หันกล้องไปที่รหัส\n2. จัดรหัสให้ตรง\n3. รอให้อ่าน\n\nเคล็ดลับ:\n• ใช้แสงสว่างที่ดี\n• ถือโทรศัพท์ให้นิ่ง\n• ทำให้รหัสแบน";
"help_text_age_verification_simplified" = "พิสูจน์ว่าท่านมีอายุเพียงพอโดยไม่แบ่งปันวันเกิดของท่าน\n\nวิธีการทำงาน:\n1. ธุรกิจสร้างคำขอ\n2. ท่านสแกนรหัสของพวกเขา\n3. แอปสร้างหลักฐาน\n4. ธุรกิจยืนยันว่าท่านมีอายุเพียงพอ\n\nวันเกิดของท่านยังคงเป็นส่วนตัว";
"help_text_credentials_simplified" = "หลักฐานดิจิทัลของอายุท่านที่เก็บไว้บนโทรศัพท์ของท่าน\n\nคุณสมบัติ:\n• เฉพาะบนโทรศัพท์ของท่านเท่านั้น\n• ไม่สามารถคัดลอกได้\n• รักษาความเป็นส่วนตัวของท่าน\n• ท่านสามารถลบได้ทุกเมื่อ\n\nท่านได้รับจากสำนักงานรัฐบาล";
"help_text_zero_knowledge_simplified" = "พิสูจน์บางสิ่งโดยไม่แบ่งปันรายละเอียด\n\nตัวอย่าง:\n• วิธีเก่า: แสดง ID ของท่าน (แสดงวันเกิดที่แน่ชัด)\n• วิธีใหม่: พิสูจน์ว่าท่านมีอายุมากกว่า 18 ปี (วันเกิดยังคงเป็นส่วนตัว)\n\nวิธีนี้รักษาความเป็นส่วนตัวของข้อมูลท่าน";
"help_text_credential_issuance_simplified" = "การรับหลักฐานอายุดิจิทัลของท่าน\n\nขั้นตอน:\n1. ไปที่สำนักงานรัฐบาล\n2. แสดง ID ของท่าน\n3. รับรหัส\n4. สแกนรหัส\n5. หลักฐานถูกบันทึกบนโทรศัพท์ของท่าน\n\nทำสิ่งนี้ครั้งเดียว จากนั้นใช้หลายครั้ง";
"help_text_officer_mode_simplified" = "สำหรับเจ้าหน้าที่รัฐบาลในการสร้างหลักฐาน\n\nต้องการ:\n• รหัสผ่านเจ้าหน้าที่\n• สิทธิ์ในการใช้\n• ID ของผู้ใช้เพื่อตรวจสอบ\n\nขั้นตอน:\n1. ลงชื่อเข้าใช้เป็นเจ้าหน้าที่\n2. ตรวจสอบ ID ของผู้ใช้\n3. กรอกวันเกิดของผู้ใช้\n4. สร้างรหัส\n5. ผู้ใช้สแกนรหัส\n\nสำหรับเจ้าหน้าที่ที่ได้รับอนุญาตเท่านั้น";

