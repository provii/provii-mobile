<?xml version="1.0" encoding="utf-8"?>
<!--
    MASVS-STORAGE-1: Data extraction rules for Android 12+ (API 31+)
    Ensures encrypted SharedPreferences and wallet data are not extracted during backup or transfer
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude entire app root to prevent any sensitive data leaking via backup -->
        <exclude domain="root" path="."/>
        <!-- Exclude all encrypted SharedPreferences (contain sensitive wallet data) -->
        <exclude domain="sharedpref" path="provii_pin_prefs.xml"/>
        <exclude domain="sharedpref" path="wallet_prefs_encrypted.xml"/>
        <exclude domain="sharedpref" path="wallet_environment.xml"/>
        <!-- MASVS-CODE-1: Exclude privacy preferences (EncryptedSharedPreferences) -->
        <exclude domain="sharedpref" path="privacy_preferences_secure.xml"/>
        <!-- Exclude secure preferences manager storage -->
        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <!-- Exclude native keystore manager storage -->
        <exclude domain="sharedpref" path="native_keystore_prefs.xml"/>
        <!-- Exclude data preservation manager (encrypted form data) -->
        <exclude domain="sharedpref" path="data_preservation_secure.xml"/>
        <!-- Exclude deep link nonce tracking (EncryptedSharedPreferences) -->
        <exclude domain="sharedpref" path="provii_deeplink_nonces.xml"/>
        <!-- Exclude secure wallet storage (EncryptedSharedPreferences) -->
        <exclude domain="sharedpref" path="provii_wallet_secure.xml"/>
        <!-- Exclude session storage (EncryptedSharedPreferences) -->
        <exclude domain="sharedpref" path="provii_wallet_session.xml"/>
        <!-- Exclude wallet database -->
        <exclude domain="database" path="wallet.db"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude entire app root to prevent any sensitive data leaking via device transfer -->
        <exclude domain="root" path="."/>
        <!-- Exclude all encrypted SharedPreferences (contain sensitive wallet data) -->
        <exclude domain="sharedpref" path="provii_pin_prefs.xml"/>
        <exclude domain="sharedpref" path="wallet_prefs_encrypted.xml"/>
        <exclude domain="sharedpref" path="wallet_environment.xml"/>
        <!-- MASVS-CODE-1: Exclude privacy preferences (EncryptedSharedPreferences) -->
        <exclude domain="sharedpref" path="privacy_preferences_secure.xml"/>
        <!-- Exclude secure preferences manager storage -->
        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <!-- Exclude native keystore manager storage -->
        <exclude domain="sharedpref" path="native_keystore_prefs.xml"/>
        <!-- Exclude data preservation manager (encrypted form data) -->
        <exclude domain="sharedpref" path="data_preservation_secure.xml"/>
        <!-- Exclude deep link nonce tracking (EncryptedSharedPreferences) -->
        <exclude domain="sharedpref" path="provii_deeplink_nonces.xml"/>
        <!-- Exclude secure wallet storage (EncryptedSharedPreferences) -->
        <exclude domain="sharedpref" path="provii_wallet_secure.xml"/>
        <!-- Exclude session storage (EncryptedSharedPreferences) -->
        <exclude domain="sharedpref" path="provii_wallet_session.xml"/>
        <!-- Exclude wallet database -->
        <exclude domain="database" path="wallet.db"/>
    </device-transfer>
</data-extraction-rules>
