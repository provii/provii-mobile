/* InfoPlist.strings - Tamil */
/* Localised permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "சான்றுச்சீட்டு பெறுதல் மற்றும் வயது சரிபார்ப்புக்கான QR குறியீடுகளை ஸ்கேன் செய்ய Provii Wallet-க்கு கேமரா அணுகல் தேவை.";

/* NFC Access */
"NFCReaderUsageDescription" = "பாதுகாப்பான அதிகாரி அங்கீகாரத்திற்காக உங்கள் YubiKey-உடன் தொடர்பு கொள்ள Provii Wallet NFC-ஐப் பயன்படுத்துகிறது.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "அணுகல்தன்மை பயன்முறையில் குரல் கட்டளைகளுக்கு Provii Wallet பேச்சு அங்கீகாரத்தைப் பயன்படுத்துகிறது, கைகள் இல்லாமல் பயன்பாட்டை கட்டுப்படுத்த உங்களை அனுமதிக்கிறது.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "அணுகல்தன்மை பயன்முறை இயக்கப்பட்டிருக்கும்போது குரல் கட்டுப்பாடு அம்சங்களுக்கு Provii Wallet-க்கு மைக்ரோஃபோன் அணுகல் தேவை.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "உங்கள் வயது சான்றுச்சீட்டுகளை பாதுகாப்பாக அணுக மற்றும் உங்கள் அடையாளத்தை சரிபார்க்க Provii Wallet Face ID-ஐப் பயன்படுத்துகிறது.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "அருகிலுள்ள சான்றுச்சீட்டு வழங்குநர்களைக் கண்டறிய Provii Wallet உள்ளூர் நெட்வொர்க்கை பயன்படுத்தலாம்.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "YubiKey சாதனங்களுடன் தொடர்பு கொள்ள Provii Wallet Bluetooth-ஐ பயன்படுத்தலாம்.";
