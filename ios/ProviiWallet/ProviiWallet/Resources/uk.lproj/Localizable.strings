// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Дуже великий текст збільшує весь текст у додатку на 50%.\n\nЦе корисно для користувачів з:\n• Ослабленим зором\n• Труднощами з читанням\n• Віковими змінами зору\n\nПрацює з динамічним розміром тексту iOS для ще більших розмірів.";
"help_text_contrast_level" = "Рівень контрастності керує контрастністю між текстом і фоном.\n\nДоступні три рівні:\n• Стандартний: кольори за замовчуванням\n• Високий (AA): коефіцієнт контрастності 4,5:1 , відповідає стандартам AA\n• Максимальний (AAA): коефіцієнт контрастності 7:1 , відповідає найвищим стандартам AAA\n\nВища контрастність полегшує читання тексту за будь-яких умов освітлення.";
"help_text_high_contrast" = "Режим високої контрастності підвищує контрастність між текстом і фоном, полегшуючи читання.\n\nЦе корисно для користувачів з:\n• Ослабленим зором\n• Чутливістю до кольору\n• Яскравим оточенням\n\nПри увімкненні:\n• Текст стає чорним на білому\n• До елементів додаються межі\n• Кольори спрощуються";
"help_text_reduce_transparency" = "Зменшення прозорості прибирає ефекти розмиття та прозорості в усьому додатку.\n\nЦе допомагає:\n• Покращити читабельність тексту\n• Зменшити візуальну складність\n• Підвищити продуктивність на старіших пристроях\n• Зробити вміст більш передбачуваним";
"help_text_color_blind_mode" = "Режими для людей з порушенням кольоросприйняття налаштовують кольори для різних типів порушення кольорового зору.\n\nДоступні режими:\n• Протанопія: сліпота до червоного (труднощі з баченням червоного)\n• Дейтеранопія: сліпота до зеленого (труднощі з баченням зеленого)\n• Тританопія: сліпота до синього (труднощі з баченням синього)\n• Монохромний: лише відтінки сірого\n\nЦі режими гарантують, що важлива інформація не передається лише через колір.";
"help_text_line_spacing" = "Міжрядковий інтервал керує відстанню між рядками тексту.\n\n• Діапазон: від 1,0x до 2,0x\n• Стандарт AAA: мінімум 1,5x\n• За замовчуванням: 1,0x\n\nЗбільшений міжрядковий інтервал полегшує читання тексту та допомагає запобігти пропуску рядків.";
"help_text_paragraph_spacing" = "Міжабзацний інтервал керує відстанню між абзацами.\n\n• Діапазон: від 1,0x до 3,0x\n• Стандарт AAA: мінімум 2,0x\n• За замовчуванням: 1,0x\n\nЗбільшений міжабзацний інтервал допомагає розрізняти різні розділи тексту.";
"help_text_letter_spacing" = "Міжлітерний інтервал керує відстанню між окремими символами.\n\n• Діапазон: від 0,0em до 0,2em\n• Стандарт AAA: мінімум 0,12em\n• За замовчуванням: 0,0em\n\nЗбільшений міжлітерний інтервал покращує розпізнавання символів і читабельність.";
"help_text_text_width" = "Ширина тексту керує максимальною довжиною рядка для комфортного читання.\n\nПараметри:\n• Повна ширина: без максимуму\n• Комфортна (80 символів): оптимально для читання\n• Вузька (60 символів): для зосередженого читання\n\nРекомендації AAA: максимум 80 символів на рядок.";
"help_text_large_touch_targets" = "Більші зони дотику збільшують усі кнопки та інтерактивні елементи щонайменше до 60 пт.\n\nЦе корисно для:\n• Порушень моторики\n• Тремору або тремтіння\n• Використання додатку в рукавичках\n• Використання однією рукою\n\nСтандартний мінімум , 44 пт; цей параметр збільшує до 60 пт.";
"help_text_reduce_motion" = "Зменшення руху мінімізує або прибирає анімацію в усьому додатку.\n\nЦе корисно для користувачів з:\n• Чутливістю до руху\n• Вестибулярними розладами\n• Епілепсією\n• Тригерами мігрені\n\nПри увімкненні анімація замінюється миттєвими переходами.";
"help_text_timeout_behavior" = "Поведінка тайм-ауту керує тим, скільки часу операції можуть тривати перед закінченням.\n\nПараметри:\n• Без тайм-ауту (AAA): операції ніколи не закінчуються\n• Стандартний (30 с): тайм-аут за замовчуванням\n• Збільшений (60 с): подвійний стандартний час\n\nРежим без тайм-ауту відповідає стандартам доступності AAA.";
"help_text_simplified_gestures" = "Спрощені жести замінюють складні мультитачові жести простими торканнями.\n\nЦе корисно для:\n• Порушень моторики\n• Обмеженої спритності\n• Використання допоміжних пристроїв\n• Роботи однією рукою\n\nСкладні жести замінюються кнопками та простими торканнями.";
"help_text_haptic_feedback" = "Тактильний відгук надає вібраційний відгук для дій та сповіщень.\n\nЦе корисно для:\n• Підтвердження натискань кнопок\n• Сигналізації про помилки або попередження\n• Надання невізуального відгуку\n• Користувачів із порушеннями слуху або зору\n\nВи можете вимкнути це, якщо вібрація викликає дискомфорт.";
"help_text_simplified_ui" = "Спрощений інтерфейс зменшує візуальну складність у всьому додатку.\n\nЦе корисно для:\n• Когнітивних порушень\n• Труднощів з навчанням\n• Розладів уваги\n• Нових або недосвідчених користувачів\n\nПри увімкненні:\n• Менше елементів на екрані\n• Більші, чіткіші елементи керування\n• Менше візуального шуму";
"help_text_step_indicators" = "Індикатори кроків показують Ваш прогрес у багатокрокових процесах.\n\nЦе допомагає:\n• Розуміти, де Ви знаходитеся в процесі\n• Знати, скільки кроків залишилося\n• Зменшити когнітивне навантаження\n• Забезпечити чітку структуру\n\nПоказує «Крок X з Y» з візуальними точками прогресу.";
"help_text_verbose_descriptions" = "Детальні описи надають додатковий пояснювальний текст у всьому додатку.\n\nЦе корисно для:\n• Розуміння складних функцій\n• Вивчення роботи додатку\n• Когнітивної підтримки\n• Користувачів зчитувача екрана\n\nНадає контекст та інструкції для всіх функцій.";
"help_text_confirm_actions" = "Підтвердження дій запитує підтвердження перед важливими діями.\n\nЦе допомагає запобігти:\n• Випадковому видаленню\n• Ненавмисним змінам\n• Передчасному надсиланню\n• Втраті даних\n\nПримітка: деструктивні дії завжди вимагають підтвердження (вимога AAA).";
"help_text_manual_code_entry" = "Ручне введення коду дозволяє вводити коди замість сканування QR-кодів.\n\nЦе корисно, коли:\n• Камера не працює\n• QR-код пошкоджено або нечіткий\n• Використовується зчитувач екрана\n• Надаєте перевагу введенню тексту перед скануванням\n\nПросто натисніть «Ввести код вручну» для введення коду, показаного на екрані.";
"help_text_voice_input" = "Голосове введення дозволяє вимовляти коди замість сканування або введення тексту.\n\nЦе корисно для:\n• Обмеженої рухливості\n• Користувачів зчитувача екрана\n• Роботи без використання рук\n• Уподобання голосу\n\nНатисніть кнопку мікрофона та чітко говоріть за підказкою.";
"help_text_qr_scanning" = "Сканування QR-коду використовує камеру для зчитування QR-кодів.\n\nЯк сканувати:\n1. Направте камеру на QR-код\n2. Вирівняйте код у рамці\n3. Зачекайте на автоматичне виявлення\n\nПоради:\n• Забезпечте гарне освітлення\n• Тримайте пристрій нерухомо\n• Тримайте QR-код рівно без перешкод\n• Якщо сканування не вдається, спробуйте ручне введення коду";
"help_text_age_verification" = "Верифікація віку доводить, що Ви відповідаєте віковій вимозі, не розкриваючи фактичний вік або дату народження.\n\nЯк це працює:\n1. Верифікатор генерує виклик\n2. Ви сканируєте QR-код або вводите вручну\n3. Додаток створює доказ з нульовим розголошенням\n4. Верифікатор підтверджує, що Ви відповідаєте вимозі\n\nКонфіденційність захищена:\n• Ваша дата народження ніколи не передається\n• Верифікатор дізнається лише про те, чи відповідаєте Ви вимозі\n• Без відстеження або збору даних";
"help_text_credentials" = "Цифрові посвідчення , це криптографічні докази Вашого віку, надійно збережені на Вашому пристрої.\n\nОсобливості:\n• Зберігаються лише на Вашому пристрої\n• Не можуть бути скопійовані або підроблені\n• Використовуються для верифікації зі збереженням конфіденційності\n• Можна видалити в будь-який час\n\nВи повинні отримати посвідчення від авторизованого видавця (наприклад, державного органу) перед тим, як підтверджувати вік.";
"help_text_zero_knowledge" = "Докази з нульовим розголошенням дозволяють довести, що щось є правдою, не розкриваючи основної інформації.\n\nПриклад:\n• Традиційно: показати посвідчення особи (розкриває точну дату народження)\n• З нульовим розголошенням: довести, що Вам більше 18 років, не показуючи дату народження\n\nПереваги:\n• Максимальний захист конфіденційності\n• Жодних особистих даних не передається\n• Криптографічно захищено\n• Не можна підробити або повторно використати\n\nЦе основна технологія, що робить Provii Wallet приватним.";
"help_text_credential_issuance" = "Видача посвідчення , це процес отримання Вашого цифрового вікового посвідчення від авторизованого видавця.\n\nКроки:\n1. Відвідайте авторизованого видавця (наприклад, державний орган)\n2. Підтвердьте особу офіційним документом\n3. Отримайте QR-код або посилання від видавця\n4. Відскануйте QR-код або натисніть посилання\n5. Посвідчення обчислюється локально та зберігається на Вашому пристрої\n\nПроцес сліпої атестації гарантує, що Ваша дата народження ніколи не передається по мережі.\nЦе потрібно зробити лише один раз. Потім Ваше посвідчення можна використовувати для необмеженої кількості верифікацій.";
"help_text_officer_mode" = "Режим службовця призначений для авторизованих видавців для створення посвідчень для користувачів.\n\nЦей режим вимагає:\n• Автентифікації службовця за допомогою YubiKey\n• Авторизації від органу, що видає\n• Фізичної верифікації документа, що посвідчує особу користувача\n\nПроцес:\n1. Автентифікуйтеся як службовець\n2. Перевірте офіційний документ користувача\n3. Введіть дату народження користувача\n4. Згенеруйте атестаційний QR-код\n5. Користувач сканує код для отримання посвідчення\n\nЦей режим мають використовувати лише авторизовані особи.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Робить весь текст на 50% більшим.\n\nДопомагає Вам, якщо Ви:\n• Маєте труднощі з баченням\n• Вважаєте читання складним\n• Потребуєте більшого тексту\n\nПрацює з налаштуваннями розміру тексту Вашого телефону.";

"help_text_contrast_level_simplified" = "Змінює насиченість тексту.\n\nТри варіанти:\n• Стандартний: звичайні кольори\n• Високий: темніший текст для легкого читання\n• Максимальний: дуже темний текст для найкращого читання\n\nТемніший текст легше читати.";

"help_text_high_contrast_simplified" = "Робить текст легшим для сприйняття.\n\nДопомагає Вам, якщо Ви:\n• Маєте труднощі з баченням\n• Потребуєте темнішого тексту\n• Використовуєте додаток при яскравому освітленні\n\nТекст стає чорним на білому.";

"help_text_reduce_transparency_simplified" = "Прибирає ефекти розмиття.\n\nЦе допомагає:\n• Зробити текст чіткішим\n• Спростити додаток\n• Прискорити старіші телефони\n\nВсе виглядає більш суцільним.";

"help_text_color_blind_mode_simplified" = "Змінює кольори, щоб допомогти Вам краще бачити.\n\nВаріанти:\n• Режим сліпоти до червоного\n• Режим сліпоти до зеленого\n• Режим сліпоти до синього\n• Лише сірий\n\nДопомагає Вам бачити важливі речі.";

"help_text_line_spacing_simplified" = "Змінює відстань між рядками тексту.\n\nВи можете обрати від 1,0x до 2,0x.\nЗа замовчуванням , 1,0x.\n\nБільша відстань полегшує читання.";

"help_text_paragraph_spacing_simplified" = "Змінює відстань між абзацами.\n\nВи можете обрати від 1,0x до 3,0x.\nЗа замовчуванням , 1,0x.\n\nБільша відстань допомагає бачити, де починаються нові ідеї.";

"help_text_letter_spacing_simplified" = "Змінює відстань між літерами.\n\nВи можете обрати від 0,0 до 0,2.\nЗа замовчуванням , 0,0.\n\nБільша відстань робить літери чіткішими.";

"help_text_text_width_simplified" = "Керує шириною тексту.\n\nВаріанти:\n• Повна ширина: використовує весь екран\n• Середня: добре для читання\n• Вузька: найкраще для зосередження\n\nСередня ширина найлегша для читання.";

"help_text_large_touch_targets_simplified" = "Робить усі кнопки більшими.\n\nДопомагає Вам, якщо Ви:\n• Маєте труднощі з натисканням малих кнопок\n• Маєте тремтячі руки\n• Носите рукавички\n• Використовуєте одну руку\n\nКнопки стають 60 пт замість 44 пт.";

"help_text_reduce_motion_simplified" = "Прибирає рухомі анімації.\n\nДопомагає Вам, якщо:\n• Рух викликає запаморочення\n• Рух спричиняє головний біль\n• Ви надаєте перевагу нерухомим речам\n\nРечі змінюються миттєво замість руху.";

"help_text_timeout_behavior_simplified" = "Керує тим, скільки часу можуть займати завдання.\n\nВаріанти:\n• Без ліміту: завдання ніколи не зупиняються\n• Звичайний: 30 секунд\n• Довший: 60 секунд\n\nОберіть «Без ліміту», якщо Вам потрібно більше часу.";

"help_text_simplified_gestures_simplified" = "Замінює складні жести простими торканнями.\n\nДопомагає Вам, якщо Ви:\n• Маєте труднощі зі складними торканнями\n• Надаєте перевагу простим торканням\n• Використовуєте одну руку\n\nВсе використовує прості торкання.";

"help_text_haptic_feedback_simplified" = "Змушує телефон вібрувати при торканні.\n\nДопомагає Вам:\n• Знати, коли Ви натиснули кнопку\n• Відчувати помилки або попередження\n• Отримувати відгук без погляду\n\nВимкніть, якщо вібрація заважає.";

"help_text_simplified_ui_simplified" = "Спрощує додаток.\n\nДопомагає Вам, якщо Ви:\n• Плутаєтеся через завантажені екрани\n• Надаєте перевагу простим макетам\n• Вперше користуєтеся додатком\n\nПоказує менше речей одночасно.";

"help_text_step_indicators_simplified" = "Показує Ваш прогрес у кроках.\n\nДопомагає Вам:\n• Знати, де Ви знаходитеся\n• Бачити, скільки кроків залишилося\n• Залишатися організованим\n\nПоказує «Крок 1 з 3» з точками.";

"help_text_verbose_descriptions_simplified" = "Дає Вам більше пояснень.\n\nДопомагає Вам:\n• Розуміти функції\n• Навчитися користуватися додатком\n• Отримувати більше деталей\n\nНадає додаткову допомогу всюди.";

"help_text_confirm_actions_simplified" = "Запитує Вас підтвердити важливі дії.\n\nДопомагає запобігти:\n• Випадковому видаленню\n• Небажаним змінам\n• Помилкам\n\nВас завжди запитуватимуть «Ви впевнені?»";

"help_text_manual_code_entry_simplified" = "Дозволяє вводити коди замість сканування.\n\nВикористовуйте це, коли:\n• Ваша камера не працює\n• Код важко сканувати\n• Ви надаєте перевагу введенню тексту\n\nНатисніть «Ввести код вручну» для введення.";

"help_text_voice_input_simplified" = "Дозволяє вимовляти коди замість введення.\n\nДопомагає Вам, якщо Ви:\n• Маєте труднощі з введенням тексту\n• Надаєте перевагу розмові\n• Хочете роботу без рук\n\nНатисніть мікрофон і говоріть чітко.";

"help_text_qr_scanning_simplified" = "Використовує камеру для зчитування квадратних кодів.\n\nЯк сканувати:\n1. Направте камеру на код\n2. Вирівняйте код\n3. Зачекайте, поки він зчитається\n\nПоради:\n• Використовуйте гарне освітлення\n• Тримайте телефон нерухомо\n• Тримайте код рівно";

"help_text_age_verification_simplified" = "Доводить, що Ви достатньо дорослі, не розкриваючи дату народження.\n\nЯк це працює:\n1. Заклад створює запит\n2. Ви сканируєте їхній код\n3. Додаток створює доказ\n4. Заклад підтверджує, що Ви достатньо дорослі\n\nВаша дата народження залишається приватною.";

"help_text_credentials_simplified" = "Цифровий доказ Вашого віку, збережений на Вашому телефоні.\n\nОсобливості:\n• Лише на Вашому телефоні\n• Не можна скопіювати\n• Зберігає приватність\n• Ви можете видалити будь-коли\n\nВи отримуєте його від державного органу.";

"help_text_zero_knowledge_simplified" = "Доводить щось, не розкриваючи деталей.\n\nПриклад:\n• Старий спосіб: показати посвідчення (показує точну дату народження)\n• Новий спосіб: довести, що Вам більше 18 (дата народження залишається приватною)\n\nЦе зберігає Вашу інформацію приватною.";

"help_text_credential_issuance_simplified" = "Отримання цифрового доказу Вашого віку.\n\nКроки:\n1. Йдіть до державного органу\n2. Покажіть Ваше посвідчення особи\n3. Отримайте код\n4. Відскануйте код\n5. Доказ зберігається на Вашому телефоні\n\nЗробіть це один раз. Потім використовуйте багато разів.";

"help_text_officer_mode_simplified" = "Для державних службовців для створення доказів.\n\nПотрібно:\n• Пароль службовця\n• Дозвіл на використання\n• Посвідчення особи користувача для перевірки\n\nКроки:\n1. Увійдіть як службовець\n2. Перевірте посвідчення особи користувача\n3. Введіть їхню дату народження\n4. Створіть код\n5. Користувач сканує код\n\nЛише для авторизованих службовців.";

