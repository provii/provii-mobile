"help_text_high_contrast" = "उच्च कॉन्ट्रास्ट मोड मजकूर आणि पार्श्वभूमी यांच्यातील कॉन्ट्रास्ट वाढवतो, वाचणे सोपे करतो.\n\nहे यांच्यासाठी उपयुक्त आहे:\n• कमी दृष्टी\n• रंग संवेदनशीलता\n• तेजस्वी स्क्रीन वातावरण\n\nसक्षम असताना:\n• मजकूर पांढऱ्यावर काळा होतो\n• घटकांना सीमा जोडल्या जातात\n• रंग सरलीकृत होतात";
"help_text_reduce_transparency" = "पारदर्शकता कमी करा संपूर्ण अॅपमधून ब्लर आणि पारदर्शकता प्रभाव काढतो.\n\nहे मदत करते:\n• मजकूर वाचनीयता सुधारते\n• दृश्य जटिलता कमी करते\n• जुन्या डिव्हाइसवर कार्यक्षमता वाढवते\n• सामग्री अधिक अंदाजानुसार बनवते";
"help_text_color_blind_mode" = "वर्णांध मोड वेगवेगळ्या प्रकारच्या रंग दृष्टी कमतरतेसाठी रंग समायोजित करतात.\n\nउपलब्ध मोड:\n• Protanopia: लाल-अंध (लाल रंग पाहण्यात अडचण)\n• Deuteranopia: हिरवा-अंध (हिरवा रंग पाहण्यात अडचण)\n• Tritanopia: निळा-अंध (निळा रंग पाहण्यात अडचण)\n• मोनोक्रोम: फक्त ग्रेस्केल\n\nहे मोड सुनिश्चित करतात की महत्त्वाची माहिती फक्त रंगाने दर्शवली जात नाही.";
"help_text_line_spacing" = "ओळींमधील अंतर मजकूराच्या ओळींमधील जागा नियंत्रित करते.\n\n• श्रेणी: 1.0x ते 2.0x\n• AAA मानक: किमान 1.5x\n• डीफॉल्ट: 1.0x\n\nवाढलेले ओळींमधील अंतर मजकूर वाचणे सोपे करते आणि ओळ उडवणे टाळण्यास मदत करते.";
"help_text_paragraph_spacing" = "परिच्छेद अंतर परिच्छेदांमधील जागा नियंत्रित करते.\n\n• श्रेणी: 1.0x ते 3.0x\n• AAA मानक: किमान 2.0x\n• डीफॉल्ट: 1.0x\n\nवाढलेले परिच्छेद अंतर मजकूराच्या वेगवेगळ्या विभागांमध्ये फरक ओळखण्यास मदत करते.";
"help_text_letter_spacing" = "अक्षर अंतर वैयक्तिक अक्षरांमधील जागा नियंत्रित करते.\n\n• श्रेणी: 0.0em ते 0.2em\n• AAA मानक: किमान 0.12em\n• डीफॉल्ट: 0.0em\n\nवाढलेले अक्षर अंतर अक्षर ओळख आणि वाचनीयता सुधारते.";
"help_text_text_width" = "मजकूर रुंदी आरामदायक वाचनासाठी कमाल ओळ लांबी नियंत्रित करते.\n\nपर्याय:\n• पूर्ण रुंदी: कमाल नाही\n• आरामदायक (80 अक्षरे): वाचनासाठी इष्टतम\n• अरुंद (60 अक्षरे): एकाग्र वाचनासाठी\n\nAAA मार्गदर्शक तत्त्वे प्रति ओळ कमाल 80 अक्षरे शिफारस करतात.";
"help_text_large_touch_targets" = "मोठी स्पर्श लक्ष्ये सर्व बटणे आणि इंटरॅक्टिव्ह घटक किमान 60pt आकारात बनवतात.\n\nहे यांच्यासाठी उपयुक्त आहे:\n• मोटर कमजोरी\n• थरथरणे किंवा हादरणे\n• हातमोजे घालून अॅप वापरणे\n• एका हाताने वापर\n\nमानक किमान 44pt आहे; ही सेटिंग 60pt पर्यंत वाढवते.";
"help_text_reduce_motion" = "गती कमी करा संपूर्ण अॅपमधील अॅनिमेशन कमी करते किंवा काढते.\n\nहे यांच्यासाठी उपयुक्त आहे:\n• गती संवेदनशीलता\n• वेस्टिब्युलर विकार\n• अपस्मार\n• मायग्रेन ट्रिगर\n\nसक्षम असताना, अॅनिमेशन त्वरित संक्रमणांनी बदलली जातात.";
"help_text_timeout_behavior" = "कालबाह्यता वर्तन ऑपरेशन कालबाह्य होण्यापूर्वी किती वेळ घेऊ शकतात ते नियंत्रित करते.\n\nपर्याय:\n• कालबाह्यता नाही (AAA): ऑपरेशन कधीही कालबाह्य होत नाहीत\n• मानक (30s): डीफॉल्ट कालबाह्यता\n• विस्तारित (60s): मानक वेळाच्या दुप्पट\n\nकोणतीही कालबाह्यता मोड नाही AAA प्रवेशयोग्यता मानके पूर्ण करते.";
"help_text_simplified_gestures" = "सरलीकृत जेश्चर जटिल मल्टी-टच जेश्चर साध्या टॅपमध्ये कमी करतात.\n\nहे यांच्यासाठी उपयुक्त आहे:\n• मोटर कमजोरी\n• मर्यादित चपळता\n• सहाय्यक उपकरणे वापरणे\n• एका हाताने ऑपरेशन\n\nजटिल जेश्चर बटणे आणि साध्या टॅपने बदलले जातात.";
"help_text_haptic_feedback" = "हॅप्टिक फीडबॅक क्रिया आणि सूचनांसाठी कंपन फीडबॅक प्रदान करतो.\n\nहे यांच्यासाठी उपयुक्त आहे:\n• बटण दाबण्याची पुष्टी करणे\n• त्रुटी किंवा सावधानींबद्दल सतर्क करणे\n• गैर-दृश्य फीडबॅक प्रदान करणे\n• ऐकण्यात किंवा दृष्टीत कमजोरी असलेले वापरकर्ते\n\nकंपन अस्वस्थ असल्यास तुम्ही हे अक्षम करू शकता.";
"help_text_simplified_ui" = "सरलीकृत इंटरफेस संपूर्ण अॅपमधील दृश्य जटिलता कमी करतो.\n\nहे यांच्यासाठी उपयुक्त आहे:\n• संज्ञानात्मक अक्षमता\n• शिकण्यात अडचणी\n• लक्ष विकार\n• नवीन किंवा अनुभवहीन वापरकर्ते\n\nसक्षम असताना:\n• स्क्रीनवर कमी घटक\n• मोठी, स्पष्ट नियंत्रणे\n• कमी दृश्य गोंधळ";
"help_text_step_indicators" = "चरण निर्देशक बहु-चरण प्रक्रियांमध्ये तुमची प्रगती दाखवतात.\n\nहे मदत करते:\n• तुम्ही प्रक्रियेत कुठे आहात ते समजण्यास\n• किती चरण उरले आहेत हे जाणण्यास\n• संज्ञानात्मक भार कमी करण्यास\n• स्पष्ट रचना प्रदान करण्यास\n\nदृश्य प्रगती बिंदूंसह 'चरण X पैकी Y' दाखवतो.";
"help_text_verbose_descriptions" = "तपशीलवार वर्णने संपूर्ण अॅपमध्ये अतिरिक्त स्पष्टीकरणात्मक मजकूर प्रदान करतात.\n\nहे यांच्यासाठी उपयुक्त आहे:\n• जटिल वैशिष्ट्ये समजण्यास\n• अॅप कसे वापरायचे ते शिकण्यास\n• संज्ञानात्मक सहाय्य\n• स्क्रीन रीडर वापरकर्ते\n\nसर्व वैशिष्ट्यांसाठी संदर्भ आणि सूचना प्रदान करते.";
"help_text_confirm_actions" = "क्रियांची पुष्टी करा महत्त्वाच्या क्रियांपूर्वी पुष्टीकरण मागते.\n\nहे रोखण्यास मदत करते:\n• चुकून हटवणे\n• अनावश्यक बदल\n• अकाली सबमिशन\n• डेटा हानी\n\nटीप: विध्वंसक क्रियांना नेहमी पुष्टीकरण आवश्यक असते (AAA आवश्यकता).";
"help_text_manual_code_entry" = "हस्तचलित कोड एंट्री तुम्हाला QR कोड स्कॅन करण्याऐवजी कोड टाइप करण्याची परवानगी देते.\n\nहे उपयुक्त आहे जेव्हा:\n• कॅमेरा काम करत नाही\n• QR कोड खराब झालेला किंवा अस्पष्ट आहे\n• स्क्रीन रीडर वापरत आहे\n• स्कॅन करण्यापेक्षा टाइप करणे पसंत आहे\n\nस्क्रीनवर दाखवलेला कोड टाइप करण्यासाठी 'कोड हस्तचलितपणे प्रविष्ट करा' टॅप करा.";
"help_text_voice_input" = "व्हॉइस इनपुट तुम्हाला स्कॅन किंवा टाइप करण्याऐवजी कोड बोलण्याची परवानगी देतो.\n\nहे यांच्यासाठी उपयुक्त आहे:\n• मर्यादित गतिशीलता\n• स्क्रीन रीडर वापरकर्ते\n• हात-मुक्त ऑपरेशन\n• आवाजाला प्राधान्य\n\nमायक्रोफोन बटण टॅप करा आणि विचारल्यावर स्पष्टपणे बोला.";
"help_text_qr_scanning" = "QR कोड स्कॅनिंग Quick Response कोड वाचण्यासाठी तुमचा कॅमेरा वापरतो.\n\nस्कॅन कसे करायचे:\n1. QR कोडकडे कॅमेरा निर्देशित करा\n2. फ्रेममध्ये कोड संरेखित करा\n3. स्वयंचलित आढळण्याची प्रतीक्षा करा\n\nटिप्स:\n• चांगला प्रकाश असल्याची खात्री करा\n• डिव्हाइस स्थिर ठेवा\n• QR कोड सपाट आणि अडथळ्यांशिवाय ठेवा\n• स्कॅनिंग अयशस्वी झाल्यास, हस्तचलित कोड एंट्री वापरून पाहा";
"help_text_age_verification" = "वय पडताळणी तुमची प्रत्यक्ष वय किंवा जन्मतारीख न सांगता वय आवश्यकता पूर्ण करत असल्याचे सिद्ध करते.\n\nहे कसे कार्य करते:\n1. पडताळणीकर्ता एक आव्हान तयार करतो\n2. तुम्ही QR कोड स्कॅन करता किंवा हस्तचलितपणे प्रविष्ट करता\n3. अॅप शून्य-ज्ञान पुरावा तयार करतो\n4. पडताळणीकर्ता पुष्टी करतो की तुम्ही आवश्यकता पूर्ण करता\n\nगोपनीयता संरक्षित:\n• तुमची जन्मतारीख कधीही सामायिक केली जात नाही\n• पडताळणीकर्त्याला फक्त हे कळते की तुम्ही आवश्यकता पूर्ण करता की नाही\n• कोणताही ट्रॅकिंग किंवा डेटा संग्रह नाही";
"help_text_credentials" = "डिजिटल ओळखपत्रे म्हणजे तुमच्या डिव्हाइसवर सुरक्षितपणे संग्रहित तुमच्या वयाचे क्रिप्टोग्राफिक पुरावे.\n\nवैशिष्ट्ये:\n• फक्त तुमच्या डिव्हाइसवर संग्रहित\n• कॉपी किंवा बनावट करता येत नाही\n• गोपनीयता-संरक्षक पडताळणीसाठी वापरली जाते\n• कधीही हटवता येते\n\nतुम्हाला तुमचे वय पडताळण्यापूर्वी अधिकृत जारीकर्त्याकडून (जसे सरकारी कार्यालय) ओळखपत्र मिळवणे आवश्यक आहे.";
"help_text_zero_knowledge" = "शून्य-ज्ञान पुरावे तुम्हाला अंतर्निहित माहिती न सांगता काहीतरी खरे असल्याचे सिद्ध करण्याची परवानगी देतात.\n\nउदाहरण:\n• पारंपारिक: ID दाखवा (अचूक वाढदिवस उघड करतो)\n• शून्य-ज्ञान: वाढदिवस न दाखवता 18 पेक्षा जास्त असल्याचे सिद्ध करा\n\nफायदे:\n• कमाल गोपनीयता संरक्षण\n• कोणताही वैयक्तिक डेटा सामायिक केला जात नाही\n• क्रिप्टोग्राफिकरित्या सुरक्षित\n• बनावट किंवा पुनरावृत्ती करता येत नाही\n\nही Provii Wallet ला खाजगी बनवणारी मुख्य तंत्रज्ञान आहे.";
"help_text_credential_issuance" = "ओळखपत्र जारी करणे म्हणजे अधिकृत जारीकर्त्याकडून तुमचे डिजिटल वय ओळखपत्र मिळवण्याची प्रक्रिया.\n\nचरण:\n1. अधिकृत जारीकर्त्याकडे भेट द्या (उदा. सरकारी कार्यालय)\n2. अधिकृत ID ने तुमची ओळख सिद्ध करा\n3. जारीकर्त्याकडून QR कोड किंवा डीप लिंक प्राप्त करा\n4. QR कोड स्कॅन करा किंवा लिंकवर टॅप करा\n5. ओळखपत्र स्थानिकरित्या मोजले जाते आणि तुमच्या डिव्हाइसवर संग्रहित केले जाते\n\nआंधळ्या साक्षांकन प्रक्रिया हे सुनिश्चित करते की तुमची जन्मतारीख कधीही नेटवर्कवर पाठवली जात नाही.\nतुम्हाला हे फक्त एकदाच करणे आवश्यक आहे. त्यानंतर तुमचे ओळखपत्र असंख्य पडताळण्यांसाठी वापरता येते.";
"help_text_officer_mode" = "अधिकारी मोड अधिकृत जारीकर्त्यांसाठी वापरकर्त्यांसाठी ओळखपत्रे तयार करण्यासाठी आहे.\n\nया मोडसाठी आवश्यक आहे:\n• YubiKey सह अधिकारी प्रमाणीकरण\n• जारी करण्याच्या प्राधिकरणाकडून परवानगी\n• वापरकर्त्याच्या ID ची भौतिक पडताळणी\n\nप्रक्रिया:\n1. अधिकारी म्हणून प्रमाणीकरण करा\n2. वापरकर्त्याचे अधिकृत ID सत्यापित करा\n3. वापरकर्त्याची जन्मतारीख प्रविष्ट करा\n4. साक्षांकन QR कोड तयार करा\n5. वापरकर्ता ओळखपत्र प्राप्त करण्यासाठी कोड स्कॅन करतो\n\nफक्त अधिकृत कर्मचाऱ्यांनी हा मोड वापरावा.";

