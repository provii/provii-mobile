// MARK: - New Strings (synced 2026-03-24)
"help_text_extra_large_text" = "អក្សរធំបំផុតបង្កើនអក្សរទាំងអស់ក្នុងកម្មវិធី 50%.\n\nមានប្រយោជន៍សម្រាប់អ្នកប្រើប្រាស់ដែលមាន:\n• ចក្ខុខ្សោយ\n• ការលំបាកអាន\n• ការផ្លាស់ប្ដូរចក្ខុដែលទាក់ទងនឹងអាយុ\n\nដំណើរការជាមួយ iOS Dynamic Type សម្រាប់ទំហំធំជាងនេះ។";
"help_text_contrast_level" = "កម្រិតពណ៌ត្រួតពិនិត្យកម្រិតពណ៌រវាងអក្សរ និងផ្ទៃខាងក្រោយ.\n\nមានបីកម្រិត:\n• ស្តង់ដារ: ពណ៌លំនាំដើម\n• ខ្ពស់ (AA): សមាមាត្រ 4.5:1 - ស្ថិតនៅស្តង់ដារ AA\n• អតិបរមា (AAA): សមាមាត្រ 7:1 - ស្ថិតនៅស្តង់ដារ AAA\n\nកម្រិតពណ៌ខ្ពស់ជួយឲ្យអក្សរងាយអានក្នុងលក្ខខណ្ឌពន្លឺទាំងអស់។";
"help_text_high_contrast" = "របៀបកម្រិតពណ៌ខ្ពស់បង្កើនកម្រិតពណ៌រវាងអក្សរ និងផ្ទៃខាងក្រោយ ធ្វើឲ្យងាយអានជាងមុន.\n\nមានប្រយោជន៍សម្រាប់អ្នកប្រើប្រាស់ដែលមាន:\n• ចក្ខុខ្សោយ\n• ភាពរំខានពណ៌\n• បរិស្ថានអេក្រង់ភ្លឺ\n\nពេលបើក:\n• អក្សរក្លាយជាខ្មៅលើស\n• គែមត្រូវបានបន្ថែម\n• ពណ៌ត្រូវបានសម្រួល";
"help_text_reduce_transparency" = "កាត់បន្ថយតម្លាភាពលប់បំបាត់ការព្រិល និងប្រभावតម្លាភាពក្នុងកម្មវិធី.\n\nជួយ:\n• ធ្វើប្រសើរការអានអក្សរ\n• កាត់បន្ថយភាពស្មុគស្មាញ\n• ដំណើរការឧបករណ៍ចាស់\n• ធ្វើខ្លឹមសារអាចទស្សន៍ទាយ";
"help_text_color_blind_mode" = "របៀបខ្វាក់ពណ៌កែតម្រូវពណ៌សម្រាប់ប្រភេទខ្វះអ្នករំញោចពណ៌ផ្សេងៗ.\n\nរបៀបដែលមាន:\n• ប្រូតាណូពៀ: ខ្វាក់ក្រហម\n• ដឺតេរ៉ាណូពៀ: ខ្វាក់បៃតង\n• ត្រីតាណូពៀ: ខ្វាក់ខៀវ\n• ស-ខ្មៅ: ប្រផ្អប់ប៉ុណ្ណោះ\n\nរបៀបទាំងនេះធានាថាព័ត៌មានសំខាន់មិនបញ្ជូនតែតាមពណ៌ប៉ុណ្ណោះ។";
"help_text_line_spacing" = "ចន្លោះបន្ទាត់ត្រួតពិនិត្យចន្លោះរវាងបន្ទាត់អក្សរ.\n\n• ជួរ: 1.0x ដល់ 2.0x\n• ស្តង់ដារ AAA: យ៉ាងហោចណាស់ 1.5x\n• លំនាំដើម: 1.0x\n\nចន្លោះបន្ទាត់ច្រើនជួយអានងាយ និងការពារការរំលងបន្ទាត់។";
"help_text_paragraph_spacing" = "ចន្លោះកថាខណ្ឌត្រួតពិនិត្យចន្លោះរវាងកថាខណ្ឌ.\n\n• ជួរ: 1.0x ដល់ 3.0x\n• ស្តង់ដារ AAA: យ៉ាងហោចណាស់ 2.0x\n• លំនាំដើម: 1.0x\n\nចន្លោះកថាខណ្ឌច្រើនជួយសម្គាល់ផ្នែកអក្សរ។";
"help_text_letter_spacing" = "ចន្លោះអក្សរត្រួតពិនិត្យចន្លោះរវាងអក្សរ.\n\n• ជួរ: 0.0em ដល់ 0.2em\n• ស្តង់ដារ AAA: យ៉ាងហោចណាស់ 0.12em\n• លំនាំដើម: 0.0em\n\nចន្លោះអក្សរច្រើនធ្វើប្រសើរការស្គាល់ និងការអាន។";
"help_text_text_width" = "ទទឹងអក្សរត្រួតពិនិត្យប្រវែងបន្ទាត់អតិបរមាសម្រាប់ការអានផាសុក.\n\nជម្រើស:\n• ទទឹងពេញ: គ្មានអតិបរមា\n• ផាសុកភាព (80 អក្សរ): ល្អបំផុតសម្រាប់ការអាន\n• ចង្អៀត (60 អក្សរ): សម្រាប់ការអានផ្ដោត\n\nគោលណែនាំ AAA ណែនាំ 80 អក្សរជាអតិបរមា។";
"help_text_large_touch_targets" = "គោលដៅប៉ះធំធ្វើប៊ូតុង និងធាតុអន្តរកម្មទំហំ 60pt.\n\nមានប្រយោជន៍សម្រាប់:\n• ពិការភាពចលនា\n• ញ័រ\n• ប្រើកម្មវិធីជាមួយដៃស្រោម\n• ប្រើដៃម្ខាង\n\nអប្បបរមាស្តង់ដារ 44pt; ការកំណត់នេះបង្កើនទៅ 60pt។";
"help_text_reduce_motion" = "កាត់បន្ថយចលនាកំណត់ ឬដក់ចលនាក្នុងកម្មវិធី.\n\nមានប្រយោជន៍សម្រាប់:\n• ភាពរំខានចលនា\n• ជំងឺ vestibular\n• ជំងឺ epilepsy\n• ការប្រឆាំងការឈឺក្បាល\n\nពេលបើក ចលនាត្រូវបានជំនួសដោយការផ្លាស់ប្ដូរភ្លាម។";
"help_text_timeout_behavior" = "ឥរិយាបថការផុតកំណត់ត្រួតពិនិត្យរយៈពេលដំណើរការ.\n\nជម្រើស:\n• គ្មានការផុតកំណត់ (AAA): ប្រតិបត្តិការមិនផុតឡើយ\n• ស្តង់ដារ (30 វិ): ការផុតកំណត់លំនាំដើម\n• បន្ថែម (60 វិ): ពេលទ្វេដង\n\nគ្មានការផុតកំណត់ស្ថិតនៅស្តង់ដារ AAA។";
"help_text_simplified_gestures" = "ចលនាសាមញ្ញកាត់បន្ថយចលនា multi-touch ស្មុគស្មាញ.\n\nមានប្រយោជន៍សម្រាប់:\n• ពិការភាពចលនា\n• ការសម្រួលការធ្វើ\n• ប្រើឧបករណ៍ជំនួយ\n• ប្រើដៃម្ខាង\n\nចលនាស្មុគស្មាញត្រូវបានជំនួសដោយប៊ូតុង។";
"help_text_haptic_feedback" = "មតិកំណត់ប៉ះផ្ដល់ការញ័រសម្រាប់សកម្មភាព.\n\nមានប្រយោជន៍:\n• ផ្ទៀងផ្ទាត់ការចុចប៊ូតុង\n• ជូនដំណឹងកំហុស\n• ផ្ដល់មតិប្រកបដោយបច្ចេកវិជ្ជា\n• អ្នកមានបញ្ហាលឺ ឬចក្ខុ\n\nអ្នកអាចបិទការញ័រ។";
"help_text_simplified_ui" = "ចំណុចប្រទាក់សាមញ្ញកាត់បន្ថយភាពស្មុគស្មាញ.\n\nមានប្រយោជន៍:\n• ពិការភាពការយល់ដឹង\n• ការលំបាករៀន\n• ជំងឺ attention\n• អ្នកប្រើប្រាស់ថ្មី\n\nពេលបើក:\n• ធាតុតិចជាងមុន\n• ការត្រួតពិនិត្យច្បាស់\n• ការរំខានអំខ្ចើ";
"help_text_step_indicators" = "សូចនាករជំហានបង្ហាញវឌ្ឍនភាព.\n\nជួយ:\n• ដឹងថាអ្នកនៅជំហានណា\n• ដឹងថានៅសល់ប៉ុន្មានជំហាន\n• កាត់បន្ថយការបញ្ចូលការយល់ដឹង\n• ផ្ដល់រចនាសម្ព័ន្ធ\n\nបង្ហាញ \"ជំហាន X ក្នុងចំណោម Y\" ជាមួយចំណុច។";
"help_text_verbose_descriptions" = "ការពិពណ៌នាលម្អិតផ្ដល់អត្ថបទពន្យល់បន្ថែម.\n\nមានប្រយោជន៍:\n• យល់មុខងារស្មុគស្មាញ\n• រៀនប្រើកម្មវិធី\n• ការគាំទ្រការយល់ដឹង\n• អ្នកប្រើ screen reader\n\nផ្ដល់បរិបទ និងការណែនាំ។";
"help_text_confirm_actions" = "បញ្ជាក់សកម្មភាពស្នើសុំការបញ្ជាក់.\n\nជួយការពារ:\n• ការលប់ចោលដោយចៃដន្យ\n• ការផ្លាស់ប្ដូរដែលមិនបានគ្រោង\n• ការដាក់ទុករាល់ទែ\n• ការបាត់ទិន្នន័យ\n\nចំណាំ: សកម្មភាពបំផ្លើត្រូវការការបញ្ជាក់ (ស្តង់ដារ AAA)។";
"help_text_manual_code_entry" = "ការបញ្ចូលកូដដោយដៃអនុញ្ញាតឲ្យវាយកូដ.\n\nមានប្រយោជន៍:\n• ម៉ាស៊ីនថតមិនដំណើរការ\n• QR ខូច\n• ប្រើ screen reader\n• ចូលចិត្តវាយ\n\nចុច \"បញ្ចូលកូដដោយដៃ\" ដើម្បីវាយ។";
"help_text_voice_input" = "ការបញ្ចូលសំឡេងអនុញ្ញាតឲ្យនិយាយកូដ.\n\nមានប្រយោជន៍:\n• ចលនាដែនកំណត់\n• screen reader\n• ប្រើដោយដៃទំនេរ\n• ចូលចិត្តសំឡេង\n\nចុចប៊ូតុងមីក្រូហ្វូន ហើយនិយាយ។";
"help_text_qr_scanning" = "ការស្កែន QR ប្រើម៉ាស៊ីនថតអ្នក.\n\nរបៀបស្កែន:\n1. ចង្អុល QR\n2. តម្រឹមក្នុងក្រប\n3. រង់ចាំការស្គាល់\n\nគន្លឹះ:\n• ប្រើពន្លឺ\n• ចាប់ឧបករណ៍ឲ្យស្ថិរ\n• ទុក QR ល្វែង\n• ប្រសិនស្កែនបរាជ័យ ប្រើការបញ្ចូលដោយដៃ";
"help_text_age_verification" = "ការផ្ទៀងផ្ទាត់អាយុបញ្ជាក់ថាអ្នកបំពេញតម្រូវការ.\n\nដំណើរការ:\n1. ការផ្ទៀងផ្ទាត់បង្កើតការប្រកួត\n2. ស្កែន QR ឬបញ្ចូលដោយដៃ\n3. កម្មវិធីបង្កើតភស្តុតាង\n4. ការផ្ទៀងផ្ទាត់ផ្ទៀងផ្ទាត់\n\nការការពារឯកជន:\n• ថ្ងៃខែឆ្នាំកំណើតមិនបានចែករំលែក\n• ការផ្ទៀងផ្ទាត់ដឹងតែថាអ្នកបំពេញ\n• គ្មានការតាមដាន";
"help_text_credentials" = "អត្តសញ្ញាណប័ណ្ណឌីជីថលគឺភស្តុតាងគ្រីប្តូ.\n\nមុខងារ:\n• ផ្ទុកតែក្នុងឧបករណ៍\n• មិនអាចចម្លង\n• ប្រើការការពារឯកជន\n• អាចលប់ពេលណា\n\nត្រូវទទួលបានពីអ្នកចេញដែលបានអនុញ្ញាត។";
"help_text_zero_knowledge" = "ភស្តុតាងចំណេះដឹងសូន្យអនុញ្ញាតឲ្យបញ្ជាក់ដោយមិនបង្ហាញ.\n\nឧទាហរណ៍:\n• ប្រពៃណី: បង្ហាញ ID\n• ចំណេះដឹងសូន្យ: បញ្ជាក់ 18+ ដោយគ្មានថ្ងៃកំណើត\n\nអត្ថប្រយោជន៍:\n• ការការពារឯកជន\n• គ្មានទិន្នន័យ\n• ការពារការក្លែងបន្លំ\n\nនេះជាបច្ចេកវិទ្យា Provii Wallet។";
"help_text_credential_issuance" = "ការចេញអត្តសញ្ញាណប័ណ្ណគឺដំណើរការទទួល.\n\nជំហាន:\n1. ទៅអ្នកចេញ (ការិយាល័យ)\n2. បញ្ជាក់អត្តសញ្ញាណ\n3. ទទួល QR ឬតំណ\n4. ស្កែន QR ឬចុចតំណ\n5. ផ្ទុកក្នុងឧបករណ៍\n\nថ្ងៃខែឆ្នាំកំណើតមិនបញ្ជូន.\nត្រូវធ្វើតែម្ដង។";
"help_text_officer_mode" = "របៀបមន្ត្រីសម្រាប់អ្នកចេញអនុញ្ញាត.\n\nត្រូវការ:\n• ការផ្ទៀងផ្ទាត់ YubiKey\n• ការអនុញ្ញាត\n• ការផ្ទៀងផ្ទាត់ ID\n\nដំណើរការ:\n1. ផ្ទៀងផ្ទាត់ជាមន្ត្រី\n2. ផ្ទៀងផ្ទាត់ ID\n3. បញ្ចូលថ្ងៃខែឆ្នាំកំណើត\n4. បង្កើត QR\n5. អ្នកប្រើស្កែន\n\nត្រឹមតែបុគ្គលិកអនុញ្ញាតប៉ុណ្ណោះ។";
"help_text_extra_large_text_simplified" = "ធ្វើអក្សរ 50% ធំ.\n\nជួយ:\n• ការមើលឃើញពិបាក\n• ការអានពិបាក\n• ត្រូវការអក្សរធំ\n\nដំណើរការជាមួយទំហំអក្សរទូរស័ព្ទ។";
"help_text_contrast_level_simplified" = "ផ្លាស់ប្ដូរភាពងងឹតអក្សរ.\n\nបីជម្រើស:\n• ស្តង់ដារ: ពណ៌ធម្មតា\n• ខ្ពស់: អក្សរងងឹតជាងមុន\n• អតិបរមា: អក្សរងងឹតបំផុត\n\nអក្សរងងឹតងាយអាន។";
