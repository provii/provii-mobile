/* InfoPlist.strings - Brazilian Portuguese (pt-BR) */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "O Provii Wallet precisa de acesso à câmera para escanear códigos QR para obter credenciais e verificação de idade.";

/* NFC Access */
"NFCReaderUsageDescription" = "O Provii Wallet usa NFC para se comunicar com seu YubiKey para autenticação segura do agente.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "O Provii Wallet usa reconhecimento de fala para comandos de voz no modo de acessibilidade, permitindo que você controle o aplicativo sem usar as mãos.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "O Provii Wallet precisa de acesso ao microfone para recursos de controle por voz quando o modo de acessibilidade está ativado.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "O Provii Wallet usa o Face ID para acessar com segurança suas credenciais de idade e verificar sua identidade.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "O Provii Wallet pode usar a rede local para descobrir emissores de credenciais próximos.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "O Provii Wallet pode usar Bluetooth para se comunicar com dispositivos YubiKey.";
