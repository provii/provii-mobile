/* InfoPlist.strings - Nepali */
/* Localised permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet लाई प्रमाणपत्र संग्रह र उमेर प्रमाणीकरणका लागि QR कोड स्क्यान गर्न क्यामेरा पहुँच आवश्यक छ।";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet ले सुरक्षित अधिकारी प्रमाणीकरणका लागि तपाईंको YubiKey सँग सञ्चार गर्न NFC प्रयोग गर्छ।";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet ले पहुँचयोग्यता मोडमा भ्वाइस आदेशहरूका लागि वाक् पहिचान प्रयोग गर्छ, जसले तपाईंलाई ह्यान्डस-फ्री एप नियन्त्रण गर्न अनुमति दिन्छ।";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet लाई पहुँचयोग्यता मोड सक्षम भएमा भ्वाइस नियन्त्रण सुविधाहरूका लागि माइक्रोफोन पहुँच आवश्यक छ।";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet ले तपाईंका उमेर प्रमाणपत्रहरू सुरक्षित रूपमा पहुँच गर्न र तपाईंको पहिचान प्रमाणित गर्न Face ID प्रयोग गर्छ।";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet ले नजिकका प्रमाणपत्र जारीकर्ताहरू पत्ता लगाउन स्थानीय नेटवर्क प्रयोग गर्न सक्छ।";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet ले YubiKey उपकरणहरूसँग सञ्चार गर्न Bluetooth प्रयोग गर्न सक्छ।";
