// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "매우 큰 텍스트는 앱의 모든 텍스트를 50% 늘립니다.\n\n다음 사용자에게 도움이 됩니다:\n• 저시력\n• 읽기 어려움\n• 노화로 인한 시력 변화\n\niOS Dynamic Type와 함께 작동하여 더 큰 크기를 제공합니다.";
"help_text_contrast_level" = "대비 수준은 텍스트와 배경 사이의 색상 대비를 조정합니다.\n\n세 가지 수준:\n• 표준: 기본 색상\n• 높음 (AA): 4.5:1 대비 비율 - AA 기준 충족\n• 최대 (AAA): 7:1 대비 비율 - 최고 AAA 기준 충족\n\n대비가 높을수록 모든 조명 조건에서 텍스트를 읽기 쉽습니다.";
"help_text_high_contrast" = "고대비 모드는 텍스트와 배경 사이의 대비를 높여 읽기 편하게 합니다.\n\n다음 사용자에게 도움이 됩니다:\n• 저시력\n• 색상 민감성\n• 밝은 화면 환경\n\n활성화 시:\n• 텍스트가 흰색 배경에 검은색으로 표시됩니다\n• 요소에 테두리가 추가됩니다\n• 색상이 단순화됩니다";
"help_text_reduce_transparency" = "투명도 줄이기는 앱 전체의 흐림 및 투명 효과를 제거합니다.\n\n다음에 도움이 됩니다:\n• 텍스트 가독성 향상\n• 시각적 복잡성 감소\n• 오래된 기기의 성능 향상\n• 더 예측 가능한 콘텐츠";
"help_text_color_blind_mode" = "색맹 모드는 다양한 유형의 색각 이상에 맞게 색상을 조정합니다.\n\n사용 가능한 모드:\n• 제1색맹: 적색맹 (빨간색 보기 어려움)\n• 제2색맹: 녹색맹 (녹색 보기 어려움)\n• 제3색맹: 청색맹 (파란색 보기 어려움)\n• 단색: 흑백만\n\n이 모드는 중요한 정보가 색상만으로 전달되지 않도록 합니다.";
"help_text_line_spacing" = "줄 간격은 텍스트 줄 사이의 공간을 조정합니다.\n\n• 범위: 1.0배 ~ 2.0배\n• AAA 기준: 최소 1.5배\n• 기본값: 1.0배\n\n줄 간격을 늘리면 텍스트를 읽기 쉽고 줄 건너뜀을 방지합니다.";
"help_text_paragraph_spacing" = "단락 간격은 단락 사이의 공간을 조정합니다.\n\n• 범위: 1.0배 ~ 3.0배\n• AAA 기준: 최소 2.0배\n• 기본값: 1.0배\n\n단락 간격을 늘리면 다른 텍스트 섹션을 구분하는 데 도움이 됩니다.";
"help_text_letter_spacing" = "자간은 개별 문자 사이의 공간을 조정합니다.\n\n• 범위: 0.0em ~ 0.2em\n• AAA 기준: 최소 0.12em\n• 기본값: 0.0em\n\n자간을 늘리면 문자 인식 및 가독성이 향상됩니다.";
"help_text_text_width" = "텍스트 너비는 편안한 읽기를 위한 최대 줄 길이를 조정합니다.\n\n옵션:\n• 전체 너비: 최대 없음\n• 편안함 (80자): 읽기에 최적\n• 좁음 (60자): 집중적인 읽기에 적합\n\nAAA 가이드라인은 줄당 최대 80자를 권장합니다.";
"help_text_large_touch_targets" = "더 큰 터치 대상은 모든 버튼과 상호작용 요소를 최소 60pt로 만듭니다.\n\n다음에 도움이 됩니다:\n• 운동 장애\n• 떨림\n• 장갑을 끼고 앱 사용\n• 한 손 사용\n\n표준 최소값은 44pt이며, 이 설정은 60pt로 늘립니다.";
"help_text_reduce_motion" = "모션 줄이기는 앱 전체의 애니메이션을 최소화하거나 제거합니다.\n\n다음 사용자에게 도움이 됩니다:\n• 동작 민감성\n• 전정 장애\n• 간질\n• 편두통 유발 요소\n\n활성화 시 애니메이션이 즉각적인 전환으로 대체됩니다.";
"help_text_timeout_behavior" = "시간 초과 동작은 작업이 시간 초과되기까지 얼마나 걸릴지 조정합니다.\n\n옵션:\n• 시간 초과 없음 (AAA): 작업 시간 제한 없음\n• 표준 (30초): 기본 시간 제한\n• 연장 (60초): 표준의 두 배\n\n시간 초과 없음 모드는 AAA 접근성 기준을 충족합니다.";
"help_text_simplified_gestures" = "간소화된 제스처는 복잡한 멀티 터치 제스처를 간단한 탭으로 대체합니다.\n\n다음에 도움이 됩니다:\n• 운동 장애\n• 제한된 손 민첩성\n• 보조 기기 사용\n• 한 손 사용\n\n복잡한 제스처가 버튼 및 간단한 탭으로 대체됩니다.";
"help_text_haptic_feedback" = "햅틱 피드백은 동작 및 알림에 진동 피드백을 제공합니다.\n\n다음에 도움이 됩니다:\n• 버튼 누름 확인\n• 오류 또는 경고 알림\n• 비시각적 피드백 제공\n• 청각 또는 시각 장애 사용자\n\n진동이 불편하면 비활성화할 수 있습니다.";
"help_text_simplified_ui" = "간소화된 인터페이스는 앱 전체의 시각적 복잡성을 줄입니다.\n\n다음에 도움이 됩니다:\n• 인지 장애\n• 학습 어려움\n• 주의력 장애\n• 새로운 사용자\n\n활성화 시:\n• 화면에 더 적은 요소\n• 더 크고 명확한 컨트롤\n• 시각적 노이즈 감소";
"help_text_step_indicators" = "단계 표시기는 다단계 프로세스에서 진행 상황을 보여줍니다.\n\n다음에 도움이 됩니다:\n• 프로세스에서 현재 위치 파악\n• 남은 단계 수 확인\n• 인지 부하 감소\n• 명확한 구조 제공\n\n시각적 진행 도트와 함께 '단계 X/Y'를 표시합니다.";
"help_text_verbose_descriptions" = "상세 설명은 앱 전체에 추가적인 설명 텍스트를 제공합니다.\n\n다음에 도움이 됩니다:\n• 복잡한 기능 이해\n• 앱 사용 방법 학습\n• 인지 지원\n• 화면 읽기 프로그램 사용자\n\n모든 기능에 맥락과 안내를 제공합니다.";
"help_text_confirm_actions" = "동작 확인은 중요한 동작 전에 확인을 요청합니다.\n\n다음을 방지합니다:\n• 실수로 삭제\n• 의도하지 않은 변경\n• 조기 제출\n• 데이터 손실\n\n참고: 위험한 동작에는 항상 확인이 필요합니다(AAA 요건).";
"help_text_manual_code_entry" = "코드 직접 입력을 통해 QR 코드를 스캔하는 대신 코드를 직접 입력할 수 있습니다.\n\n다음 경우에 유용합니다:\n• 카메라가 작동하지 않을 때\n• QR 코드가 손상되었거나 불명확할 때\n• 화면 읽기 프로그램 사용 시\n• 스캔보다 입력을 선호할 때\n\n'코드 직접 입력'을 탭하여 화면에 표시된 코드를 입력하십시오.";
"help_text_voice_input" = "음성 입력을 통해 스캔하거나 입력하는 대신 코드를 말할 수 있습니다.\n\n다음에 도움이 됩니다:\n• 이동성 제한\n• 화면 읽기 프로그램 사용자\n• 핸즈프리 작동\n• 음성 선호\n\n마이크 버튼을 탭하고 안내에 따라 명확하게 말하십시오.";
"help_text_qr_scanning" = "QR 코드 스캔은 카메라를 사용하여 빠른 응답 코드를 읽습니다.\n\n스캔 방법:\n1. 카메라를 QR 코드에 향하십시오\n2. 프레임 내에 코드를 맞추십시오\n3. 자동 감지를 기다리십시오\n\n팁:\n• 충분한 조명 확보\n• 기기를 안정적으로 유지\n• QR 코드를 평평하게 놓고 가리지 않도록\n• 스캔에 실패하면 코드 직접 입력 시도";
"help_text_age_verification" = "나이 검증은 실제 나이나 생년월일을 공개하지 않고 나이 요건을 충족함을 증명합니다.\n\n작동 방식:\n1. 검증자가 챌린지를 생성합니다\n2. QR 코드를 스캔하거나 직접 입력합니다\n3. 앱이 영지식 증명을 생성합니다\n4. 검증자가 요건 충족을 확인합니다\n\n프라이버시 보호:\n• 생년월일은 절대 공유되지 않습니다\n• 검증자는 요건 충족 여부만 확인합니다\n• 추적 또는 데이터 수집 없음";
"help_text_credentials" = "디지털 자격 증명은 기기에 안전하게 저장된 나이의 암호학적 증명입니다.\n\n특징:\n• 기기에만 저장됩니다\n• 복사하거나 위조할 수 없습니다\n• 프라이버시 보호 검증에 사용됩니다\n• 언제든지 삭제할 수 있습니다\n\n나이를 검증하기 전에 공인 발급 기관(예: 정부 사무소)에서 자격 증명을 받아야 합니다.";
"help_text_zero_knowledge" = "영지식 증명을 통해 기본 정보를 공개하지 않고도 무언가가 사실임을 증명할 수 있습니다.\n\n예시:\n• 기존 방식: 신분증 제시 (정확한 생일 공개)\n• 영지식: 생일을 보여주지 않고 18세 이상임을 증명\n\n장점:\n• 최대 프라이버시 보호\n• 개인 데이터 공유 없음\n• 암호학적으로 안전\n• 위조하거나 재사용할 수 없음\n\n이것이 Provii Wallet을 프라이버시 보호로 만드는 핵심 기술입니다.";
"help_text_credential_issuance" = "자격 증명 발급은 공인 발급 기관에서 디지털 나이 자격 증명을 받는 과정입니다.\n\n단계:\n1. 공인 발급 기관 방문 (예: 정부 사무소)\n2. 공식 신분증으로 신원 증명\n3. 발급 기관에서 QR 코드 또는 딥링크 받기\n4. QR 코드 스캔 또는 링크 탭\n5. 자격 증명이 로컬에서 계산되어 기기에 저장됩니다\n\n맹목적 증명 과정을 통해 생년월일이 네트워크를 통해 절대 전송되지 않습니다.\n한 번만 수행하면 됩니다. 이후 자격 증명을 무제한으로 검증에 사용할 수 있습니다.";
"help_text_officer_mode" = "담당자 모드는 공인 발급 기관이 사용자를 위해 자격 증명을 생성하는 데 사용됩니다.\n\n이 모드에는 다음이 필요합니다:\n• YubiKey로 담당자 인증\n• 발급 기관의 권한 부여\n• 사용자 신분증 실물 확인\n\n절차:\n1. 담당자로 인증\n2. 사용자의 공식 신분증 확인\n3. 사용자의 생년월일 입력\n4. 증명 QR 코드 생성\n5. 사용자가 코드를 스캔하여 자격 증명 수령\n\n공인된 담당자만 이 모드를 사용해야 합니다.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "모든 텍스트를 50% 크게 만듭니다.\n\n다음과 같은 경우에 도움이 됩니다:\n• 보기 어려울 때\n• 읽기가 힘들 때\n• 더 큰 텍스트가 필요할 때\n\n휴대폰의 텍스트 크기 설정과 함께 작동합니다.";

"help_text_contrast_level_simplified" = "텍스트가 얼마나 어두운지 변경합니다.\n\n세 가지 선택:\n• 표준: 일반 색상\n• 높음: 읽기 쉬운 더 어두운 텍스트\n• 최대: 최상의 읽기를 위한 매우 어두운 텍스트\n\n어두운 텍스트가 읽기 더 쉽습니다.";

"help_text_high_contrast_simplified" = "텍스트를 더 잘 보이게 합니다.\n\n다음과 같은 경우에 도움이 됩니다:\n• 보기 어려울 때\n• 더 어두운 텍스트가 필요할 때\n• 밝은 빛에서 앱을 사용할 때\n\n텍스트가 흰색 배경에 검은색으로 표시됩니다.";

"help_text_reduce_transparency_simplified" = "흐릿한 효과를 제거합니다.\n\n다음에 도움이 됩니다:\n• 텍스트를 더 명확하게\n• 앱을 더 단순하게\n• 오래된 휴대폰 속도 향상\n\n모든 것이 더 확실하게 보입니다.";

"help_text_color_blind_mode_simplified" = "더 잘 볼 수 있도록 색상을 변경합니다.\n\n선택:\n• 적색맹 모드\n• 녹색맹 모드\n• 청색맹 모드\n• 회색만 모드\n\n중요한 것을 볼 수 있도록 도와줍니다.";

"help_text_line_spacing_simplified" = "텍스트 줄 사이의 공간을 변경합니다.\n\n1.0배에서 2.0배까지 선택할 수 있습니다.\n기본값은 1.0배입니다.\n\n더 많은 공간이 읽기를 더 쉽게 합니다.";

"help_text_paragraph_spacing_simplified" = "단락 사이의 공간을 변경합니다.\n\n1.0배에서 3.0배까지 선택할 수 있습니다.\n기본값은 1.0배입니다.\n\n더 많은 공간이 새로운 생각이 시작되는 곳을 알기 쉽게 합니다.";

"help_text_letter_spacing_simplified" = "글자 사이의 공간을 변경합니다.\n\n0.0에서 0.2까지 선택할 수 있습니다.\n기본값은 0.0입니다.\n\n더 많은 공간이 글자를 더 명확하게 합니다.";

"help_text_text_width_simplified" = "텍스트의 너비를 조정합니다.\n\n선택:\n• 전체 너비: 전체 화면 사용\n• 보통: 읽기에 좋음\n• 좁음: 집중에 최적\n\n보통 너비가 읽기 가장 쉽습니다.";

"help_text_large_touch_targets_simplified" = "모든 버튼을 크게 만듭니다.\n\n다음과 같은 경우에 도움이 됩니다:\n• 작은 버튼을 탭하기 어려울 때\n• 손이 떨릴 때\n• 장갑을 끼고 있을 때\n• 한 손으로 사용할 때\n\n버튼이 44pt 대신 60pt가 됩니다.";

"help_text_reduce_motion_simplified" = "움직이는 애니메이션을 제거합니다.\n\n다음과 같은 경우에 도움이 됩니다:\n• 움직임 때문에 어지러울 때\n• 동작으로 두통이 생길 때\n• 정적인 화면을 선호할 때\n\n움직이는 대신 즉시 변경됩니다.";

"help_text_timeout_behavior_simplified" = "작업이 얼마나 오래 걸릴 수 있는지 조정합니다.\n\n선택:\n• 제한 없음: 작업이 중단되지 않음\n• 보통: 30초\n• 더 오래: 60초\n\n더 많은 시간이 필요하면 '제한 없음'을 선택하십시오.";

"help_text_simplified_gestures_simplified" = "어려운 제스처를 간단한 탭으로 대체합니다.\n\n다음과 같은 경우에 도움이 됩니다:\n• 복잡한 터치가 어려울 때\n• 간단한 탭을 선호할 때\n• 한 손으로 사용할 때\n\n모든 것이 간단한 탭을 사용합니다.";

"help_text_haptic_feedback_simplified" = "탭할 때 휴대폰이 진동합니다.\n\n다음에 도움이 됩니다:\n• 버튼을 탭했는지 확인\n• 오류나 경고 느끼기\n• 보지 않고 피드백 받기\n\n진동이 불편하면 끄십시오.";

"help_text_simplified_ui_simplified" = "앱을 더 단순하게 만듭니다.\n\n다음과 같은 경우에 도움이 됩니다:\n• 복잡한 화면에 혼란스러울 때\n• 단순한 레이아웃을 선호할 때\n• 앱이 처음일 때\n\n한 번에 더 적은 것을 표시합니다.";

"help_text_step_indicators_simplified" = "단계 진행 상황을 보여줍니다.\n\n다음에 도움이 됩니다:\n• 현재 위치 파악\n• 남은 단계 수 확인\n• 체계적으로 유지\n\n도트와 함께 '1/3단계'를 표시합니다.";

"help_text_verbose_descriptions_simplified" = "더 많은 설명을 제공합니다.\n\n다음에 도움이 됩니다:\n• 기능 이해\n• 앱 사용 방법 학습\n• 더 많은 세부 정보 얻기\n\n모든 곳에서 추가 도움을 제공합니다.";

"help_text_confirm_actions_simplified" = "중요한 동작에 대해 확인을 요청합니다.\n\n다음을 방지합니다:\n• 실수로 삭제\n• 원하지 않는 변경\n• 실수\n\n항상 '정말로 하시겠습니까?'라고 묻습니다.";

"help_text_manual_code_entry_simplified" = "스캔 대신 코드를 입력할 수 있습니다.\n\n다음 경우에 사용하십시오:\n• 카메라가 작동하지 않을 때\n• 코드를 스캔하기 어려울 때\n• 입력을 선호할 때\n\n'코드 직접 입력'을 탭하여 입력하십시오.";

"help_text_voice_input_simplified" = "입력하는 대신 코드를 말할 수 있습니다.\n\n다음과 같은 경우에 도움이 됩니다:\n• 입력하기 어려울 때\n• 말하는 것을 선호할 때\n• 핸즈프리로 사용하고 싶을 때\n\n마이크를 탭하고 명확하게 말하십시오.";

"help_text_qr_scanning_simplified" = "카메라를 사용하여 사각형 코드를 읽습니다.\n\n스캔 방법:\n1. 카메라를 코드에 향하십시오\n2. 코드를 정렬하십시오\n3. 읽힐 때까지 기다리십시오\n\n팁:\n• 충분한 조명 사용\n• 휴대폰을 안정적으로 유지\n• 코드를 평평하게 유지";

"help_text_age_verification_simplified" = "생일을 공유하지 않고 충분히 나이가 됐음을 증명합니다.\n\n작동 방식:\n1. 업체가 요청을 생성합니다\n2. 코드를 스캔합니다\n3. 앱이 증명을 생성합니다\n4. 업체가 충분히 나이가 됐음을 확인합니다\n\n생일은 비공개로 유지됩니다.";

"help_text_credentials_simplified" = "휴대폰에 저장된 나이의 디지털 증명입니다.\n\n특징:\n• 휴대폰에만 있습니다\n• 복사할 수 없습니다\n• 비공개로 유지됩니다\n• 언제든지 삭제할 수 있습니다\n\n정부 사무소에서 받습니다.";

"help_text_zero_knowledge_simplified" = "세부 정보를 공유하지 않고 무언가를 증명합니다.\n\n예시:\n• 기존 방식: 신분증 제시 (정확한 생일 표시)\n• 새로운 방식: 18세 이상임을 증명 (생일은 비공개)\n\n이것이 귀하의 정보를 비공개로 유지합니다.";

"help_text_credential_issuance_simplified" = "디지털 나이 증명 받기.\n\n단계:\n1. 정부 사무소 방문\n2. 신분증 제시\n3. 코드 받기\n4. 코드 스캔\n5. 증명이 휴대폰에 저장됩니다\n\n한 번 하면 여러 번 사용할 수 있습니다.";

"help_text_officer_mode_simplified" = "정부 직원이 증명을 만들기 위한 모드입니다.\n\n필요한 것:\n• 담당자 비밀번호\n• 사용 권한\n• 확인할 사용자의 신분증\n\n단계:\n1. 담당자로 로그인\n2. 사용자의 신분증 확인\n3. 생일 입력\n4. 코드 생성\n5. 사용자가 코드 스캔\n\n공인된 직원만 사용 가능합니다.";

