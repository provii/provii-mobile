/* Локализирани описания за разрешения на Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet се нуждае от достъп до камерата, за да сканира QR кодове за получаване на удостоверения и верификация на възраст.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet използва NFC за комуникация с Вашия YubiKey за сигурно удостоверяване на служителя.";

