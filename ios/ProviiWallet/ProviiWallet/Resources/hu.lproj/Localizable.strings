/* Help Text Descriptions */
"help_text_extra_large_text" = "A Nagyon nagy szöveg az alkalmazás összes szövegét 50%-kal növeli.\n\nEz hasznos a következők számára:\n• Gyengénlátók\n• Olvasási nehézségek\n• Korral járó látásváltozások\n\nMűködik az iOS Dinamikus Típussal a még nagyobb méretekért.";
"help_text_contrast_level" = "A Kontraszt szint szabályozza a szöveg és a háttér kontrasztarányát.\n\nHárom szint érhető el:\n• Standard: Alapértelmezett színek\n• Magas (AA): 4,5:1 kontrasztarány – megfelel az AA szabványnak\n• Maximum (AAA): 7:1 kontrasztarány – megfelel a legmagasabb AAA szabványnak\n\nA nagyobb kontraszt minden fényviszony mellett megkönnyíti a szöveg olvasását.";
"help_text_high_contrast" = "A Nagy kontrasztú mód növeli a szöveg és a háttér kontrasztját, megkönnyítve az olvasást.\n\nEz hasznos a következők számára:\n• Gyengénlátók\n• Színérzékenyek\n• Erős fényes képernyős környezetek\n\nEngedélyezéskor:\n• A szöveg fehéren fekete lesz\n• Elemek köré kereteket ad\n• Egyszerűsíti a színeket";
"help_text_reduce_transparency" = "Az Átlátszóság csökkentése eltávolítja az elmosódási és átlátszósági effektusokat az alkalmazásból.\n\nEz segít:\n• A szöveg olvashatóságának javításában\n• A vizuális összetettség csökkentésében\n• A teljesítmény javításában régebbi eszközökön\n• A tartalom kiszámíthatóbbá tételében";
"help_text_color_blind_mode" = "A Színvak módok a különböző típusú színlátási hiányhoz igazítják a színeket.\n\nElérhető módok:\n• Protanópia: Piros-vak (nehézség a piros látásával)\n• Deuteranópia: Zöld-vak (nehézség a zöld látásával)\n• Tritanópia: Kék-vak (nehézség a kék látásával)\n• Monokróm: Csak szürkeárnyalatos\n\nEzek a módok biztosítják, hogy a fontos információk ne csak szín alapján legyenek közölve.";
"help_text_line_spacing" = "A Sorköz szabályozza a szövegsorok közötti távolságot.\n\n• Tartomány: 1,0-szoros – 2,0-szoros\n• AAA szabvány: legalább 1,5-szoros\n• Alapértelmezett: 1,0-szoros\n\nA megnövelt sorköz megkönnyíti a szöveg olvasását és segít megelőzni a sorok kihagyását.";
"help_text_paragraph_spacing" = "A Bekezdésköz szabályozza a bekezdések közötti távolságot.\n\n• Tartomány: 1,0-szoros – 3,0-szoros\n• AAA szabvány: legalább 2,0-szoros\n• Alapértelmezett: 1,0-szoros\n\nA megnövelt bekezdésköz segít megkülönböztetni a szöveg különböző részeit.";
"help_text_letter_spacing" = "A Betűköz szabályozza az egyes karakterek közötti távolságot.\n\n• Tartomány: 0,0 em – 0,2 em\n• AAA szabvány: legalább 0,12 em\n• Alapértelmezett: 0,0 em\n\nA megnövelt betűköz javítja a karakterfelismerést és az olvashatóságot.";
"help_text_text_width" = "A Szövegszélesség szabályozza a maximális sorhoszszt a kényelmes olvasáshoz.\n\nLehetőségek:\n• Teljes szélesség: Nincs maximum\n• Kényelmes (80 karakter): Olvasáshoz optimális\n• Keskeny (60 karakter): Koncentrált olvasáshoz\n\nAz AAA irányelvek soronként legfeljebb 80 karaktert ajánlanak.";
"help_text_large_touch_targets" = "A Nagyobb érintési célterületek az összes gombot és interaktív elemet legalább 60 pontos méretűre növelik.\n\nEz hasznos:\n• Mozgáskorlátozott felhasználóknak\n• Remegéssel küzdőknek\n• Kesztyűvel való használathoz\n• Egykezes használathoz\n\nA standard minimum 44 pont; ez a beállítás 60 pontra növeli.";
"help_text_reduce_motion" = "A Mozgás csökkentése minimalizálja vagy eltávolítja az animációkat az alkalmazásból.\n\nEz hasznos a következők számára:\n• Mozgásérzékenyek\n• Vesztibuláris zavarokkal küzdők\n• Epilepsziások\n• Migrén kiváltó tényezők\n\nEngedélyezéskor az animációkat azonnali átmenetek váltják fel.";
"help_text_timeout_behavior" = "Az Időtúllépési viselkedés szabályozza, mennyi ideig tarthatnak a műveletek az időtúllépés előtt.\n\nLehetőségek:\n• Nincs időtúllépés (AAA): A műveletek soha nem lépnek időtúllépésbe\n• Standard (30s): Alapértelmezett időtúllépés\n• Kiterjesztett (60s): A standard idő kétszerese\n\nAz időtúllépés nélküli mód megfelel az AAA akadálymentesítési szabványoknak.";
"help_text_simplified_gestures" = "Az Egyszerűsített kézmozdulatok az összetett többérintéses kézmozdulatokat egyszerű koppintásokra csökkentik.\n\nEz hasznos:\n• Mozgáskorlátozott felhasználóknak\n• Korlátozott ügyességűeknek\n• Segédeszközöket használóknak\n• Egykezes használathoz\n\nAz összetett kézmozdulatokat gombok és egyszerű koppintások váltják fel.";
"help_text_haptic_feedback" = "A Haptikus visszajelzés rezgéses visszajelzést biztosít a műveletekhez és értesítésekhez.\n\nEz hasznos:\n• A gombnyomások megerősítéséhez\n• Hibák vagy figyelmeztetések jelzéséhez\n• Nem vizuális visszajelzés nyújtásához\n• Hallás- vagy látássérült felhasználóknak\n\nLetilthatja, ha a rezgések kellemetlenek.";
"help_text_simplified_ui" = "Az Egyszerűsített felület csökkenti a vizuális összetettséget az alkalmazásban.\n\nEz hasznos:\n• Kognitív fogyatékossággal élőknek\n• Tanulási nehézségekkel küzdőknek\n• Figyelmi zavarokkal élőknek\n• Új vagy tapasztalatlan felhasználóknak\n\nEngedélyezéskor:\n• Kevesebb elem a képernyőn\n• Nagyobb, áttekinthetőbb vezérlők\n• Kevesebb vizuális zaj";
"help_text_step_indicators" = "A Lépésjelzők megmutatják a haladását a többlépéses folyamatokon keresztül.\n\nEz segít:\n• Megérteni, hol tart a folyamatban\n• Tudni, hány lépés maradt\n• Csökkenteni a kognitív terhelést\n• Egyértelmű struktúrát biztosítani\n\nMegjelenít: „%d. lépés / %d” vizuális haladási pontokkal.";
"help_text_verbose_descriptions" = "A Részletes leírások kiegészítő magyarázó szöveget nyújt az alkalmazásban.\n\nEz hasznos:\n• Az összetett funkciók megértéséhez\n• Az alkalmazás használatának megtanulásához\n• Kognitív támogatáshoz\n• Képernyőolvasó felhasználóknak\n\nKontextust és utasításokat biztosít az összes funkcióhoz.";
"help_text_confirm_actions" = "A Műveletek megerősítése megerősítést kér a fontos műveletek előtt.\n\nEz segít megelőzni:\n• Véletlenszerű törléseket\n• Nem szándékos módosításokat\n• Korai beküldéseket\n• Adatvesztést\n\nMegjegyzés: A romboló műveletek mindig megerősítést igényelnek (AAA követelmény).";
"help_text_manual_code_entry" = "A Kézi kódbevitel lehetővé teszi, hogy kódokat gépeljen be QR-kódok beolvasása helyett.\n\nEz hasznos, ha:\n• A kamera nem működik\n• A QR-kód sérült vagy nem olvasható\n• Képernyőolvasót használ\n• Szívesebben gépel, mint beolvas\n\nEgyszerűen koppintson a „Kód kézi megadása” lehetőségre a képernyőn látható kód begépeléséhez.";
"help_text_voice_input" = "A Hangbevitel lehetővé teszi, hogy kódokat mondjon be beolvasás vagy gépelés helyett.\n\nEz hasznos:\n• Korlátozott mozgékonyság esetén\n• Képernyőolvasó felhasználóknak\n• Kézzel szabad használathoz\n• Hang preferálásához\n\nKoppintson a mikrofon gombra, és mondja be érthetően, amikor szólítják.";
"help_text_qr_scanning" = "A QR-kód beolvasás a kamerát használja a Quick Response kódok olvasásához.\n\nBeolvasási mód:\n1. Irányítsa a kamerát a QR-kódra\n2. Igazítsa a kódot a keretbe\n3. Várja az automatikus felismerést\n\nTippek:\n• Biztosítson jó megvilágítást\n• Tartsa stabilan az eszközt\n• Tartsa a QR-kódot laposan és akadálymentesen\n• Ha a beolvasás sikertelen, próbálja a Kézi kódbevitelt";
"help_text_age_verification" = "Az Életkor-ellenőrzés bizonyítja, hogy megfelel egy életkori követelménynek anélkül, hogy felfedné tényleges életkorát vagy születési dátumát.\n\nMűködési elve:\n1. Az ellenőrző kihívást generál\n2. Beolvassa a QR-kódot vagy kézzel megadja\n3. Az alkalmazás zéró tudásbizonyítékot hoz létre\n4. Az ellenőrző megerősíti, hogy megfelel a követelménynek\n\nAdatvédelem:\n• A születési dátumát soha nem osztjuk meg\n• Az ellenőrző csak azt tudja meg, hogy megfelel-e a követelménynek\n• Nincs nyomon követés vagy adatgyűjtés";
"help_text_credentials" = "A Digitális hitelesítő adatok az eszközén biztonságosan tárolt kriptográfiai életkori bizonyítékok.\n\nJellemzők:\n• Csak az eszközén tárolódnak\n• Nem másolhatók és nem hamisíthatók\n• Adatvédelmet megőrző ellenőrzéshez használhatók\n• Bármikor törölhetők\n\nJogosult kibocsátótól (például kormányzati irodától) kell hitelesítő adatot igényelni, mielőtt igazolni tudja az életkorát.";
"help_text_zero_knowledge" = "A Zéró tudásbizonyítékok lehetővé teszik, hogy valamit igazoljon anélkül, hogy felfedné a mögöttes információt.\n\nPélda:\n• Hagyományos mód: Azonosító bemutatása (felfedi a pontos születési napot)\n• Zéró tudás: Igazolja, hogy 18 éves feletti, anélkül hogy megmutatná a születési napot\n\nElőnyök:\n• Maximális adatvédelem\n• Nincs személyes adat megosztva\n• Kriptográfiailag biztonságos\n• Nem hamisítható és nem játszható vissza\n\nEz az alapvető technológia, amely a Provii Wallet privátságát biztosítja.";
"help_text_credential_issuance" = "A Hitelesítő adat kibocsátása az a folyamat, amelynek során digitális életkori hitelesítő adatot igényel egy jogosult kibocsátótól.\n\nLépések:\n1. Látogasson el egy jogosult kibocsátóhoz (pl. kormányzati irodához)\n2. Igazolja személyazonosságát hivatalos azonosítóval\n3. Kapjon QR-kódot vagy mélyhivatkozást a kibocsátótól\n4. Olvassa be a QR-kódot vagy koppintson a hivatkozásra\n5. A hitelesítő adat helyileg kerül kiszámításra és az eszközén tárolódik\n\nA vak tanúsítási folyamat biztosítja, hogy a születési dátuma soha ne kerüljön hálózaton továbbításra. Ezt csak egyszer kell elvégeznie. A hitelesítő adatát ezután korlátlan számú ellenőrzéshez használhatja.";
"help_text_officer_mode" = "A Tisztviselői mód a jogosult kibocsátók számára szolgál arra, hogy hitelesítő adatokat hozzanak létre a felhasználóknak.\n\nEhhez a módhoz szükséges:\n• Tisztviselői hitelesítés YubiKey-jel\n• Engedélyezés a kibocsátó hatóságtól\n• A felhasználó azonosítójának fizikai ellenőrzése\n\nFolyamat:\n1. Bejelentkezés tisztviselőként\n2. A felhasználó hivatalos azonosítójának ellenőrzése\n3. A felhasználó születési dátumának megadása\n4. Tanúsítási QR-kód generálása\n5. A felhasználó beolvassa a kódot a hitelesítő adat megszerzéséhez\n\nEzt a módot csak jogosult személyzet használhatja.";

/* Simplified Help Text (Reading Level: Grade 6-8) */
"help_text_extra_large_text_simplified" = "Az összes szöveget 50%-kal nagyobbá teszi.\n\nSegít, ha:\n• Nehezen látja a szöveget\n• Nehezen olvas\n• Nagyobb szövegre van szüksége\n\nMűködik a telefon szövegméret-beállításával.";

"help_text_contrast_level_simplified" = "Megváltoztatja, mennyire sötét a szöveg.\n\nHárom választási lehetőség:\n• Standard: Normál színek\n• Magas: Sötétebb szöveg a könnyű olvasáshoz\n• Maximum: Nagyon sötét szöveg a legjobb olvashatóságért\n\nA sötétebb szöveg könnyebben olvasható.";

"help_text_high_contrast_simplified" = "Könnyebben láthatóvá teszi a szöveget.\n\nSegít, ha:\n• Nehezen látja a szöveget\n• Sötétebb szövegre van szüksége\n• Erős fényben használja az alkalmazást\n\nA szöveg fehéren feketévé válik.";

"help_text_reduce_transparency_simplified" = "Eltávolítja az elmosódott effektusokat.\n\nEz segít:\n• A szöveg átlátszóbbá tételében\n• Az alkalmazás egyszerűsítésében\n• Régebbi telefonok gyorsításában\n\nMindennek szilárdabb megjelenése lesz.";

"help_text_color_blind_mode_simplified" = "Megváltoztatja a színeket a jobb láthatóságért.\n\nLehetőségek:\n• Piros-vak mód\n• Zöld-vak mód\n• Kék-vak mód\n• Csak szürke mód\n\nSegít látni a fontos dolgokat.";

"help_text_line_spacing_simplified" = "Megváltoztatja a szövegsorok közötti távolságot.\n\n1,0-szoros és 2,0-szoros között választhat.\nAlapértelmezett: 1,0-szoros.\n\nTöbb távolság megkönnyíti az olvasást.";

"help_text_paragraph_spacing_simplified" = "Megváltoztatja a bekezdések közötti távolságot.\n\n1,0-szoros és 3,0-szoros között választhat.\nAlapértelmezett: 1,0-szoros.\n\nTöbb távolság segít látni, hol kezdődnek az új gondolatok.";

"help_text_letter_spacing_simplified" = "Megváltoztatja a betűk közötti távolságot.\n\n0,0 és 0,2 között választhat.\nAlapértelmezett: 0,0.\n\nTöbb távolság tisztábbá teszi a betűket.";

"help_text_text_width_simplified" = "Szabályozza, milyen széles a szöveg.\n\nLehetőségek:\n• Teljes szélesség: Egész képernyőt használja\n• Közepes: Olvasáshoz jó\n• Keskeny: Koncentráláshoz a legjobb\n\nA közepes szélesség a legkönnyebben olvasható.";

"help_text_large_touch_targets_simplified" = "Az összes gombot nagyobbá teszi.\n\nSegít, ha:\n• Nehéz a kis gombokat koppintani\n• Remeg a keze\n• Kesztyűt visel\n• Egy kézzel használja\n\nA gombok 44 pont helyett 60 pontossá válnak.";

"help_text_reduce_motion_simplified" = "Eltávolítja a mozgó animációkat.\n\nSegít, ha:\n• A mozgás szédülést okoz\n• Fejfájást kap a mozgástól\n• Szívesebben látja, ha minden helyben marad\n\nA dolgok mozgás helyett azonnal változnak.";

"help_text_timeout_behavior_simplified" = "Szabályozza, mennyi ideig tarthatnak a feladatok.\n\nLehetőségek:\n• Nincs korlát: A feladatok soha nem állnak le\n• Normal: 30 másodperc\n• Hosszabb: 60 másodperc\n\nVálassza a „Nincs korlát” lehetőséget, ha több időre van szüksége.";

"help_text_simplified_gestures_simplified" = "A nehéz kézmozdulatokat egyszerű koppintásokkal helyettesíti.\n\nSegít, ha:\n• Nehéz az összetett érintések elvégzése\n• Egyszerű koppintásokat preferál\n• Egy kézzel használja\n\nMindenhez egyszerű koppintásokat használ.";

"help_text_haptic_feedback_simplified" = "Rezgést érez, amikor koppint.\n\nSegít:\n• Tudni, hogy megkoppintott egy gombot\n• Érezni a hibákat vagy figyelmeztetéseket\n• Visszajelzést kapni anélkül, hogy nézne\n\nKapcsolja ki, ha a rezgések zavarnak.";

"help_text_simplified_ui_simplified" = "Az alkalmazást egyszerűbbé teszi.\n\nSegít, ha:\n• Összezavarja a zsúfolt képernyő\n• Egyszerű elrendezéseket preferál\n• Új az alkalmazásban\n\nEgyszerre kevesebb dolgot mutat.";

"help_text_step_indicators_simplified" = "Megmutatja a haladását a lépéseken keresztül.\n\nSegít:\n• Tudni, hol tart\n• Látni, hány lépés maradt\n• Szervezett maradni\n\nMegjelenít: „1. lépés / 3” pontokkal.";

"help_text_verbose_descriptions_simplified" = "Több magyarázatot ad.\n\nSegít:\n• A funkciók megértésében\n• Az alkalmazás használatának megtanulásában\n• Több részlet megszerzésében\n\nMindenütt extra segítséget nyújt.";

"help_text_confirm_actions_simplified" = "Megkérdezi, hogy megerősíti-e a fontos műveleteket.\n\nSegít megelőzni:\n• Véletlenszerű törléseket\n• Nem kívánt módosításokat\n• Hibákat\n\nMindig megkérdezi: „Biztos benne?”";

"help_text_manual_code_entry_simplified" = "Lehetővé teszi, hogy kódokat gépeljen be beolvasás helyett.\n\nHasználja, ha:\n• A kamera nem működik\n• A kód nehéz beolvasni\n• Szívesebben gépel\n\nKoppintson a „Kód kézi megadása” gombra a gépeléshez.";

"help_text_voice_input_simplified" = "Lehetővé teszi, hogy kódokat mondjon be gépelés helyett.\n\nSegít, ha:\n• Nehéz gépelni\n• Inkább beszél\n• Kézzel szabad használatot szeretne\n\nKoppintson a mikrofonra és mondja be érthetően.";

"help_text_qr_scanning_simplified" = "A kameráját használja a négyzetes kódok olvasásához.\n\nBeolvasási mód:\n1. Irányítsa a kamerát a kódra\n2. Igazítsa be a kódot\n3. Várja meg az olvasást\n\nTippek:\n• Használjon jó megvilágítást\n• Tartsa stabilan a telefont\n• Tartsa a kódot laposan";

"help_text_age_verification_simplified" = "Igazolja, hogy elég idős anélkül, hogy megmutatná a születési napját.\n\nMűködési elve:\n1. A vállalkozás kérést hoz létre\n2. Beolvassa a kódjukat\n3. Az alkalmazás bizonyítékot hoz létre\n4. A vállalkozás megerősíti, hogy elég idős\n\nA születési napja privát marad.";

"help_text_credentials_simplified" = "Az életkora digitális bizonyítéka, amelyet a telefonján tárol.\n\nJellemzők:\n• Csak a telefonján van\n• Nem másolható\n• Megőrzi az adatvédelmet\n• Bármikor törölheti\n\nEgy kormányzati irodától kapja meg.";

"help_text_zero_knowledge_simplified" = "Bizonyít valamit anélkül, hogy megosztaná a részleteket.\n\nPélda:\n• Régi mód: Megmutatja az azonosítóját (megmutatja a pontos születési napot)\n• Új mód: Igazolja, hogy 18 éves feletti (a születési nap privát marad)\n\nEz megőrzi az adatvédelmét.";

"help_text_credential_issuance_simplified" = "Digitális életkori bizonyítékának megszerzése.\n\nLépések:\n1. Menjen egy kormányzati irodába\n2. Mutassa be az azonosítóját\n3. Kapjon egy kódot\n4. Olvassa be a kódot\n5. A bizonyítéka elmentődik a telefonján\n\nEzt egyszer csinálja meg. Ezután sokszor használhatja.";

"help_text_officer_mode_simplified" = "Kormányzati dolgozók számára a bizonyítékok létrehozásához.\n\nSzükséges:\n• Tisztviselői jelszó\n• Használati engedély\n• Ellenőrizendő felhasználói azonosító\n\nLépések:\n1. Bejelentkezés tisztviselőként\n2. Ellenőrizze a felhasználó azonosítóját\n3. Adja meg a születési napját\n4. Hozzon létre kódot\n5. A felhasználó beolvassa a kódot\n\nCsak jogosult dolgozók számára.";

