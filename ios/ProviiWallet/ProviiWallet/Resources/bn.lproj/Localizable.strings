"help_text_high_contrast" = "উচ্চ কন্ট্রাস্ট মোড টেক্সট ও ব্যাকগ্রাউন্ডের মধ্যে কন্ট্রাস্ট বাড়িয়ে পড়া সহজ করে।\n\nযাদের জন্য সহায়ক:\n• কম দৃষ্টিশক্তি\n• রঙ সংবেদনশীলতা\n• উজ্জ্বল স্ক্রিন পরিবেশ\n\nচালু হলে:\n• টেক্সট সাদার উপর কালো হয়\n• উপাদানে বর্ডার যোগ হয়\n• রঙ সরলীকৃত হয়";
"help_text_reduce_transparency" = "স্বচ্ছতা হ্রাস অ্যাপ জুড়ে ব্লার ও স্বচ্ছতার প্রভাব সরিয়ে দেয়।\n\nএটি সাহায্য করে:\n• টেক্সট পাঠযোগ্যতা উন্নত করতে\n• দৃশ্যগত জটিলতা কমাতে\n• পুরনো ডিভাইসে পারফরম্যান্স বাড়াতে\n• বিষয়বস্তু আরও পূর্বানুমানযোগ্য করতে";
"help_text_color_blind_mode" = "বর্ণান্ধ মোড বিভিন্ন ধরনের রঙ দৃষ্টিজনিত প্রতিবন্ধিতার জন্য রঙ সামঞ্জস্য করে।\n\nউপলব্ধ মোড:\n• প্রোটানোপিয়া: লাল-অন্ধ (লাল দেখতে অসুবিধা)\n• ডিউটেরানোপিয়া: সবুজ-অন্ধ (সবুজ দেখতে অসুবিধা)\n• ট্রিটানোপিয়া: নীল-অন্ধ (নীল দেখতে অসুবিধা)\n• একরঙা: শুধুমাত্র গ্রেস্কেল\n\nএই মোডগুলি নিশ্চিত করে যে গুরুত্বপূর্ণ তথ্য শুধুমাত্র রঙ দিয়ে প্রকাশ করা হয় না।";
"help_text_line_spacing" = "লাইন স্পেসিং টেক্সটের লাইনের মধ্যে স্পেস নিয়ন্ত্রণ করে।\n\n• পরিসীমা: 1.0x থেকে 2.0x\n• AAA মান: ন্যূনতম 1.5x\n• ডিফল্ট: 1.0x\n\nবর্ধিত লাইন স্পেসিং পড়া সহজ করে এবং লাইন এড়িয়ে যাওয়া রোধ করে।";
"help_text_paragraph_spacing" = "অনুচ্ছেদ স্পেসিং অনুচ্ছেদের মধ্যে স্পেস নিয়ন্ত্রণ করে।\n\n• পরিসীমা: 1.0x থেকে 3.0x\n• AAA মান: ন্যূনতম 2.0x\n• ডিফল্ট: 1.0x\n\nবর্ধিত অনুচ্ছেদ স্পেসিং টেক্সটের বিভিন্ন অংশ আলাদা করতে সাহায্য করে।";
"help_text_letter_spacing" = "অক্ষর স্পেসিং পৃথক অক্ষরের মধ্যে স্পেস নিয়ন্ত্রণ করে।\n\n• পরিসীমা: 0.0em থেকে 0.2em\n• AAA মান: ন্যূনতম 0.12em\n• ডিফল্ট: 0.0em\n\nবর্ধিত অক্ষর স্পেসিং অক্ষর চেনা ও পাঠযোগ্যতা উন্নত করে।";
"help_text_text_width" = "টেক্সট প্রস্থ সহজ পড়ার জন্য সর্বোচ্চ লাইন দৈর্ঘ্য নিয়ন্ত্রণ করে।\n\nবিকল্প:\n• পূর্ণ প্রস্থ: কোনো সর্বোচ্চ নেই\n• আরামদায়ক (80 অক্ষর): পড়ার জন্য সর্বোত্তম\n• সরু (60 অক্ষর): মনোযোগী পড়ার জন্য\n\nAAA নির্দেশিকা প্রতি লাইনে সর্বোচ্চ 80 অক্ষর সুপারিশ করে।";
"help_text_large_touch_targets" = "বড় টাচ টার্গেট সব বোতাম ও ইন্টারেক্টিভ উপাদান কমপক্ষে 60pt করে তোলে।\n\nযাদের জন্য সহায়ক:\n• মোটর প্রতিবন্ধিতা\n• কম্পন বা কাঁপুনি\n• গ্লাভস পরে অ্যাপ ব্যবহার\n• এক হাতে ব্যবহার\n\nস্ট্যান্ডার্ড সর্বনিম্ন 44pt; এই সেটিং 60pt-এ বাড়ায়।";
"help_text_reduce_motion" = "মোশন কমান অ্যাপ জুড়ে অ্যানিমেশন কমিয়ে বা সরিয়ে দেয়।\n\nযাদের জন্য সহায়ক:\n• মোশন সংবেদনশীলতা\n• ভেস্টিবুলার ব্যাধি\n• মৃগীরোগ\n• মাইগ্রেনের ট্রিগার\n\nচালু হলে অ্যানিমেশন তাৎক্ষণিক ট্রানজিশন দিয়ে প্রতিস্থাপিত হয়।";
"help_text_timeout_behavior" = "টাইমআউট আচরণ অপারেশনের সময়সীমা নিয়ন্ত্রণ করে।\n\nবিকল্প:\n• কোনো টাইমআউট নেই (AAA): অপারেশনের কখনো টাইমআউট হয় না\n• স্ট্যান্ডার্ড (30 সেকেন্ড): ডিফল্ট টাইমআউট\n• বর্ধিত (60 সেকেন্ড): স্ট্যান্ডার্ডের দ্বিগুণ সময়\n\nকোনো টাইমআউট মোড AAA অ্যাক্সেসিবিলিটি মান পূরণ করে।";
"help_text_simplified_gestures" = "সরলীকৃত জেসচার জটিল মাল্টি-টাচ জেসচার সহজ ট্যাপে পরিণত করে।\n\nযাদের জন্য সহায়ক:\n• মোটর প্রতিবন্ধিতা\n• সীমিত আঙুলের দক্ষতা\n• সহায়ক ডিভাইস ব্যবহার\n• এক হাতে অপারেশন\n\nজটিল জেসচার বোতাম ও সহজ ট্যাপ দিয়ে প্রতিস্থাপিত হয়।";
"help_text_haptic_feedback" = "হ্যাপটিক ফিডব্যাক কাজ ও বিজ্ঞপ্তির জন্য কম্পন প্রদান করে।\n\nযাদের জন্য সহায়ক:\n• বোতাম চাপা নিশ্চিত করতে\n• ত্রুটি বা সতর্কতা জানাতে\n• অ-দৃশ্যমান ফিডব্যাক দিতে\n• শ্রবণ বা দৃষ্টি প্রতিবন্ধী ব্যবহারকারীদের\n\nকম্পন অস্বস্তিকর হলে এটি অক্ষম করতে পারবেন।";
"help_text_simplified_ui" = "সরলীকৃত ইন্টারফেস অ্যাপ জুড়ে দৃশ্যগত জটিলতা কমায়।\n\nযাদের জন্য সহায়ক:\n• জ্ঞানীয় প্রতিবন্ধিতা\n• শেখার অসুবিধা\n• মনোযোগের ব্যাধি\n• নতুন বা অনভিজ্ঞ ব্যবহারকারী\n\nচালু হলে:\n• স্ক্রিনে কম উপাদান\n• বড়, স্পষ্টতর নিয়ন্ত্রণ\n• কম দৃশ্যগত ব্যস্ততা";
"help_text_step_indicators" = "ধাপ নির্দেশক বহু-ধাপের প্রক্রিয়ায় আপনার অগ্রগতি দেখায়।\n\nএটি সাহায্য করে:\n• আপনি কোথায় আছেন বুঝতে\n• কতটা ধাপ বাকি জানতে\n• জ্ঞানীয় চাপ কমাতে\n• স্পষ্ট কাঠামো দিতে\n\nদৃশ্যমান অগ্রগতি বিন্দুসহ 'X এর মধ্যে ধাপ Y' দেখায়।";
"help_text_verbose_descriptions" = "বিস্তারিত বিবরণ অ্যাপ জুড়ে অতিরিক্ত ব্যাখ্যামূলক টেক্সট প্রদান করে।\n\nযাদের জন্য সহায়ক:\n• জটিল ফিচার বুঝতে\n• অ্যাপ ব্যবহার শিখতে\n• জ্ঞানীয় সহায়তার জন্য\n• স্ক্রিন রিডার ব্যবহারকারীদের\n\nসব ফিচারের জন্য প্রেক্ষাপট ও নির্দেশনা প্রদান করে।";
"help_text_confirm_actions" = "কার্যক্রম নিশ্চিত করুন গুরুত্বপূর্ণ কাজের আগে নিশ্চিতকরণ চায়।\n\nএটি রোধ করতে সাহায্য করে:\n• আকস্মিক মুছে ফেলা\n• অনিচ্ছাকৃত পরিবর্তন\n• অপরিপক্ক জমা দেওয়া\n• ডেটা হারানো\n\nনোট: ধ্বংসাত্মক কাজের সব সময় নিশ্চিতকরণ প্রয়োজন (AAA প্রয়োজনীয়তা)।";
"help_text_manual_code_entry" = "ম্যানুয়াল কোড এন্ট্রি আপনাকে QR কোড স্ক্যান না করে কোড টাইপ করতে দেয়।\n\nযখন সহায়ক:\n• ক্যামেরা কাজ না করলে\n• QR কোড ক্ষতিগ্রস্ত বা অস্পষ্ট হলে\n• স্ক্রিন রিডার ব্যবহার করলে\n• স্ক্যানের চেয়ে টাইপিং পছন্দ হলে\n\nস্ক্রিনে দেখানো কোড টাইপ করতে 'ম্যানুয়ালি কোড লিখুন' ট্যাপ করুন।";
"help_text_voice_input" = "ভয়েস ইনপুট আপনাকে স্ক্যান বা টাইপ না করে কোড বলতে দেয়।\n\nযাদের জন্য সহায়ক:\n• সীমিত গতিশীলতা\n• স্ক্রিন রিডার ব্যবহারকারী\n• হাত-মুক্ত অপারেশন\n• ভয়েস পছন্দ\n\nমাইক্রোফোন বোতাম ট্যাপ করুন এবং অনুরোধ করলে স্পষ্টভাবে বলুন।";
"help_text_qr_scanning" = "QR কোড স্ক্যানিং আপনার ক্যামেরা ব্যবহার করে কুইক রেসপন্স কোড পড়ে।\n\nস্ক্যান করার উপায়:\n1. QR কোডে ক্যামেরা তাক করুন\n2. ফ্রেমে কোড সারিবদ্ধ করুন\n3. স্বয়ংক্রিয় শনাক্তের জন্য অপেক্ষা করুন\n\nটিপস:\n• ভালো আলো নিশ্চিত করুন\n• ডিভাইস স্থির রাখুন\n• QR কোড সমতল ও অবাধ রাখুন\n• স্ক্যান ব্যর্থ হলে ম্যানুয়াল কোড এন্ট্রি ব্যবহার করুন";
"help_text_age_verification" = "বয়স যাচাই আপনার প্রকৃত বয়স বা জন্ম তারিখ প্রকাশ না করে বয়সের প্রয়োজনীয়তা পূরণের প্রমাণ দেয়।\n\nএটি কীভাবে কাজ করে:\n1. যাচাইকারী একটি চ্যালেঞ্জ তৈরি করে\n2. আপনি QR কোড স্ক্যান করেন বা ম্যানুয়ালি লিখুন\n3. অ্যাপ একটি শূন্য-জ্ঞান প্রমাণ তৈরি করে\n4. যাচাইকারী নিশ্চিত করে আপনি প্রয়োজনীয়তা পূরণ করেছেন\n\nগোপনীয়তা সুরক্ষিত:\n• আপনার জন্ম তারিখ কখনো শেয়ার হয় না\n• যাচাইকারী শুধু জানে আপনি প্রয়োজনীয়তা পূরণ করেছেন কিনা\n• কোনো ট্র্যাকিং বা ডেটা সংগ্রহ নেই";
"help_text_credentials" = "ডিজিটাল প্রমাণপত্র হলো আপনার ডিভাইসে নিরাপদে সংরক্ষিত আপনার বয়সের ক্রিপ্টোগ্রাফিক প্রমাণ।\n\nবৈশিষ্ট্য:\n• শুধুমাত্র আপনার ডিভাইসে সংরক্ষিত\n• কপি বা জাল করা যায় না\n• গোপনীয়তা-রক্ষাকারী যাচাইয়ের জন্য ব্যবহৃত\n• যেকোনো সময় মুছে ফেলা যায়\n\nবয়স যাচাই করার আগে আপনাকে একটি অনুমোদিত ইস্যুকারীর (যেমন সরকারি অফিস) কাছ থেকে প্রমাণপত্র নিতে হবে।";
"help_text_zero_knowledge" = "শূন্য-জ্ঞান প্রমাণ আপনাকে অন্তর্নিহিত তথ্য প্রকাশ না করে কোনো কিছু সত্য প্রমাণ করতে দেয়।\n\nউদাহরণ:\n• ঐতিহ্যগত: পরিচয়পত্র দেখান (সঠিক জন্মদিন প্রকাশ পায়)\n• শূন্য-জ্ঞান: জন্মদিন না দেখিয়ে প্রমাণ করুন আপনি 18 বছরের বেশি\n\nসুবিধা:\n• সর্বোচ্চ গোপনীয়তা সুরক্ষা\n• কোনো ব্যক্তিগত ডেটা শেয়ার হয় না\n• ক্রিপ্টোগ্রাফিকভাবে নিরাপদ\n• জাল বা পুনরায় ব্যবহার করা যায় না\n\nএটি Provii Wallet-কে গোপনীয় করে তোলার মূল প্রযুক্তি।";
"help_text_credential_issuance" = "প্রমাণপত্র ইস্যুয়েন্স হলো একটি অনুমোদিত ইস্যুকারীর কাছ থেকে আপনার ডিজিটাল বয়সের প্রমাণপত্র পাওয়ার প্রক্রিয়া।\n\nধাপ:\n1. অনুমোদিত ইস্যুকারীর কাছে যান (যেমন সরকারি অফিস)\n2. সরকারি পরিচয়পত্র দিয়ে আপনার পরিচয় প্রমাণ করুন\n3. ইস্যুকারীর কাছ থেকে QR কোড বা ডিপ লিংক পান\n4. QR কোড স্ক্যান করুন বা লিংকে ট্যাপ করুন\n5. প্রমাণপত্র স্থানীয়ভাবে গণনা হয়ে আপনার ডিভাইসে সংরক্ষিত হয়\n\nব্লাইন্ড সত্যায়ন প্রক্রিয়া নিশ্চিত করে যে আপনার জন্ম তারিখ নেটওয়ার্কে কখনো প্রেরণ হয় না।\nআপনাকে এটি শুধুমাত্র একবার করতে হবে। তারপর আপনার প্রমাণপত্র অসীম যাচাইয়ের জন্য ব্যবহার করা যাবে।";
"help_text_officer_mode" = "অফিসার মোড অনুমোদিত ইস্যুকারীদের জন্য ব্যবহারকারীদের প্রমাণপত্র তৈরি করতে।\n\nএই মোডের জন্য প্রয়োজন:\n• YubiKey দিয়ে অফিসার প্রমাণীকরণ\n• ইস্যু কর্তৃপক্ষের অনুমোদন\n• ব্যবহারকারীর পরিচয়পত্রের ভৌত যাচাই\n\nপ্রক্রিয়া:\n1. অফিসার হিসেবে প্রমাণীকরণ করুন\n2. ব্যবহারকারীর সরকারি পরিচয়পত্র যাচাই করুন\n3. ব্যবহারকারীর জন্ম তারিখ লিখুন\n4. সত্যায়ন QR কোড তৈরি করুন\n5. ব্যবহারকারী প্রমাণপত্র পেতে কোড স্ক্যান করে\n\nশুধুমাত্র অনুমোদিত কর্মীরা এই মোড ব্যবহার করবেন।";

