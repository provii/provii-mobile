/* Help Text Descriptions */
"help_text_extra_large_text" = "Sehr großer Text vergrößert den gesamten Text in der App um 50 %.\n\nDies ist hilfreich für Benutzer mit:\n• Eingeschränktem Sehvermögen\n• Leseschwierigkeiten\n• Altersbedingten Sehveränderungen\n\nFunktioniert mit dem iOS Dynamic Type für noch größere Schriften.";
"help_text_contrast_level" = "Kontraststufe steuert den Farbkontrast zwischen Text und Hintergründen.\n\nDrei Stufen verfügbar:\n• Standard: Standardfarben\n• Hoch (AA): 4,5:1-Kontrastverhältnis – AA-Standards\n• Maximum (AAA): 7:1-Kontrastverhältnis – höchste AAA-Standards\n\nHöherer Kontrast macht Text in allen Lichtverhältnissen leichter lesbar.";
"help_text_high_contrast" = "Hochkontrastmodus erhöht den Kontrast zwischen Text und Hintergrund für bessere Lesbarkeit.\n\nDies ist hilfreich für Benutzer mit:\n• Eingeschränktem Sehvermögen\n• Farbempfindlichkeit\n• Hellen Bildschirmumgebungen\n\nBei Aktivierung:\n• Text wird schwarz auf weiß\n• Elemente erhalten Rahmen\n• Farben werden vereinfacht";
"help_text_reduce_transparency" = "Transparenz reduzieren entfernt Unschärfe- und Transparenzeffekte in der App.\n\nDies hilft:\n• Lesbarkeit des Textes verbessern\n• Visuelle Komplexität reduzieren\n• Leistung auf älteren Geräten verbessern\n• Inhalte vorhersehbarer machen";
"help_text_color_blind_mode" = "Farbenblind-Modi passen Farben für verschiedene Arten von Farbsehschwäche an.\n\nVerfügbare Modi:\n• Protanopie: Rotblind\n• Deuteranopie: Grünblind\n• Tritanopie: Blaublind\n• Monochrom: Nur Graustufen\n\nDiese Modi stellen sicher, dass wichtige Informationen nicht allein durch Farbe vermittelt werden.";
"help_text_line_spacing" = "Zeilenabstand steuert den Abstand zwischen Textzeilen.\n\n• Bereich: 1,0-fach bis 2,0-fach\n• AAA-Standard: mindestens 1,5-fach\n• Standard: 1,0-fach\n\nVergrößerter Zeilenabstand erleichtert das Lesen und hilft, Zeilen nicht zu überspringen.";
"help_text_paragraph_spacing" = "Absatzabstand steuert den Abstand zwischen Absätzen.\n\n• Bereich: 1,0-fach bis 3,0-fach\n• AAA-Standard: mindestens 2,0-fach\n• Standard: 1,0-fach\n\nVergrößerter Absatzabstand hilft, verschiedene Textabschnitte zu unterscheiden.";
"help_text_letter_spacing" = "Buchstabenabstand steuert den Abstand zwischen einzelnen Zeichen.\n\n• Bereich: 0,0 em bis 0,2 em\n• AAA-Standard: mindestens 0,12 em\n• Standard: 0,0 em\n\nVergrößerter Buchstabenabstand verbessert Zeichenerkennung und Lesbarkeit.";
"help_text_text_width" = "Textbreite steuert die maximale Zeilenlänge für angenehmes Lesen.\n\nOptionen:\n• Volle Breite: Kein Maximum\n• Komfortabel (80 Zeichen): Optimal zum Lesen\n• Schmal (60 Zeichen): Für konzentriertes Lesen\n\nAAA-Richtlinien empfehlen maximal 80 Zeichen pro Zeile.";
"help_text_large_touch_targets" = "Größere Berührungsziele macht alle Schaltflächen und interaktiven Elemente mindestens 60 Punkte groß.\n\nDies ist hilfreich für:\n• Motorische Beeinträchtigungen\n• Zittern\n• App-Nutzung mit Handschuhen\n• Einhandbedienung\n\nDer Standardmindestabstand beträgt 44 Punkte; diese Einstellung erhöht ihn auf 60 Punkte.";
"help_text_reduce_motion" = "Bewegung reduzieren minimiert oder entfernt Animationen in der App.\n\nDies ist hilfreich für Benutzer mit:\n• Bewegungsempfindlichkeit\n• Vestibulären Störungen\n• Epilepsie\n• Migrauslösern\n\nBei Aktivierung werden Animationen durch sofortige Übergänge ersetzt.";
"help_text_timeout_behavior" = "Zeitlimit-Verhalten steuert, wie lange Vorgänge dauern können, bevor sie ablaufen.\n\nOptionen:\n• Kein Timeout (AAA): Vorgänge laufen nie ab\n• Standard (30 s): Standard-Timeout\n• Verlängert (60 s): Doppelte Standardzeit\n\nKein-Timeout-Modus erfüllt AAA-Barrierefreiheitsstandards.";
"help_text_simplified_gestures" = "Vereinfachte Gesten reduziert komplexe Mehrfingergesten auf einfache Tipp-Gesten.\n\nDies ist hilfreich für:\n• Motorische Beeinträchtigungen\n• Eingeschränkte Fingerfertigkeit\n• Nutzung von Hilfsmitteln\n• Einhandbedienung\n\nKomplexe Gesten werden durch Schaltflächen und einfaches Antippen ersetzt.";
"help_text_haptic_feedback" = "Haptisches Feedback bietet Vibrations-Feedback für Aktionen und Benachrichtigungen.\n\nDies ist hilfreich für:\n• Bestätigung von Schaltflächendrücken\n• Warnung bei Fehlern\n• Nicht-visuelle Rückmeldung\n• Benutzer mit Hör- oder Sehbeeinträchtigungen\n\nSie können dies deaktivieren, wenn Vibrationen unangenehm sind.";
"help_text_simplified_ui" = "Vereinfachte Benutzeroberfläche reduziert die visuelle Komplexität in der App.\n\nDies ist hilfreich für:\n• Kognitive Beeinträchtigungen\n• Lernschwierigkeiten\n• Aufmerksamkeitsstörungen\n• Neue oder unerfahrene Benutzer\n\nBei Aktivierung:\n• Weniger Elemente auf dem Bildschirm\n• Größere, klarere Steuerelemente\n• Weniger visuelles Rauschen";
"help_text_step_indicators" = "Schrittanzeigen zeigen Ihren Fortschritt bei mehrstufigen Prozessen.\n\nDies hilft:\n• Zu verstehen, wo Sie im Prozess sind\n• Zu wissen, wie viele Schritte noch verbleiben\n• Kognitive Belastung zu reduzieren\n• Klare Struktur zu bieten\n\nZeigt \"Schritt X von Y\" mit visuellen Fortschrittspunkten.";
"help_text_verbose_descriptions" = "Detaillierte Beschreibungen bieten zusätzlichen Erklärungstext in der App.\n\nDies ist hilfreich für:\n• Verstehen komplexer Funktionen\n• Lernen der App-Nutzung\n• Kognitive Unterstützung\n• Bildschirmleser-Benutzer\n\nBietet Kontext und Anleitungen für alle Funktionen.";
"help_text_confirm_actions" = "Aktionen bestätigen fragt vor wichtigen Aktionen nach Bestätigung.\n\nDies hilft, folgendes zu verhindern:\n• Versehentliches Löschen\n• Unbeabsichtigte Änderungen\n• Vorzeitiges Absenden\n• Datenverlust\n\nHinweis: Destruktive Aktionen erfordern immer Bestätigung (AAA-Anforderung).";
"help_text_manual_code_entry" = "Manuelle Codeeingabe ermöglicht das Eingeben von Codes statt QR-Codes zu scannen.\n\nDies ist hilfreich, wenn:\n• Kamera nicht funktioniert\n• QR-Code beschädigt oder unklar ist\n• Bildschirmleser verwendet wird\n• Tippen dem Scannen bevorzugt wird\n\nTippen Sie einfach auf \"Code manuell eingeben\", um den angezeigten Code einzugeben.";
"help_text_voice_input" = "Spracheingabe ermöglicht das Sprechen von Codes statt Scannen oder Tippen.\n\nDies ist hilfreich für:\n• Eingeschränkte Mobilität\n• Bildschirmleser-Benutzer\n• Freihändigen Betrieb\n• Bevorzugung von Sprache\n\nTippen Sie auf die Mikrofon-Schaltfläche und sprechen Sie deutlich, wenn Sie dazu aufgefordert werden.";
"help_text_qr_scanning" = "QR-Code-Scannen verwendet Ihre Kamera zum Lesen von Quick-Response-Codes.\n\nSo scannen Sie:\n1. Kamera auf QR-Code richten\n2. Code im Rahmen ausrichten\n3. Auf automatische Erkennung warten\n\nTipps:\n• Gute Beleuchtung sicherstellen\n• Gerät ruhig halten\n• QR-Code flach und unverdeckt halten\n• Bei Scanfehler manuelle Codeeingabe versuchen";
"help_text_age_verification" = "Altersverifizierung beweist, dass Sie eine Altersanforderung erfüllen, ohne Ihr tatsächliches Alter oder Geburtsdatum preiszugeben.\n\nSo funktioniert es:\n1. Prüfer generiert eine Challenge\n2. Sie scannen den QR-Code oder geben ihn manuell ein\n3. App erstellt einen Zero-Knowledge-Beweis\n4. Prüfer bestätigt, dass Sie die Anforderung erfüllen\n\nDatenschutz gewährleistet:\n• Ihr Geburtsdatum wird niemals weitergegeben\n• Prüfer erfährt nur, ob Sie die Anforderung erfüllen\n• Kein Tracking oder Datenerfassung";
"help_text_credentials" = "Digitale Nachweise sind kryptografische Altersnachweise, die sicher auf Ihrem Gerät gespeichert werden.\n\nFunktionen:\n• Nur auf Ihrem Gerät gespeichert\n• Können nicht kopiert oder gefälscht werden\n• Für datenschutzfreundliche Verifizierung verwendet\n• Können jederzeit gelöscht werden\n\nSie müssen einen Nachweis von einem autorisierten Aussteller (z. B. einer Behörde) erhalten, bevor Sie Ihr Alter verifizieren können.";
"help_text_zero_knowledge" = "Zero-Knowledge-Beweise ermöglichen es Ihnen, etwas als wahr zu beweisen, ohne die zugrunde liegenden Informationen preiszugeben.\n\nBeispiel:\n• Traditionell: Ausweis zeigen (zeigt genaues Geburtsdatum)\n• Zero-Knowledge: Nachweis, dass Sie über 18 sind, ohne Geburtsdatum zu zeigen\n\nVorteile:\n• Maximaler Datenschutz\n• Keine persönlichen Daten weitergegeben\n• Kryptografisch sicher\n• Kann nicht gefälscht oder wiederholt werden\n\nDies ist die Kerntechnologie, die Provii Wallet privat macht.";
"help_text_credential_issuance" = "Nachweisausstellung ist der Vorgang, bei dem Sie Ihren digitalen Altersnachweis von einem autorisierten Aussteller erhalten.\n\nSchritte:\n1. Autorisierten Aussteller besuchen (z. B. Behörde)\n2. Identität mit offiziellem Ausweis nachweisen\n3. QR-Code oder Deeplink vom Aussteller erhalten\n4. QR-Code scannen oder Link antippen\n5. Nachweis wird lokal berechnet und auf Ihrem Gerät gespeichert\n\nDas blinde Attestierungsverfahren stellt sicher, dass Ihr Geburtsdatum nie über das Netzwerk übertragen wird.\nDies muss nur einmal durchgeführt werden. Ihr Nachweis kann dann für unbegrenzte Verifizierungen verwendet werden.";
"help_text_officer_mode" = "Beamtenmodus ist für autorisierte Aussteller zum Erstellen von Nachweisen für Benutzer.\n\nDieser Modus erfordert:\n• Beamtenauthentifizierung mit YubiKey\n• Autorisierung von der Ausstellungsbehörde\n• Physische Überprüfung des Benutzerausweises\n\nProzess:\n1. Als Beamter authentifizieren\n2. Offiziellen Ausweis des Benutzers prüfen\n3. Geburtsdatum des Benutzers eingeben\n4. Attestierungs-QR-Code generieren\n5. Benutzer scannt Code, um Nachweis zu erhalten\n\nNur autorisiertes Personal sollte diesen Modus verwenden.";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "Macht den gesamten Text um 50 % größer.\n\nHilft Ihnen, wenn Sie:\n• Schwierigkeiten beim Sehen haben\n• Lesen schwierig finden\n• Größeren Text benötigen\n\nFunktioniert mit den Textgrößeneinstellungen Ihres Telefons.";
"help_text_contrast_level_simplified" = "Ändert, wie dunkel der Text ist.\n\nDrei Optionen:\n• Standard: Normale Farben\n• Hoch: Dunklerer Text für einfaches Lesen\n• Maximum: Sehr dunkler Text für bestes Lesen\n\nDunklerer Text ist einfacher zu lesen.";
"help_text_high_contrast_simplified" = "Macht Text einfacher zu sehen.\n\nHilft Ihnen, wenn Sie:\n• Schwierigkeiten beim Sehen haben\n• Dunkleren Text benötigen\n• Die App in hellem Licht nutzen\n\nText wird schwarz auf weiß.";
"help_text_reduce_transparency_simplified" = "Entfernt verschwommene Effekte.\n\nDies hilft:\n• Text klarer zu machen\n• App einfacher zu machen\n• Ältere Telefone zu beschleunigen\n\nAlles sieht fester aus.";
"help_text_color_blind_mode_simplified" = "Ändert Farben, damit Sie besser sehen.\n\nOptionen:\n• Rotblind-Modus\n• Grünblind-Modus\n• Blaublind-Modus\n• Nur Grau-Modus\n\nHilft Ihnen, wichtige Dinge zu sehen.";
"help_text_line_spacing_simplified" = "Ändert Abstand zwischen Textzeilen.\n\nSie können zwischen 1,0-fach und 2,0-fach wählen.\nStandard ist 1,0-fach.\n\nMehr Abstand erleichtert das Lesen.";
"help_text_paragraph_spacing_simplified" = "Ändert Abstand zwischen Absätzen.\n\nSie können zwischen 1,0-fach und 3,0-fach wählen.\nStandard ist 1,0-fach.\n\nMehr Abstand hilft Ihnen zu sehen, wo neue Gedanken beginnen.";
"help_text_letter_spacing_simplified" = "Ändert Abstand zwischen Buchstaben.\n\nSie können zwischen 0,0 und 0,2 wählen.\nStandard ist 0,0.\n\nMehr Abstand macht Buchstaben klarer.";
"help_text_text_width_simplified" = "Steuert, wie breit der Text ist.\n\nOptionen:\n• Volle Breite: Gesamten Bildschirm nutzen\n• Mittel: Gut zum Lesen\n• Schmal: Am besten zum Fokussieren\n\nMittlere Breite ist am einfachsten zu lesen.";
"help_text_large_touch_targets_simplified" = "Macht alle Schaltflächen größer.\n\nHilft Ihnen, wenn Sie:\n• Schwierigkeiten beim Antippen kleiner Schaltflächen haben\n• Zitternde Hände haben\n• Handschuhe tragen\n• Eine Hand verwenden\n\nSchaltflächen werden 60 Punkte statt 44 Punkte groß.";
"help_text_reduce_motion_simplified" = "Entfernt bewegte Animationen.\n\nHilft Ihnen, wenn:\n• Bewegung Sie schwindelig macht\n• Sie Kopfschmerzen durch Bewegung bekommen\n• Sie bevorzugen, dass alles stillbleibt\n\nDinge ändern sich sofort statt sich zu bewegen.";
"help_text_timeout_behavior_simplified" = "Steuert, wie lange Aufgaben dauern können.\n\nOptionen:\n• Kein Limit: Aufgaben hören nie auf\n• Normal: 30 Sekunden\n• Länger: 60 Sekunden\n\nWählen Sie 'Kein Limit', wenn Sie mehr Zeit benötigen.";
"help_text_simplified_gestures_simplified" = "Ersetzt schwierige Gesten durch einfache Tipps.\n\nHilft Ihnen, wenn Sie:\n• Schwierigkeiten mit komplexen Berührungen haben\n• Einfache Tipps bevorzugen\n• Eine Hand verwenden\n\nAlles verwendet einfache Tipps.";
"help_text_haptic_feedback_simplified" = "Lässt Ihr Telefon vibrieren, wenn Sie tippen.\n\nHilft Ihnen:\n• Zu wissen, wann Sie eine Schaltfläche gedrückt haben\n• Fehler oder Warnungen zu spüren\n• Rückmeldung ohne Hinsehen zu erhalten\n\nDeaktivieren, wenn Vibrationen stören.";
"help_text_simplified_ui_simplified" = "Macht die App einfacher.\n\nHilft Ihnen, wenn Sie:\n• Von vollen Bildschirmen verwirrt werden\n• Einfache Layouts bevorzugen\n• Neu in der App sind\n\nZeigt weniger Dinge auf einmal.";
"help_text_step_indicators_simplified" = "Zeigt Ihren Fortschritt durch Schritte.\n\nHilft Ihnen:\n• Zu wissen, wo Sie sind\n• Zu sehen, wie viele Schritte verbleiben\n• Organisiert zu bleiben\n\nZeigt 'Schritt 1 von 3' mit Punkten.";
"help_text_verbose_descriptions_simplified" = "Gibt Ihnen mehr Erklärungen.\n\nHilft Ihnen:\n• Funktionen zu verstehen\n• Zu lernen, die App zu nutzen\n• Mehr Details zu erhalten\n\nBietet überall zusätzliche Hilfe.";
"help_text_confirm_actions_simplified" = "Fragt Sie, wichtige Aktionen zu bestätigen.\n\nHilft, folgendes zu verhindern:\n• Versehentliches Löschen\n• Ungewollte Änderungen\n• Fehler\n\nSie werden immer gefragt 'Sind Sie sicher?'";
"help_text_manual_code_entry_simplified" = "Lässt Sie Codes eingeben statt zu scannen.\n\nVerwenden Sie dies, wenn:\n• Ihre Kamera nicht funktioniert\n• Der Code schwer zu scannen ist\n• Sie Tippen bevorzugen\n\nTippen Sie auf 'Code manuell eingeben', um zu tippen.";
"help_text_voice_input_simplified" = "Lässt Sie Codes sprechen statt zu tippen.\n\nHilft Ihnen, wenn Sie:\n• Schwierigkeiten beim Tippen haben\n• Lieber sprechen\n• Freihändige Nutzung möchten\n\nTippen Sie auf das Mikrofon und sprechen Sie deutlich.";
"help_text_qr_scanning_simplified" = "Verwendet Ihre Kamera zum Lesen quadratischer Codes.\n\nSo scannen Sie:\n1. Kamera auf den Code richten\n2. Code ausrichten\n3. Warten, bis er gelesen wird\n\nTipps:\n• Gute Beleuchtung verwenden\n• Telefon ruhig halten\n• Code flach halten";
"help_text_age_verification_simplified" = "Beweist, dass Sie alt genug sind, ohne Ihren Geburtstag preiszugeben.\n\nSo funktioniert es:\n1. Einrichtung erstellt eine Anfrage\n2. Sie scannen deren Code\n3. App erstellt einen Beweis\n4. Einrichtung bestätigt, dass Sie alt genug sind\n\nIhr Geburtstag bleibt privat.";
"help_text_credentials_simplified" = "Digitaler Altersbeweis auf Ihrem Telefon gespeichert.\n\nFunktionen:\n• Nur auf Ihrem Telefon\n• Kann nicht kopiert werden\n• Hält Sie privat\n• Kann jederzeit gelöscht werden\n\nSie erhalten ihn von einer Behörde.";
"help_text_zero_knowledge_simplified" = "Beweist etwas ohne Details zu teilen.\n\nBeispiel:\n• Alte Methode: Ausweis zeigen (zeigt genauen Geburtstag)\n• Neue Methode: Beweisen, dass Sie über 18 sind (Geburtstag bleibt privat)\n\nDies hält Ihre Informationen privat.";
"help_text_credential_issuance_simplified" = "Ihren digitalen Altersbeweis erhalten.\n\nSchritte:\n1. Zur Behörde gehen\n2. Ausweis vorzeigen\n3. Code erhalten\n4. Code scannen\n5. Beweis wird auf Ihrem Telefon gespeichert\n\nEinmal tun. Dann viele Male verwenden.";
"help_text_officer_mode_simplified" = "Für Behördenmitarbeiter zum Erstellen von Beweisen.\n\nErfordert:\n• Beamtenpasswort\n• Nutzungsberechtigung\n• Benutzerausweis zum Prüfen\n\nSchritte:\n1. Als Beamter anmelden\n2. Benutzerausweis prüfen\n3. Geburtstag eingeben\n4. Code erstellen\n5. Benutzer scannt Code\n\nNur für autorisiertes Personal.";

