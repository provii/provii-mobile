/* InfoPlist.strings - Malayalam (ml) */
/* Localizable permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "ക്രെഡൻഷ്യൽ ശേഖരണത്തിനും പ്രായ സ്ഥിരീകരണത്തിനുമായി QR കോഡ് സ്കാൻ ചെയ്യുന്നതിന് Provii Wallet-ന് ക്യാമറ ആക്സസ് ആവശ്യമാണ്.";

/* NFC Access */
"NFCReaderUsageDescription" = "സുരക്ഷിത ഉദ്യോഗസ്ഥ പ്രാമാണീകരണത്തിനായി നിങ്ങളുടെ YubiKey-മായി ആശയവിനിമയം നടത്താൻ Provii Wallet NFC ഉപയോഗിക്കുന്നു.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "ആക്സസിബിലിറ്റി മോഡിൽ വോയ്സ് കമാൻഡുകൾക്കായി Provii Wallet സ്പീച്ച് റെക്കഗ്നിഷൻ ഉപയോഗിക്കുന്നു, ഇത് ആപ്പ് ഹാൻഡ്സ്-ഫ്രീ ആയി നിയന്ത്രിക്കാൻ നിങ്ങളെ അനുവദിക്കുന്നു.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "ആക്സസിബിലിറ്റി മോഡ് പ്രവർത്തനക്ഷമമാക്കുമ്പോൾ വോയ്സ് കൺട്രോൾ ഫീച്ചറുകൾക്കായി Provii Wallet-ന് മൈക്രോഫോൺ ആക്സസ് ആവശ്യമാണ്.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "നിങ്ങളുടെ പ്രായ ക്രെഡൻഷ്യലുകൾ സുരക്ഷിതമായി ആക്സസ് ചെയ്യാനും നിങ്ങളുടെ ഐഡന്റിറ്റി സ്ഥിരീകരിക്കാനും Provii Wallet Face ID ഉപയോഗിക്കുന്നു.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "സമീപത്തുള്ള ക്രെഡൻഷ്യൽ ഇഷ്യൂവർമാരെ കണ്ടെത്താൻ Provii Wallet ലോക്കൽ നെറ്റ്‌വർക്ക് ഉപയോഗിക്കാം.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "YubiKey ഉപകരണങ്ങളുമായി ആശയവിനിമയം നടത്താൻ Provii Wallet Bluetooth ഉപയോഗിക്കാം.";
