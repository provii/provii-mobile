/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet wuxuu u baahan yahay helitaanka kamiradda si uu u sawiro koodhyada QR ee qaadashada warqadda aqoonsiga iyo xaqiijinta da'da.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet wuxuu isticmaashaa NFC si uu ula xiriiro YubiKey-gaaga xaqiijinta ammaan ah ee sarkaalka.";

