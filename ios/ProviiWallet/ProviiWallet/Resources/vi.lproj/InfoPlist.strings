/* InfoPlist.strings - Vietnamese (vi) */
/* Mô tả quyền truy cập đã được bản địa hoá cho Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet cần quyền truy cập camera để quét mã QR khi nhận chứng chỉ và xác minh độ tuổi.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet sử dụng NFC để giao tiếp với YubiKey của bạn nhằm xác thực nhân viên an toàn.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet sử dụng nhận dạng giọng nói cho các lệnh thoại trong chế độ hỗ trợ tiếp cận, cho phép bạn điều khiển ứng dụng rảnh tay.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet cần quyền truy cập micro cho tính năng điều khiển bằng giọng nói khi chế độ hỗ trợ tiếp cận được bật.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet sử dụng Face ID để truy cập an toàn vào chứng chỉ độ tuổi và xác minh danh tính của bạn.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet có thể sử dụng mạng cục bộ để tìm kiếm các tổ chức phát hành chứng chỉ gần đây.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet có thể sử dụng Bluetooth để giao tiếp với các thiết bị YubiKey.";
