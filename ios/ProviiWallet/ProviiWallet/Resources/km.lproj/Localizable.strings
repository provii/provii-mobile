"help_text_simplified_ui_simplified" = "ធ្វើកម្មវិធីសាមញ្ញ.\n\nជួយ:\n• អេក្រង់ច្រំដែល\n• ចូលចិត្ដសាមញ្ញ\n• ថ្មី\n\nបង្ហាញតិច។";
"help_text_step_indicators_simplified" = "បង្ហាញជំហាន.\n\nជួយ:\n• ដឹងអ្នកនៅណា\n• ដឹងនៅសល់\n• ដឹង\n\nបង្ហាញ 'ជំហាន 1 ក្នុង 3'.";
"help_text_verbose_descriptions_simplified" = "ឲ្យការពន្យល់.\n\nជួយ:\n• យល់\n• រៀន\n• ព័ត៌មាន\n\nជំនួយ។";
"help_text_confirm_actions_simplified" = "ស្នើ.\n\nជួយ:\n• ការលប់\n• ការផ្លាស់ប្ដូរ\n• កំហុស\n\n'ពិតទេ?'";
"help_text_manual_code_entry_simplified" = "វាយកូដ.\n\nប្រើ:\n• ម៉ាស៊ីនថតខូច\n• QR ពិបាក\n• ចូលចិត្ដវាយ\n\nចុច 'បញ្ចូលកូដ'.";
"help_text_voice_input_simplified" = "និយាយ.\n\nជួយ:\n• វាយពិបាក\n• ចូលចិត្ដសំឡេង\n• ដៃទំនេរ\n\nចុចមីក្រូហ្វូន។";
"help_text_qr_scanning_simplified" = "ស្កែន QR.\n\nរបៀប:\n1. ចង្អុល\n2. តម្រឹម\n3. រង់ចាំ\n\nគន្លឹះ:\n• ពន្លឺ\n• ឈប់\n• ល្វែង";
"help_text_age_verification_simplified" = "បញ្ជាក់ 18+ ដោយគ្មានថ្ងៃ.\n\nដំណើរការ:\n1. អ្នកលក់ស្នើ\n2. ស្កែន\n3. បង្កើតភស្តុតាង\n4. ផ្ទៀងផ្ទាត់\n\nថ្ងៃបន្ត។";
"help_text_credentials_simplified" = "ភស្តុតាងអាយុ.\n\nមុខងារ:\n• ក្នុងទូរស័ព្ទ\n• គ្មានការចម្លង\n• ឯកជន\n• លប់ចេញ\n\nពីការិយាល័យ។";
"help_text_zero_knowledge_simplified" = "បញ្ជាក់.\n\nឧទាហរណ៍:\n• ចាស់: ID\n• ថ្មី: 18+ ប្រឆាំង\n\nឯកជន។";
"help_text_credential_issuance_simplified" = "ទទួលភស្តុតាង.\n\nជំហាន:\n1. ការិយាល័យ\n2. ID\n3. ទទួលកូដ\n4. ស្កែន\n5. ផ្ទុក\n\nម្ដង ប្រើច្រើន។";
"help_text_officer_mode_simplified" = "សម្រាប់មន្ត្រី.\n\nត្រូវការ:\n• លេខកូដ\n• ការអនុញ្ញាត\n• ID\n\nជំហាន:\n1. ចូល\n2. ពិនិត្យ ID\n3. បញ្ចូលថ្ងៃ\n4. បង្កើតកូដ\n5. ស្កែន\n\nត្រឹមមន្ត្រី។";
