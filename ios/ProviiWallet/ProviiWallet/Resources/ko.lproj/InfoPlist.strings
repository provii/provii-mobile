/* InfoPlist.strings - Korean */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet은 자격 증명 수령 및 나이 검증을 위한 QR 코드 스캔에 카메라 접근이 필요합니다.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet은 안전한 담당자 인증을 위해 YubiKey와 통신하는 데 NFC를 사용합니다.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet은 접근성 모드에서 음성 명령을 위해 음성 인식을 사용하며, 핸즈프리로 앱을 제어할 수 있습니다.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet은 접근성 모드가 활성화되었을 때 음성 제어 기능을 위해 마이크 접근이 필요합니다.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet은 나이 자격 증명에 안전하게 접근하고 신원을 확인하기 위해 Face ID를 사용합니다.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet은 근처의 자격 증명 발급 기관을 찾기 위해 로컬 네트워크를 사용할 수 있습니다.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet은 YubiKey 기기와 통신하기 위해 Bluetooth를 사용할 수 있습니다.";
