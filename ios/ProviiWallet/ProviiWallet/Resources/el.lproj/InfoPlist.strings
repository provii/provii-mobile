/* InfoPlist.strings - Greek (el) */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Το Provii Wallet χρειάζεται πρόσβαση στην κάμερα για σάρωση κωδικών QR κατά την παραλαβή διαπιστευτηρίου και την επαλήθευση ηλικίας.";

/* NFC Access */
"NFCReaderUsageDescription" = "Το Provii Wallet χρησιμοποιεί NFC για επικοινωνία με το YubiKey σας για ασφαλή ταυτοποίηση υπαλλήλου.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Το Provii Wallet χρησιμοποιεί αναγνώριση ομιλίας για φωνητικές εντολές στη λειτουργία προσβασιμότητας, επιτρέποντάς σας να ελέγχετε την εφαρμογή χωρίς χέρια.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Το Provii Wallet χρειάζεται πρόσβαση στο μικρόφωνο για λειτουργίες φωνητικού ελέγχου όταν η λειτουργία προσβασιμότητας είναι ενεργοποιημένη.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Το Provii Wallet χρησιμοποιεί Face ID για ασφαλή πρόσβαση στα διαπιστευτήρια ηλικίας σας και επαλήθευση της ταυτότητάς σας.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Το Provii Wallet ενδέχεται να χρησιμοποιεί το τοπικό δίκτυο για εντοπισμό κοντινών εκδοτών διαπιστευτηρίων.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Το Provii Wallet ενδέχεται να χρησιμοποιεί Bluetooth για επικοινωνία με συσκευές YubiKey.";
