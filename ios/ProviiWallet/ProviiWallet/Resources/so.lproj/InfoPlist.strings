/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet wuxuu isticmaashaa Face ID si ammaan ah u helista warqadahaada aqoonsiga da'da iyo xaqiijinta aqoonsigaaga.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet wuxuu isticmaali karaa shabakadda maxalliga ah si uu u ogaado bixiyeyaasha warqadda aqoonsiga ee deegaanka.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet wuxuu isticmaali karaa Bluetooth si uu ula xiriiro aaladaha YubiKey.";
