/* MARK: - Help Text Descriptions */
"help_text_extra_large_text" = "טקסט גדול במיוחד מגדיל את כל הטקסט ביישום ב-\u200F\u206850\u2069%.\n\nהדבר מועיל למשתמשים עם:\n• ראייה חלשה\n• קשיי קריאה\n• שינויי ראייה הקשורים לגיל\n\nפועל עם \u2068iOS Dynamic Type\u2069 לגדלים גדולים עוד יותר.";
"help_text_contrast_level" = "רמת ניגודיות שולטת בניגודיות הצבעים בין טקסט לרקעים.\n\nשלוש רמות זמינות:\n• סטנדרטי: צבעי ברירת מחדל\n• גבוה (AA): יחס ניגודיות \u200F\u20684.5:1\u2069 , עומד בתקני AA\n• מקסימלי (AAA): יחס ניגודיות \u200F\u20687:1\u2069 , עומד בתקני AAA הגבוהים ביותר\n\nניגודיות גבוהה יותר מקלה על קריאת טקסט בכל תנאי תאורה.";
"help_text_high_contrast" = "מצב ניגודיות גבוהה מגביר את הניגודיות בין טקסט לרקע, מה שמקל על הקריאה.\n\nהדבר מועיל למשתמשים עם:\n• ראייה חלשה\n• רגישות לצבע\n• סביבות עם מסך בהיר\n\nכאשר מופעל:\n• הטקסט הופך לשחור על לבן\n• מסגרות נוספות לרכיבים\n• הצבעים מפושטים";
"help_text_reduce_transparency" = "הפחת שקיפות מסיר אפקטי טשטוש ושקיפות ברחבי היישום.\n\nהדבר מסייע:\n• לשפר קריאות טקסט\n• להפחית מורכבות חזותית\n• לשפר ביצועים במכשירים ישנים\n• להפוך תוכן לצפוי יותר";
"help_text_color_blind_mode" = "מצבי עיוורון צבעים מכווננים צבעים עבור סוגים שונים של ליקוי ראיית צבע.\n\nמצבים זמינים:\n• פרוטנופיה: עיוור אדום (קושי בראיית אדום)\n• דאוטרנופיה: עיוור ירוק (קושי בראיית ירוק)\n• טריטנופיה: עיוור כחול (קושי בראיית כחול)\n• מונוכרום: גווני אפור בלבד\n\nמצבים אלה מבטיחים שמידע חשוב לא מועבר דרך צבע בלבד.";
"help_text_line_spacing" = "מרווח שורות שולט ברווח בין שורות טקסט.\n\n• טווח: \u200F\u20681.0x\u2069 עד \u200F\u20682.0x\u2069\n• תקן AAA: \u200F\u20681.5x\u2069 לפחות\n• ברירת מחדל: \u200F\u20681.0x\u2069\n\nמרווח שורות מוגדל מקל על קריאה ומסייע במניעת דילוג על שורות.";
"help_text_paragraph_spacing" = "מרווח פסקאות שולט ברווח בין פסקאות.\n\n• טווח: \u200F\u20681.0x\u2069 עד \u200F\u20683.0x\u2069\n• תקן AAA: \u200F\u20682.0x\u2069 לפחות\n• ברירת מחדל: \u200F\u20681.0x\u2069\n\nמרווח פסקאות מוגדל מסייע בהבחנה בין מקטעי טקסט שונים.";
"help_text_letter_spacing" = "מרווח אותיות שולט ברווח בין תווים בודדים.\n\n• טווח: \u200F\u20680.0em\u2069 עד \u200F\u20680.2em\u2069\n• תקן AAA: \u200F\u20680.12em\u2069 לפחות\n• ברירת מחדל: \u200F\u20680.0em\u2069\n\nמרווח אותיות מוגדל משפר זיהוי תווים וקריאות.";
"help_text_text_width" = "רוחב טקסט שולט באורך השורה המקסימלי לקריאה נוחה.\n\nאפשרויות:\n• רוחב מלא: ללא מגבלה\n• נוח (\u200F\u206880\u2069 תווים): אופטימלי לקריאה\n• צר (\u200F\u206860\u2069 תווים): לקריאה ממוקדת\n\nהנחיות AAA ממליצות על מקסימום \u200F\u206880\u2069 תווים לשורה.";
"help_text_large_touch_targets" = "אזורי מגע גדולים יותר הופכים את כל הלחצנים והרכיבים האינטראקטיביים לגודל מינימלי של \u200F\u206860\u2069 נקודות.\n\nהדבר מועיל עבור:\n• ליקויים מוטוריים\n• רעד\n• שימוש ביישום עם כפפות\n• שימוש ביד אחת\n\nהמינימום הסטנדרטי הוא \u200F\u206844\u2069 נקודות; הגדרה זו מגדילה ל-\u200F\u206860\u2069 נקודות.";
"help_text_reduce_motion" = "הפחת תנועה ממזער או מסיר אנימציות ברחבי היישום.\n\nהדבר מועיל למשתמשים עם:\n• רגישות לתנועה\n• הפרעות וסטיבולריות\n• אפילפסיה\n• גורמי מיגרנה\n\nכאשר מופעל, אנימציות מוחלפות במעברים מיידיים.";
"help_text_timeout_behavior" = "התנהגות פסק זמן שולטת בזמן שפעולות יכולות לקחת לפני פסק זמן.\n\nאפשרויות:\n• ללא פסק זמן (AAA): פעולות לא פוגות לעולם\n• סטנדרטי (\u200F\u206830\u2069 שניות): פסק זמן ברירת מחדל\n• מורחב (\u200F\u206860\u2069 שניות): כפול מהזמן הסטנדרטי\n\nמצב ללא פסק זמן עומד בתקני נגישות AAA.";
"help_text_simplified_gestures" = "מחוות פשוטות מחליפות מחוות מגע מורכבות בחלופות פשוטות.\n\nהדבר מועיל עבור:\n• ליקויים מוטוריים\n• גמישות מוגבלת\n• שימוש בהתקני עזר\n• פעולה ביד אחת\n\nמחוות מורכבות מוחלפות בלחצנים והקשות פשוטות.";
"help_text_haptic_feedback" = "משוב הפטי מספק רטט עבור פעולות והתראות.\n\nהדבר מועיל עבור:\n• אישור לחיצות לחצן\n• התראה על שגיאות ואזהרות\n• מתן משוב שאינו חזותי\n• משתמשים עם ליקויי שמיעה או ראייה\n\nניתן להשבית אם רטט אינו נוח.";
"help_text_simplified_ui" = "ממשק פשוט מפחית מורכבות חזותית ברחבי היישום.\n\nהדבר מועיל עבור:\n• מוגבלויות קוגניטיביות\n• קשיי למידה\n• הפרעות קשב\n• משתמשים חדשים\n\nכאשר מופעל:\n• פחות רכיבים על המסך\n• פקדים גדולים וברורים יותר\n• פחות רעש חזותי";
"help_text_step_indicators" = "מחווני שלבים מציגים התקדמות בתהליכים מרובי שלבים.\n\nהדבר מסייע:\n• להבין היכן אתה נמצא בתהליך\n• לדעת כמה שלבים נותרו\n• להפחית עומס קוגניטיבי\n• לספק מבנה ברור\n\nמציג 'שלב X מתוך Y' עם נקודות התקדמות חזותיות.";
"help_text_verbose_descriptions" = "תיאורים מפורטים מספקים טקסט הסבר נוסף ברחבי היישום.\n\nהדבר מועיל עבור:\n• הבנת תכונות מורכבות\n• למידת השימוש ביישום\n• תמיכה קוגניטיבית\n• משתמשי קורא מסך\n\nמספק הקשר והוראות לכל התכונות.";
"help_text_confirm_actions" = "אשר פעולות מבקש אישור לפני פעולות חשובות.\n\nהדבר מסייע במניעת:\n• מחיקות מקריות\n• שינויים לא מכוונים\n• הגשות מוקדמות\n• אובדן נתונים\n\nהערה: פעולות הרסניות תמיד דורשות אישור (דרישת AAA).";
"help_text_manual_code_entry" = "הזנת קוד ידנית מאפשרת לך להקליד קודים במקום לסרוק קודי \u2068QR\u2069.\n\nהדבר מועיל כאשר:\n• המצלמה אינה פועלת\n• קוד \u2068QR\u2069 פגום או לא ברור\n• משתמשים בקורא מסך\n• מעדיפים הקלדה על סריקה\n\nפשוט הקש 'הזן קוד ידנית' כדי להקליד את הקוד המוצג על המסך.";
"help_text_voice_input" = "קלט קולי מאפשר לך לאמר קודים במקום לסרוק או להקליד.\n\nהדבר מועיל עבור:\n• ניידות מוגבלת\n• משתמשי קורא מסך\n• פעולה ללא ידיים\n• העדפה לקול\n\nהקש על לחצן המיקרופון ודבר בבירור כשהתבקשת.";
"help_text_qr_scanning" = "סריקת קוד \u2068QR\u2069 משתמשת במצלמה שלך לקריאת קודי תגובה מהירה.\n\nכיצד לסרוק:\n\u200F\u20681.\u2069 כוון מצלמה אל קוד \u2068QR\u2069\n\u200F\u20682.\u2069 יישר קוד במסגרת\n\u200F\u20683.\u2069 המתן לזיהוי אוטומטי\n\nטיפים:\n• ודא תאורה טובה\n• החזק מכשיר יציב\n• השאר קוד \u2068QR\u2069 שטוח ולא מכוסה\n• אם הסריקה נכשלת, נסה הזנת קוד ידנית";
"help_text_age_verification" = "אימות גיל מוכיח שאתה עומד בדרישת גיל מבלי לחשוף את גילך בפועל או תאריך לידתך.\n\nכיצד זה עובד:\n\u200F\u20681.\u2069 המאמת מייצר אתגר\n\u200F\u20682.\u2069 אתה סורק את קוד \u2068QR\u2069 או מזין ידנית\n\u200F\u20683.\u2069 היישום יוצר הוכחה מתמטית\n\u200F\u20684.\u2069 המאמת מאשר שאתה עומד בדרישה\n\nפרטיות מוגנת:\n• תאריך לידתך לא נחשף לעולם\n• המאמת לומד רק אם אתה עומד בדרישה\n• ללא מעקב או איסוף נתונים";
"help_text_credentials" = "אישורים דיגיטליים הם הוכחות קריפטוגרפיות לגילך השמורות באופן מאובטח במכשיר שלך.\n\nתכונות:\n• שמורים רק במכשיר שלך\n• לא ניתן להעתיק או לזייף\n• משמשים לאימות בשמירת פרטיות\n• ניתן למחוק בכל עת\n\nעליך לקבל אישור ממנפיק מורשה (כגון משרד ממשלתי) לפני שתוכל לאמת את גילך.";
"help_text_zero_knowledge" = "הוכחות אפס ידע מאפשרות לך להוכיח שמשהו נכון מבלי לחשוף את המידע הבסיסי.\n\nדוגמה:\n• מסורתי: הצג תעודת זהות (חושף יום הולדת מדויק)\n• אפס ידע: הוכח שאתה מעל גיל \u200F\u206818\u2069 מבלי להראות יום הולדת\n\nיתרונות:\n• הגנת פרטיות מקסימלית\n• לא נחשף מידע אישי\n• אבטחה קריפטוגרפית\n• לא ניתן לזייף או להשמיש שוב\n\nזוהי הטכנולוגיה המרכזית שהופכת את \u2068Provii Wallet\u2069 לפרטי.";
"help_text_credential_issuance" = "הנפקת אישור היא התהליך של קבלת אישור הגיל הדיגיטלי שלך ממנפיק מורשה.\n\nשלבים:\n\u200F\u20681.\u2069 בקר אצל מנפיק מורשה (למשל, משרד ממשלתי)\n\u200F\u20682.\u2069 הוכח את זהותך עם תעודת זיהוי רשמית\n\u200F\u20683.\u2069 קבל קוד \u2068QR\u2069 או קישור עמוק מהמנפיק\n\u200F\u20684.\u2069 סרוק קוד \u2068QR\u2069 או הקש על הקישור\n\u200F\u20685.\u2069 האישור מחושב מקומית ונשמר במכשיר שלך\n\nתהליך ההצהרה העיוורת מבטיח שתאריך לידתך לא מועבר לעולם דרך הרשת.\nעליך לבצע זאת פעם אחת בלבד. לאחר מכן ניתן להשתמש באישור לאימותים ללא הגבלה.";
"help_text_officer_mode" = "מצב פקיד מיועד למנפיקים מורשים ליצירת אישורים עבור משתמשים.\n\nמצב זה דורש:\n• אימות פקיד עם \u2068YubiKey\u2069\n• הרשאה מהרשות המנפיקה\n• אימות פיזי של תעודת הזיהוי של המשתמש\n\nתהליך:\n\u200F\u20681.\u2069 אמת כפקיד\n\u200F\u20682.\u2069 אמת את תעודת הזיהוי הרשמית של המשתמש\n\u200F\u20683.\u2069 הזן את תאריך לידת המשתמש\n\u200F\u20684.\u2069 צור קוד \u2068QR\u2069 להצהרה\n\u200F\u20685.\u2069 המשתמש סורק קוד לקבלת האישור\n\nרק אנשי סגל מורשים צריכים להשתמש במצב זה.";

/* MARK: - Simplified Help Text (Reading Level: Grade 6-8) */
"help_text_extra_large_text_simplified" = "מגדיל את כל הטקסט ב-\u200F\u206850\u2069%.\n\nעוזר לך אם אתה:\n• מתקשה לראות\n• מוצא קריאה קשה\n• זקוק לטקסט גדול יותר\n\nפועל עם הגדרות גודל טקסט הטלפון.";
"help_text_contrast_level_simplified" = "משנה עד כמה הטקסט כהה.\n\nשלוש בחירות:\n• סטנדרטי: צבעים רגילים\n• גבוה: טקסט כהה יותר לקריאה קלה\n• מקסימלי: טקסט כהה מאוד לקריאה הטובה ביותר\n\nטקסט כהה יותר קל יותר לקריאה.";
"help_text_high_contrast_simplified" = "מקל על ראיית טקסט.\n\nעוזר לך אם אתה:\n• מתקשה לראות\n• זקוק לטקסט כהה יותר\n• משתמש ביישום באור בהיר\n\nהטקסט הופך לשחור על לבן.";
"help_text_reduce_transparency_simplified" = "מסיר אפקטים מטושטשים.\n\nזה מסייע:\n• להפוך טקסט לברור יותר\n• לפשט את היישום\n• לזרז טלפונים ישנים\n\nהכל נראה מוצק יותר.";
"help_text_color_blind_mode_simplified" = "משנה צבעים לעזרה בראייה טובה יותר.\n\nבחירות:\n• מצב עיוור אדום\n• מצב עיוור ירוק\n• מצב עיוור כחול\n• מצב אפור בלבד\n\nעוזר לך לראות דברים חשובים.";
"help_text_line_spacing_simplified" = "משנה מרווח בין שורות טקסט.\n\nניתן לבחור מ-\u200F\u20681.0x\u2069 עד \u200F\u20682.0x\u2069.\nברירת מחדל היא \u200F\u20681.0x\u2069.\n\nמרווח גדול יותר מקל על הקריאה.";
"help_text_paragraph_spacing_simplified" = "משנה מרווח בין פסקאות.\n\nניתן לבחור מ-\u200F\u20681.0x\u2069 עד \u200F\u20683.0x\u2069.\nברירת מחדל היא \u200F\u20681.0x\u2069.\n\nמרווח גדול יותר עוזר לך לראות היכן מתחילות רעיונות חדשים.";
"help_text_letter_spacing_simplified" = "משנה מרווח בין אותיות.\n\nניתן לבחור מ-\u200F\u20680.0\u2069 עד \u200F\u20680.2\u2069.\nברירת מחדל היא \u200F\u20680.0\u2069.\n\nמרווח גדול יותר מבהיר אותיות.";
"help_text_text_width_simplified" = "שולט בעד כמה טקסט רחב.\n\nבחירות:\n• רוחב מלא: משתמש בכל המסך\n• בינוני: טוב לקריאה\n• צר: הכי טוב למיקוד\n\nרוחב בינוני הוא הקל ביותר לקריאה.";
"help_text_large_touch_targets_simplified" = "מגדיל את כל הלחצנים.\n\nעוזר לך אם אתה:\n• מתקשה להקיש על לחצנים קטנים\n• יש לך ידיים רועדות\n• לובש כפפות\n• משתמש ביד אחת\n\nהלחצנים הופכים ל-\u200F\u206860\u2069 נקודות במקום \u200F\u206844\u2069 נקודות.";
"help_text_reduce_motion_simplified" = "מסיר אנימציות זזות.\n\nעוזר לך אם:\n• תנועה גורמת לך לסחרחורת\n• אתה מקבל כאבי ראש מתנועה\n• אתה מעדיף שדברים יישארו דוממים\n\nדברים משתנים מיידית במקום לנוע.";
"help_text_timeout_behavior_simplified" = "שולט בכמה זמן משימות יכולות לקחת.\n\nבחירות:\n• ללא מגבלה: משימות לא נעצרות לעולם\n• רגיל: \u200F\u206830\u2069 שניות\n• ארוך יותר: \u200F\u206860\u2069 שניות\n\nבחר 'ללא מגבלה' אם אתה צריך יותר זמן.";
"help_text_simplified_gestures_simplified" = "מחליף מחוות קשות בהקשות פשוטות.\n\nעוזר לך אם אתה:\n• מתקשה עם מגעים מורכבים\n• מעדיף הקשות פשוטות\n• משתמש ביד אחת\n\nהכל משתמש בהקשות פשוטות.";
"help_text_haptic_feedback_simplified" = "גורם לטלפון שלך לרטוט כאשר אתה מקיש.\n\nעוזר לך:\n• לדעת כאשר הקשת על לחצן\n• להרגיש שגיאות ואזהרות\n• לקבל משוב מבלי להסתכל\n\nכבה אם רטט מפריע לך.";
"help_text_simplified_ui_simplified" = "מפשט את היישום.\n\nעוזר לך אם אתה:\n• מתבלבל ממסכים עמוסים\n• מעדיף פריסות פשוטות\n• חדש ביישום\n\nמציג פחות דברים בבת אחת.";
"help_text_step_indicators_simplified" = "מציג התקדמות שלך בשלבים.\n\nעוזר לך:\n• לדעת היכן אתה נמצא\n• לראות כמה שלבים נותרו\n• להישאר מאורגן\n\nמציג 'שלב \u200F\u20681\u2069 מתוך \u200F\u20683\u2069' עם נקודות.";
"help_text_verbose_descriptions_simplified" = "נותן לך הסברים נוספים.\n\nעוזר לך:\n• להבין תכונות\n• ללמוד כיצד להשתמש ביישום\n• לקבל פרטים נוספים\n\nמספק עזרה נוספת בכל מקום.";
"help_text_confirm_actions_simplified" = "מבקש ממך לאשר פעולות חשובות.\n\nמסייע במניעת:\n• מחיקות מקריות\n• שינויים לא רצויים\n• טעויות\n\nתמיד תישאל 'האם אתה בטוח?'.";
"help_text_manual_code_entry_simplified" = "מאפשר לך להקליד קודים במקום לסרוק.\n\nהשתמש בזה כאשר:\n• המצלמה שלך לא עובדת\n• הקוד קשה לסריקה\n• אתה מעדיף להקליד\n\nהקש 'הזן קוד ידנית' להקלדה.";
"help_text_voice_input_simplified" = "מאפשר לך לאמר קודים במקום להקליד.\n\nעוזר לך אם אתה:\n• מתקשה בהקלדה\n• מעדיף לדבר\n• רוצה שימוש ללא ידיים\n\nהקש על המיקרופון ודבר בבירור.";
"help_text_qr_scanning_simplified" = "משתמש במצלמה שלך לקריאת קודים מרובעים.\n\nכיצד לסרוק:\n\u200F\u20681.\u2069 כוון מצלמה אל הקוד\n\u200F\u20682.\u2069 יישר את הקוד\n\u200F\u20683.\u2069 המתן לקריאה\n\nטיפים:\n• השתמש בתאורה טובה\n• החזק הטלפון יציב\n• השאר הקוד שטוח";
"help_text_age_verification_simplified" = "מוכיח שאתה מבוגר מספיק מבלי לשתף יום הולדתך.\n\nכיצד זה עובד:\n\u200F\u20681.\u2069 עסק יוצר בקשה\n\u200F\u20682.\u2069 אתה סורק את הקוד שלו\n\u200F\u20683.\u2069 היישום יוצר הוכחה\n\u200F\u20684.\u2069 העסק מאשר שאתה מבוגר מספיק\n\nיום ההולדת שלך נשאר פרטי.";
"help_text_credentials_simplified" = "הוכחה דיגיטלית לגילך השמורה בטלפון שלך.\n\nתכונות:\n• רק בטלפון שלך\n• לא ניתן להעתיק\n• שומר עליך פרטי\n• ניתן למחוק בכל עת\n\nאתה מקבל אותה ממשרד ממשלתי.";
"help_text_zero_knowledge_simplified" = "מוכיח משהו מבלי לשתף פרטים.\n\nדוגמה:\n• דרך ישנה: הצג תעודת זהות (מראה יום הולדת מדויק)\n• דרך חדשה: הוכח שאתה מעל גיל \u200F\u206818\u2069 (יום הולדת נשאר פרטי)\n\nזה שומר על המידע שלך פרטי.";
"help_text_credential_issuance_simplified" = "קבלת הוכחת גיל דיגיטלית שלך.\n\nשלבים:\n\u200F\u20681.\u2069 לך למשרד ממשלתי\n\u200F\u20682.\u2069 הצג תעודת הזיהוי שלך\n\u200F\u20683.\u2069 קבל קוד\n\u200F\u20684.\u2069 סרוק את הקוד\n\u200F\u20685.\u2069 ההוכחה נשמרת בטלפון שלך\n\nעשה זאת פעם אחת. ואז השתמש בה פעמים רבות.";
"help_text_officer_mode_simplified" = "לעובדי ממשלה ליצירת הוכחות.\n\nדורש:\n• סיסמת פקיד\n• הרשאה לשימוש\n• תעודת זיהוי של המשתמש לבדיקה\n\nשלבים:\n\u200F\u20681.\u2069 התחבר כפקיד\n\u200F\u20682.\u2069 בדוק תעודת זהות משתמש\n\u200F\u20683.\u2069 הזן יום הולדתו\n\u200F\u20684.\u2069 צור קוד\n\u200F\u20685.\u2069 המשתמש סורק קוד\n\nרק לעובדים מורשים.";

