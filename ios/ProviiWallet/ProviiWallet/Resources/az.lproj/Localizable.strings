// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Çox böyük mətn tətbiqdəki bütün mətni 50% artırır.\n\nAşağıdakı istifadəçilərə kömək edir:\n• Aşağı görmə qabiliyyəti\n• Oxu çətinlikləri\n• Yaşla bağlı görmə dəyişiklikləri\n\nDaha böyük ölçülər üçün iOS Dinamik Növü ilə işləyir.";
"help_text_contrast_level" = "Kontrast səviyyəsi mətn ilə arxa plan arasındakı rəng kontrastını idarə edir.\n\nÜç səviyyə mövcuddur:\n• Standart: Standart rənglər\n• Yüksək (AA): 4.5:1 kontrast nisbəti , AA standartlarını ödəyir\n• Maksimum (AAA): 7:1 kontrast nisbəti , ən yüksək AAA standartlarını ödəyir\n\nDaha yüksək kontrast bütün işıqlandırma şərtlərindəki mətni oxumağı asanlaşdırır.";
"help_text_high_contrast" = "Yüksək kontrast rejimi mətn ilə arxa plan arasındakı kontrastı artırır.\n\nAşağıdakı istifadəçilərə kömək edir:\n• Aşağı görmə qabiliyyəti\n• Rəng həssaslığı\n• Parlaq ekran mühitləri\n\nAktivləşdirildikdə:\n• Mətn ağ üzərindəki qara olur\n• Elementlərə kənarlar əlavə edilir\n• Rənglər sadələşdirilir";
"help_text_reduce_transparency" = "Şəffaflığı azaldın tətbiq boyunca bulanıqlıq və şəffaflıq effektlərini aradan qaldırır.\n\nFaydaları:\n• Mətn oxunuşunu yaxşılaşdırır\n• Vizual mürəkkəbliyi azaldır\n• Köhnə cihazlarda performansı artırır\n• Məzmunu daha öngörülü edir";
"help_text_color_blind_mode" = "Rəng korluğu rejimləri müxtəlif rəng görmə çatışmazlığı növləri üçün rəngləri tənzimləyir.\n\nMövcud rejimlər:\n• Protanopiya: Qırmızı korluğu (qırmızı görmə çətinliyi)\n• Deuteranopiya: Yaşıl korluğu (yaşıl görmə çətinliyi)\n• Tritanopiya: Mavi korluğu (mavi görmə çətinliyi)\n• Monoxrom: Yalnız boz çalar\n\nBu rejimlər mühüm məlumatın yalnız rənglə çatdırılmamasını təmin edir.";
"help_text_line_spacing" = "Sətir aralığı mətn sətirləri arasındakı boşluğu idarə edir.\n\n• Aralıq: 1.0x-dən 2.0x-ə\n• AAA standartı: minimum 1.5x\n• Standart: 1.0x\n\nArtırılmış sətir aralığı mətni oxumağı asanlaşdırır və sətir atlamağın qarşısını alır.";
"help_text_paragraph_spacing" = "Abzas aralığı abzaslar arasındakı boşluğu idarə edir.\n\n• Aralıq: 1.0x-dən 3.0x-ə\n• AAA standartı: minimum 2.0x\n• Standart: 1.0x\n\nArtırılmış abzas aralığı mətnin müxtəlif bölmələrini bir-birindən ayırd etməyə kömək edir.";
"help_text_letter_spacing" = "Hərf aralığı ayrı-ayrı simvollar arasındakı boşluğu idarə edir.\n\n• Aralıq: 0.0em-dən 0.2em-ə\n• AAA standartı: minimum 0.12em\n• Standart: 0.0em\n\nArtırılmış hərf aralığı simvol tanınmasını və oxunuşunu yaxşılaşdırır.";
"help_text_text_width" = "Mətn eni rahat oxumaq üçün maksimum sətir uzunluğunu idarə edir.\n\nSeçimlər:\n• Tam genişlik: Maksimum yoxdur\n• Rahat (80 simvol): Oxumaq üçün optimal\n• Dar (60 simvol): Cəmləşdirilmiş oxumaq üçün\n\nAAA bələdçiləri sətir başına maksimum 80 simvol tövsiyə edir.";
"help_text_large_touch_targets" = "Daha böyük toxunma hədəfləri bütün düymə və interaktiv elementləri ən azı 60 nöqtə ölçüsündə edir.\n\nAşağıdakılar üçün faydalıdır:\n• Hərəkət qüsurları\n• Titrəmə\n• Əlcəklə tətbiqdən istifadə\n• Tək əllə istifadə\n\nStandart minimum 44 nöqtədir; bu parametr 60 nöqtəyə qədər artırır.";
"help_text_reduce_motion" = "Hərəkəti azaldın tətbiq boyunca animasiyaları minimuma endirir.\n\nAşağıdakı istifadəçilərə kömək edir:\n• Hərəkət həssaslığı\n• Vestibulyar pozğunluqlar\n• Epilepsiya\n• Miqren tetikleyicilər\n\nAktivləşdirildikdə animasiyalar ani keçidlərlə əvəz edilir.";
"help_text_timeout_behavior" = "Vaxt limiti davranışı əməliyyatların vaxt limitini keçməsinin nə qədər sürdüyünü idarə edir.\n\nSeçimlər:\n• Vaxt limiti yoxdur (AAA): Əməliyyatlar heç vaxt vaxt limitini keçmir\n• Standart (30s): Standart vaxt limiti\n• Uzadılmış (60s): Standart vaxtın iki qatı\n\nVaxt limiti olmayan rejim AAA əlçatanlıq standartlarını ödəyir.";
"help_text_simplified_gestures" = "Sadələşdirilmiş jestlər mürəkkəb çox toxunuşlu jestləri sadə toxunuşlarla əvəz edir.\n\nAşağıdakılar üçün faydalıdır:\n• Hərəkət qüsurları\n• Məhdud çeviklik\n• Yardımçı cihazlardan istifadə\n• Tək əllə idarəetmə\n\nMürəkkəb jestlər düymə və sadə toxunuşlarla əvəz edilir.";
"help_text_haptic_feedback" = "Haptik geribildirim əməliyyatlar və bildirişlər üçün vibrasiya geribildirim verir.\n\nAşağıdakılar üçün faydalıdır:\n• Düymə basmalarını təsdiqləmək\n• Xəta və ya xəbərdarlıqlara diqqəti cəlb etmək\n• Vizual olmayan geribildirim vermək\n• Eşitmə və ya görmə qüsurlu istifadəçilər\n\nVibrasiyalar narahat edicilik yaradan halda bunu deaktivləşdirə bilərsiniz.";
"help_text_simplified_ui" = "Sadələşdirilmiş interfeys tətbiq boyunca vizual mürəkkəbliyi azaldır.\n\nAşağıdakılar üçün faydalıdır:\n• Koqnitiv qüsurlar\n• Öyrənmə çətinlikləri\n• Diqqət pozğunluqları\n• Yeni və ya təcrübəsiz istifadəçilər\n\nAktivləşdirildikdə:\n• Ekranda daha az element\n• Daha böyük, daha aydın idarəetmə elementləri\n• Daha az vizual gürültü";
"help_text_step_indicators" = "Addım göstəriciləri çox addımlı proseslərdə tərəqqinizi göstərir.\n\nFaydaları:\n• Bir prosesdə harada olduğunuzu bilmək\n• Neçə addım qaldığını bilmək\n• Koqnitiv yükü azaltmaq\n• Aydın quruluş vermək\n\nVizual tərəqqi nöqtələri ilə 'Addım X / Y' göstərir.";
"help_text_verbose_descriptions" = "Ətraflı açıqlamalar tətbiq boyunca əlavə izahlı mətn verir.\n\nAşağıdakılar üçün faydalıdır:\n• Mürəkkəb xüsusiyyətləri anlamaq\n• Tətbiqdən istifadəni öyrənmək\n• Koqnitiv dəstək\n• Ekran oxuyucu istifadəçiləri\n\nBütün xüsusiyyətlər üçün kontekst və təlimatlar verir.";
"help_text_confirm_actions" = "Əməliyyatları təsdiqləyin mühüm əməliyyatlardan əvvəl təsdiq tələb edir.\n\nAşağıdakıların qarşısını almağa kömək edir:\n• Təsadüfi silmələr\n• İstəkdən kənar dəyişikliklər\n• Vaxtından əvvəl göndərmə\n• Məlumat itkisi\n\nQeyd: Dağıdıcı əməliyyatlar həmişə təsdiq tələb edir (AAA tələbi).";
"help_text_manual_code_entry" = "Manual kod daxiletmə QR kodlarını skan etmək əvəzinə kodları yazmanıza imkan verir.\n\nAşağıdakı hallarda faydalıdır:\n• Kamera işləmir\n• QR kodu zədələnib və ya aydın deyil\n• Ekran oxuyucusu istifadə edilir\n• Skanlamaq yerinə yazmaq üstündür\n\n'Kodu manual daxil et' düyməsinə toxunaraq ekranda göstərilən kodu yazın.";
"help_text_voice_input" = "Səs girişi skanlamaq və ya yazmaq əvəzinə kodları danışmağınıza imkan verir.\n\nAşağıdakılar üçün faydalıdır:\n• Məhdud hərəkətlilik\n• Ekran oxuyucu istifadəçiləri\n• Əllərsiz idarəetmə\n• Səs üstünlüyü\n\nMikrofon düyməsinə toxunun və istənildikdə aydın danışın.";
"help_text_qr_scanning" = "QR kodu skanlaması Quick Response kodlarını oxumaq üçün kameranızdan istifadə edir.\n\nNecə skan etmək olar:\n1. Kameranı QR koduna yönəldin\n2. Kodu çərçivəyə hizalayın\n3. Avtomatik aşkarlanmasını gözləyin\n\nİpuçları:\n• Yaxşı işıqlandırma təmin edin\n• Cihazı sabit tutun\n• QR kodunu düz və açıq saxlayın\n• Skan uğursuz olduqda Manual kod daxiletməni sınayın";
"help_text_age_verification" = "Yaş doğrulaması real yaşınızı və ya doğum tarixinizi açıqlamadan yaş tələbini ödədiyinizi sübut edir.\n\nNecə işləyir:\n1. Doğrulayıcı çağırış yaradır\n2. QR kodu skan edirsiniz və ya manual daxil edirsiniz\n3. Tətbiq sıfır bilik sübutu yaradır\n4. Doğrulayıcı tələbi ödədiyinizi təsdiqləyir\n\nMəxfilik qorunur:\n• Doğum tarixi heç vaxt paylaşılmır\n• Doğrulayıcı yalnız tələbi ödəyib-ödəmədiyinizi bilir\n• İzləmə və ya məlumat toplanması yoxdur";
"help_text_credentials" = "Rəqəmsal etimadnamələr cihazınızda təhlükəsiz saxlanılan yaşınızın kriptoqrafik sübutlarıdır.\n\nXüsusiyyətlər:\n• Yalnız cihazınızda saxlanılır\n• Kopyalana və ya saxtalaşdırıla bilmir\n• Məxfiliyi qoruyan doğrulama üçün istifadə edilir\n• İstənilən vaxt silinə bilər\n\nYaşınızı doğrulamadan əvvəl səlahiyyətli vericidən (hökumət idarəsi kimi) etimadnamə əldə etməlisiniz.";
"help_text_zero_knowledge" = "Sıfır bilik sübutları əsas məlumatı açıqlamadan bir şeyin doğru olduğunu sübut etməyə imkan verir.\n\nMisal:\n• Ənənəvi: Kimliyinizi göstərin (dəqiq doğum günü açıqlanır)\n• Sıfır bilik: Doğum günü göstərmədən 18 yaşdan böyük olduğunuzu sübut edin\n\nFaydaları:\n• Maksimum məxfilik mühafizəsi\n• Şəxsi məlumat paylaşılmır\n• Kriptoqrafik olaraq təhlükəsizdir\n• Saxtalaşdırıla və ya yenidən oynadıla bilmir\n\nBu, Provii Wallet-i şəxsi edən əsas texnologiyadır.";
"help_text_credential_issuance" = "Etimadnamə vermə rəqəmsal yaş etimadnamənizi səlahiyyətli vericidən əldə etmə prosesidir.\n\nAddımlar:\n1. Səlahiyyətli vericini ziyarət edin (hökumət idarəsi kimi)\n2. Rəsmi kimliklə kimliyinizi sübut edin\n3. Vericidən QR kodu və ya dərin keçid alın\n4. QR kodunu skan edin və ya keçidə toxunun\n5. Etimadnamə yerli olaraq hesablanır və cihazınızda saxlanılır\n\nKorlandırılmış attestasiya prosesi doğum tarixinin şəbəkə üzərindən heç vaxt ötürülməməsini təmin edir.\nBunu yalnız bir dəfə etməlisiniz. Etimadnaməniz daha sonra limitsiz doğrulama üçün istifadə edilə bilər.";
"help_text_officer_mode" = "Məmur rejimi səlahiyyətli vericilər üçün istifadəçilər üçün etimadnamə yaratmaq məqsədilə nəzərdə tutulub.\n\nBu rejim tələb edir:\n• YubiKey ilə məmur autentifikasiyası\n• Verici orqanından icazə\n• İstifadəçi kimliyinin fiziki yoxlanılması\n\nProsesi:\n1. Məmur kimi autentifikasiya edin\n2. İstifadəçinin rəsmi kimliyini yoxlayın\n3. İstifadəçinin doğum tarixini daxil edin\n4. Attestasiya QR kodunu yaradın\n5. İstifadəçi etimadnaməni almaq üçün kodu skan edir\n\nYalnız səlahiyyətli heyət bu rejimdən istifadə etməlidir.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Bütün mətni 50% böyüdür.\n\nAşağıdakı hallarda kömək edir:\n• Görmə problemi varsa\n• Oxumaq çətin gəlirsə\n• Daha böyük mətn lazımdırsa\n\nTelefonun mətn ölçüsü parametrləri ilə işləyir.";

"help_text_contrast_level_simplified" = "Mətni necə tünd olduğunu dəyişir.\n\nÜç seçim:\n• Standart: Normal rənglər\n• Yüksək: Asan oxumaq üçün daha tünd mətn\n• Maksimum: Ən yaxşı oxumaq üçün çox tünd mətn\n\nDaha tünd mətn oxumağı asanlaşdırır.";

"help_text_high_contrast_simplified" = "Mətni görməyi asanlaşdırır.\n\nAşağıdakı hallarda kömək edir:\n• Görmə problemi varsa\n• Daha tünd mətn lazımdırsa\n• Parlaq işıqda tətbiq istifadə edirsinizsə\n\nMətn ağ üzərindəki qara olur.";

"help_text_reduce_transparency_simplified" = "Bulanıq effektləri aradan qaldırır.\n\nFaydaları:\n• Mətni daha aydın edir\n• Tətbiqi sadələşdirir\n• Köhnə telefonlarda sürəti artırır\n\nHər şey daha möhkəm görünür.";

"help_text_color_blind_mode_simplified" = "Daha yaxşı görmək üçün rəngləri dəyişir.\n\nSeçimlər:\n• Qırmızı korluğu rejimi\n• Yaşıl korluğu rejimi\n• Mavi korluğu rejimi\n• Yalnız boz rejim\n\nMühüm şeyləri görməyinizə kömək edir.";

"help_text_line_spacing_simplified" = "Mətn sətirləri arasındakı boşluğu dəyişir.\n\n1.0x-dən 2.0x-ə qədər seçə bilərsiniz.\nStandart 1.0x-dir.\n\nDaha çox boşluq oxumağı asanlaşdırır.";

"help_text_paragraph_spacing_simplified" = "Abzaslar arasındakı boşluğu dəyişir.\n\n1.0x-dən 3.0x-ə qədər seçə bilərsiniz.\nStandart 1.0x-dir.\n\nDaha çox boşluq yeni fikirlərin haradan başladığını görməyə kömək edir.";

"help_text_letter_spacing_simplified" = "Hərflər arasındakı boşluğu dəyişir.\n\n0.0-dan 0.2-yə qədər seçə bilərsiniz.\nStandart 0.0-dır.\n\nDaha çox boşluq hərfləri daha aydın edir.";

"help_text_text_width_simplified" = "Mətni nə qədər geniş olduğunu idarə edir.\n\nSeçimlər:\n• Tam genişlik: Bütün ekranı istifadə edir\n• Orta: Oxumaq üçün yaxşıdır\n• Dar: Diqqəti cəmləmək üçün ən yaxşısı\n\nOrta genişlik oxumağı ən asan edir.";

"help_text_large_touch_targets_simplified" = "Bütün düymələri böyüdür.\n\nAşağıdakı hallarda kömək edir:\n• Kiçik düymələrə toxunmaqda çətinlik varsa\n• Əlləriniz titrəyirsə\n• Əlcək taxırsınızsa\n• Tək əllə istifadə edirsinizsə\n\nDüymələr 44 nöqtə əvəzinə 60 nöqtə olur.";

"help_text_reduce_motion_simplified" = "Hərəkət animasiyalarını aradan qaldırır.\n\nAşağıdakı hallarda kömək edir:\n• Hərəkət başgicəlləndirirsə\n• Hərəkətdən baş ağrısı gəlirsə\n• Şeylərin hərəkətsiz qalmasına üstünlük verirsinizsə\n\nŞeylər hərəkət etmək əvəzinə ani olaraq dəyişir.";

"help_text_timeout_behavior_simplified" = "Tapşırıqların nə qədər vaxt ala biləcəyini idarə edir.\n\nSeçimlər:\n• Limit yoxdur: Tapşırıqlar heç vaxt dayanmır\n• Normal: 30 saniyə\n• Uzun: 60 saniyə\n\nDaha çox vaxta ehtiyacınız varsa 'Limit yoxdur' seçin.";

"help_text_simplified_gestures_simplified" = "Çətin jestləri sadə toxunuşlarla əvəz edir.\n\nAşağıdakı hallarda kömək edir:\n• Mürəkkəb toxunuşlarda problem varsa\n• Sadə toxunuşlara üstünlük verirsinizsə\n• Tək əllə istifadə edirsinizsə\n\nHər şey sadə toxunuşlarla işləyir.";

"help_text_haptic_feedback_simplified" = "Toxunduğunuzda telefonunuzu titrədir.\n\nFaydaları:\n• Düyməyə toxunduğunuzu bilmək\n• Xəta və ya xəbərdarlıqları hiss etmək\n• Baxmadan geribildirim almaq\n\nVibrasiyalar narahat edicilik yaradan halda deaktivləşdirin.";

"help_text_simplified_ui_simplified" = "Tətbiqi daha sadə edir.\n\nAşağıdakı hallarda kömək edir:\n• Dolu ekranlardan çaşdırılırsınızsa\n• Sadə görünüşlərə üstünlük verirsinizsə\n• Tətbiqə yenisinizsə\n\nBir anda daha az şey göstərir.";

"help_text_step_indicators_simplified" = "Addımlar vasitəsilə tərəqqinizi göstərir.\n\nFaydaları:\n• Harada olduğunuzu bilmək\n• Neçə addım qaldığını görmək\n• Mütəşəkkil qalmaq\n\nNöqtələrlə 'Addım 1 / 3' göstərir.";

"help_text_verbose_descriptions_simplified" = "Daha çox izah verir.\n\nFaydaları:\n• Xüsusiyyətləri anlamaq\n• Tətbiqdən istifadəni öyrənmək\n• Daha çox təfərrüat almaq\n\nHər yerdə əlavə kömək verir.";

"help_text_confirm_actions_simplified" = "Mühüm əməliyyatları təsdiqləməyinizi xahiş edir.\n\nAşağıdakıların qarşısını almağa kömək edir:\n• Təsadüfi silmələr\n• İstəkdən kənar dəyişikliklər\n• Səhvlər\n\nHəmişə 'Əminsiniz?' sorusu veriləcək.";

"help_text_manual_code_entry_simplified" = "Skan etmək əvəzinə kodları yazmanıza imkan verir.\n\nAşağıdakı hallarda istifadə edin:\n• Kameranız işləmir\n• Kodu skan etmək çətindir\n• Yazmağa üstünlük verirsinizsə\n\nYazmaq üçün 'Kodu manual daxil et' düyməsinə toxunun.";

"help_text_voice_input_simplified" = "Yazmaq əvəzinə kodları danışmanıza imkan verir.\n\nAşağıdakı hallarda kömək edir:\n• Yazmaqda çətinlik varsa\n• Danışmağa üstünlük verirsinizsə\n• Əllərsiz istifadə etmək istəyirsinizsə\n\nMikrofona toxunun və aydın danışın.";

"help_text_qr_scanning_simplified" = "Kvadrat kodları oxumaq üçün kameranızdan istifadə edir.\n\nNecə skan etmək olar:\n1. Kameranı koda yönəldin\n2. Kodu hizalayın\n3. Oxumasını gözləyin\n\nİpuçları:\n• Yaxşı işıqlandırma istifadə edin\n• Telefonu sabit tutun\n• Kodu düz saxlayın";

"help_text_age_verification_simplified" = "Doğum gününüzü paylaşmadan kifayət qədər böyük olduğunuzu sübut edir.\n\nNecə işləyir:\n1. İş yeri sorğu yaradır\n2. Onların kodunu skan edirsiniz\n3. Tətbiq sübut yaradır\n4. İş yeri kifayət qədər böyük olduğunuzu təsdiqləyir\n\nDoğum günü məxfi qalır.";

"help_text_credentials_simplified" = "Telefonunuzda saxlanılan yaşınızın rəqəmsal sübutu.\n\nXüsusiyyətlər:\n• Yalnız telefonunuzda\n• Kopyalana bilmir\n• Sizi məxfi saxlayır\n• İstənilən vaxt silinə bilər\n\nHökumət idarəsindən alırsınız.";

"help_text_zero_knowledge_simplified" = "Təfərrüat paylaşmadan bir şeyi sübut edir.\n\nMisal:\n• Köhnə üsul: Kimliyinizi göstərin (dəqiq doğum günü görünür)\n• Yeni üsul: 18 yaşdan böyük olduğunuzu sübut edin (doğum günü məxfi qalır)\n\nBu, məlumatlarınızı məxfi saxlayır.";

"help_text_credential_issuance_simplified" = "Rəqəmsal yaş sübutunuzu almaq.\n\nAddımlar:\n1. Hökumət idarəsinə gedin\n2. Kimliyinizi göstərin\n3. Kod alın\n4. Kodu skan edin\n5. Sübut telefonunuzda saxlanılır\n\nBunu bir dəfə edin. Sonra dəfələrlə istifadə edin.";

"help_text_officer_mode_simplified" = "Sübutlar yaratmaq üçün hökumət işçiləri üçündür.\n\nLazım olan:\n• Məmur parolu\n• İstifadə icazəsi\n• Yoxlamaq üçün istifadəçinin kimliyi\n\nAddımlar:\n1. Məmur kimi daxil olun\n2. İstifadəçinin kimliyini yoxlayın\n3. Doğum gününü daxil edin\n4. Kod yaradın\n5. İstifadəçi kodu skan edir\n\nYalnız səlahiyyətli işçilər üçündür.";

