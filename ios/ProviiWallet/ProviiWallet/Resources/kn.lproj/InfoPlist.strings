/* InfoPlist.strings - Kannada */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet ಗೆ ಪ್ರಮಾಣಪತ್ರ ಸ್ವೀಕಾರ ಮತ್ತು ವಯಸ್ಸು ಪರಿಶೀಲನೆಗಾಗಿ QR ಕೋಡ್‌ಗಳನ್ನು ಸ್ಕ್ಯಾನ್ ಮಾಡಲು ಕ್ಯಾಮೆರಾ ಪ್ರವೇಶ ಅಗತ್ಯ.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet ಸುರಕ್ಷಿತ ಅಧಿಕಾರಿ ದೃಢೀಕರಣಕ್ಕಾಗಿ ನಿಮ್ಮ YubiKey ಯೊಂದಿಗೆ ಸಂವಹನ ಮಾಡಲು NFC ಬಳಸುತ್ತದೆ.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet ಪ್ರವೇಶಸಾಧ್ಯತೆ ಮೋಡ್‌ನಲ್ಲಿ ಧ್ವನಿ ಆದೇಶಗಳಿಗಾಗಿ ವಾಕ್ ಗುರುತಿಸುವಿಕೆ ಬಳಸುತ್ತದೆ, ಇದರಿಂದ ನೀವು ಕೈ ಬಿಡದೆ ಅಪ್ಲಿಕೇಶನ್ ನಿಯಂತ್ರಿಸಬಹುದು.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "ಪ್ರವೇಶಸಾಧ್ಯತೆ ಮೋಡ್ ಸಕ್ರಿಯವಾಗಿದ್ದಾಗ ಧ್ವನಿ ನಿಯಂತ್ರಣ ವೈಶಿಷ್ಟ್ಯಗಳಿಗಾಗಿ Provii Wallet ಗೆ ಮೈಕ್ರೊಫೋನ್ ಪ್ರವೇಶ ಅಗತ್ಯ.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet ನಿಮ್ಮ ವಯಸ್ಸು ಪ್ರಮಾಣಪತ್ರಗಳನ್ನು ಸುರಕ್ಷಿತವಾಗಿ ಪ್ರವೇಶಿಸಲು ಮತ್ತು ನಿಮ್ಮ ಗುರುತು ಪರಿಶೀಲಿಸಲು Face ID ಬಳಸುತ್ತದೆ.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet ಹತ್ತಿರದ ಪ್ರಮಾಣಪತ್ರ ನೀಡುಗರನ್ನು ಕಂಡುಹಿಡಿಯಲು ಸ್ಥಳೀಯ ನೆಟ್‌ವರ್ಕ್ ಬಳಸಬಹುದು.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet YubiKey ಸಾಧನಗಳೊಂದಿಗೆ ಸಂವಹನ ಮಾಡಲು Bluetooth ಬಳಸಬಹುದು.";
