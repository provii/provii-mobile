/* InfoPlist.strings - Urdu */
/* Localised permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "⁨Provii Wallet⁩ کو سند حاصل کرنے اور عمر کی تصدیق کے لیے ⁨QR⁩ کوڈ اسکین کرنے ہیتو کیمرے تک رسائی درکار ہے۔";

/* NFC Access */
"NFCReaderUsageDescription" = "⁨Provii Wallet⁩ محفوظ افسر توثیق کے لیے آپ کے ⁨YubiKey⁩ سے رابطے ہیتو ⁨NFC⁩ استعمال کرتا ہے۔";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "⁨Provii Wallet⁩ رسائی پذیری موڈ میں آواز کے احکامات کے لیے تقریر کی شناخت استعمال کرتا ہے، جس سے آپ ایپ کو بغیر ہاتھ لگائے چلا سکتے ہیں۔";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "⁨Provii Wallet⁩ کو رسائی پذیری موڈ فعال ہونے پر آواز کنٹرول کی سہولیات کے لیے مائیکروفون تک رسائی درکار ہے۔";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "⁨Provii Wallet⁩ آپ کی عمر کی اسناد تک محفوظ رسائی اور آپ کی شناخت کی تصدیق کے لیے ⁨Face ID⁩ استعمال کرتا ہے۔";

/* Local Network */
"NSLocalNetworkUsageDescription" = "⁨Provii Wallet⁩ قریبی سند جاری کنندگان دریافت کرنے کے لیے مقامی نیٹ ورک استعمال کر سکتا ہے۔";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "⁨Provii Wallet⁩ ⁨YubiKey⁩ آلات سے رابطے کے لیے ⁨Bluetooth⁩ استعمال کر سکتا ہے۔";
