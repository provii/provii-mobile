// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Веома велики текст повећава сав текст у апликацији за 50%.\n\nОво је корисно за кориснике са:\n• Слабим видом\n• Тешкоћама у читању\n• Променама вида везаним за старост\n\nРади са iOS Dynamic Type за чак веће величине.";
"help_text_contrast_level" = "Ниво контраста контролише контраст боја између текста и позадине.\n\nДоступна су три нивоа:\n• Стандардно: Подразумеване боје\n• Високо (AA): Однос контраста 4,5:1 , испуњава AA стандарде\n• Максимално (AAA): Однос контраста 7:1 , испуњава највише AAA стандарде\n\nВећи контраст олакшава читање текста у свим условима осветљења.";
"help_text_high_contrast" = "Режим високог контраста повећава контраст између текста и позадине, чинећи га лакшим за читање.\n\nОво је корисно за кориснике са:\n• Слабим видом\n• Осетљивошћу на боје\n• Светлим екранским окружењима\n\nКада је омогућен:\n• Текст постаје црн на белој подлози\n• Ивице се додају елементима\n• Боје се поједностављују";
"help_text_reduce_transparency" = "Смањи провидност уклања ефекте замућења и провидности из апликације.\n\nОво помаже:\n• Побољшати читљивост текста\n• Смањити визуелну сложеност\n• Повећати перформансе на старијим уређајима\n• Учинити садржај предвидљивијим";
"help_text_color_blind_mode" = "Режими за поремећај распознавања боја прилагођавају боје за различите врсте.\n\nДоступни режими:\n• Протанопија: Слепило за црвену\n• Деутеранопија: Слепило за зелену\n• Тританопија: Слепило за плаву\n• Монохром: Само нијансе сиве\n\nОви режими осигуравају да важне информације нису пренете само бојом.";
"help_text_line_spacing" = "Размак редова контролише размак између редова текста.\n\n• Опсег: 1,0x до 2,0x\n• AAA стандард: Минимум 1,5x\n• Подразумевано: 1,0x\n\nПовећани размак редова олакшава читање и помаже у спречавању прескакања редова.";
"help_text_paragraph_spacing" = "Размак пасуса контролише размак између пасуса.\n\n• Опсег: 1,0x до 3,0x\n• AAA стандард: Минимум 2,0x\n• Подразумевано: 1,0x\n\nПовећани размак пасуса помаже у разликовању различитих одељака текста.";
"help_text_letter_spacing" = "Размак слова контролише размак између појединачних знакова.\n\n• Опсег: 0,0em до 0,2em\n• AAA стандард: Минимум 0,12em\n• Подразумевано: 0,0em\n\nПовећани размак слова побољшава препознавање знакова и читљивост.";
"help_text_text_width" = "Ширина текста контролише максималну дужину реда ради удобног читања.\n\nОпције:\n• Пуна ширина: Без максимума\n• Удобно (80 знакова): Оптимално за читање\n• Уско (60 знакова): За концентрисано читање\n\nAAA смернице препоручују максимум 80 знакова по реду.";
"help_text_large_touch_targets" = "Веће области додира чине сва дугмад и интерактивне елементе минималне величине 60pt.\n\nОво је корисно за:\n• Моторичка оштећења\n• Треморе или дрхтање\n• Коришћење апликације са рукавицама\n• Коришћење једном руком\n\nСтандардни минимум је 44pt; ово подешавање повећава на 60pt.";
"help_text_reduce_motion" = "Смањи кретање смањује или уклања анимације из апликације.\n\nОво је корисно за кориснике са:\n• Осетљивошћу на кретање\n• Поремећајима вестибуларног апарата\n• Епилепсијом\n• Окидачима мигрене\n\nКада је омогућено, анимације се замењују тренутним прелазима.";
"help_text_timeout_behavior" = "Понашање при истеку времена контролише колико дуго операције могу трајати.\n\nОпције:\n• Без временског ограничења (AAA): Операције никада не истичу\n• Стандардно (30с): Подразумевани рок\n• Продужено (60с): Двоструко стандардно време\n\nРежим без временског ограничења испуњава AAA стандарде приступачности.";
"help_text_simplified_gestures" = "Поједностављене гесте смањују сложене вишекорачне гесте наједноставне додире.\n\nОво је корисно за:\n• Моторичка оштећења\n• Ограничену спретност\n• Коришћење помоћних уређаја\n• Коришћење једном руком\n\nСложене гесте се замењују дугмадима и једноставним додирима.";
"help_text_haptic_feedback" = "Хаптична повратна информација пружа вибрациону повратну информацију за радње и обавештења.\n\nОво је корисно за:\n• Потврду притиска дугмади\n• Упозорење на грешке или упозорења\n• Пружање неовизуелне повратне информације\n• Кориснике са оштећењем слуха или вида\n\nМожете то онемогућити ако су вибрације непријатне.";
"help_text_simplified_ui" = "Поједностављен интерфејс смањује визуелну сложеност апликације.\n\nОво је корисно за:\n• Когнитивна оштећења\n• Тешкоће у учењу\n• Поремећаје пажње\n• Нове или неискусне кориснике\n\nКада је омогућен:\n• Мање елемената на екрану\n• Веће, јасније контроле\n• Мање визуелне буке";
"help_text_step_indicators" = "Индикатори корака приказују Ваш напредак кроз вишекорачне процесе.\n\nОво помаже:\n• Да разумете где се налазите у процесу\n• Да знате колико корака остаје\n• Да смањите когнитивно оптерећење\n• Да обезбедите јасну структуру\n\nПриказује 'Корак X од Y' са визуалним тачкама напретка.";
"help_text_verbose_descriptions" = "Детаљни описи пружају додатни објашњавајући текст.\n\nОво је корисно за:\n• Разумевање сложених функција\n• Учење коришћења апликације\n• Когнитивну подршку\n• Кориснике читача екрана\n\nПружа контекст и упутства за све функције.";
"help_text_confirm_actions" = "Потврди радње тражи потврду пре важних радњи.\n\nОво помаже у спречавању:\n• Случајних брисања\n• Ненамерних промена\n• Преурањених подношења\n• Губитка података\n\nНапомена: Деструктивне радње увек захтевају потврду (захтев AAA).";
"help_text_manual_code_entry" = "Ручни унос кода омогућава Вам да куцате кодове уместо скенирања QR кодова.\n\nОво је корисно када:\n• Камера не ради\n• QR код је оштећен или нејасан\n• Користите читач екрана\n• Преферирате куцање у односу на скенирање\n\nЈедноставно додирните 'Унесите код ручно' да бисте откуцали код приказан на екрану.";
"help_text_voice_input" = "Гласовни унос омогућава Вам да изговарате кодове уместо скенирања или куцања.\n\nОво је корисно за:\n• Ограничену покретљивост\n• Кориснике читача екрана\n• Употребу без употребе руку\n• Склоност ка гласу\n\nДодирните дугме микрофона и јасно говорите када се то затражи.";
"help_text_qr_scanning" = "Скенирање QR кода користи камеру за читање Quick Response кодова.\n\nКако скенирати:\n1. Усмерите камеру на QR код\n2. Центрирајте код у оквиру\n3. Сачекајте аутоматско откривање\n\nСавети:\n• Осигурајте добро осветљење\n• Држите уређај мирно\n• Нека QR код буде раван и без препрека\n• Ако скенирање не успе, покушајте ручни унос кода";
"help_text_age_verification" = "Верификација старости доказује да испуњавате услов старости без откривања стварне старости или датума рођења.\n\nКако функционише:\n1. Верификатор генерише изазов\n2. Скенирате QR код или ручно унесете\n3. Апликација креира доказ нултог знања\n4. Верификатор потврђује да испуњавате услов\n\nПриватност заштићена:\n• Ваш датум рођења никада се не дели\n• Верификатор сазнаје само да ли испуњавате услов\n• Нема праћења нити прикупљања података";
"help_text_credentials" = "Дигитални акредитиви су криптографски докази Ваше старости безбедно сачувани на Вашем уређају.\n\nФункције:\n• Сачувани само на Вашем уређају\n• Не могу се копирати нити фалсификовати\n• Користе се за верификацију уз очување приватности\n• Могу се избрисати у свако доба\n\nМорате набавити акредитив од овлашћеног издаваоца (попут владине канцеларије) пре него што можете верификовати своју старост.";
"help_text_zero_knowledge" = "Докази нултог знања омогућавају Вам да докажете да је нешто тачно без откривања основних информација.\n\nПример:\n• Традиционално: Покажите ID (открива тачан датум рођења)\n• Нулто знање: Докажите да сте старији од 18 без показивања датума рођења\n\nПредности:\n• Максимална заштита приватности\n• Нема дељења личних података\n• Криптографски безбедно\n• Не може се фалсификовати нити поновити\n\nОво је основна технологија која чини Provii Wallet приватним.";
"help_text_credential_issuance" = "Издавање акредитива је процес добијања Вашег дигиталног акредитива за верификацију старости од овлашћеног издаваоца.\n\nКораци:\n1. Посетите овлашћеног издаваоца (нпр. владину канцеларију)\n2. Докажите свој идентитет службеним ID документом\n3. Примите QR код или дубоку везу од издаваоца\n4. Скенирајте QR код или додирните везу\n5. Акредитив се рачуна локално и чува на Вашем уређају\n\nПроцес слепе потврде осигурава да Ваш датум рођења никада није пренет преко мреже.\nОво треба да урадите само једном. Ваш акредитив се онда може користити за неограничен број верификација.";
"help_text_officer_mode" = "Режим службеника је за овлашћене издаваоце да креирају акредитиве за кориснике.\n\nОвај режим захтева:\n• Аутентификацију службеника са YubiKey уређајем\n• Овлашћење од стране органа за издавање\n• Физичку верификацию ID документа корисника\n\nПроцес:\n1. Аутентификујте се као службеник\n2. Верификујте службени ID корисника\n3. Унесите датум рођења корисника\n4. Генеришите QR код потврде\n5. Корисник скенира код да би примио акредитив\n\nОвај режим треба да користи само овлашћено особље.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Повећава сав текст за 50%.\n\nПомаже Вам ако:\n• Имате тешкоће са видом\n• Вам је тешко да читате\n• Вам је потребан већи текст\n\nРади са подешавањима величине текста Вашег телефона.";

"help_text_contrast_level_simplified" = "Мења колико је текст тамнији.\n\nТри избора:\n• Стандардно: Нормалне боје\n• Високо: Тамнији текст за лако читање\n• Максимално: Веома тамнији текст за најбоље читање\n\nТамнији текст је лакши за читање.";

"help_text_high_contrast_simplified" = "Олакшава видљивост текста.\n\nПомаже Вам ако:\n• Имате тешкоће са видом\n• Вам је потребан тамнији текст\n• Користите апликацију на јаком светлу\n\nТекст постаје црн на белој подлози.";

"help_text_reduce_transparency_simplified" = "Уклања ефекте замућења.\n\nОво помаже:\n• Да текст буде јаснији\n• Да апликација будеједноставнија\n• Да убрза старије телефоне\n\nСве изгледа компактније.";

"help_text_color_blind_mode_simplified" = "Мења боје да би Вам помогло боље видети.\n\nИзбори:\n• Режим за слепило за црвену\n• Режим за слепило за зелену\n• Режим за слепило за плаву\n• Режим само сивих нијанси\n\nПомаже Вам да видите важне ствари.";

"help_text_line_spacing_simplified" = "Мења размак између редова текста.\n\nМожете бирати од 1,0x до 2,0x.\nПодразумевано је 1,0x.\n\nВећи размак олакшава читање.";

"help_text_paragraph_spacing_simplified" = "Мења размак између пасуса.\n\nМожете бирати од 1,0x до 3,0x.\nПодразумевано је 1,0x.\n\nВећи размак помаже да видите где почињу нове идеје.";

"help_text_letter_spacing_simplified" = "Мења размак између слова.\n\nМожете бирати од 0,0 до 0,2.\nПодразумевано је 0,0.\n\nВећи размак чини слова јаснијима.";

"help_text_text_width_simplified" = "Контролише колико је текст широк.\n\nИзбори:\n• Пуна ширина: Користи цео екран\n• Средња: Добро за читање\n• Уска: Најбоља за фокус\n\nСредња ширина је најлакша за читање.";

"help_text_large_touch_targets_simplified" = "Чини сва дугмад већим.\n\nПомаже Вам ако:\n• Имате тешкоће са додиривањем малих дугмади\n• Имате нестабилне руке\n• Носите рукавице\n• Користите једну руку\n\nДугмад постају 60pt уместо 44pt.";

"help_text_reduce_motion_simplified" = "Уклања анимације кретања.\n\nПомаже Вам ако:\n• Кретање изазива вртоглавицу\n• Добијате главобоље од кретања\n• Преферирате да ствари мирују\n\nСтвари се мењају тренутно уместо да се крећу.";

"help_text_timeout_behavior_simplified" = "Контролише колико дуго задаци могу трајати.\n\nИзбори:\n• Без ограничења: Задаци никада не завршавају\n• Нормално: 30 секунди\n• Дуже: 60 секунди\n\nИзаберите 'Без ограничења' ако Вам треба више времена.";

"help_text_simplified_gestures_simplified" = "Замењује тешке гесте са једноставним додирима.\n\nПомаже Вам ако:\n• Имате тешкоће са сложеним додирима\n• Преферирате једноставне додире\n• Користите једну руку\n\nСве користи једноставне додире.";

"help_text_haptic_feedback_simplified" = "Нека Ваш телефон вибрира када додирнете.\n\nПомаже Вам:\n• Да знате када сте додирнули дугме\n• Да осетите грешке или упозорења\n• Да добијете повратну информацију без гледања\n\nИскључите ако Вас вибрације нервирају.";

"help_text_simplified_ui_simplified" = "Чини апликацију једноставнијом.\n\nПомаже Вам ако:\n• Вас збуњују преоптерећени екрани\n• Преферирате једноставне изгледе\n• Сте нови у апликацији\n\nПриказује мање ствари одједном.";

"help_text_step_indicators_simplified" = "Приказује Ваш напредак кроз кораке.\n\nПомаже Вам:\n• Да знате где се налазите\n• Да видите колико корака је остало\n• Да останете организовани\n\nПриказује 'Корак 1 од 3' са тачкама.";

"help_text_verbose_descriptions_simplified" = "Даје Вам више објашњења.\n\nПомаже Вам:\n• Да разумете функције\n• Да научите да користите апликацију\n• Да добијете више детаља\n\nПружа додатну помоћ свуда.";

"help_text_confirm_actions_simplified" = "Пита Вас да потврдите важне радње.\n\nПомаже у спречавању:\n• Случајних брисања\n• Нежељених промена\n• Грешака\n\nУвек ће бити упитани 'Да ли сте сигурни?'";

"help_text_manual_code_entry_simplified" = "Омогућава Вам да куцате кодове уместо скенирања.\n\nКористите ово када:\n• Камера не ради\n• Код је тешко скенирати\n• Преферирате куцање\n\nДодирните 'Унесите код ручно' за куцање.";

"help_text_voice_input_simplified" = "Омогућава Вам да изговарате кодове уместо куцања.\n\nПомаже Вам ако:\n• Имате тешкоће са куцањем\n• Преферирате разговор\n• Желите употребу без руку\n\nДодирните микрофон и јасно говорите.";

"help_text_qr_scanning_simplified" = "Користи камеру за читање квадратних кодова.\n\nКако скенирати:\n1. Усмерите камеру на код\n2. Центрирајте код\n3. Сачекајте да се очита\n\nСавети:\n• Користите добро осветљење\n• Држите телефон мирно\n• Нека код буде раван";

"help_text_age_verification_simplified" = "Доказује да сте довољно стари без дељења датума рођења.\n\nКако функционише:\n1. Пословни субјект креира захтев\n2. Скенирате њихов код\n3. Апликација креира доказ\n4. Пословни субјект потврђује да сте довољно стари\n\nВаш датум рођења остаје приватан.";

"help_text_credentials_simplified" = "Дигитални доказ Ваше старости сачуван на Вашем телефону.\n\nФункције:\n• Само на Вашем телефону\n• Не може се копирати\n• Чува Вашу приватност\n• Можете га обрисати у свако доба\n\nДобијате га у владиној канцеларији.";

"help_text_zero_knowledge_simplified" = "Доказује нешто без дељења детаља.\n\nПример:\n• Стари начин: Покажите ID (открива тачан датум рођења)\n• Нови начин: Докажите да имате преко 18 (датум рођења остаје приватан)\n\nОво чува Ваше информације приватним.";

"help_text_credential_issuance_simplified" = "Добијање Вашег дигиталног доказа о старости.\n\nКораци:\n1. Идите у владину канцеларију\n2. Покажите свој ID\n3. Добијте код\n4. Скенирајте код\n5. Доказ је сачуван на Вашем телефону\n\nУрадите ово једном. Затим користите многопута.";

"help_text_officer_mode_simplified" = "За државне службенике за креирање доказа.\n\nПотребно:\n• Лозинка службеника\n• Дозвола за коришћење\n• ID корисника за провјеру\n\nКораци:\n1. Пријавите се као службеник\n2. Проверите ID корисника\n3. Унесите датум рођења\n4. Направите код\n5. Корисник скенира код\n\nСамо за овлашћене службенике.";

