/* InfoPlist.strings - Latvian (lv) */
/* Localized permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet vajadzīga piekļuve kamerai, lai skenētu QR kodus akreditācijas datu saņemšanai un vecuma pārbaudei.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet izmanto NFC, lai sazinātos ar Jūsu YubiKey drošai amatpersonas autentifikācijai.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet izmanto runas atpazīšanu balss komandām pieejamības režīmā, ļaujot Jums vadīt lietotni bez rokām.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet vajadzīga piekļuve mikrofonam balss vadības funkcijām, kad pieejamības režīms ir iespējots.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet izmanto Face ID, lai droši piekļūtu Jūsu vecuma akreditācijas datiem un pārbaudītu Jūsu identitāti.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet var izmantot vietējo tīklu, lai atklātu tuvumā esošos akreditācijas datu izsniedzējus.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet var izmantot Bluetooth, lai sazinātos ar YubiKey ierīcēm.";
