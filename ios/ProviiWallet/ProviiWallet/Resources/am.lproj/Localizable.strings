"help_text_contrast_level_simplified" = "ጽሑፉ ምን ያህል ጥቁር እንደሆነ ይቀይሩ።\n\nሦስት ምርጫዎች፦\n• ደረጃ፦ ነባሪ ቀለሞች\n• ከፍተኛ፦ ቀለሉ ንባብ ጥቁር ጽሑፍ\n• ከፍተኛ ደረጃ፦ ለምርጥ ንባብ በጣም ጥቁር ጽሑፍ\n\nጥቁር ጽሑፍ ለማንበብ ቀሉ ያደርጋሉ።";

"help_text_high_contrast_simplified" = "ጽሑፍ ለማየት ቀሉ ያደርጋሉ።\n\nለሚከተሉ ይረዳሉ፦\n• ማየት ችግር ካለ\n• ጥቁር ጽሑፍ ካስፈለጋቸሽ\n• ደምቅ ብርሃን ላይ አፕ ሲጠቀሙ\n\nጽሑፍ ነጭ ላይ ጥቁር ይሆናሉ።";

"help_text_reduce_transparency_simplified" = "ደብዛዛ ተጽዕኖዎች ያስወግዳሉ።\n\nይህ ይረዳሉ፦\n• ጽሑፍ ግልጽ ያደርጋሉ\n• አፕ ቀለሉ ያደርጋሉ\n• ድሮ ስልኮች ፍጥነት ያሻሽሉ\n\nሁሉም ነገር ጠንካራ ይሆናሉ።";

"help_text_color_blind_mode_simplified" = "ለሻሻለ ዕይታ ቀለሞችን ይቀይሩ።\n\nምርጫዎቹ፦\n• ቀይ-ዕውር ሁነታ\n• አረንጓዴ-ዕውር ሁነታ\n• ሰማያዊ-ዕውር ሁነታ\n• ግራጫ ብቻ ሁነታ\n\nለሚያስፈልጉዎት ነገሮች ማየት ይረዳሉ።";

"help_text_line_spacing_simplified" = "ጽሑፍ መስመሮች ያለውን ቦታ ይቀይሩ።\n\nከ1.0x እስከ 2.0x ዋጋ ማቀናበር ይቻሉ።\nነባሪ 1.0x ነው።\n\nበለጠ ቦታ ለማንበብ ቀሉ ያደርጋሉ።";

"help_text_paragraph_spacing_simplified" = "አንቀጾች ያለውን ቦታ ይቀይሩ።\n\nከ1.0x እስከ 3.0x ዋጋ ማቀናበር ይቻሉ።\nነባሪ 1.0x ነው።\n\nበለጠ ቦታ አዲስ ሃሳቦቹ የት ይጀምሩ ለማወቅ ይረዳሉ።";

"help_text_letter_spacing_simplified" = "ፊደሎች ያለውን ቦታ ይቀይሩ።\n\nከ0.0 እስከ 0.2 ዋጋ ማቀናበር ይቻሉ።\nነባሪ 0.0 ነው።\n\nበለጠ ቦታ ፊደሎቹ ለማወቅ ቀሉ ያደርጋሉ።";

"help_text_text_width_simplified" = "ጽሑፍ ምን ያህል ሰፊ እንደሆነ ይቆጣጠሩ።\n\nምርጫዎቹ፦\n• ሙሉ ስፋት፦ ሙሉ ስክሪን\n• መካከለኛ፦ ለንባብ ጥሩ\n• ጠባብ፦ ለትኩረት ምርጥ\n\nመካከለኛ ስፋት ለማንበብ ቀሉ ነው።";

"help_text_large_touch_targets_simplified" = "ሁሉም ቁልፎች ይበልጣሉ።\n\nለሚከተሉ ይረዳሉ፦\n• ትናንሽ ቁልፎች መንካት ከባድ ካሆነ\n• ተርፋሪ እጆች ካሉ\n• ጓንት ለብሰው ሲጠቀሙ\n• አንድ እጅ ሲጠቀሙ\n\nቁልፎቹ ከ44 ፕት ወደ 60 ፕት ይበልጣሉ።";

"help_text_reduce_motion_simplified" = "ተንቀሳቃሽ አኒሜሽኖች ያስወግዳሉ።\n\nለሚከተሉ ይረዳሉ፦\n• ንቅናቄ ሲያዞርዎ\n• ርዕሴ ንቅናቄ ካምጣ\n• ነገሮቹ ዝምታ ሲፈልጉ\n\nነገሮቹ ፍጥነት ይቀያቸሩ ይሆናሉ።";

"help_text_timeout_behavior_simplified" = "ሥራዎቹ ምን ያህል ጊዜ ሊወስዱ እንደሚቻሉ ይቆጣጠሩ።\n\nምርጫዎቹ፦\n• ምንም ወሰን፦ ሥራዎቹ ፈጽሞ አያቆሙ\n• ደረጃ፦ 30 ሰከንዶች\n• ረዘም፦ 60 ሰከንዶች\n\nበለጠ ጊዜ ካስፈለጋቸሽ 'ምንም ወሰን' ይምረጡ።";

"help_text_simplified_gestures_simplified" = "ከባዱ ምልክቶችን ቀለሉ ንካዎች ይተካሉ።\n\nለሚከተሉ ይረዳሉ፦\n• ውስብስብ ምልክቶች ከባድ ካሆኑ\n• ቀለሉ ንካዎች ሲፈልጉ\n• አንድ እጅ ሲጠቀሙ\n\nሁሉም ቀለሉ ንካዎች ይሆናሉ።";

"help_text_haptic_feedback_simplified" = "ቁልፍ ሲነኩ ስልኩ ይንዘራሉ።\n\nለሚከተሉ ይረዳሉ፦\n• ቁልፍ ስጋ ለማወቅ\n• ስህተቶቹ ወይም ማስጠንቀቂያዎችን ለማሰሚዎ\n• ሳያዩ ምላሽ ለማወቅ\n\nንዝረቶቹ ምቹ ካልሆኑ ያጥፉ።";

"help_text_simplified_ui_simplified" = "አፕ ቀለሉ ያደርጋሉ።\n\nለሚከተሉ ይረዳሉ፦\n• ጭቅጭቅ ስክሪኖቹ ካዘናቡ\n• ቀለሉ ቅርጸት ሲፈልጉ\n• ለአፕ አዲስ ከሆኑ\n\nበአንድ ጊዜ ያነሱ ነገሮቹ ያሳያሉ።";

"help_text_step_indicators_simplified" = "ሂደቱ ደረጃዎቹ ሂደቱ ያሳያሉ።\n\nለሚከተሉ ይረዳሉ፦\n• ያሉበቱን ለማወቅ\n• ምን ያህል ደረጃዎቹ ቀሩ ለማየት\n• ሥርዓት ለማዘጋጀት\n\n'ደረጃ 1 ከ 3' ከነጥቦቹ ጋር ያሳያሉ።";

"help_text_verbose_descriptions_simplified" = "ብዙ ማብራሪያዎቹ ይሰጣሉ።\n\nለሚከተሉ ይረዳሉ፦\n• ባህሪያቱ ለማወቅ\n• አፕ ሲጠቀሙ ለመማር\n• ብዙ ዝርዝሮቹ ለማግኘት\n\nሁሉም ቦታ ተጨማሪ እርዳታ ይሰጣሉ።";

"help_text_confirm_actions_simplified" = "አስፈላጊ ድርጊቶቹ ቅን ይጠይቁ ናቸው።\n\nለሚከተሉ ይከላከሉ፦\n• አጋጣሚ ሰርዛ\n• ያልፈለጉ ለውጦቹ\n• ስህተቶቹ\n\nሁሌ 'እርግጠኞት ናቸው?' ይጠየቃሉ።";

"help_text_manual_code_entry_simplified" = "ከቅኘት ይልቅ ኮዶቹን ለመጻፍ ያስፈቅዳሉ።\n\nሲ ተጠቀሙ፦\n• ካሜራዎ አይሰራም\n• ኮዱ ለመቃኘት ከባድ ነው\n• ለመጻፍ ይፈልጋሉ\n\n'ኮዱን በእጅ ያስገቡ' ይንኩ ለመጻፍ።";

"help_text_voice_input_simplified" = "ከጻፈ ይልቅ ኮዶቹን ለመናገር ያስፈቅዳሉ።\n\nለሚከተሉ ይረዳሉ፦\n• ጻፈ ከባድ ካሆነ\n• ለመናገር ሲፈልጉ\n• ያለ እጅ ሲሠሩ\n\nማይክሮፎን ቁልፉን ይንኩ ጮክ ብለው ይናገሩ።";

"help_text_qr_scanning_simplified" = "ካሜራዎን ካሬ ኮዶቹ ለማንበብ ይጠቀሙ ናቸው።\n\nለመቃኘት፦\n1. ካሜራ ወደ ኮዱ ያዞሩ\n2. ኮዱ ፍሬሙ ውስጥ ያቀናብሩ\n3. እስኪያነቡ ይጠብቁ\n\nምክሮቹ፦\n• ጥሩ ብርሃን ያስፈልጋሉ\n• ስልኩን ያቁሙ\n• ኮዱ ፍፁምና ያልተዘጋ ያዝዙ";

"help_text_age_verification_simplified" = "ልደት ቀን ሳይጋሩ ዕድሜዎ ደርሷል ይረዳሉ።\n\nሥርዓቱ፦\n1. ንግድ ቤቱ ጥያቄ ያዘጋጃሉ\n2. ኮዳቸሽን ቃኙ\n3. አፕ ማረጋገጫ ይፈጥሩ\n4. ንግድ ቤቱ ዕድሜዎ ደርሷል ያረጋግጣሉ\n\nልደት ቀን ሥውር ሆኖ ይቆያሉ።";

"help_text_credentials_simplified" = "ዕድሜዎ ዲጂታሊ ማስረጃ ስልክዎ ላይ ይቀመጣሉ።\n\nባህሪያቱ፦\n• ስልክዎ ላይ ብቻ\n• ሊቀዱ አይቻልም\n• ሥውር ያደርጋሉ\n• ሁሌ መሰረዝ ይቻሉ\n\nከካቢኔ ቢሮ ማግኘት ይቻሉ።";

"help_text_zero_knowledge_simplified" = "ዝርዝሮቹ ሳይጋሩ ነገሩ ትክክል ማረጋገጥ ይቻሉ።\n\nምሳሌ፦\n• ድሮ ዘዴ፦ መታወቂያ ያሳዩ (ትክክለኛ ልደት ቀን ያሳያሉ)\n• አዲስ ዘዴ፦ ዕድሜ 18 ካለፈ ያረጋግጡ (ልደት ቀን ሳያሳዩ)\n\nይህ ውሂብዎ ሥውር ያቆያሉ።";

"help_text_credential_issuance_simplified" = "ዲጂታሊ ዕድሜ ማስረጃ ማግኘት።\n\nደረጃዎቹ፦\n1. ካቢኔ ቢሮ ይሂዱ\n2. መታወቂያ ያሳዩ\n3. ኮድ ያግኙ\n4. ኮዱን ቃኙ\n5. ማስረጃ ስልክዎ ላይ ይቀምጣሉ\n\nይህን አንድ ጊዜ ያድርጉ። ቀጥሎ ብዙ ጊዜ ይጠቀሙ ናቸው።";

"help_text_officer_mode_simplified" = "ካቢኔ ሠራተኞቹ ማስረጃ ለማፍጠር ናቸው።\n\nያስፈልጋቸዋል፦\n• የሹም ፈቃድ\n• ፈቃድ ለመጠቀም\n• ሰው ዎ መታወቂያ ለማረጋገጥ\n\nደረጃዎቹ፦\n1. እንደ ሹም ግቡ\n2. ሰው ዎ መታወቂያ ያረጋግጡ\n3. ልደት ቀናቸሽን ያስገቡ\n4. ኮድ ፍጠሩ\n5. ሰዎቹ ኮዱን ቃኙ\n\nፈቃድ ላለው ሠራተኞቹ ብቻ ናቸው።";

