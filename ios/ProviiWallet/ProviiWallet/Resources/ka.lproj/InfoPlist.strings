/* InfoPlist.strings - Georgian */
/* Localised permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet-ს სჭირდება კამერაზე წვდომა სერტიფიკატის მიღებისა და ასაკის ვერიფიკაციისთვის QR კოდების სკანირებისთვის.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet იყენებს NFC-ს თქვენს YubiKey-თან კომუნიკაციისთვის, თანამშრომლის უსაფრთხო ავთენტიფიკაციის მიზნით.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet იყენებს მეტყველების ამოცნობას ხელმისაწვდომობის რეჟიმში ხმოვანი ბრძანებებისთვის, რაც საშუალებას გაძლევთ მართოთ აპი ხელის გარეშე.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet-ს სჭირდება მიკროფონზე წვდომა ხმოვანი მართვის ფუნქციებისთვის, როდესაც ხელმისაწვდომობის რეჟიმი ჩართულია.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet იყენებს Face ID-ს თქვენი ასაკის სერტიფიკატებზე უსაფრთხო წვდომისა და თქვენი ვინაობის დადასტურებისთვის.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet შეიძლება გამოიყენოს ლოკალური ქსელი ახლომდებარე სერტიფიკატის გამცემების აღმოსაჩენად.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet შეიძლება გამოიყენოს Bluetooth YubiKey მოწყობილობებთან კომუნიკაციისთვის.";
