/* Help Text Descriptions */
"help_text_extra_large_text" = "மிகவும் பெரிய உரை பயன்பாட்டில் உள்ள அனைத்து உரையையும் 50% அதிகரிக்கிறது.\n\nஇது பின்வரும் பயனர்களுக்கு உதவுகிறது:\n• குறைந்த பார்வை\n• வாசிப்பு சிரமங்கள்\n• வயது தொடர்பான பார்வை மாற்றங்கள்\n\nஇன்னும் பெரிய அளவுகளுக்கு iOS Dynamic Type-உடன் வேலை செய்கிறது.";
"help_text_contrast_level" = "மாறுபாடு நிலை உரைக்கும் பின்னணிக்கும் இடையிலான வண்ண மாறுபாட்டை கட்டுப்படுத்துகிறது.\n\nமூன்று நிலைகள் கிடைக்கின்றன:\n• நிலையான: இயல்புநிலை நிறங்கள்\n• அதிக (AA): 4.5:1 மாறுபாடு விகிதம் - AA தரங்களை பூர்த்தி செய்கிறது\n• அதிகபட்சம் (AAA): 7:1 மாறுபாடு விகிதம் - உயர்ந்த AAA தரங்களை பூர்த்தி செய்கிறது\n\nஅதிக மாறுபாடு அனைத்து வெளிச்ச நிலைகளிலும் உரையை படிக்க எளிதாக்குகிறது.";
"help_text_high_contrast" = "அதிக மாறுபாடு பயன்முறை உரைக்கும் பின்னணிக்கும் இடையிலான மாறுபாட்டை அதிகரிக்கிறது, படிக்க எளிதாக்குகிறது.\n\nஇது பின்வரும் பயனர்களுக்கு உதவுகிறது:\n• குறைந்த பார்வை\n• வண்ண உணர்திறன்\n• பிரகாசமான திரை சூழல்கள்\n\nஇயக்கப்படும்போது:\n• உரை வெள்ளையில் கறுப்பாக மாறும்\n• கூறுகளுக்கு எல்லைகள் சேர்க்கப்படும்\n• நிறங்கள் எளிமைப்படுத்தப்படும்";
"help_text_reduce_transparency" = "வெளிப்படைத்தன்மையை குறைக்கவும் பயன்பாடு முழுவதும் மங்கல் மற்றும் வெளிப்படைத்தன்மை விளைவுகளை நீக்குகிறது.\n\nஇது உதவுகிறது:\n• உரை படிக்கும் திறனை மேம்படுத்துகிறது\n• காட்சி சிக்கலை குறைக்கிறது\n• பழைய சாதனங்களில் செயல்திறனை அதிகரிக்கிறது\n• உள்ளடக்கத்தை கணிக்கக்கூடியதாக செய்கிறது";
"help_text_color_blind_mode" = "நிறக்குருடு பயன்முறைகள் வெவ்வேறு வகையான வண்ண பார்வை குறைபாட்டிற்கு நிறங்களை சரிசெய்கின்றன.\n\nகிடைக்கும் பயன்முறைகள்:\n• Protanopia: சிவப்பு குருட்டுத்தன்மை (சிவப்பு பார்க்க சிரமம்)\n• Deuteranopia: பச்சை குருட்டுத்தன்மை (பச்சை பார்க்க சிரமம்)\n• Tritanopia: நீல குருட்டுத்தன்மை (நீலம் பார்க்க சிரமம்)\n• ஒற்றை வண்ணம்: சாம்பல் நிறம் மட்டுமே\n\nமுக்கியமான தகவல்கள் வண்ணத்தால் மட்டுமே தெரிவிக்கப்படுவதில்லை என்பதை இந்த பயன்முறைகள் உறுதிசெய்கின்றன.";
"help_text_line_spacing" = "வரி இடைவெளி உரை வரிகளுக்கு இடையிலான இடைவெளியை கட்டுப்படுத்துகிறது.\n\n• வரம்பு: 1.0x முதல் 2.0x வரை\n• AAA தரம்: குறைந்தது 1.5x\n• இயல்புநிலை: 1.0x\n\nகூடுதல் வரி இடைவெளி உரையை படிக்க எளிதாக்குகிறது மற்றும் வரி தவிப்பதை தடுக்க உதவுகிறது.";
"help_text_paragraph_spacing" = "பத்தி இடைவெளி பத்திகளுக்கு இடையிலான இடைவெளியை கட்டுப்படுத்துகிறது.\n\n• வரம்பு: 1.0x முதல் 3.0x வரை\n• AAA தரம்: குறைந்தது 2.0x\n• இயல்புநிலை: 1.0x\n\nகூடுதல் பத்தி இடைவெளி உரையின் வெவ்வேறு பிரிவுகளை வேறுபடுத்த உதவுகிறது.";
"help_text_letter_spacing" = "எழுத்து இடைவெளி தனிப்பட்ட எழுத்துகளுக்கு இடையிலான இடைவெளியை கட்டுப்படுத்துகிறது.\n\n• வரம்பு: 0.0em முதல் 0.2em வரை\n• AAA தரம்: குறைந்தது 0.12em\n• இயல்புநிலை: 0.0em\n\nகூடுதல் எழுத்து இடைவெளி எழுத்து அங்கீகாரத்தை மற்றும் படிக்கும் திறனை மேம்படுத்துகிறது.";
"help_text_text_width" = "உரை அகலம் வசதியான வாசிப்புக்கான அதிகபட்ச வரி நீளத்தை கட்டுப்படுத்துகிறது.\n\nவிருப்பங்கள்:\n• முழு அகலம்: அதிகபட்சம் இல்லை\n• வசதியான (80 எழுத்துகள்): வாசிப்புக்கு சிறந்தது\n• குறுகிய (60 எழுத்துகள்): கவனமான வாசிப்புக்கு\n\nAAA வழிகாட்டுதல்கள் ஒரு வரியில் அதிகபட்சம் 80 எழுத்துகள் பரிந்துரைக்கின்றன.";
"help_text_large_touch_targets" = "பெரிய தொடு இலக்குகள் அனைத்து பொத்தான்கள் மற்றும் ஊடாடும் கூறுகளையும் குறைந்தது 60pt அளவில் செய்கிறது.\n\nஇது பின்வரும் வழக்குகளுக்கு உதவுகிறது:\n• இயக்க குறைபாடுகள்\n• நடுக்கம் அல்லது அதிர்வு\n• கையுறைகளுடன் பயன்பாட்டை பயன்படுத்துவது\n• ஒரு கை பயன்பாடு\n\nநிலையான குறைந்தபட்சம் 44pt; இந்த அமைப்பு 60pt-க்கு அதிகரிக்கிறது.";
"help_text_reduce_motion" = "இயக்கத்தை குறைக்கவும் பயன்பாடு முழுவதும் படவியக்கங்களை குறைக்கிறது அல்லது நீக்குகிறது.\n\nஇது பின்வரும் பயனர்களுக்கு உதவுகிறது:\n• இயக்க உணர்திறன்\n• சமநிலை கோளாறுகள்\n• வலிப்பு\n• மைக்கிரேன் தூண்டுதல்கள்\n\nஇயக்கப்படும்போது, படவியக்கங்கள் உடனடி மாற்றங்களால் மாற்றப்படுகின்றன.";
"help_text_timeout_behavior" = "காலாவதி நடத்தை செயல்பாடுகள் எவ்வளவு நேரம் காலாவதியாவதற்கு முன் எடுக்கலாம் என்பதை கட்டுப்படுத்துகிறது.\n\nவிருப்பங்கள்:\n• நேர வரம்பு இல்லை (AAA): செயல்பாடுகள் ஒருபோதும் காலாவதியாவதில்லை\n• நிலையான (30 வி): இயல்புநிலை காலாவதி\n• நீட்டிக்கப்பட்ட (60 வி): நிலையான நேரத்தை இரட்டிப்பாக்கவும்\n\nநேர வரம்பு இல்லாத பயன்முறை AAA அணுகல்தன்மை தரங்களை பூர்த்தி செய்கிறது.";
"help_text_simplified_gestures" = "எளிமைப்படுத்தப்பட்ட சைகைகள் சிக்கலான பல-தொடல் சைகைகளை எளிய தட்டல்களாக குறைக்கிறது.\n\nஇது பின்வரும் வழக்குகளுக்கு உதவுகிறது:\n• இயக்க குறைபாடுகள்\n• குறைந்த கை நுட்பம்\n• உதவி சாதனங்களைப் பயன்படுத்துவது\n• ஒரு கை செயல்பாடு\n\nசிக்கலான சைகைகள் பொத்தான்கள் மற்றும் எளிய தட்டல்களால் மாற்றப்படுகின்றன.";
"help_text_haptic_feedback" = "ஹாப்டிக் கருத்துரை செயல்கள் மற்றும் அறிவிப்புகளுக்கு அதிர்வு கருத்துரை வழங்குகிறது.\n\nஇது பின்வரும் வழக்குகளுக்கு உதவுகிறது:\n• பொத்தான் அழுத்தல்களை உறுதிப்படுத்துதல்\n• பிழைகள் அல்லது எச்சரிக்கைகளை எச்சரிக்கை செய்தல்\n• காட்சியற்ற கருத்துரை வழங்குதல்\n• கேட்கும் அல்லது பார்வை குறைபாடுகள் உள்ள பயனர்கள்\n\nஅதிர்வுகள்불편 என்றால் இதை முடக்கலாம்.";
"help_text_simplified_ui" = "எளிமைப்படுத்தப்பட்ட இடைமுகம் பயன்பாடு முழுவதும் காட்சி சிக்கலை குறைக்கிறது.\n\nஇது பின்வரும் வழக்குகளுக்கு உதவுகிறது:\n• அறிவாற்றல் குறைபாடுகள்\n• கற்றல் சிரமங்கள்\n• கவனம் கோளாறுகள்\n• புதிய அல்லது அனுபவமற்ற பயனர்கள்\n\nஇயக்கப்படும்போது:\n• திரையில் குறைவான கூறுகள்\n• பெரிய, தெளிவான கட்டுப்பாடுகள்\n• குறைவான காட்சி இரைச்சல்";
"help_text_step_indicators" = "படி குறிகாட்டிகள் பல-படி செயல்முறைகளில் உங்கள் முன்னேற்றத்தை காட்டுகின்றன.\n\nஇது உதவுகிறது:\n• நீங்கள் ஒரு செயல்முறையில் எங்கே இருக்கிறீர்கள் என்று புரிந்துகொள்ளவும்\n• எத்தனை படிகள் மீதமுள்ளன என்று தெரிந்துகொள்ளவும்\n• அறிவாற்றல் சுமையை குறைக்கவும்\n• தெளிவான அமைப்பை வழங்கவும்\n\nகாட்சி முன்னேற்ற புள்ளிகளுடன் 'படி X இல் Y' காட்டுகிறது.";
"help_text_verbose_descriptions" = "விரிவான விளக்கங்கள் பயன்பாடு முழுவதும் கூடுதல் விளக்க உரையை வழங்குகின்றன.\n\nஇது பின்வரும் வழக்குகளுக்கு உதவுகிறது:\n• சிக்கலான அம்சங்களை புரிந்துகொள்ளவும்\n• பயன்பாட்டை எவ்வாறு பயன்படுத்துவது என்று கற்கவும்\n• அறிவாற்றல் ஆதரவு\n• திரை வாசிப்பாளர் பயனர்கள்\n\nஅனைத்து அம்சங்களுக்கும் சூழல் மற்றும் வழிமுறைகளை வழங்குகிறது.";
"help_text_confirm_actions" = "செயல்களை உறுதிசெய்யவும் முக்கியமான செயல்களுக்கு முன் உறுதிப்படுத்தலை கேட்கிறது.\n\nதவிர்க்க உதவுகிறது:\n• தற்செயலான நீக்கல்கள்\n• நோக்கமற்ற மாற்றங்கள்\n• முன்கூட்டி சமர்ப்பிக்கல்\n• தரவு இழப்பு\n\nகுறிப்பு: அழிவுகரமான செயல்கள் எப்போதும் உறுதிப்படுத்தலை தேவைப்படுகின்றன (AAA தேவை).";
"help_text_manual_code_entry" = "கைமுறை குறியீடு உள்ளீடு QR குறியீடுகளை ஸ்கேன் செய்வதற்கு பதிலாக குறியீடுகளை தட்டச்சு செய்ய அனுமதிக்கிறது.\n\nபின்வரும் சந்தர்ப்பங்களில் உதவுகிறது:\n• கேமரா வேலை செய்யவில்லை\n• QR குறியீடு சேதமடைந்தது அல்லது தெளிவற்றது\n• திரை வாசிப்பாளரைப் பயன்படுத்துவது\n• ஸ்கேன் செய்வதை விட தட்டச்சு செய்ய விரும்புவது\n\nதிரையில் காட்டப்படும் குறியீட்டை தட்டச்சு செய்ய 'குறியீட்டை கைமுறையாக உள்ளிடவும்' தட்டவும்.";
"help_text_voice_input" = "குரல் உள்ளீடு ஸ்கேன் செய்வதற்கு அல்லது தட்டச்சு செய்வதற்கு பதிலாக குறியீடுகளை பேசுவதை அனுமதிக்கிறது.\n\nபின்வரும் வழக்குகளுக்கு உதவுகிறது:\n• குறைந்த இயக்க தன்மை\n• திரை வாசிப்பாளர் பயனர்கள்\n• கைகள் இல்லாத செயல்பாடு\n• குரல் விருப்பம்\n\nமைக்ரோஃபோன் பொத்தானை தட்டி கேட்கும்போது தெளிவாக பேசவும்.";
"help_text_qr_scanning" = "QR குறியீடு ஸ்கேனிங் விரைவு மறுமொழி குறியீடுகளை படிக்க உங்கள் கேமராவைப் பயன்படுத்துகிறது.\n\nஸ்கேன் செய்வது எவ்வாறு:\n1. QR குறியீட்டில் கேமராவை நோக்குங்கள்\n2. சட்டத்தினுள் குறியீட்டை சரிசெய்யவும்\n3. தானியங்கி கண்டறிதலுக்காக காத்திருக்கவும்\n\nகுறிப்புகள்:\n• நல்ல வெளிச்சத்தை உறுதிசெய்யவும்\n• சாதனத்தை நிலையாக வைத்திருங்கள்\n• QR குறியீட்டை தட்டையாகவும் தடையின்றிவும் வைக்கவும்\n• ஸ்கேன் தோல்வியடைந்தால், கைமுறை குறியீடு உள்ளீட்டை முயற்சிக்கவும்";
"help_text_age_verification" = "வயது சரிபார்ப்பு உங்கள் உண்மையான வயது அல்லது பிறந்த தேதியை வெளிப்படுத்தாமல் வயது தேவையை பூர்த்தி செய்கிறீர்கள் என்பதை நிரூபிக்கிறது.\n\nவேலை செய்வது எவ்வாறு:\n1. சரிபார்ப்பாளர் ஒரு சவாலை உருவாக்குகிறார்\n2. QR குறியீட்டை ஸ்கேன் செய்யவும் அல்லது கைமுறையாக உள்ளிடவும்\n3. பயன்பாடு பூஜ்ஜிய அறிவு நிரூபணத்தை உருவாக்குகிறது\n4. சரிபார்ப்பாளர் நீங்கள் தேவையை பூர்த்தி செய்கிறீர்கள் என்று உறுதிப்படுத்துகிறார்\n\nதனியுரிமை பாதுகாக்கப்படுகிறது:\n• உங்கள் பிறந்த தேதி ஒருபோதும் பகிரப்படாது\n• சரிபார்ப்பாளர் நீங்கள் தேவையை பூர்த்தி செய்கிறீர்களா என்பதை மட்டுமே அறிவார்\n• கண்காணிப்பு அல்லது தரவு சேகரிப்பு இல்லை";
"help_text_credentials" = "டிஜிட்டல் சான்றுச்சீட்டுகள் உங்கள் சாதனத்தில் பாதுகாப்பாக சேமிக்கப்படும் உங்கள் வயதின் கிரிப்டோகிராஃபிக் நிரூபணங்கள்.\n\nஅம்சங்கள்:\n• உங்கள் சாதனத்தில் மட்டுமே சேமிக்கப்படும்\n• நகலெடுக்க அல்லது போலியாக்க முடியாது\n• தனியுரிமை பாதுகாக்கும் சரிபார்ப்புக்கு பயன்படுத்தப்படுகிறது\n• எந்நேரமும் நீக்கலாம்\n\nவயதை சரிபார்க்கும் முன் அங்கீகரிக்கப்பட்ட வழங்குநரிடமிருந்து (அரசு அலுவலகம் போன்றவை) சான்றுச்சீட்டு பெற வேண்டும்.";
"help_text_zero_knowledge" = "பூஜ்ஜிய அறிவு நிரூபணங்கள் அடிப்படை தகவல்களை வெளிப்படுத்தாமல் ஏதாவது உண்மை என்பதை நிரூபிக்க அனுமதிக்கின்றன.\n\nஎடுத்துக்காட்டு:\n• பாரம்பரியம்: அடையாளத்தை காட்டுக (சரியான பிறந்த நாளை வெளிப்படுத்துகிறது)\n• பூஜ்ஜிய அறிவு: பிறந்த நாளை காட்டாமல் 18 வயதுக்கு மேல் என்று நிரூபிக்கவும்\n\nநன்மைகள்:\n• அதிகபட்ச தனியுரிமை பாதுகாப்பு\n• தனிப்பட்ட தரவு பகிரப்படாது\n• கிரிப்டோகிராஃபிக்கலாக பாதுகாப்பானது\n• போலியாக்க அல்லது மீண்டும் பயன்படுத்த முடியாது\n\nProvii Wallet-ஐ தனியுரிமையானதாக செய்யும் முக்கிய தொழில்நுட்பம் இதுவே.";
"help_text_credential_issuance" = "சான்றுச்சீட்டு வழங்கல் என்பது அங்கீகரிக்கப்பட்ட வழங்குநரிடமிருந்து உங்கள் டிஜிட்டல் வயது சான்றுச்சீட்டைப் பெறும் செயல்முறை.\n\nபடிகள்:\n1. அங்கீகரிக்கப்பட்ட வழங்குநரை சந்திக்கவும் (எ.கா., அரசு அலுவலகம்)\n2. உத்தியோகபூர்வ அடையாளத்துடன் உங்கள் அடையாளத்தை நிரூபிக்கவும்\n3. வழங்குநரிடமிருந்து QR குறியீடு அல்லது ஆழ்இணைப்பை பெறுக\n4. QR குறியீட்டை ஸ்கேன் செய்யவும் அல்லது இணைப்பை தட்டவும்\n5. சான்றுச்சீட்டு உள்ளூரில் கணக்கிடப்பட்டு உங்கள் சாதனத்தில் சேமிக்கப்படும்\n\nஒட்டுறவு சான்றளிப்பு செயல்முறை உங்கள் பிறந்த தேதி நெட்வொர்க் மூலம் ஒருபோதும் அனுப்பப்படாது என்பதை உறுதிசெய்கிறது.\nஒரு முறை மட்டுமே இதை செய்ய வேண்டும். உங்கள் சான்றுச்சீட்டை வரம்பற்ற சரிபார்ப்புகளுக்கு பயன்படுத்தலாம்.";
"help_text_officer_mode" = "அதிகாரி பயன்முறை பயனர்களுக்கு சான்றுச்சீட்டுகளை உருவாக்க அங்கீகரிக்கப்பட்ட வழங்குநர்களுக்கானது.\n\nஇந்த பயன்முறைக்கு தேவை:\n• YubiKey-உடன் அதிகாரி அங்கீகாரம்\n• வழங்கும் அதிகாரத்திடமிருந்து அங்கீகாரம்\n• பயனரின் அடையாளத்தின் இயற்பியல் சரிபார்ப்பு\n\nசெயல்முறை:\n1. அதிகாரியாக அங்கீகரிக்கவும்\n2. பயனரின் உத்தியோகபூர்வ அடையாளத்தை சரிபார்க்கவும்\n3. பயனரின் பிறந்த தேதியை உள்ளிடவும்\n4. சான்றளிப்பு QR குறியீட்டை உருவாக்கவும்\n5. பயனர் சான்றுச்சீட்டைப் பெற குறியீட்டை ஸ்கேன் செய்கிறார்\n\nஇந்த பயன்முறையை அங்கீகரிக்கப்பட்ட பணியாளர்கள் மட்டுமே பயன்படுத்த வேண்டும்.";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "அனைத்து உரையையும் 50% பெரிதாக்குகிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• பார்க்க சிரமப்படுகிறீர்கள்\n• வாசிப்பு கடினமாக உள்ளது\n• பெரிய உரை தேவை\n\nதொலைபேசியின் உரை அளவு அமைப்புகளுடன் வேலை செய்கிறது.";
"help_text_contrast_level_simplified" = "உரை எவ்வளவு இருண்டதாக இருக்கும் என்பதை மாற்றுகிறது.\n\nமூன்று தேர்வுகள்:\n• நிலையான: சாதாரண நிறங்கள்\n• அதிக: எளிதாக படிக்க இருண்ட உரை\n• அதிகபட்சம்: சிறந்த வாசிப்புக்கு மிகவும் இருண்ட உரை\n\nகருமையான உரை படிக்க எளிதானது.";
"help_text_high_contrast_simplified" = "உரையை பார்க்க எளிதாக்குகிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• பார்க்க சிரமப்படுகிறீர்கள்\n• கருமையான உரை தேவை\n• பிரகாசமான வெளிச்சத்தில் பயன்பாட்டைப் பயன்படுத்துகிறீர்கள்\n\nவெள்ளையில் கறுப்பு உரையாக மாறும்.";
"help_text_reduce_transparency_simplified" = "மங்கலான விளைவுகளை நீக்குகிறது.\n\nபின்வரும் வழக்குகளில் உதவுகிறது:\n• உரையை தெளிவாக்குகிறது\n• பயன்பாட்டை எளிமையாக்குகிறது\n• பழைய தொலைபேசிகளை வேகமாக்குகிறது\n\nஎல்லாமே திடமாக தெரிகிறது.";
"help_text_color_blind_mode_simplified" = "நீங்கள் சிறப்பாக பார்க்க நிறங்களை மாற்றுகிறது.\n\nதேர்வுகள்:\n• சிவப்பு குருட்டுத்தன்மை பயன்முறை\n• பச்சை குருட்டுத்தன்மை பயன்முறை\n• நீல குருட்டுத்தன்மை பயன்முறை\n• சாம்பல் நிறம் மட்டுமே பயன்முறை\n\nமுக்கியமான விஷயங்களை பார்க்க உதவுகிறது.";
"help_text_line_spacing_simplified" = "உரை வரிகளுக்கு இடையிலான இடைவெளியை மாற்றுகிறது.\n\n1.0x முதல் 2.0x வரை தேர்வு செய்யலாம்.\nஇயல்புநிலை 1.0x.\n\nகூடுதல் இடைவெளி வாசிப்பை எளிதாக்குகிறது.";
"help_text_paragraph_spacing_simplified" = "பத்திகளுக்கு இடையிலான இடைவெளியை மாற்றுகிறது.\n\n1.0x முதல் 3.0x வரை தேர்வு செய்யலாம்.\nஇயல்புநிலை 1.0x.\n\nகூடுதல் இடைவெளி புதிய யோசனைகள் எங்கே தொடங்குகின்றன என்று பார்க்க உதவுகிறது.";
"help_text_letter_spacing_simplified" = "எழுத்துகளுக்கு இடையிலான இடைவெளியை மாற்றுகிறது.\n\n0.0 முதல் 0.2 வரை தேர்வு செய்யலாம்.\nஇயல்புநிலை 0.0.\n\nகூடுதல் இடைவெளி எழுத்துகளை தெளிவாக்குகிறது.";
"help_text_text_width_simplified" = "உரை எவ்வளவு அகலமாக இருக்கும் என்பதை கட்டுப்படுத்துகிறது.\n\nதேர்வுகள்:\n• முழு அகலம்: முழு திரையைப் பயன்படுத்துகிறது\n• நடுத்தரம்: வாசிப்புக்கு நல்லது\n• குறுகிய: கவனத்திற்கு சிறந்தது\n\nநடுத்தர அகலம் படிக்க எளிதானது.";
"help_text_large_touch_targets_simplified" = "அனைத்து பொத்தான்களையும் பெரிதாக்குகிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• சிறிய பொத்தான்களை தட்ட சிரமப்படுகிறீர்கள்\n• கைகள் நடுங்குகின்றன\n• கையுறைகள் அணிகிறீர்கள்\n• ஒரு கை பயன்படுத்துகிறீர்கள்\n\nபொத்தான்கள் 44pt க்கு பதிலாக 60pt ஆகின்றன.";
"help_text_reduce_motion_simplified" = "நகரும் படவியக்கங்களை நீக்குகிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• இயக்கம் உங்களை சுழல வைக்கிறது\n• இயக்கத்தால் தலைவலி வருகிறது\n• விஷயங்கள் நிலையாக இருக்க விரும்புகிறீர்கள்\n\nவிஷயங்கள் நகர்வதற்கு பதிலாக உடனடியாக மாறுகின்றன.";
"help_text_timeout_behavior_simplified" = "பணிகள் எவ்வளவு நேரம் எடுக்கலாம் என்பதை கட்டுப்படுத்துகிறது.\n\nதேர்வுகள்:\n• வரம்பு இல்லை: பணிகள் நிறுத்தப்படுவதில்லை\n• சாதாரண: 30 வினாடிகள்\n• நீண்ட நேரம்: 60 வினாடிகள்\n\nகூடுதல் நேரம் தேவையென்றால் 'வரம்பு இல்லை' தேர்வு செய்யவும்.";
"help_text_simplified_gestures_simplified" = "கடினமான சைகைகளை எளிய தட்டல்களால் மாற்றுகிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• சிக்கலான தொடுதல்களில் சிரமம் உள்ளது\n• எளிய தட்டல்களை விரும்புகிறீர்கள்\n• ஒரு கை பயன்படுத்துகிறீர்கள்\n\nஎல்லாமே எளிய தட்டல்களைப் பயன்படுத்துகின்றன.";
"help_text_haptic_feedback_simplified" = "நீங்கள் தட்டும்போது உங்கள் தொலைபேசியை அதிர வைக்கிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• நீங்கள் ஒரு பொத்தானை தட்டியதை அறியவும்\n• பிழைகள் அல்லது எச்சரிக்கைகளை உணரவும்\n• பார்க்காமல் கருத்துரை பெறவும்\n\nஅதிர்வுகள் சுமையாக இருந்தால் அணைக்கவும்.";
"help_text_simplified_ui_simplified" = "பயன்பாட்டை எளிமையாக்குகிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• வேலைப்பளு திரைகளால் குழப்பமடைகிறீர்கள்\n• எளிய தளவமைப்புகளை விரும்புகிறீர்கள்\n• பயன்பாட்டில் புதியவர்\n\nஒரே நேரத்தில் குறைவான விஷயங்களை காட்டுகிறது.";
"help_text_step_indicators_simplified" = "படிகள் மூலம் உங்கள் முன்னேற்றத்தை காட்டுகிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• நீங்கள் எங்கே இருக்கிறீர்கள் என்று அறியவும்\n• எத்தனை படிகள் மீதமுள்ளன என்று பார்க்கவும்\n• ஒழுங்கமைப்பை பராமரிக்கவும்\n\nபுள்ளிகளுடன் 'படி 1 இல் 3' காட்டுகிறது.";
"help_text_verbose_descriptions_simplified" = "கூடுதல் விளக்கங்களை வழங்குகிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• அம்சங்களை புரிந்துகொள்ளவும்\n• பயன்பாட்டை எவ்வாறு பயன்படுத்துவது என்று கற்கவும்\n• கூடுதல் விவரங்களை பெறவும்\n\nஎல்லா இடங்களிலும் கூடுதல் உதவியை வழங்குகிறது.";
"help_text_confirm_actions_simplified" = "முக்கியமான செயல்களை உறுதிப்படுத்த கேட்கிறது.\n\nதடுக்க உதவுகிறது:\n• தற்செயலான நீக்கல்கள்\n• விரும்பாத மாற்றங்கள்\n• தவறுகள்\n\n'நீங்கள் உறுதியாக இருக்கிறீர்களா?' என்று எப்போதும் கேட்கப்படும்.";
"help_text_manual_code_entry_simplified" = "ஸ்கேன் செய்வதற்கு பதிலாக குறியீடுகளை தட்டச்சு செய்ய அனுமதிக்கிறது.\n\nபின்வரும் சந்தர்ப்பங்களில் பயன்படுத்துக:\n• கேமரா வேலை செய்யவில்லை\n• குறியீட்டை ஸ்கேன் செய்வது கடினம்\n• தட்டச்சு செய்ய விரும்புகிறீர்கள்\n\nதட்டச்சு செய்ய 'குறியீட்டை கைமுறையாக உள்ளிடவும்' தட்டவும்.";
"help_text_voice_input_simplified" = "தட்டச்சு செய்வதற்கு பதிலாக குறியீடுகளை பேச அனுமதிக்கிறது.\n\nபின்வரும் நிலைகளில் உதவுகிறது:\n• தட்டச்சு செய்வதில் சிரமம் உள்ளது\n• பேசுவதை விரும்புகிறீர்கள்\n• கைகள் இல்லாத பயன்பாடு தேவை\n\nமைக்ரோஃபோனை தட்டி தெளிவாக பேசவும்.";
"help_text_qr_scanning_simplified" = "சதுர குறியீடுகளை படிக்க கேமராவைப் பயன்படுத்துகிறது.\n\nஸ்கேன் செய்வது எவ்வாறு:\n1. குறியீட்டில் கேமராவை நோக்குங்கள்\n2. குறியீட்டை சரிசெய்யவும்\n3. படிக்கும் வரை காத்திருக்கவும்\n\nகுறிப்புகள்:\n• நல்ல வெளிச்சத்தைப் பயன்படுத்துங்கள்\n• தொலைபேசியை நிலையாக வைத்திருங்கள்\n• குறியீட்டை தட்டையாக வைத்திருங்கள்";
"help_text_age_verification_simplified" = "உங்கள் பிறந்த நாளை பகிராமல் நீங்கள் போதுமான வயதுடையவர் என்று நிரூபிக்கிறது.\n\nவேலை செய்வது எவ்வாறு:\n1. நிறுவனம் ஒரு கோரிக்கையை உருவாக்குகிறது\n2. அவர்களின் குறியீட்டை ஸ்கேன் செய்யுங்கள்\n3. பயன்பாடு ஒரு நிரூபணத்தை உருவாக்குகிறது\n4. நீங்கள் போதுமான வயதுடையவர் என்று நிறுவனம் உறுதிப்படுத்துகிறது\n\nஉங்கள் பிறந்த நாள் தனியுரிமையாக இருக்கும்.";
"help_text_credentials_simplified" = "உங்கள் தொலைபேசியில் சேமிக்கப்படும் உங்கள் வயதின் டிஜிட்டல் நிரூபணம்.\n\nஅம்சங்கள்:\n• உங்கள் தொலைபேசியில் மட்டுமே\n• நகலெடுக்க முடியாது\n• உங்களை தனியுரிமையாக வைக்கிறது\n• எந்நேரமும் நீக்கலாம்\n\nஅரசு அலுவலகத்திலிருந்து பெறுகிறீர்கள்.";
"help_text_zero_knowledge_simplified" = "விவரங்களை பகிராமல் ஏதாவது நிரூபிக்கிறது.\n\nஎடுத்துக்காட்டு:\n• பழைய முறை: அடையாளத்தை காட்டுக (சரியான பிறந்த நாளை காட்டுகிறது)\n• புதிய முறை: 18 வயதுக்கு மேல் என்று நிரூபிக்கவும் (பிறந்த நாள் தனியுரிமையாக இருக்கும்)\n\nஇது உங்கள் தகவல்களை தனியுரிமையாக வைக்கிறது.";
"help_text_credential_issuance_simplified" = "உங்கள் டிஜிட்டல் வயது நிரூபணத்தைப் பெறுவது.\n\nபடிகள்:\n1. அரசு அலுவலகத்திற்கு செல்லுங்கள்\n2. உங்கள் அடையாளத்தை காட்டுங்கள்\n3. ஒரு குறியீட்டை பெறுங்கள்\n4. குறியீட்டை ஸ்கேன் செய்யுங்கள்\n5. நிரூபணம் உங்கள் தொலைபேசியில் சேமிக்கப்படும்\n\nஒரு முறை செய்யுங்கள். பிறகு பல முறை பயன்படுத்துங்கள்.";
"help_text_officer_mode_simplified" = "அரசு ஊழியர்கள் நிரூபணங்களை உருவாக்குவதற்கு.\n\nதேவைகள்:\n• அதிகாரி கடவுச்சொல்\n• பயன்படுத்த அனுமதி\n• சரிபார்க்க பயனரின் அடையாளம்\n\nபடிகள்:\n1. அதிகாரியாக உள்நுழையுங்கள்\n2. பயனரின் அடையாளத்தை சரிபார்க்கவும்\n3. அவர்களின் பிறந்த நாளை உள்ளிடவும்\n4. குறியீட்டை உருவாக்குங்கள்\n5. பயனர் குறியீட்டை ஸ்கேன் செய்கிறார்\n\nஅங்கீகரிக்கப்பட்ட ஊழியர்களுக்கு மட்டுமே.";

