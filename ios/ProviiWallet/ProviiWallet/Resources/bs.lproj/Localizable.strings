/* Help Text Descriptions */
"help_text_extra_large_text" = "Ekstra veliki tekst povećava sav tekst u aplikaciji za 50%.\n\nOvo je korisno za korisnike s:\n• Oslabljenim vidom\n• Teškoćama čitanja\n• Promjenama vida vezanim za dob\n\nRadi s iOS dinamičkim tipom za još veće veličine.";
"help_text_contrast_level" = "Nivo kontrasta kontroliše kontrast boja između teksta i pozadina.\n\nTri nivoa dostupna:\n• Standardni: Zadane boje\n• Visoki (AA): Omjer kontrasta 4,5:1 - ispunjava AA standarde\n• Maksimalni (AAA): Omjer kontrasta 7:1 - ispunjava najviše AAA standarde\n\nViši kontrast olakšava čitanje teksta u svim uvjetima osvjetljenja.";
"help_text_high_contrast" = "Način visokog kontrasta povećava kontrast između teksta i pozadine, olakšavajući čitanje.\n\nOvo je korisno za korisnike s:\n• Oslabljenim vidom\n• Osjetljivošću na boje\n• Okruženjima s jakim ekranom\n\nKada je omogućeno:\n• Tekst postaje crn na bijelom\n• Elementima se dodaju granice\n• Boje su pojednostavnjene";
"help_text_reduce_transparency" = "Smanji transparentnost uklanja efekte zamućenja i transparentnosti kroz cijelu aplikaciju.\n\nOvo pomaže:\n• Poboljšati čitljivost teksta\n• Smanjiti vizualnu kompleksnost\n• Povećati performanse na starijim uređajima\n• Učiniti sadržaj predvidljivijim";
"help_text_color_blind_mode" = "Načini za slijepe na boje prilagođavaju boje za različite vrste nedostataka vidne boje.\n\nDostupni načini:\n• Protanopija: sljepilo na crvenu\n• Deuteranopija: sljepilo na zelenu\n• Tritanopija: sljepilo na plavu\n• Monokromatski: samo sivi tonovi\n\nOvi načini osiguravaju da važne informacije nisu prenošene samo bojom.";
"help_text_line_spacing" = "Razmak između redova kontroliše prostor između redova teksta.\n\n• Raspon: 1,0x do 2,0x\n• AAA standard: minimum 1,5x\n• Zadano: 1,0x\n\nPovećani razmak između redova olakšava čitanje teksta i pomaže u sprječavanju preskakanja redova.";
"help_text_paragraph_spacing" = "Razmak između odlomaka kontroliše prostor između odlomaka.\n\n• Raspon: 1,0x do 3,0x\n• AAA standard: minimum 2,0x\n• Zadano: 1,0x\n\nPovećani razmak između odlomaka pomaže razlikovati između različitih sekcija teksta.";
"help_text_letter_spacing" = "Razmak između slova kontroliše prostor između pojedinačnih znakova.\n\n• Raspon: 0,0em do 0,2em\n• AAA standard: minimum 0,12em\n• Zadano: 0,0em\n\nPovećani razmak između slova poboljšava prepoznavanje znakova i čitljivost.";
"help_text_text_width" = "Širina teksta kontroliše maksimalnu dužinu reda za ugodno čitanje.\n\nOpcije:\n• Puna širina: bez maksimuma\n• Udobno (80 znakova): optimalno za čitanje\n• Usko (60 znakova): za fokusirano čitanje\n\nAAA smjernice preporučuju maksimalno 80 znakova po redu.";
"help_text_large_touch_targets" = "Veća područja dodira čine sva dugmad i interaktivne elemente najmanje 60pt veličine.\n\nOvo je korisno za:\n• Motorička oštećenja\n• Tremor ili drhtanje\n• Upotrebu aplikacije s rukavicama\n• Upotrebu jednom rukom\n\nStandardni minimum je 44pt; ova postavka povećava na 60pt.";
"help_text_reduce_motion" = "Smanji kretanje minimizira ili uklanja animacije kroz cijelu aplikaciju.\n\nOvo je korisno za korisnike s:\n• Osjetljivošću na kretanje\n• Vestibularnim poremećajima\n• Epilepsijom\n• Okidačima migrene\n\nKada je omogućeno, animacije se zamjenjuju trenutnim prijelazima.";
"help_text_timeout_behavior" = "Ponašanje vremenskog ograničenja kontroliše koliko dugo operacije mogu trajati prije isteka.\n\nOpcije:\n• Bez vremenskog ograničenja (AAA): operacije nikada ne istekaju\n• Standardno (30s): zadano vremensko ograničenje\n• Produženo (60s): duplo standardnog vremena\n\nNačin bez vremenskog ograničenja ispunjava AAA standarde pristupačnosti.";
"help_text_simplified_gestures" = "Pojednostavnjene geste zamjenjuju složene geste s više dodira jednostavnim dodirivanjima.\n\nOvo je korisno za:\n• Motorička oštećenja\n• Ograničenu spretnost\n• Upotrebu pomoćnih uređaja\n• Operaciju jednom rukom\n\nSložene geste se zamjenjuju dugmadima i jednostavnim dodirivanjima.";
"help_text_haptic_feedback" = "Haptična povratna informacija pruža vibracijske povratne informacije za radnje i obavijesti.\n\nOvo je korisno za:\n• Potvrđivanje pritisaka dugmadi\n• Upozoravanje na greške ili upozorenja\n• Pružanje ne-vizualnih povratnih informacija\n• Korisnike s oštećenjima sluha ili vida\n\nOvo možete onemogućiti ako su vibracije neugodne.";
"help_text_simplified_ui" = "Pojednostavnjeno sučelje smanjuje vizualnu kompleksnost kroz cijelu aplikaciju.\n\nOvo je korisno za:\n• Kognitivna oštećenja\n• Teškoće učenja\n• Poremećaje pažnje\n• Nove ili neiskusne korisnike\n\nKada je omogućeno:\n• Manje elemenata na ekranu\n• Veće, jasnije kontrole\n• Manje vizualne buke";
"help_text_verbose_descriptions" = "Detaljni opisi pružaju dodatni objašnjavajući tekst kroz cijelu aplikaciju.\n\nOvo je korisno za:\n• Razumijevanje složenih funkcija\n• Učenje kako koristiti aplikaciju\n• Kognitivnu podršku\n• Korisnike čitača ekrana\n\nPruža kontekst i upute za sve funkcije.";
"help_text_confirm_actions" = "Potvrdi radnje traži potvrdu prije važnih radnji.\n\nOvo pomaže spriječiti:\n• Slučajno brisanje\n• Nenamjerne promjene\n• Prerano slanje\n• Gubitak podataka\n\nNapomena: Destruktivne radnje uvijek zahtijevaju potvrdu (AAA zahtjev).";
"help_text_voice_input" = "Glasovni unos Vam omogućava da izgovorite kodove umjesto skeniranja ili ukucavanja.\n\nOvo je korisno za:\n• Ograničenu mobilnost\n• Korisnike čitača ekrana\n• Operaciju bez upotrebe ruku\n• Preferenciju za glas\n\nDodirnite dugme mikrofona i govorite jasno kada se to od Vas traži.";
"help_text_qr_scanning" = "Skeniranje QR koda koristi Vašu kameru za čitanje kodova brzog odgovora.\n\nKako skenirati:\n1. Usmjerite kameru na QR kod\n2. Poravnajte kod u okviru\n3. Pričekajte automatsko otkrivanje\n\nSavjeti:\n• Osigurajte dobro osvjetljenje\n• Držite uređaj mirno\n• Držite QR kod ravnim i slobodnim\n• Ako skeniranje ne uspije, pokušajte ručni unos koda";
"help_text_age_verification" = "Verifikacija dobi dokazuje da ispunjavate zahtjev dobi bez otkrivanja Vaše stvarne dobi ili datuma rođenja.\n\nKako funkcioniše:\n1. Verifikator generiše izazov\n2. Vi skenirate QR kod ili unosite ručno\n3. Aplikacija kreira dokaz nultog znanja\n4. Verifikator potvrđuje da ispunjavate zahtjev\n\nPrivatnost zaštićena:\n• Vaš datum rođenja nikada nije podijeljen\n• Verifikator samo saznaje da li ispunjavate zahtjev\n• Nema praćenja ni prikupljanja podataka";
"help_text_credentials" = "Digitalne akreditacije su kriptografski dokazi Vaše dobi sigurno pohranjeni na Vašem uređaju.\n\nFunkcije:\n• Pohranjene samo na Vašem uređaju\n• Ne mogu se kopirati ni krivotvoriti\n• Koriste se za verifikaciju uz čuvanje privatnosti\n• Mogu se obrisati u bilo koje vrijeme\n\nMorate pribaviti akreditaciju od ovlaštenog izdavača (poput vladine kancelarije) prije nego što možete verificirati Vašu dob.";
"help_text_zero_knowledge" = "Dokazi nultog znanja Vam omogućavaju da dokažete da je nešto istinito bez otkrivanja osnovnih informacija.\n\nPrimjer:\n• Tradicionalno: Pokažite identifikaciju (otkriva tačan datum rođenja)\n• Nulto znanje: Dokažite da imate više od 18 bez pokazivanja datuma rođenja\n\nPrednosti:\n• Maksimalna zaštita privatnosti\n• Nema dijeljenja ličnih podataka\n• Kriptografski sigurno\n• Ne može se krivotvoriti ili ponovo koristiti\n\nOvo je osnovna tehnologija koja čini Provii Wallet privatnim.";
"help_text_credential_issuance" = "Izdavanje akreditacije je proces dobivanja Vaše digitalne akreditacije dobi od ovlaštenog izdavača.\n\nKoraci:\n1. Posjetite ovlaštenog izdavača (npr. vladinu kancelariju)\n2. Dokažite Vaš identitet zvaničnom identifikacijom\n3. Primite QR kod ili duboki link od izdavača\n4. Skenirajte QR kod ili dodirnite link\n5. Akreditacija se izračunava lokalno i pohranjuje na Vašem uređaju\n\nProces slijepe ovjere osigurava da Vaš datum rođenja nikada nije prenesen mrežom.\nOvo trebate uraditi samo jednom. Vaša akreditacija se tada može koristiti za neograničene verifikacije.";
"help_text_officer_mode" = "Način rada za službenika je za ovlaštene izdavače koji kreiraju akreditacije za korisnike.\n\nOvaj način zahtijeva:\n• Autentifikaciju službenika s YubiKey-om\n• Autorizaciju od nadležnog organa za izdavanje\n• Fizičku verifikaciju identifikacije korisnika\n\nProces:\n1. Autentificirajte se kao službenik\n2. Verificirajte zvaničnu identifikaciju korisnika\n3. Unesite datum rođenja korisnika\n4. Generirajte QR kod za ovjeru\n5. Korisnik skenira kod za primanje akreditacije\n\nSamo ovlašteno osoblje treba koristiti ovaj način.";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "Povećava sav tekst za 50%.\n\nPomaže Vam ako:\n• Imate problema s vidom\n• Teško čitate\n• Trebate veći tekst\n\nRadi s postavkama veličine teksta Vašeg telefona.";
"help_text_contrast_level_simplified" = "Mijenja koliko je tekst taman.\n\nTri izbora:\n• Standardni: Normalne boje\n• Visoki: Tamniji tekst za lako čitanje\n• Maksimalni: Vrlo taman tekst za najbolje čitanje\n\nTamniji tekst je lakši za čitanje.";
"help_text_high_contrast_simplified" = "Olakšava viđenje teksta.\n\nPomaže Vam ako:\n• Imate problema s vidom\n• Trebate tamniji tekst\n• Koristite aplikaciju na jakom svjetlu\n\nTekst postaje crn na bijelom.";
"help_text_reduce_transparency_simplified" = "Uklanja efekte zamućenja.\n\nOvo pomaže:\n• Učiniti tekst jasnijim\n• Učiniti aplikaciju jednostavnijom\n• Ubrzati starije telefone\n\nSve izgleda punije.";
"help_text_color_blind_mode_simplified" = "Mijenja boje da Vam pomogne bolje vidjeti.\n\nIzbori:\n• Način sljepila na crvenu\n• Način sljepila na zelenu\n• Način sljepila na plavu\n• Samo sivi tonovi\n\nPomaže Vam vidjeti važne stvari.";
"help_text_line_spacing_simplified" = "Mijenja prostor između redova teksta.\n\nMožete birati od 1,0x do 2,0x.\nZadano je 1,0x.\n\nViše prostora olakšava čitanje.";
"help_text_paragraph_spacing_simplified" = "Mijenja prostor između odlomaka.\n\nMožete birati od 1,0x do 3,0x.\nZadano je 1,0x.\n\nViše prostora pomaže Vam vidjeti gdje počinju nove ideje.";
"help_text_letter_spacing_simplified" = "Mijenja prostor između slova.\n\nMožete birati od 0,0 do 0,2.\nZadano je 0,0.\n\nViše prostora čini slova jasnijima.";
"help_text_text_width_simplified" = "Kontroliše koliko je tekst širok.\n\nIzbori:\n• Puna širina: Koristi cijeli ekran\n• Srednje: Dobro za čitanje\n• Usko: Najbolje za fokus\n\nSrednja širina je najlakša za čitanje.";
"help_text_large_touch_targets_simplified" = "Čini sva dugmad većima.\n\nPomaže Vam ako:\n• Imate problema s dodirivanjem malih dugmadi\n• Imate drhtanje ruku\n• Nosite rukavice\n• Koristite jednu ruku\n\nDugmad postaju 60pt umjesto 44pt.";
"help_text_reduce_motion_simplified" = "Uklanja animacije kretanja.\n\nPomaže Vam ako:\n• Kretanje Vas vrti\n• Dobivate glavobolje od kretanja\n• Preferirate da stvari ostanu mirne\n\nStvari se mijenjaju trenutno umjesto da se kreću.";
"help_text_timeout_behavior_simplified" = "Kontroliše koliko dugo zadaci mogu trajati.\n\nIzbori:\n• Bez ograničenja: Zadaci nikada ne prestaju\n• Normalno: 30 sekundi\n• Duže: 60 sekundi\n\nOdaberite 'Bez ograničenja' ako trebate više vremena.";
"help_text_simplified_gestures_simplified" = "Zamjenjuje teške geste jednostavnim dodirivanjima.\n\nPomaže Vam ako:\n• Imate problema sa složenim dodirima\n• Preferirate jednostavna dodirivanja\n• Koristite jednu ruku\n\nSve koristi jednostavna dodirivanja.";
"help_text_haptic_feedback_simplified" = "Čini Vaš telefon da vibrira kada dodirnete.\n\nPomaže Vam:\n• Znati kada ste dodirnuli dugme\n• Osjetiti greške ili upozorenja\n• Dobiti povratnu informaciju bez gledanja\n\nIsključite ako Vas vibracije smetaju.";
"help_text_simplified_ui_simplified" = "Čini aplikaciju jednostavnijom.\n\nPomaže Vam ako:\n• Zbunjuju Vas zauzeti ekrani\n• Preferirate jednostavne rasporede\n• Ste novi u aplikaciji\n\nPrikazuje manje stvari odjednom.";
"help_text_step_indicators_simplified" = "Prikazuje Vaš napredak kroz korake.\n\nPomaže Vam:\n• Znati gdje se nalazite\n• Vidjeti koliko koraka preostaje\n• Ostati organizovani\n\nPrikazuje 'Korak 1 od 3' s točkama.";
"help_text_verbose_descriptions_simplified" = "Daje Vam više objašnjenja.\n\nPomaže Vam:\n• Razumjeti funkcije\n• Naučiti kako koristiti aplikaciju\n• Dobiti više detalja\n\nPruža dodatnu pomoć svugdje.";
"help_text_confirm_actions_simplified" = "Pita Vas da potvrdite važne radnje.\n\nPomaže spriječiti:\n• Slučajno brisanje\n• Neželjene promjene\n• Greške\n\nUvijek ćete biti pitani 'Jeste li sigurni?'";
"help_text_manual_code_entry_simplified" = "Omogućava Vam da ukucate kodove umjesto skeniranja.\n\nKoristite ovo kada:\n• Vaša kamera ne radi\n• Kod je teško skenirati\n• Preferirate ukucavanje\n\nDodirnite 'Unesite kod ručno' za ukucavanje.";
"help_text_voice_input_simplified" = "Omogućava Vam da izgovorite kodove umjesto ukucavanja.\n\nPomaže Vam ako:\n• Imate problema s ukucavanjem\n• Preferirate govor\n• Želite upotrebu bez ruku\n\nDodirnite mikrofon i govorite jasno.";
"help_text_qr_scanning_simplified" = "Koristite Vašu kameru za čitanje kvadratnih kodova.\n\nKako skenirati:\n1. Usmjerite kameru na kod\n2. Poravnajte kod\n3. Pričekajte da se pročita\n\nSavjeti:\n• Koristite dobro osvjetljenje\n• Držite telefon mirno\n• Držite kod ravnim";
"help_text_age_verification_simplified" = "Dokazuje da ste dovoljno stari/stara bez dijeljenja Vašeg datuma rođenja.\n\nKako funkcioniše:\n1. Preduzeće kreira zahtjev\n2. Vi skenirate njihov kod\n3. Aplikacija kreira dokaz\n4. Preduzeće potvrđuje da ste dovoljno stari/stara\n\nVaš datum rođenja ostaje privatan.";
"help_text_credentials_simplified" = "Digitalni dokaz Vaše dobi pohranjen na Vašem telefonu.\n\nFunkcije:\n• Samo na Vašem telefonu\n• Ne može se kopirati\n• Čuva Vašu privatnost\n• Možete ga obrisati u bilo koje vrijeme\n\nDobivate ga od vladine kancelarije.";
"help_text_zero_knowledge_simplified" = "Dokazuje nešto bez dijeljenja detalja.\n\nPrimjer:\n• Stari način: Pokažite Vašu identifikaciju (prikazuje tačan datum rođenja)\n• Novi način: Dokažite da imate više od 18 (datum rođenja ostaje privatan)\n\nOvo čuva Vaše informacije privatnima.";
"help_text_credential_issuance_simplified" = "Dobivanje Vašeg digitalnog dokaza dobi.\n\nKoraci:\n1. Idite u vladinu kancelariju\n2. Pokažite Vašu identifikaciju\n3. Dobijte kod\n4. Skenirajte kod\n5. Dokaz je pohranjen na Vašem telefonu\n\nUradite ovo jednom. Zatim koristite mnogo puta.";
"help_text_officer_mode_simplified" = "Za vladine radnike za kreiranje dokaza.\n\nTreba:\n• Lozinku službenika\n• Dozvolu za upotrebu\n• Identifikaciju korisnika za provjeru\n\nKoraci:\n1. Prijavite se kao službenik\n2. Provjerite identifikaciju korisnika\n3. Unesite njihov datum rođenja\n4. Kreirajte kod\n5. Korisnik skenira kod\n\nSamo za ovlaštene radnike.";

