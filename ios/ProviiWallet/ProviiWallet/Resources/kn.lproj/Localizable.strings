"help_text_extra_large_text_simplified" = "ಎಲ್ಲಾ ಪಠ್ಯ 50% ದೊಡ್ಡದಾಗಿಸುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ನೋಡಲು ತೊಂದರೆ ಇದ್ದಾಗ\n• ಓದಲು ಕಷ್ಟ ಇದ್ದಾಗ\n• ದೊಡ್ಡ ಪಠ್ಯ ಬೇಕಾದಾಗ\n\nನಿಮ್ಮ ಫೋನ್‌ನ ಪಠ್ಯ ಗಾತ್ರ ಸೆಟ್ಟಿಂಗ್‌ಗಳೊಂದಿಗೆ ಕೆಲಸ ಮಾಡುತ್ತದೆ.";
"help_text_contrast_level_simplified" = "ಪಠ್ಯ ಎಷ್ಟು ಗಾಢ ಎಂಬುದನ್ನು ಬದಲಾಯಿಸುತ್ತದೆ.\n\nಮೂರು ಆಯ್ಕೆಗಳು:\n• ಪ್ರಮಾಣಿತ: ಸಾಮಾನ್ಯ ಬಣ್ಣಗಳು\n• ಹೆಚ್ಚು: ಓದಲು ಸುಲಭಕ್ಕಾಗಿ ಗಾಢ ಪಠ್ಯ\n• ಗರಿಷ್ಠ: ಉತ್ತಮ ಓದಿಗಾಗಿ ಅತ್ಯಂತ ಗಾಢ ಪಠ್ಯ\n\nಗಾಢ ಪಠ್ಯ ಓದಲು ಸುಲಭ.";
"help_text_high_contrast_simplified" = "ಪಠ್ಯ ನೋಡಲು ಸುಲಭಗೊಳಿಸುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ನೋಡಲು ತೊಂದರೆ ಇದ್ದಾಗ\n• ಗಾಢ ಪಠ್ಯ ಬೇಕಾದಾಗ\n• ಪ್ರಕಾಶಮಾನ ಬೆಳಕಿನಲ್ಲಿ ಅಪ್ಲಿಕೇಶನ್ ಬಳಸುವಾಗ\n\nಪಠ್ಯ ಬಿಳಿ ಮೇಲೆ ಕಪ್ಪಾಗುತ್ತದೆ.";
"help_text_reduce_transparency_simplified" = "ಮಸುಕಾದ ಪ್ರಭಾವಗಳನ್ನು ತೆಗೆದುಹಾಕುತ್ತದೆ.\n\nಇದು ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಪಠ್ಯ ಸ್ಪಷ್ಟಗೊಳಿಸಲು\n• ಅಪ್ಲಿಕೇಶನ್ ಸರಳಗೊಳಿಸಲು\n• ಹಳೆಯ ಫೋನ್‌ಗಳನ್ನು ವೇಗಗೊಳಿಸಲು\n\nಎಲ್ಲವೂ ಹೆಚ್ಚು ಘನವಾಗಿ ಕಾಣಿಸುತ್ತದೆ.";
"help_text_color_blind_mode_simplified" = "ನೀವು ಉತ್ತಮವಾಗಿ ನೋಡಲು ಬಣ್ಣಗಳನ್ನು ಬದಲಾಯಿಸುತ್ತದೆ.\n\nಆಯ್ಕೆಗಳು:\n• ಕೆಂಪು-ಕುರುಡು ಮೋಡ್\n• ಹಸಿರು-ಕುರುಡು ಮೋಡ್\n• ನೀಲಿ-ಕುರುಡು ಮೋಡ್\n• ಕೇವಲ ಬೂದು ಮೋಡ್\n\nಮಹತ್ವದ ವಿಷಯಗಳನ್ನು ನೋಡಲು ಸಹಾಯ ಮಾಡುತ್ತದೆ.";
"help_text_line_spacing_simplified" = "ಪಠ್ಯದ ಸಾಲುಗಳ ನಡುವಿನ ಜಾಗ ಬದಲಾಯಿಸುತ್ತದೆ.\n\n1.0x ರಿಂದ 2.0x ವರೆಗೆ ಆರಿಸಬಹುದು.\nಡೀಫಾಲ್ಟ್ 1.0x.\n\nಹೆಚ್ಚಿನ ಜಾಗ ಓದಲು ಸುಲಭಗೊಳಿಸುತ್ತದೆ.";
"help_text_paragraph_spacing_simplified" = "ಪ್ಯಾರಾಗ್ರಾಫ್‌ಗಳ ನಡುವಿನ ಜಾಗ ಬದಲಾಯಿಸುತ್ತದೆ.\n\n1.0x ರಿಂದ 3.0x ವರೆಗೆ ಆರಿಸಬಹುದು.\nಡೀಫಾಲ್ಟ್ 1.0x.\n\nಹೆಚ್ಚಿನ ಜಾಗ ಹೊಸ ವಿಚಾರಗಳು ಎಲ್ಲಿ ಪ್ರಾರಂಭವಾಗುತ್ತವೆ ಎಂದು ನೋಡಲು ಸಹಾಯ ಮಾಡುತ್ತದೆ.";
"help_text_letter_spacing_simplified" = "ಅಕ್ಷರಗಳ ನಡುವಿನ ಜಾಗ ಬದಲಾಯಿಸುತ್ತದೆ.\n\n0.0 ರಿಂದ 0.2 ವರೆಗೆ ಆರಿಸಬಹುದು.\nಡೀಫಾಲ್ಟ್ 0.0.\n\nಹೆಚ್ಚಿನ ಜಾಗ ಅಕ್ಷರಗಳು ಸ್ಪಷ್ಟಗೊಳಿಸುತ್ತದೆ.";
"help_text_text_width_simplified" = "ಪಠ್ಯ ಎಷ್ಟು ಅಗಲ ಎಂಬುದನ್ನು ನಿಯಂತ್ರಿಸುತ್ತದೆ.\n\nಆಯ್ಕೆಗಳು:\n• ಪೂರ್ಣ ಅಗಲ: ಇಡೀ ಪರದೆ ಬಳಸುತ್ತದೆ\n• ಮಧ್ಯಮ: ಓದಲು ಉತ್ತಮ\n• ಕಿರಿದು: ಗಮನಕ್ಕಾಗಿ ಉತ್ತಮ\n\nಮಧ್ಯಮ ಅಗಲ ಓದಲು ಅತ್ಯಂತ ಸುಲಭ.";
"help_text_large_touch_targets_simplified" = "ಎಲ್ಲಾ ಬಟನ್‌ಗಳನ್ನು ದೊಡ್ಡದಾಗಿಸುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಸಣ್ಣ ಬಟನ್‌ಗಳನ್ನು ಟ್ಯಾಪ್ ಮಾಡಲು ತೊಂದರೆ ಇದ್ದಾಗ\n• ಕೈ ನಡುಗುವಾಗ\n• ಕೈಗವಸು ತೊಟ್ಟಾಗ\n• ಒಂದೇ ಕೈ ಬಳಸುವಾಗ\n\nಬಟನ್‌ಗಳು 44pt ಬದಲು 60pt ಆಗುತ್ತವೆ.";
"help_text_reduce_motion_simplified" = "ಚಲಿಸುವ ಅನಿಮೇಷನ್‌ಗಳನ್ನು ತೆಗೆದುಹಾಕುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಚಲನ ತಲೆಸುತ್ತು ಮಾಡಿದಾಗ\n• ಚಲನದಿಂದ ತಲೆನೋವು ಬಂದಾಗ\n• ವಸ್ತುಗಳು ಸ್ಥಿರವಾಗಿರಲು ಆದ್ಯತೆ ಇದ್ದಾಗ\n\nಚಲಿಸುವ ಬದಲು ತಕ್ಷಣ ಬದಲಾಗುತ್ತದೆ.";
"help_text_timeout_behavior_simplified" = "ಕಾರ್ಯಗಳಿಗೆ ಎಷ್ಟು ಸಮಯ ತೆಗೆದುಕೊಳ್ಳಬಹುದು ಎಂಬುದನ್ನು ನಿಯಂತ್ರಿಸುತ್ತದೆ.\n\nಆಯ್ಕೆಗಳು:\n• ಮಿತಿ ಇಲ್ಲ: ಕಾರ್ಯಗಳು ಎಂದಿಗೂ ನಿಲ್ಲುವುದಿಲ್ಲ\n• ಸಾಮಾನ್ಯ: 30 ಸೆಕೆಂಡ್‌ಗಳು\n• ಹೆಚ್ಚು: 60 ಸೆಕೆಂಡ್‌ಗಳು\n\nಹೆಚ್ಚು ಸಮಯ ಬೇಕಾದರೆ 'ಮಿತಿ ಇಲ್ಲ' ಆರಿಸಿ.";
"help_text_simplified_gestures_simplified" = "ಕಷ್ಟದ ಗೆಸ್ಚರ್‌ಗಳನ್ನು ಸರಳ ಟ್ಯಾಪ್‌ಗಳಿಂದ ಬದಲಾಯಿಸುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಸಂಕೀರ್ಣ ಸ್ಪರ್ಶಗಳಲ್ಲಿ ತೊಂದರೆ ಇದ್ದಾಗ\n• ಸರಳ ಟ್ಯಾಪ್‌ಗಳಿಗೆ ಆದ್ಯತೆ ಇದ್ದಾಗ\n• ಒಂದೇ ಕೈ ಬಳಸುವಾಗ\n\nಎಲ್ಲವೂ ಸರಳ ಟ್ಯಾಪ್‌ಗಳನ್ನು ಬಳಸುತ್ತವೆ.";
"help_text_haptic_feedback_simplified" = "ಟ್ಯಾಪ್ ಮಾಡಿದಾಗ ಫೋನ್ ಕಂಪಿಸುವಂತೆ ಮಾಡುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಬಟನ್ ಟ್ಯಾಪ್ ಮಾಡಿದ್ದೀರಿ ಎಂದು ತಿಳಿಯಲು\n• ದೋಷಗಳು ಅಥವಾ ಎಚ್ಚರಿಕೆಗಳನ್ನು ಅನುಭವಿಸಲು\n• ನೋಡದೆ ಪ್ರತಿಕ್ರಿಯೆ ಪಡೆಯಲು\n\nಕಂಪನಗಳು ತೊಂದರೆ ಮಾಡಿದರೆ ಆಫ್ ಮಾಡಿ.";
"help_text_simplified_ui_simplified" = "ಅಪ್ಲಿಕೇಶನ್ ಸರಳಗೊಳಿಸುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಕಿಕ್ಕಿರಿದ ಪರದೆಗಳಿಂದ ಗೊಂದಲವಾದಾಗ\n• ಸರಳ ವಿನ್ಯಾಸಗಳಿಗೆ ಆದ್ಯತೆ ಇದ್ದಾಗ\n• ಅಪ್ಲಿಕೇಶನ್‌ಗೆ ಹೊಸಬರಾಗಿದ್ದಾಗ\n\nಒಂದೇ ಸಮಯದಲ್ಲಿ ಕಡಿಮೆ ವಸ್ತುಗಳನ್ನು ತೋರಿಸುತ್ತದೆ.";
"help_text_step_indicators_simplified" = "ಹಂತಗಳ ಮೂಲಕ ನಿಮ್ಮ ಪ್ರಗತಿ ತೋರಿಸುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ನೀವು ಎಲ್ಲಿ ಇದ್ದೀರಿ ಎಂದು ತಿಳಿಯಲು\n• ಎಷ್ಟು ಹಂತಗಳು ಉಳಿದಿವೆ ಎಂದು ನೋಡಲು\n• ಸಂಘಟಿತವಾಗಿ ಇರಲು\n\nಚುಕ್ಕೆಗಳೊಂದಿಗೆ 'ಹಂತ 1 ರಲ್ಲಿ 3' ತೋರಿಸುತ್ತದೆ.";
"help_text_verbose_descriptions_simplified" = "ಹೆಚ್ಚಿನ ವಿವರಣೆಗಳನ್ನು ನೀಡುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ವೈಶಿಷ್ಟ್ಯಗಳನ್ನು ಅರ್ಥಮಾಡಿಕೊಳ್ಳಲು\n• ಅಪ್ಲಿಕೇಶನ್ ಬಳಸುವುದನ್ನು ಕಲಿಯಲು\n• ಹೆಚ್ಚಿನ ವಿವರಗಳು ಪಡೆಯಲು\n\nಎಲ್ಲೆಡೆ ಹೆಚ್ಚುವರಿ ಸಹಾಯ ಒದಗಿಸುತ್ತದೆ.";
"help_text_confirm_actions_simplified" = "ಮಹತ್ವದ ಕ್ರಿಯೆಗಳಿಗೆ ದೃಢೀಕರಣ ಕೇಳುತ್ತದೆ.\n\nಇದು ತಡೆಯಲು ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಆಕಸ್ಮಿಕ ಅಳಿಸುವಿಕೆ\n• ಅನಪೇಕ್ಷಿತ ಬದಲಾವಣೆಗಳು\n• ತಪ್ಪುಗಳು\n\nನೀವು ಯಾವಾಗಲೂ 'ಖಚಿತವೇ?' ಎಂದು ಕೇಳಲ್ಪಡುತ್ತೀರಿ.";
"help_text_manual_code_entry_simplified" = "ಸ್ಕ್ಯಾನ್ ಮಾಡುವ ಬದಲು ಕೋಡ್‌ಗಳನ್ನು ಟೈಪ್ ಮಾಡಲು ಅನುಮತಿಸುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಬಳಸಿ:\n• ಕ್ಯಾಮೆರಾ ಕೆಲಸ ಮಾಡದಿದ್ದಾಗ\n• ಕೋಡ್ ಸ್ಕ್ಯಾನ್ ಮಾಡಲು ಕಷ್ಟ ಆದಾಗ\n• ಟೈಪ್ ಮಾಡಲು ಆದ್ಯತೆ ಇದ್ದಾಗ\n\nಟೈಪ್ ಮಾಡಲು 'ಕೋಡ್ ಕೈಯಾರೆ ನಮೂದಿಸಿ' ಟ್ಯಾಪ್ ಮಾಡಿ.";
"help_text_voice_input_simplified" = "ಟೈಪ್ ಮಾಡುವ ಬದಲು ಕೋಡ್‌ಗಳನ್ನು ಮಾತನಾಡಲು ಅನುಮತಿಸುತ್ತದೆ.\n\nಈ ಸಂದರ್ಭದಲ್ಲಿ ಸಹಾಯ ಮಾಡುತ್ತದೆ:\n• ಟೈಪ್ ಮಾಡಲು ತೊಂದರೆ ಇದ್ದಾಗ\n• ಮಾತನಾಡಲು ಆದ್ಯತೆ ಇದ್ದಾಗ\n• ಕೈ ಮುಕ್ತ ಬಳಕೆ ಬೇಕಾದಾಗ\n\nಮೈಕ್ರೊಫೋನ್ ಟ್ಯಾಪ್ ಮಾಡಿ ಮತ್ತು ಸ್ಪಷ್ಟವಾಗಿ ಮಾತನಾಡಿ.";
"help_text_qr_scanning_simplified" = "ಚೌಕ ಕೋಡ್‌ಗಳನ್ನು ಓದಲು ಕ್ಯಾಮೆರಾ ಬಳಸುತ್ತದೆ.\n\nಸ್ಕ್ಯಾನ್ ಮಾಡುವ ವಿಧಾನ:\n1. ಕ್ಯಾಮೆರಾ ಕೋಡ್‌ನತ್ತ ತೋರಿಸಿ\n2. ಕೋಡ್ ಜೋಡಿಸಿ\n3. ಓದಲು ಕಾಯಿರಿ\n\nಸಲಹೆಗಳು:\n• ಉತ್ತಮ ಬೆಳಕು ಬಳಸಿ\n• ಫೋನ್ ಸ್ಥಿರವಾಗಿ ಹಿಡಿಯಿರಿ\n• ಕೋಡ್ ಚಪ್ಪಟೆ ಇರಲಿ";
"help_text_age_verification_simplified" = "ಹುಟ್ಟಿದ ದಿನ ಹಂಚಿಕೊಳ್ಳದೆ ನೀವು ಸಾಕಷ್ಟು ಹಳೆಯವರು ಎಂದು ಸಾಬೀತುಪಡಿಸುತ್ತದೆ.\n\nಹೇಗೆ ಕಾರ್ಯನಿರ್ವಹಿಸುತ್ತದೆ:\n1. ವ್ಯಾಪಾರ ವಿನಂತಿ ರಚಿಸುತ್ತದೆ\n2. ನೀವು ಅವರ ಕೋಡ್ ಸ್ಕ್ಯಾನ್ ಮಾಡಿ\n3. ಅಪ್ಲಿಕೇಶನ್ ಪುರಾವೆ ರಚಿಸುತ್ತದೆ\n4. ವ್ಯಾಪಾರ ನೀವು ಸಾಕಷ್ಟು ಹಳೆಯವರು ಎಂದು ದೃಢಪಡಿಸುತ್ತದೆ\n\nನಿಮ್ಮ ಹುಟ್ಟಿದ ದಿನ ಖಾಸಗಿಯಾಗಿ ಉಳಿಯುತ್ತದೆ.";
"help_text_credentials_simplified" = "ನಿಮ್ಮ ಫೋನ್‌ನಲ್ಲಿ ಸಂಗ್ರಹಿಸಲಾದ ನಿಮ್ಮ ವಯಸ್ಸಿನ ಡಿಜಿಟಲ್ ಪ್ರಮಾಣ.\n\nವೈಶಿಷ್ಟ್ಯಗಳು:\n• ಕೇವಲ ನಿಮ್ಮ ಫೋನ್‌ನಲ್ಲಿ\n• ನಕಲಿಸಲಾಗುವುದಿಲ್ಲ\n• ನಿಮ್ಮನ್ನು ಖಾಸಗಿಯಾಗಿ ಇಡುತ್ತದೆ\n• ನೀವು ಯಾವಾಗಲಾದರೂ ಅಳಿಸಬಹುದು\n\nನೀವು ಸರ್ಕಾರಿ ಕಚೇರಿಯಿಂದ ಪಡೆಯುತ್ತೀರಿ.";
"help_text_zero_knowledge_simplified" = "ವಿವರಗಳು ಹಂಚಿಕೊಳ್ಳದೆ ಏನಾದರೊಂದು ಸಾಬೀತುಪಡಿಸುತ್ತದೆ.\n\nಉದಾಹರಣೆ:\n• ಹಳೆಯ ಮಾರ್ಗ: ನಿಮ್ಮ ID ತೋರಿಸಿ (ನಿಖರ ಹುಟ್ಟಿದ ದಿನ ತೋರಿಸುತ್ತದೆ)\n• ಹೊಸ ಮಾರ್ಗ: 18 ವರ್ಷಕ್ಕಿಂತ ಮೇಲಿದ್ದೀರಿ ಎಂದು ಸಾಬೀತುಪಡಿಸಿ (ಹುಟ್ಟಿದ ದಿನ ಖಾಸಗಿ)\n\nಇದು ನಿಮ್ಮ ಮಾಹಿತಿ ಖಾಸಗಿಯಾಗಿ ಇಡುತ್ತದೆ.";
"help_text_credential_issuance_simplified" = "ನಿಮ್ಮ ಡಿಜಿಟಲ್ ವಯಸ್ಸಿನ ಪ್ರಮಾಣ ಪಡೆಯುವುದು.\n\nಹಂತಗಳು:\n1. ಸರ್ಕಾರಿ ಕಚೇರಿಗೆ ಹೋಗಿ\n2. ನಿಮ್ಮ ID ತೋರಿಸಿ\n3. ಕೋಡ್ ಪಡೆಯಿರಿ\n4. ಕೋಡ್ ಸ್ಕ್ಯಾನ್ ಮಾಡಿ\n5. ಪ್ರಮಾಣ ನಿಮ್ಮ ಫೋನ್‌ನಲ್ಲಿ ಉಳಿಸಲ್ಪಡುತ್ತದೆ\n\nಒಮ್ಮೆ ಮಾಡಿ. ನಂತರ ಅನೇಕ ಬಾರಿ ಬಳಸಿ.";
"help_text_officer_mode_simplified" = "ಸರ್ಕಾರಿ ಕೆಲಸಗಾರರು ಪ್ರಮಾಣಗಳನ್ನು ರಚಿಸಲು.\n\nಅಗತ್ಯ:\n• ಅಧಿಕಾರಿ ಪಾಸ್‌ವರ್ಡ್\n• ಬಳಸಲು ಅನುಮತಿ\n• ಪರಿಶೀಲಿಸಲು ಬಳಕೆದಾರರ ID\n\nಹಂತಗಳು:\n1. ಅಧಿಕಾರಿಯಾಗಿ ಲಾಗ್ ಇನ್\n2. ಬಳಕೆದಾರರ ID ಪರಿಶೀಲಿಸಿ\n3. ಅವರ ಹುಟ್ಟಿದ ದಿನ ನಮೂದಿಸಿ\n4. ಕೋಡ್ ರಚಿಸಿ\n5. ಬಳಕೆದಾರರು ಕೋಡ್ ಸ್ಕ್ಯಾನ್ ಮಾಡುತ್ತಾರೆ\n\nಅಧಿಕೃತ ಕೆಲಸಗಾರರಿಗೆ ಮಾತ್ರ.";

