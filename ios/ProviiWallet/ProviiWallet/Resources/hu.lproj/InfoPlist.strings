/* InfoPlist.strings - Hungarian */
/* Lokalizált jogosultságleírások a Provii Wallet alkalmazáshoz */

/* Camera Access */
"NSCameraUsageDescription" = "A Provii Wallet kameraengedélyre van szüksége a QR-kódok beolvasásához hitelesítő adatok igénylésekor és életkor-ellenőrzéskor.";

/* NFC Access */
"NFCReaderUsageDescription" = "A Provii Wallet NFC-t használ a YubiKey-jel való kommunikációhoz a biztonságos tisztviselői hitelesítéshez.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "A Provii Wallet hangfelismerést használ hangparancsokhoz akadálymentesítési módban, lehetővé téve az alkalmazás kézzel szabad irányítását.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "A Provii Wallet mikrofonhozzáférésre van szüksége a hangvezérlési funkciókhoz, amikor az akadálymentesítési mód engedélyezve van.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "A Provii Wallet Face ID-t használ az életkori hitelesítő adataihoz való biztonságos hozzáféréshez és személyazonosságának ellenőrzéséhez.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "A Provii Wallet helyi hálózatot használhat a közeli hitelesítő adat-kibocsátók felderítéséhez.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "A Provii Wallet Bluetooth-t használhat a YubiKey eszközökkel való kommunikációhoz.";
