// MARK: - Hjälptextbeskrivningar
"help_text_extra_large_text" = "Extra stor text ökar all text i appen med 50 %.\n\nDet hjälper användare med:\n• Nedsatt syn\n• Lässvårigheter\n• Åldersrelaterade synförändringar\n\nFungerar med iOS Dynamic Type för ännu större storlekar.";
"help_text_contrast_level" = "Kontrastnivå styr färgkontrasten mellan text och bakgrunder.\n\nTre nivåer finns:\n• Standard: Standardfärger\n• Hög (AA): 4,5:1 kontrastförhållande – uppfyller AA-standard\n• Maximal (AAA): 7:1 kontrastförhållande – uppfyller högsta AAA-standard\n\nHögre kontrast gör text lättare att läsa i alla ljusförhållanden.";
"help_text_high_contrast" = "Högkontrastläge ökar kontrasten mellan text och bakgrund, vilket gör det lättare att läsa.\n\nDet hjälper användare med:\n• Nedsatt syn\n• Färgkänslighet\n• Ljusa skärmmiljöer\n\nNär aktiverat:\n• Text blir svart på vitt\n• Kanter läggs till element\n• Färger förenklas";
"help_text_reduce_transparency" = "Reducera genomskinlighet tar bort oskärpe och genomskinlighetseffekter i appen.\n\nDet hjälper:\n• Förbättra textläsbarhet\n• Minska visuell komplexitet\n• Öka prestanda på äldre enheter\n• Göra innehåll mer förutsägbart";
"help_text_color_blind_mode" = "Färgblindlägen justerar färger för olika typer av färgseendedeficienser.\n\nTillgängliga lägen:\n• Protanopi: Röd-blind (svårt att se rött)\n• Deuteranopi: Grön-blind (svårt att se grönt)\n• Tritanopi: Blå-blind (svårt att se blått)\n• Monokrom: Bara gråskala\n\nDessa lägen säkerställer att viktig information inte enbart förmedlas via färg.";
"help_text_line_spacing" = "Radavstånd styr utrymmet mellan textrader.\n\n• Intervall: 1,0x till 2,0x\n• AAA-standard: 1,5x minimum\n• Standard: 1,0x\n\nÖkat radavstånd gör text lättare att läsa och förhindrar radhopp.";
"help_text_paragraph_spacing" = "Styckemellanrum styr utrymmet mellan stycken.\n\n• Intervall: 1,0x till 3,0x\n• AAA-standard: 2,0x minimum\n• Standard: 1,0x\n\nÖkat styckemellanrum hjälper till att skilja olika textavsnitt åt.";
"help_text_letter_spacing" = "Teckenavstånd styr utrymmet mellan enskilda tecken.\n\n• Intervall: 0,0em till 0,2em\n• AAA-standard: 0,12em minimum\n• Standard: 0,0em\n\nÖkat teckenavstånd förbättrar teckenigenkänning och läsbarhet.";
"help_text_text_width" = "Textbredd styr den maximala radlängden för bekväm läsning.\n\nAlternativ:\n• Full bredd: Ingen maxgräns\n• Bekväm (80 tecken): Optimal för läsning\n• Smal (60 tecken): För koncentrerad läsning\n\nAAA-riktlinjerna rekommenderar max 80 tecken per rad.";
"help_text_large_touch_targets" = "Större tryckytor gör alla knappar och interaktiva element minst 60 pt stora.\n\nDet hjälper vid:\n• Motorisk funktionsnedsättning\n• Skakningar eller darrningar\n• Användning med handskar\n• Enhandsanvändning\n\nStandardminimum är 44 pt; den här inställningen ökar till 60 pt.";
"help_text_reduce_motion" = "Reducera rörelse minimerar eller tar bort animationer i appen.\n\nDet hjälper användare med:\n• Rörelsekänslighet\n• Vestibulära störningar\n• Epilepsi\n• Migrän\n\nNär aktiverat ersätts animationer med omedelbara övergångar.";
"help_text_timeout_behavior" = "Tidsgränsbeteende styr hur länge åtgärder kan pågå innan de får timeout.\n\nAlternativ:\n• Ingen tidsgräns (AAA): Åtgärder får aldrig timeout\n• Standard (30 s): Standardtimeout\n• Utökad (60 s): Dubbla standardtiden\n\nInget tidsgränsläge uppfyller AAA-tillgänglighetsstandarder.";
"help_text_simplified_gestures" = "Förenklade gester reducerar komplexa flerpunktsrörelser till enkla tryckningar.\n\nDet hjälper vid:\n• Motorisk funktionsnedsättning\n• Begränsad fingerfärdighet\n• Användning av hjälpmedel\n• Enhandsanvändning\n\nKomplexa gester ersätts med knappar och enkla tryckningar.";
"help_text_haptic_feedback" = "Haptisk återkoppling ger vibrationsfeedback för åtgärder och meddelanden.\n\nDet hjälper vid:\n• Bekräftelse av knapptryckningar\n• Varning vid fel\n• Icke-visuell feedback\n• Hörsel- eller synskada\n\nDu kan inaktivera det om vibrationer känns obehagligt.";
"help_text_simplified_ui" = "Förenklat gränssnitt minskar visuell komplexitet i appen.\n\nDet hjälper vid:\n• Kognitiva funktionsnedsättningar\n• Inlärningssvårigheter\n• Koncentrationssvårigheter\n• Nya eller oerfarna användare\n\nNär aktiverat:\n• Färre element på skärmen\n• Större, tydligare kontroller\n• Mindre visuellt brus";
"help_text_step_indicators" = "Stegsindikatorer visar ditt förlopp genom flerstegsprocesser.\n\nDet hjälper till att:\n• Förstå var du är i processen\n• Veta hur många steg som återstår\n• Minska kognitiv belastning\n• Ge tydlig struktur\n\nVisar 'Steg X av Y' med visuella förloppspunkter.";
"help_text_verbose_descriptions" = "Detaljerade beskrivningar ger ytterligare förklarande text i appen.\n\nDet hjälper vid:\n• Förståelse av komplexa funktioner\n• Att lära sig använda appen\n• Kognitivt stöd\n• Skärmläsaranvändare\n\nGer sammanhang och instruktioner för alla funktioner.";
"help_text_confirm_actions" = "Bekräfta åtgärder ber om bekräftelse innan viktiga åtgärder.\n\nDet förhindrar:\n• Oavsiktliga raderingar\n• Oavsiktliga ändringar\n• Förtida inlämningar\n• Dataförlust\n\nObs: Destruktiva åtgärder kräver alltid bekräftelse (AAA-krav).";
"help_text_manual_code_entry" = "Manuell kodinmatning låter dig skriva koder i stället för att skanna QR-koder.\n\nDet är användbart när:\n• Kameran inte fungerar\n• QR-koden är skadad eller otydlig\n• Du använder skärmläsare\n• Du föredrar att skriva\n\nTryck på 'Ange kod manuellt' för att skriva koden som visas på skärmen.";
"help_text_voice_input" = "Röstinmatning låter dig tala koder i stället för att skanna eller skriva.\n\nDet hjälper vid:\n• Begränsad rörlighet\n• Skärmläsaranvändning\n• Handsfreedrift\n• Preferens för röst\n\nTryck på mikrofonknappen och tala tydligt när du uppmanas.";
"help_text_qr_scanning" = "QR-kodsskanning använder kameran för att läsa Quick Response-koder.\n\nHur du skannar:\n1. Rikta kameran mot QR-koden\n2. Centrera koden i ramen\n3. Vänta på automatisk identifiering\n\nTips:\n• Se till att det är bra belysning\n• Håll enheten still\n• Håll QR-koden plan och fri\n• Om skanning misslyckas, prova manuell kodinmatning";
"help_text_age_verification" = "Åldersverifiering bevisar att du uppfyller ett ålderskrav utan att avslöja din faktiska ålder eller ditt födelsedatum.\n\nHur det fungerar:\n1. Verifieraren genererar en utmaning\n2. Du skannar QR-koden eller anger manuellt\n3. Appen skapar ett nollkunskapsbevis\n4. Verifieraren bekräftar att du uppfyller kravet\n\nIntegritet skyddad:\n• Ditt födelsedatum delas aldrig\n• Verifieraren lär sig bara om du uppfyller kravet\n• Ingen spårning eller datainsamling";
"help_text_credentials" = "Digitala legitimationer är kryptografiska bevis på din ålder som lagras säkert på din enhet.\n\nEgenskaper:\n• Lagras bara på din enhet\n• Kan inte kopieras eller förfalskas\n• Används för integritetsbevarande verifiering\n• Kan raderas när som helst\n\nDu måste hämta en legitimation från en auktoriserad utfärdare (till exempel ett myndighetskontور) innan du kan verifiera din ålder.";
"help_text_zero_knowledge" = "Nollkunskapsbevis låter dig bevisa att något är sant utan att avslöja den underliggande informationen.\n\nExempel:\n• Traditionellt: Visa ID (avslöjar exakt födelsedag)\n• Nollkunskap: Bevisa att du är över 18 utan att visa födelsedag\n\nFördelar:\n• Maximalt integritetsskydd\n• Inga personuppgifter delas\n• Kryptografiskt säkert\n• Kan inte förfalskas eller spelas upp\n\nDet här är kärnteknologin som gör Provii Wallet privat.";
"help_text_credential_issuance" = "Utfärdning av legitimation är processen att hämta din digitala ålderslegitimation från en auktoriserad utfärdare.\n\nSteg:\n1. Besök auktoriserad utfärdare (t.ex. myndighet)\n2. Bevisa din identitet med officiellt ID\n3. Ta emot QR-kod eller djuplänk från utfärdare\n4. Skanna QR-koden eller tryck på länken\n5. Legitimationen beräknas lokalt och lagras på din enhet\n\nBlindintygsprocessen säkerställer att ditt födelsedatum aldrig överförs via nätverket.\nDu behöver bara göra det här en gång. Din legitimation kan sedan användas för obegränsat antal verifieringar.";
"help_text_officer_mode" = "Tjänstemannaläget är för auktoriserade utfärdare att skapa legitimationer för användare.\n\nDet här läget kräver:\n• Tjänstemannaautentisering med YubiKey\n• Auktorisation från utfärdarmyndigheten\n• Fysisk verifiering av användarens ID\n\nProcess:\n1. Autentisera som tjänsteman\n2. Verifiera användarens officiella ID\n3. Ange användarens födelsedatum\n4. Generera intygs-QR-kod\n5. Användaren skannar koden för att ta emot legitimationen\n\nBara auktoriserad personal får använda det här läget.";

// MARK: - Förenklade hjälptexter (Läsnivå: klass 6–8)

"help_text_extra_large_text_simplified" = "Gör all text 50 % större.\n\nHjälper dig om du:\n• Har svårt att se\n• Tycker att läsning är svårt\n• Behöver större text\n\nFungerar med din telefons textstorleksinställningar.";

"help_text_contrast_level_simplified" = "Ändrar hur mörk texten är.\n\nTre val:\n• Standard: Normala färger\n• Hög: Mörkare text för enkel läsning\n• Maximal: Mycket mörk text för bästa läsning\n\nMörkare text är lättare att läsa.";

"help_text_high_contrast_simplified" = "Gör text lättare att se.\n\nHjälper dig om du:\n• Har svårt att se\n• Behöver mörkare text\n• Använder appen i starkt ljus\n\nText blir svart på vitt.";

"help_text_reduce_transparency_simplified" = "Tar bort suddiga effekter.\n\nDet hjälper:\n• Göra text tydligare\n• Göra appen enklare\n• Snabba upp äldre telefoner\n\nAllt ser mer solitt ut.";

"help_text_color_blind_mode_simplified" = "Ändrar färger så du ser bättre.\n\nVal:\n• Röd-blindläge\n• Grön-blindläge\n• Blå-blindläge\n• Bara gråskala\n\nHjälper dig se viktiga saker.";

"help_text_line_spacing_simplified" = "Ändrar utrymme mellan textrader.\n\nDu kan välja från 1,0x till 2,0x.\nStandard är 1,0x.\n\nMer utrymme gör läsning enklare.";

"help_text_paragraph_spacing_simplified" = "Ändrar utrymme mellan stycken.\n\nDu kan välja från 1,0x till 3,0x.\nStandard är 1,0x.\n\nMer utrymme hjälper dig se var nya idéer börjar.";

"help_text_letter_spacing_simplified" = "Ändrar utrymme mellan bokstäver.\n\nDu kan välja från 0,0 till 0,2.\nStandard är 0,0.\n\nMer utrymme gör bokstäver tydligare.";

"help_text_text_width_simplified" = "Styr hur bred texten är.\n\nVal:\n• Full bredd: Använder hela skärmen\n• Medel: Bra för läsning\n• Smal: Bäst för fokus\n\nMedelbredd är lättast att läsa.";

"help_text_large_touch_targets_simplified" = "Gör alla knappar större.\n\nHjälper dig om du:\n• Har svårt att trycka på små knappar\n• Har skakiga händer\n• Bär handskar\n• Använder en hand\n\nKnappar blir 60 pt i stället för 44 pt.";

"help_text_reduce_motion_simplified" = "Tar bort rörliga animationer.\n\nHjälper dig om:\n• Rörelse gör dig yr\n• Du får huvudvärk av rörelse\n• Du föredrar att saker är stilla\n\nSaker ändras omedelbart i stället för att röra sig.";

"help_text_timeout_behavior_simplified" = "Styr hur lång tid uppgifter kan ta.\n\nVal:\n• Ingen gräns: Uppgifter slutar aldrig\n• Normal: 30 sekunder\n• Längre: 60 sekunder\n\nVälj 'Ingen gräns' om du behöver mer tid.";

"help_text_simplified_gestures_simplified" = "Ersätter svåra gester med enkla tryckningar.\n\nHjälper dig om du:\n• Har svårt med komplexa rörelser\n• Föredrar enkla tryckningar\n• Använder en hand\n\nAllt använder enkla tryckningar.";

"help_text_haptic_feedback_simplified" = "Gör din telefon vibrera när du trycker.\n\nHjälper dig:\n• Veta när du tryckt på en knapp\n• Känna fel eller varningar\n• Få feedback utan att titta\n\nStäng av om vibrationer stör dig.";

"help_text_simplified_ui_simplified" = "Gör appen enklare.\n\nHjälper dig om du:\n• Blir förvirrad av röriga skärmar\n• Föredrar enkla layouter\n• Är ny i appen\n\nVisar färre saker åt gången.";

"help_text_step_indicators_simplified" = "Visar ditt förlopp genom steg.\n\nHjälper dig:\n• Veta var du är\n• Se hur många steg som återstår\n• Hålla ordning\n\nVisar 'Steg 1 av 3' med punkter.";

"help_text_verbose_descriptions_simplified" = "Ger dig mer förklaringar.\n\nHjälper dig:\n• Förstå funktioner\n• Lära dig använda appen\n• Få mer detaljer\n\nGer extra hjälp överallt.";

"help_text_confirm_actions_simplified" = "Ber dig bekräfta viktiga åtgärder.\n\nHjälper förhindra:\n• Oavsiktliga raderingar\n• Oönskade ändringar\n• Misstag\n\nDu tillfrågas alltid 'Är du säker?'.";

"help_text_manual_code_entry_simplified" = "Låter dig skriva koder i stället för att skanna.\n\nAnvänd det när:\n• Din kamera inte fungerar\n• Koden är svår att skanna\n• Du föredrar att skriva\n\nTryck på 'Ange kod manuellt' för att skriva.";

"help_text_voice_input_simplified" = "Låter dig säga koder i stället för att skriva.\n\nHjälper dig om du:\n• Har svårt att skriva\n• Föredrar att prata\n• Vill använda handsfree\n\nTryck på mikrofonen och tala tydligt.";

"help_text_qr_scanning_simplified" = "Använder kameran för att läsa fyrkantiga koder.\n\nHur du skannar:\n1. Rikta kameran mot koden\n2. Rikta in koden\n3. Vänta tills den läses\n\nTips:\n• Använd bra belysning\n• Håll telefonen still\n• Håll koden plan";

"help_text_age_verification_simplified" = "Bevisar att du är tillräckligt gammal utan att dela din födelsedag.\n\nHur det fungerar:\n1. Verksamhet skapar en begäran\n2. Du skannar deras kod\n3. Appen skapar ett bevis\n4. Verksamhet bekräftar att du är tillräckligt gammal\n\nDin födelsedag förblir privat.";

"help_text_credentials_simplified" = "Digitalt bevis på din ålder lagrat på din telefon.\n\nEgenskaper:\n• Bara på din telefon\n• Kan inte kopieras\n• Skyddar din integritet\n• Du kan radera det när som helst\n\nDu hämtar det från ett myndighetskontor.";

"help_text_zero_knowledge_simplified" = "Bevisar något utan att dela detaljer.\n\nExempel:\n• Gammalt sätt: Visa ditt ID (visar exakt födelsedag)\n• Nytt sätt: Bevisa att du är över 18 (födelsedag förblir privat)\n\nDet här håller din information privat.";

"help_text_credential_issuance_simplified" = "Hämta ditt digitala åldersbevis.\n\nSteg:\n1. Gå till myndighetskontor\n2. Visa ditt ID\n3. Få en kod\n4. Skanna koden\n5. Bevis sparas på din telefon\n\nGör det en gång. Använd det sedan många gånger.";

"help_text_officer_mode_simplified" = "För myndighetspersonal att skapa bevis.\n\nBehöver:\n• Tjänstemannalösenord\n• Tillstånd att använda\n• Användarens ID att kontrollera\n\nSteg:\n1. Logga in som tjänsteman\n2. Kontrollera användarens ID\n3. Ange deras födelsedag\n4. Skapa kod\n5. Användaren skannar kod\n\nBara för auktoriserad personal.";

