/* Help Text Descriptions */
"help_text_extra_large_text" = "超大字体将应用中的所有文字放大 50%。\n\n适合以下用户：\n• 低视力\n• 阅读困难\n• 年龄相关的视力变化\n\n可与 iOS 动态字体配合使用，获得更大的字号。";
"help_text_contrast_level" = "对比度级别控制文字与背景之间的颜色对比度。\n\n三个级别：\n• 标准：默认颜色\n• 高（AA）：4.5:1 对比度 - 符合 AA 标准\n• 最高（AAA）：7:1 对比度 - 符合最高 AAA 标准\n\n更高的对比度让文字在所有光线条件下更易阅读。";
"help_text_high_contrast" = "高对比度模式增强文字和背景之间的对比度，使阅读更容易。\n\n适合以下用户：\n• 低视力\n• 颜色敏感\n• 强光环境\n\n启用后：\n• 文字变为白色背景上的黑色\n• 元素添加边框\n• 颜色简化";
"help_text_reduce_transparency" = "减少透明效果可移除应用中的模糊和透明效果。\n\n好处：\n• 提高文字可读性\n• 降低视觉复杂度\n• 提高旧设备性能\n• 使内容更可预期";
"help_text_color_blind_mode" = "色觉障碍模式为不同类型的色觉缺陷调整颜色。\n\n可用模式：\n• 红色盲：看不清红色\n• 绿色盲：看不清绿色\n• 蓝色盲：看不清蓝色\n• 单色：仅灰度\n\n这些模式确保重要信息不单靠颜色传达。";
"help_text_line_spacing" = "行间距控制文字行之间的间距。\n\n• 范围：1.0x 至 2.0x\n• AAA 标准：最低 1.5x\n• 默认：1.0x\n\n增大行间距使文字更易阅读，有助于防止跳行。";
"help_text_paragraph_spacing" = "段落间距控制段落之间的间距。\n\n• 范围：1.0x 至 3.0x\n• AAA 标准：最低 2.0x\n• 默认：1.0x\n\n增大段落间距有助于区分不同的文本节。";
"help_text_letter_spacing" = "字间距控制字符之间的间距。\n\n• 范围：0.0em 至 0.2em\n• AAA 标准：最低 0.12em\n• 默认：0.0em\n\n增大字间距可提高字符识别和可读性。";
"help_text_text_width" = "文本宽度控制舒适阅读的最大行长。\n\n选项：\n• 全宽：无最大限制\n• 舒适（80 字符）：适合阅读\n• 窄（60 字符）：适合专注阅读\n\nAAA 指南建议每行最多 80 个字符。";
"help_text_large_touch_targets" = "更大的触控目标使所有按钮和交互元素至少达到 60 点大小。\n\n适合以下情况：\n• 肢体障碍\n• 震颤或抖动\n• 戴手套使用应用\n• 单手操作\n\n标准最低为 44 点，此设置增加到 60 点。";
"help_text_reduce_motion" = "减少动画可最小化或移除应用中的动画。\n\n适合以下用户：\n• 运动敏感\n• 前庭功能障碍\n• 癫痫\n• 偏头痛触发\n\n启用后，动画将替换为即时过渡。";
"help_text_timeout_behavior" = "超时行为控制操作超时前的时长。\n\n选项：\n• 不超时（AAA）：操作永不超时\n• 标准（30 秒）：默认超时\n• 延长（60 秒）：标准时间的两倍\n\n不超时模式符合 AAA 无障碍标准。";
"help_text_simplified_gestures" = "简化手势将复杂的多点触控手势简化为简单点击。\n\n适合以下情况：\n• 肢体障碍\n• 灵活性有限\n• 使用辅助设备\n• 单手操作\n\n复杂手势替换为按钮和简单点击。";
"help_text_haptic_feedback" = "触觉反馈为操作和通知提供振动反馈。\n\n好处：\n• 确认按钮按下\n• 提示错误或警告\n• 提供非视觉反馈\n• 适合有听力或视力障碍的用户\n\n如果振动让您不适，可以关闭此功能。";
"help_text_simplified_ui" = "简化界面降低应用的视觉复杂度。\n\n适合以下情况：\n• 认知障碍\n• 学习困难\n• 注意力障碍\n• 新用户或缺乏经验的用户\n\n启用后：\n• 屏幕上的元素更少\n• 控件更大更清晰\n• 视觉干扰更少";
"help_text_step_indicators" = "步骤指示器显示您在多步骤流程中的进度。\n\n好处：\n• 了解您在流程中的位置\n• 知道还有多少步骤\n• 降低认知负担\n• 提供清晰的结构\n\n显示”第 X 步，共 Y 步”及可视化进度点。";
"help_text_verbose_descriptions" = "详细描述在应用中提供额外的说明文字。\n\n适合以下情况：\n• 理解复杂功能\n• 学习如何使用应用\n• 认知支持\n• 屏幕阅读器用户\n\n为所有功能提供上下文和说明。";
"help_text_confirm_actions" = "操作确认在重要操作前询问确认。\n\n有助于防止：\n• 意外删除\n• 非预期更改\n• 提前提交\n• 数据丢失\n\n注意：破坏性操作始终需要确认（AAA 要求）。";
"help_text_manual_code_entry" = "手动输入代码让您可以输入代码而无需扫描 QR 码。\n\n适合以下情况：\n• 相机不工作\n• QR 码损坏或不清晰\n• 使用屏幕阅读器\n• 偏好输入而非扫描\n\n只需点击”手动输入代码”即可输入屏幕上显示的代码。";
"help_text_voice_input" = "语音输入让您可以说出代码而无需扫描或输入。\n\n适合以下情况：\n• 行动不便\n• 屏幕阅读器用户\n• 免提操作\n• 偏好语音\n\n点击麦克风按钮，在提示时清晰说出代码。";
"help_text_qr_scanning" = "QR 码扫描使用相机读取 Quick Response 码。\n\n扫描方法：\n1. 将相机对准 QR 码\n2. 在取景框内对齐代码\n3. 等待自动检测\n\n提示：\n• 确保光线良好\n• 保持设备稳定\n• 保持 QR 码平整不遮挡\n• 如果扫描失败，请尝试手动输入代码";
"help_text_age_verification" = "年龄验证证明您满足年龄要求，而无需透露实际年龄或出生日期。\n\n工作原理：\n1. 验证方生成质询\n2. 您扫描 QR 码或手动输入\n3. 应用创建零知识证明\n4. 验证方确认您满足要求\n\n隐私保护：\n• 您的出生日期绝不会被共享\n• 验证方只能得知您是否满足要求\n• 无跟踪或数据收集";
"help_text_credentials" = "数字凭证是安全存储在您设备上的年龄加密证明。\n\n特点：\n• 仅存储在您的设备上\n• 无法复制或伪造\n• 用于隐私保护型验证\n• 可随时删除\n\n在验证年龄之前，您必须从授权签发机构（如政府办事处）获取凭证。";
"help_text_zero_knowledge" = "零知识证明让您可以证明某事为真，而无需透露底层信息。\n\n示例：\n• 传统方式：出示证件（透露确切生日）\n• 零知识：证明您年满 18 岁，无需显示生日\n\n好处：\n• 最大隐私保护\n• 不共享个人数据\n• 加密安全\n• 无法伪造或重放\n\n这是 Provii Wallet 私密性的核心技术。";
"help_text_credential_issuance" = "凭证签发是从授权签发机构获取数字年龄凭证的过程。\n\n步骤：\n1. 前往授权签发机构（如政府办事处）\n2. 用官方证件证明身份\n3. 从签发机构获取 QR 码或深度链接\n4. 扫描 QR 码或点击链接\n5. 凭证在本地计算并存储在您的设备上\n\n盲签名证明流程确保您的出生日期不会通过网络传输。\n您只需进行一次。之后您的凭证可用于无限次验证。";
"help_text_officer_mode" = "工作人员模式供授权签发机构为用户创建凭证。\n\n此模式需要：\n• 使用 YubiKey 进行工作人员身份验证\n• 来自签发机构的授权\n• 亲自核实用户证件\n\n流程：\n1. 以工作人员身份进行身份验证\n2. 核实用户的官方证件\n3. 输入用户的出生日期\n4. 生成证明 QR 码\n5. 用户扫描码以领取凭证\n\n仅授权人员应使用此模式。";

/* Simplified Help Text */
"help_text_extra_large_text_simplified" = "将所有文字放大 50%。\n\n如果您：\n• 看不清文字\n• 觉得阅读困难\n• 需要更大的文字\n\n可与手机的文字大小设置配合使用。";
"help_text_contrast_level_simplified" = "更改文字的深浅。\n\n三个选择：\n• 标准：正常颜色\n• 高：文字更深，便于阅读\n• 最高：文字非常深，阅读效果最佳\n\n文字越深越容易阅读。";
"help_text_high_contrast_simplified" = "让文字更容易看清。\n\n如果您：\n• 看不清文字\n• 需要文字更深\n• 在强光下使用应用\n\n文字变为白色背景上的黑色。";
"help_text_reduce_transparency_simplified" = "移除模糊效果。\n\n好处：\n• 让文字更清晰\n• 让应用更简洁\n• 加快旧手机的速度\n\n所有内容看起来更实在。";
"help_text_color_blind_mode_simplified" = "更改颜色以帮助您看得更清楚。\n\n选项：\n• 红色盲模式\n• 绿色盲模式\n• 蓝色盲模式\n• 仅灰度模式\n\n帮助您看清重要信息。";
"help_text_line_spacing_simplified" = "更改文字行间的间距。\n\n可选范围为 1.0x 至 2.0x。\n默认为 1.0x。\n\n更大的间距使阅读更容易。";
"help_text_paragraph_spacing_simplified" = "更改段落之间的间距。\n\n可选范围为 1.0x 至 3.0x。\n默认为 1.0x。\n\n更大的间距帮助您看清新想法从哪里开始。";
"help_text_letter_spacing_simplified" = "更改字母之间的间距。\n\n可选范围为 0.0 至 0.2。\n默认为 0.0。\n\n更大的间距使字母更清晰。";
"help_text_text_width_simplified" = "控制文字的宽度。\n\n选项：\n• 全宽：使用整个屏幕\n• 中等：适合阅读\n• 窄：最适合专注\n\n中等宽度最容易阅读。";
"help_text_large_touch_targets_simplified" = "让所有按钮变大。\n\n如果您：\n• 难以点击小按钮\n• 手抖\n• 戴手套\n• 单手使用\n\n按钮从 44 点变为 60 点。";
"help_text_reduce_motion_simplified" = "移除移动动画。\n\n如果您：\n• 因运动感到头晕\n• 因动态引起头痛\n• 偏好静止的界面\n\n内容立即切换而不是移动。";
"help_text_timeout_behavior_simplified" = "控制任务需要多长时间。\n\n选项：\n• 无限制：任务永不停止\n• 正常：30 秒\n• 更长：60 秒\n\n如果您需要更多时间，请选择”无限制”。";
"help_text_simplified_gestures_simplified" = "用简单点击替换复杂手势。\n\n如果您：\n• 难以进行复杂触控\n• 偏好简单点击\n• 单手使用\n\n所有操作都使用简单点击。";
"help_text_haptic_feedback_simplified" = "点击时让手机振动。\n\n好处：\n• 知道您点了按钮\n• 感受错误或警告\n• 无需看屏幕即可获得反馈\n\n如果振动让您不适，可以关闭。";
"help_text_simplified_ui_simplified" = "让应用更简洁。\n\n如果您：\n• 觉得繁忙的屏幕令人困惑\n• 偏好简洁布局\n• 是应用新用户\n\n一次显示更少的内容。";
"help_text_step_indicators_simplified" = "显示您的步骤进度。\n\n好处：\n• 知道您在哪里\n• 看到还有多少步骤\n• 保持有条不紊\n\n显示”第 1 步，共 3 步”及圆点。";
"help_text_verbose_descriptions_simplified" = "提供更多说明。\n\n好处：\n• 理解功能\n• 学习如何使用应用\n• 获得更多详情\n\n到处提供额外帮助。";
"help_text_confirm_actions_simplified" = "询问您确认重要操作。\n\n防止：\n• 意外删除\n• 不想要的更改\n• 失误\n\n总会询问您”确定吗？”";
"help_text_manual_code_entry_simplified" = "让您输入代码而非扫描。\n\n适用于：\n• 相机不工作\n• 代码难以扫描\n• 偏好输入\n\n点击”手动输入代码”输入。";
"help_text_voice_input_simplified" = "让您说出代码而非输入。\n\n如果您：\n• 难以输入\n• 偏好说话\n• 想要免提使用\n\n点击麦克风并清晰说出。";
"help_text_qr_scanning_simplified" = "使用相机读取方形码。\n\n扫描方法：\n1. 将相机对准码\n2. 对齐码\n3. 等待读取\n\n提示：\n• 使用良好光线\n• 保持手机稳定\n• 保持码平整";
"help_text_age_verification_simplified" = "证明您已达到年龄要求，而不共享生日。\n\n工作原理：\n1. 商家创建请求\n2. 您扫描他们的码\n3. 应用创建证明\n4. 商家确认您已达到年龄要求\n\n您的生日保持私密。";
"help_text_credentials_simplified" = "存储在手机上的数字年龄证明。\n\n特点：\n• 仅在您的手机上\n• 无法复制\n• 保护您的隐私\n• 可随时删除\n\n您可以从政府办事处获取。";
"help_text_zero_knowledge_simplified" = "证明某事而不共享详情。\n\n示例：\n• 旧方式：出示证件（显示确切生日）\n• 新方式：证明您年满 18 岁（生日保持私密）\n\n这保护了您的信息隐私。";
"help_text_credential_issuance_simplified" = "获取您的数字年龄证明。\n\n步骤：\n1. 前往政府办事处\n2. 出示证件\n3. 获取代码\n4. 扫描代码\n5. 证明保存在您的手机上\n\n进行一次，之后可多次使用。";
"help_text_officer_mode_simplified" = "供政府工作人员创建证明。\n\n需要：\n• 工作人员密码\n• 使用许可\n• 需要核查用户的证件\n\n步骤：\n1. 以工作人员身份登录\n2. 核查用户的证件\n3. 输入其生日\n4. 创建码\n5. 用户扫描码\n\n仅供授权工作人员使用。";

