<?xml version="1.0" encoding="utf-8"?>
<!--
  Example of a custom directional icon with RTL support using android:autoMirrored="true"

  This icon will automatically flip horizontally when the app is in RTL mode.

  Usage in Compose:
  Icon(
      painter = painterResource(R.drawable.ic_arrow_forward_example),
      contentDescription = "Next"
  )

  Note: This is an example file. For production code, prefer using Material Icons
  with Icons.AutoMirrored.* variants when available.
-->
<vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:autoMirrored="true"
    android:tint="?attr/colorControlNormal">

    <!-- Arrow pointing right (will point left in RTL) -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M12,4l-1.41,1.41L16.17,11H4v2h12.17l-5.58,5.59L12,20l8,-8z"/>
</vector>
