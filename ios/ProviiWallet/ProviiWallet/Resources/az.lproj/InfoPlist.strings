/* InfoPlist.strings - Azerbaijani */
/* Localised permission descriptions for Provii Wallet */

/* Camera Access */
"NSCameraUsageDescription" = "Provii Wallet etimadnamə götürmək və yaş doğrulaması üçün QR kodlarını skan etmək məqsədilə kameraya giriş tələb edir.";

/* NFC Access */
"NFCReaderUsageDescription" = "Provii Wallet təhlükəsiz məmur autentifikasiyası üçün YubiKey ilə əlaqə saxlamaq məqsədilə NFC-dən istifadə edir.";

/* Speech Recognition */
"NSSpeechRecognitionUsageDescription" = "Provii Wallet əlçatımlılıq rejimində səs əmrləri üçün nitqin tanınmasından istifadə edir. Bu, tətbiqi əlsiz idarə etməyinizə imkan verir.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet əlçatımlılıq rejimi aktiv olduqda səs idarəetmə xüsusiyyətləri üçün mikrofona giriş tələb edir.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet yaş etimadnamələrinizə təhlükəsiz daxil olmaq və kimliyinizi doğrulamaq üçün Face ID-dən istifadə edir.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet yaxınlıqdakı etimadnamə verənləri aşkar etmək üçün lokal şəbəkədən istifadə edə bilər.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet YubiKey cihazları ilə əlaqə saxlamaq üçün Bluetooth-dan istifadə edə bilər.";
