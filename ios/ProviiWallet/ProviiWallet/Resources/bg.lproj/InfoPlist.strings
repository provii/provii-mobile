"NSSpeechRecognitionUsageDescription" = "Provii Wallet използва разпознаване на реч за гласови команди в режим на достъпност, което Ви позволява да управлявате приложението без ръце.";

/* Microphone Access */
"NSMicrophoneUsageDescription" = "Provii Wallet се нуждае от достъп до микрофона за функции за гласово управление, когато режимът на достъпност е активиран.";

/* Face ID / Touch ID */
"NSFaceIDUsageDescription" = "Provii Wallet използва Face ID за сигурен достъп до Вашите удостоверения за възраст и верификация на самоличността Ви.";

/* Local Network */
"NSLocalNetworkUsageDescription" = "Provii Wallet може да използва локалната мрежа за намиране на близки издатели на удостоверения.";

/* Bluetooth */
"NSBluetoothAlwaysUsageDescription" = "Provii Wallet може да използва Bluetooth за комуникация с устройства YubiKey.";
