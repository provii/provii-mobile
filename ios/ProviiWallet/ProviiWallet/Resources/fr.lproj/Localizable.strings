// MARK: - Help Text Descriptions
"help_text_extra_large_text" = "Le texte très grand augmente tout le texte de l'application de 50 %.\n\nCela est utile pour les utilisateurs ayant :\n• Une basse vision\n• Des difficultés de lecture\n• Des changements de vision liés à l'âge\n\nFonctionne avec le type dynamique iOS pour des tailles encore plus grandes.";
"help_text_contrast_level" = "Le niveau de contraste contrôle le contraste des couleurs entre le texte et les arrière-plans.\n\nTrois niveaux disponibles :\n• Standard : couleurs par défaut\n• Élevé (AA) : rapport de contraste 4,5:1 - conforme aux normes AA\n• Maximum (AAA) : rapport de contraste 7:1 - conforme aux normes AAA les plus élevées\n\nUn contraste plus élevé facilite la lecture du texte dans toutes les conditions d'éclairage.";
"help_text_high_contrast" = "Le mode contraste élevé augmente le contraste entre le texte et l'arrière-plan, facilitant la lecture.\n\nCela est utile pour les utilisateurs ayant :\n• Une basse vision\n• Une sensibilité aux couleurs\n• Des environnements à écran lumineux\n\nLorsqu'il est activé :\n• Le texte devient noir sur blanc\n• Des bordures sont ajoutées aux éléments\n• Les couleurs sont simplifiées";
"help_text_reduce_transparency" = "Réduire la transparence supprime les effets de flou et de transparence dans toute l'application.\n\nCela aide à :\n• Améliorer la lisibilité du texte\n• Réduire la complexité visuelle\n• Améliorer les performances sur les anciens appareils\n• Rendre le contenu plus prévisible";
"help_text_color_blind_mode" = "Les modes daltonien ajustent les couleurs pour différents types de déficiences de la vision des couleurs.\n\nModes disponibles :\n• Protanopie : daltonisme rouge (difficulté à voir le rouge)\n• Deutéranopie : daltonisme vert (difficulté à voir le vert)\n• Tritanopie : daltonisme bleu (difficulté à voir le bleu)\n• Monochrome : niveaux de gris uniquement\n\nCes modes garantissent que les informations importantes ne sont pas transmises uniquement par la couleur.";
"help_text_line_spacing" = "L'interligne contrôle l'espace entre les lignes de texte.\n\n• Plage : 1,0x à 2,0x\n• Norme AAA : minimum 1,5x\n• Par défaut : 1,0x\n\nUn interligne accru facilite la lecture du texte et évite de sauter des lignes.";
"help_text_paragraph_spacing" = "L'espacement des paragraphes contrôle l'espace entre les paragraphes.\n\n• Plage : 1,0x à 3,0x\n• Norme AAA : minimum 2,0x\n• Par défaut : 1,0x\n\nUn espacement de paragraphe accru aide à distinguer les différentes sections du texte.";
"help_text_letter_spacing" = "L'espacement des lettres contrôle l'espace entre les caractères individuels.\n\n• Plage : 0,0em à 0,2em\n• Norme AAA : minimum 0,12em\n• Par défaut : 0,0em\n\nUn espacement de lettres accru améliore la reconnaissance des caractères et la lisibilité.";
"help_text_text_width" = "La largeur du texte contrôle la longueur maximale des lignes pour une lecture confortable.\n\nOptions :\n• Largeur totale : sans maximum\n• Confortable (80 caractères) : optimal pour la lecture\n• Étroit (60 caractères) : pour une lecture concentrée\n\nLes directives AAA recommandent un maximum de 80 caractères par ligne.";
"help_text_large_touch_targets" = "Les zones tactiles agrandies rendent tous les boutons et éléments interactifs d'au moins 60 pt.\n\nCela est utile pour :\n• Les déficiences motrices\n• Les tremblements\n• L'utilisation de l'application avec des gants\n• L'utilisation à une main\n\nLe minimum standard est 44 pt ; ce paramètre l'augmente à 60 pt.";
"help_text_reduce_motion" = "Réduire les animations minimise ou supprime les animations dans toute l'application.\n\nCela est utile pour les utilisateurs ayant :\n• Une sensibilité aux mouvements\n• Des troubles vestibulaires\n• L'épilepsie\n• Des déclencheurs de migraine\n\nLorsqu'il est activé, les animations sont remplacées par des transitions instantanées.";
"help_text_timeout_behavior" = "Le comportement du délai contrôle la durée des opérations avant expiration.\n\nOptions :\n• Aucun délai (AAA) : les opérations n'expirent jamais\n• Standard (30s) : délai par défaut\n• Prolongé (60s) : double du temps standard\n\nLe mode sans délai satisfait aux normes d'accessibilité AAA.";
"help_text_simplified_gestures" = "Les gestes simplifiés réduisent les gestes multi-touch complexes à de simples appuis.\n\nCela est utile pour :\n• Les déficiences motrices\n• La dextérité limitée\n• L'utilisation de dispositifs d'assistance\n• L'utilisation à une main\n\nLes gestes complexes sont remplacés par des boutons et des appuis simples.";
"help_text_haptic_feedback" = "Le retour haptique fournit des vibrations pour les actions et notifications.\n\nCela est utile pour :\n• Confirmer les pressions de bouton\n• Signaler les erreurs ou avertissements\n• Fournir un retour non visuel\n• Les utilisateurs ayant des déficiences auditives ou visuelles\n\nVous pouvez désactiver cela si les vibrations sont inconfortables.";
"help_text_simplified_ui" = "L'interface simplifiée réduit la complexité visuelle dans toute l'application.\n\nCela est utile pour :\n• Les handicaps cognitifs\n• Les difficultés d'apprentissage\n• Les troubles de l'attention\n• Les utilisateurs nouveaux ou inexpérimentés\n\nLorsqu'elle est activée :\n• Moins d'éléments à l'écran\n• Commandes plus grandes et plus claires\n• Moins de bruit visuel";
"help_text_step_indicators" = "Les indicateurs d'étape montrent votre progression dans les processus en plusieurs étapes.\n\nCela aide à :\n• Comprendre où vous en êtes dans un processus\n• Savoir combien d'étapes il reste\n• Réduire la charge cognitive\n• Fournir une structure claire\n\nAffiche « Étape X sur Y » avec des points de progression visuels.";
"help_text_verbose_descriptions" = "Les descriptions détaillées fournissent du texte explicatif supplémentaire dans toute l'application.\n\nCela est utile pour :\n• Comprendre les fonctionnalités complexes\n• Apprendre à utiliser l'application\n• L'aide cognitive\n• Les utilisateurs de lecteurs d'écran\n\nFournit du contexte et des instructions pour toutes les fonctionnalités.";
"help_text_confirm_actions" = "Confirmer les actions demande une confirmation avant les actions importantes.\n\nCela aide à éviter :\n• Les suppressions accidentelles\n• Les modifications non intentionnelles\n• Les soumissions prématurées\n• La perte de données\n\nRemarque : les actions destructrices nécessitent toujours une confirmation (exigence AAA).";
"help_text_manual_code_entry" = "La saisie manuelle du code vous permet de saisir des codes au lieu de scanner des codes QR.\n\nCela est utile quand :\n• L'appareil photo ne fonctionne pas\n• Le code QR est endommagé ou illisible\n• Vous utilisez un lecteur d'écran\n• Vous préférez saisir plutôt que scanner\n\nAppuyez simplement sur « Saisir le code manuellement » pour saisir le code affiché à l'écran.";
"help_text_voice_input" = "La saisie vocale vous permet de dicter des codes au lieu de les scanner ou de les saisir.\n\nCela est utile pour :\n• La mobilité réduite\n• Les utilisateurs de lecteurs d'écran\n• L'utilisation mains libres\n• La préférence pour la voix\n\nAppuyez sur le bouton microphone et parlez clairement lorsque vous y êtes invité.";
"help_text_qr_scanning" = "Le scan de code QR utilise votre appareil photo pour lire les codes de réponse rapide.\n\nComment scanner :\n1. Pointez l'appareil photo vers le code QR\n2. Alignez le code dans le cadre\n3. Attendez la détection automatique\n\nConseils :\n• Assurez-vous d'un bon éclairage\n• Tenez l'appareil immobile\n• Gardez le code QR plat et dégagé\n• En cas d'échec du scan, essayez la saisie manuelle du code";
"help_text_age_verification" = "La vérification d'âge prouve que vous remplissez une condition d'âge sans révéler votre âge réel ni votre date de naissance.\n\nFonctionnement :\n1. Le vérificateur génère un défi\n2. Vous scannez le code QR ou le saisissez manuellement\n3. L'application crée une preuve sans divulgation\n4. Le vérificateur confirme que vous remplissez la condition\n\nVie privée protégée :\n• Votre date de naissance n'est jamais partagée\n• Le vérificateur sait uniquement si vous remplissez la condition\n• Aucun suivi ni collecte de données";
"help_text_credentials" = "Les justificatifs numériques sont des preuves cryptographiques de votre âge stockées de manière sécurisée sur votre appareil.\n\nCaractéristiques :\n• Stockés uniquement sur votre appareil\n• Impossibles à copier ou falsifier\n• Utilisés pour une vérification respectueuse de la vie privée\n• Peuvent être supprimés à tout moment\n\nVous devez obtenir un justificatif auprès d'un émetteur autorisé (comme un bureau gouvernemental) avant de pouvoir vérifier votre âge.";
"help_text_zero_knowledge" = "Les preuves sans divulgation vous permettent de prouver que quelque chose est vrai sans révéler les informations sous-jacentes.\n\nExemple :\n• Traditionnel : montrer sa pièce d'identité (révèle la date de naissance exacte)\n• Preuve sans divulgation : prouver que vous avez plus de 18 ans sans montrer votre date de naissance\n\nAvantages :\n• Protection maximale de la vie privée\n• Aucune donnée personnelle partagée\n• Cryptographiquement sécurisé\n• Impossible à falsifier ou reproduire\n\nC'est la technologie fondamentale qui rend Provii Wallet privé.";
"help_text_credential_issuance" = "La délivrance de justificatifs est le processus d'obtention de votre justificatif d'âge numérique auprès d'un émetteur autorisé.\n\nÉtapes :\n1. Rendez-vous auprès d'un émetteur autorisé (p. ex. un bureau gouvernemental)\n2. Prouvez votre identité avec une pièce d'identité officielle\n3. Recevez un code QR ou un lien profond de l'émetteur\n4. Scannez le code QR ou appuyez sur le lien\n5. Le justificatif est calculé localement et stocké sur votre appareil\n\nLe processus d'attestation aveugle garantit que votre date de naissance n'est jamais transmise sur le réseau.\nVous n'avez besoin de faire cela qu'une seule fois. Votre justificatif peut ensuite être utilisé pour des vérifications illimitées.";
"help_text_officer_mode" = "Le mode Agent est destiné aux émetteurs autorisés pour créer des justificatifs pour les utilisateurs.\n\nCe mode nécessite :\n• L'authentification de l'agent avec YubiKey\n• Une autorisation de l'autorité émettrice\n• La vérification physique de la pièce d'identité de l'utilisateur\n\nProcessus :\n1. S'authentifier en tant qu'agent\n2. Vérifier la pièce d'identité officielle de l'utilisateur\n3. Saisir la date de naissance de l'utilisateur\n4. Générer le code QR d'attestation\n5. L'utilisateur scanne le code pour recevoir son justificatif\n\nSeul le personnel autorisé doit utiliser ce mode.";

// MARK: - Simplified Help Text (Reading Level: Grade 6-8)

"help_text_extra_large_text_simplified" = "Agrandit tout le texte de 50 %.\n\nVous aide si vous :\n• Avez du mal à voir\n• Trouvez la lecture difficile\n• Avez besoin d'un texte plus grand\n\nFonctionne avec les paramètres de taille de texte de votre téléphone.";

"help_text_contrast_level_simplified" = "Change la foncé du texte.\n\nTrois choix :\n• Standard : couleurs normales\n• Élevé : texte plus foncé pour une lecture facile\n• Maximum : texte très foncé pour la meilleure lisibilité\n\nLe texte plus foncé est plus facile à lire.";

"help_text_high_contrast_simplified" = "Rend le texte plus facile à voir.\n\nVous aide si vous :\n• Avez du mal à voir\n• Avez besoin d'un texte plus foncé\n• Utilisez l'appli en pleine lumière\n\nLe texte devient noir sur blanc.";

"help_text_reduce_transparency_simplified" = "Supprime les effets flous.\n\nCela aide à :\n• Rendre le texte plus clair\n• Simplifier l'appli\n• Accélérer les anciens téléphones\n\nTout paraît plus solide.";

"help_text_color_blind_mode_simplified" = "Change les couleurs pour vous aider à mieux voir.\n\nChoix :\n• Mode daltonisme rouge\n• Mode daltonisme vert\n• Mode daltonisme bleu\n• Mode niveaux de gris uniquement\n\nVous aide à voir les choses importantes.";

"help_text_line_spacing_simplified" = "Change l'espace entre les lignes de texte.\n\nVous pouvez choisir entre 1,0x et 2,0x.\nPar défaut : 1,0x.\n\nPlus d'espace facilite la lecture.";

"help_text_paragraph_spacing_simplified" = "Change l'espace entre les paragraphes.\n\nVous pouvez choisir entre 1,0x et 3,0x.\nPar défaut : 1,0x.\n\nPlus d'espace aide à voir où commencent les nouvelles idées.";

"help_text_letter_spacing_simplified" = "Change l'espace entre les lettres.\n\nVous pouvez choisir entre 0,0 et 0,2.\nPar défaut : 0,0.\n\nPlus d'espace rend les lettres plus claires.";

"help_text_text_width_simplified" = "Contrôle la largeur du texte.\n\nChoix :\n• Largeur totale : utilise tout l'écran\n• Moyen : bon pour la lecture\n• Étroit : idéal pour la concentration\n\nLa largeur moyenne est la plus facile à lire.";

"help_text_large_touch_targets_simplified" = "Agrandit tous les boutons.\n\nVous aide si vous :\n• Avez du mal à appuyer sur les petits boutons\n• Avez les mains qui tremblent\n• Portez des gants\n• Utilisez une seule main\n\nLes boutons passent de 44 pt à 60 pt.";

"help_text_reduce_motion_simplified" = "Supprime les animations en mouvement.\n\nVous aide si :\n• Le mouvement vous donne le vertige\n• Vous avez des maux de tête liés au mouvement\n• Vous préférez que les choses restent fixes\n\nLes changements sont instantanés au lieu de se déplacer.";

"help_text_timeout_behavior_simplified" = "Contrôle la durée des tâches.\n\nChoix :\n• Sans limite : les tâches ne s'arrêtent jamais\n• Normal : 30 secondes\n• Plus long : 60 secondes\n\nChoisissez « Sans limite » si vous avez besoin de plus de temps.";

"help_text_simplified_gestures_simplified" = "Remplace les gestes difficiles par de simples appuis.\n\nVous aide si vous :\n• Avez du mal avec les touches complexes\n• Préférez les appuis simples\n• Utilisez une seule main\n\nTout fonctionne avec de simples appuis.";

"help_text_haptic_feedback_simplified" = "Fait vibrer votre téléphone quand vous appuyez.\n\nVous aide à :\n• Savoir quand vous avez appuyé sur un bouton\n• Ressentir les erreurs ou avertissements\n• Obtenir un retour sans regarder\n\nDésactivez si les vibrations vous dérangent.";

"help_text_simplified_ui_simplified" = "Simplifie l'application.\n\nVous aide si vous :\n• Êtes troublé par les écrans chargés\n• Préférez les mises en page simples\n• Êtes nouveau dans l'application\n\nAffiche moins de choses à la fois.";

"help_text_step_indicators_simplified" = "Montre votre progression dans les étapes.\n\nVous aide à :\n• Savoir où vous en êtes\n• Voir combien d'étapes il reste\n• Rester organisé\n\nAffiche « Étape 1 sur 3 » avec des points.";

"help_text_verbose_descriptions_simplified" = "Vous donne plus d'explications.\n\nVous aide à :\n• Comprendre les fonctionnalités\n• Apprendre à utiliser l'appli\n• Obtenir plus de détails\n\nFournit une aide supplémentaire partout.";

"help_text_confirm_actions_simplified" = "Vous demande de confirmer les actions importantes.\n\nAide à éviter :\n• Les suppressions accidentelles\n• Les modifications non souhaitées\n• Les erreurs\n\nOn vous demandera toujours « Êtes-vous sûr ? »";

"help_text_manual_code_entry_simplified" = "Vous permet de saisir des codes au lieu de les scanner.\n\nUtilisez ceci quand :\n• Votre appareil photo ne fonctionne pas\n• Le code est difficile à scanner\n• Vous préférez saisir\n\nAppuyez sur « Saisir le code manuellement » pour saisir.";

"help_text_voice_input_simplified" = "Vous permet de dicter des codes au lieu de les saisir.\n\nVous aide si vous :\n• Avez du mal à saisir\n• Préférez parler\n• Voulez une utilisation mains libres\n\nAppuyez sur le microphone et parlez clairement.";

"help_text_qr_scanning_simplified" = "Utilise votre appareil photo pour lire les codes carrés.\n\nComment scanner :\n1. Pointez l'appareil photo vers le code\n2. Alignez le code\n3. Attendez qu'il soit lu\n\nConseils :\n• Utilisez un bon éclairage\n• Tenez votre téléphone immobile\n• Gardez le code à plat";

"help_text_age_verification_simplified" = "Prouve que vous êtes assez âgé sans partager votre anniversaire.\n\nFonctionnement :\n1. L'établissement crée une demande\n2. Vous scannez son code\n3. L'appli crée une preuve\n4. L'établissement confirme que vous êtes assez âgé\n\nVotre anniversaire reste privé.";

"help_text_credentials_simplified" = "Preuve numérique de votre âge stockée sur votre téléphone.\n\nCaractéristiques :\n• Uniquement sur votre téléphone\n• Impossible à copier\n• Préserve votre vie privée\n• Vous pouvez la supprimer à tout moment\n\nVous l'obtenez auprès d'un bureau gouvernemental.";

"help_text_zero_knowledge_simplified" = "Prouve quelque chose sans partager les détails.\n\nExemple :\n• Ancienne méthode : montrer sa pièce d'identité (montre l'anniversaire exact)\n• Nouvelle méthode : prouver que vous avez plus de 18 ans (l'anniversaire reste privé)\n\nCela préserve la confidentialité de vos informations.";

"help_text_credential_issuance_simplified" = "Obtenir votre preuve d'âge numérique.\n\nÉtapes :\n1. Aller au bureau gouvernemental\n2. Montrer votre pièce d'identité\n3. Obtenir un code\n4. Scanner le code\n5. La preuve est sauvegardée sur votre téléphone\n\nFaites-le une fois. Utilisez-le ensuite plusieurs fois.";

"help_text_officer_mode_simplified" = "Pour les agents gouvernementaux pour créer des preuves.\n\nNécessite :\n• Mot de passe de l'agent\n• Autorisation d'utilisation\n• Pièce d'identité de l'utilisateur à vérifier\n\nÉtapes :\n1. Se connecter en tant qu'agent\n2. Vérifier la pièce d'identité de l'utilisateur\n3. Saisir sa date de naissance\n4. Créer le code\n5. L'utilisateur scanne le code\n\nUniquement pour le personnel autorisé.";

